{
  "name": "twilight-website",
  "build": {
    "dockerfile": "../Dockerfile",
    "target": "dev"
  },
  "workspaceFolder": "/workspaces/twilight-website",
  "overrideCommand": true,
  "mounts": [
    "source=twilight-node-modules,target=/workspaces/twilight-website/node_modules,type=volume"
  ],
  "containerEnv": {
    "CHOKIDAR_USEPOLLING": "true"
  },
  "forwardPorts": [4321],
  "postCreateCommand": "npm ci",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash"
          }
        }
      },
      "extensions": [
        "astro-build.astro-vscode",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode"
      ]
    }
  }
}

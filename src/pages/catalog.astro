---
import Layout from "../layouts/Layout.astro";
import { PHONE_NUMBER, PHONE_NUMBER_FORMATTED } from "../data/resource";
import PageHeroWrapper from "../components/PageHeroWrapper.astro";
import CatalogTabsWrapper from "../components/CatalogTabsWrapper.astro";
import AnimatedSection from "../components/react/primitives/AnimatedSection";

const categories = [
  {
    id: "neurodivergence",
    title: "Neurodivergence & Testing",
    concerns: [
      { name: "Autism Spectrum (including High-Masking)" },
      { name: "ADHD (Adult & Pediatric)" },
      { name: "PDA (Pathological Demand Avoidance) Profile" },
      { name: "Learning Disability Evaluations" },
      { name: "Medical Marijuana Consultations" },
      { name: "Comprehensive Psychological Testing" },
      { name: "Psychoeducational Evaluations" },
    ],
  },
  {
    id: "clinical",
    title: "Clinical Specialties",
    concerns: [
      { name: "Depression & Persistent Low Mood" },
      { name: "Anxiety & Panic Disorders" },
      { name: "Trauma & PTSD" },
      { name: "Bipolar Disorder" },
      { name: "Borderline Personality Disorder (BPD)" },
      { name: "Grief & Loss" },
    ],
  },
  {
    id: "identity",
    title: "Identity & Specialized Advocacy",
    concerns: [
      { name: "LGBTQ+ Issues & Gender Affirming Care" },
      { name: "Women’s Health & Reproductive Transitions" },
      { name: "Health at Every Size (HAES) Approach" },
      { name: "Intimacy & Relationship Therapy" },
      { name: "Life Changes & Self-Esteem Issues" },
    ],
  },
];
---

<Layout
  title="Catalog of Services | Twilight Psychology"
  description="Explore Twilight Psychology's full catalog of psychological evaluations, medication management, and therapy services in Kentucky."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">

  <PageHeroWrapper
    title="Areas of Care"
    accentWord="Care"
    subtitle="From diagnostic clarification to identity-affirming therapy, we provide specialized support for the complex intersections of the human experience."
    badge="Full Catalog"
    size="lg"
  />

  <section class="max-w-7xl mx-auto px-4 mt-20">
    <CatalogTabsWrapper categories={categories} />
  </section>

  <section class="max-w-4xl mx-auto px-4 mt-20 mb-10">
    <AnimatedSection client:visible animation="fadeInUp" delay={200}>
      <div class="bg-surface-2 border p-8 md:p-12 rounded-[2.5rem]" style="border-color: var(--color-border-strong)">
        <h2 class="font-serif text-3xl font-black text-site-text mb-4">
          Our approach is rooted in validation, not pathology.
        </h2>
        <p class="text-site-text leading-relaxed font-medium mb-8">
          Whether you are seeking a formal diagnosis or a safe space to process
          life&apos;s transitions, we prioritize your lived experience. All our
          clinicians are neuro-affirming and trauma-informed, with specialized
          training in the unique challenges faced by marginalized communities.
        </p>
        <div class="pt-6 border-t" style="border-color: var(--color-border)">
          <p class="text-[10px] font-black text-site-sub uppercase tracking-widest mb-2">
            Ready to start?
          </p>
          <a
            href={`tel:${PHONE_NUMBER}`}
            class="inline-block text-cta font-black text-2xl hover:text-site-text transition-colors"
          >
            &#128222; {PHONE_NUMBER_FORMATTED}
          </a>
        </div>
      </div>
    </AnimatedSection>
  </section>

      </div>
    </div>
  </div>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import PageHeroWrapper from "../components/PageHeroWrapper.astro";
import { PHONE_NUMBER, PHONE_NUMBER_FORMATTED } from "../data/resource";

const title = "Mental Health Concerns & Services in Kentucky";
const description =
  "Browse ADHD, autism, anxiety, trauma, school-support, therapy, and psychiatry concerns in Kentucky, then choose the right Twilight Psychology service path.";

const categories = [
  {
    id: "neurodivergence",
    title: "Neurodivergence & Learning",
    concerns: [
      { name: "Autism evaluations & support" },
      { name: "ADHD across the lifespan" },
      { name: "Executive functioning challenges" },
      { name: "Learning differences & dyslexia" },
      { name: "Giftedness and twice-exceptionality" },
      { name: "Sensory processing differences" },
    ],
    pathways: [
      { href: "/services/autism-testing", label: "Autism evaluations" },
      { href: "/services/adhd-testing", label: "ADHD evaluations" },
      { href: "/specialties/psychoeducational-evaluations", label: "Psychoeducational evaluations" },
    ],
  },
  {
    id: "anxiety-mood",
    title: "Anxiety, Mood & Trauma",
    concerns: [
      { name: "Anxiety and panic" },
      { name: "OCD and intrusive thoughts" },
      { name: "Depression and mood shifts" },
      { name: "Burnout and chronic stress" },
      { name: "Trauma and PTSD" },
      { name: "Sleep concerns related to mental health" },
    ],
    pathways: [
      { href: "/services/therapy", label: "Therapy in Kentucky" },
      { href: "/services/therapy/cognitive-behavioral-therapy", label: "Cognitive Behavioral Therapy" },
      { href: "/services/medication-management", label: "Medication management" },
    ],
  },
  {
    id: "identity",
    title: "Identity, Family & Relationships",
    concerns: [
      { name: "LGBTQIA+ affirming care" },
      { name: "Gender-affirming support letters" },
      { name: "Parenting and family dynamics" },
      { name: "Relationship challenges" },
      { name: "Life transitions and adjustment" },
      { name: "Self-esteem and identity exploration" },
    ],
    pathways: [
      { href: "/services/therapy", label: "Individual therapy" },
      { href: "/services/therapy/couples-counseling", label: "Couples counseling" },
      { href: "/services/therapy/clinicians", label: "Match with a therapist" },
    ],
  },
  {
    id: "psychiatry",
    title: "Medication & Psychiatry",
    concerns: [
      { name: "Medication management for anxiety or depression" },
      { name: "ADHD medication support" },
      { name: "Psychiatric consultation and follow-up" },
      { name: "Coordinating therapy and medication care" },
      { name: "Symptom monitoring and treatment adjustments" },
    ],
    pathways: [
      { href: "/services/medication-management", label: "Medication management" },
      { href: "/resources/insurances-accepted", label: "Accepted insurance plans" },
      { href: "/contact", label: "Contact the practice" },
    ],
  },
  {
    id: "documentation",
    title: "Documentation, School & Legal Needs",
    concerns: [
      { name: "Diagnostic clarification" },
      { name: "Accommodation documentation" },
      { name: "School-based support recommendations" },
      { name: "Neuro-affirming psychoeducational evaluations" },
      { name: "Evaluations for care planning" },
    ],
    pathways: [
      { href: "/services/psychological-evaluations", label: "Psychological evaluations" },
      { href: "/specialties/dyslexia-testing", label: "Dyslexia & learning disability testing" },
      { href: "/specialties/iee", label: "Independent Educational Evaluations" },
    ],
  },
] as const;

const totalConcerns = categories.reduce((sum, category) => sum + category.concerns.length, 0);
---

<Layout title={title} description={description}>
  <div class="prose prose-lg dark:prose-invert max-w-none">
    <PageHeroWrapper
      title="Browse by concern, not just service type"
      subtitle="Use this Kentucky care directory to compare concerns tied to evaluations, therapy, and medication management before choosing the right next step."
      badge="Care directory"
      accentWord="concern"
    />

    <section class="max-w-6xl mx-auto px-6 py-8 sm:py-10">
      <div class="grid gap-6 xl:grid-cols-[minmax(0,1.45fr)_minmax(18rem,0.95fr)]">
        <div
          class="rounded-4xl border border-border bg-surface-soft p-8 md:p-10 shadow-sm shadow-black/5"
        >
          <p class="text-xs font-bold uppercase tracking-[0.3em] text-cta/80 mb-3">How to use this page</p>
          <h2 class="font-serif text-3xl md:text-4xl font-black text-site-text mb-4">
            Start with the concern, then follow the right care path
          </h2>
          <p class="text-base md:text-lg text-site-sub leading-relaxed mb-6">
            If you are still figuring out what kind of support you need, this page is a good starting point. Browse the categories below, then move into the relevant Kentucky service line once you know whether you are looking for therapy, medication management, or an evaluation.
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href="/services"
              class="inline-flex items-center justify-center rounded-full bg-cta px-5 py-3 text-sm font-bold text-cta-fg no-underline transition-transform duration-200 hover:-translate-y-0.5 hover:bg-cta/90"
            >
              Explore core services
            </a>
            <a
              href="/specialties"
              class="inline-flex items-center justify-center rounded-full border border-border bg-surface px-5 py-3 text-sm font-bold text-site-text no-underline transition-colors duration-200 hover:border-cta/40 hover:text-cta"
            >
              View specialty evaluations
            </a>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-3 xl:grid-cols-1">
          <div class="rounded-[1.75rem] border border-border bg-surface p-6">
            <p class="text-xs font-bold uppercase tracking-[0.3em] text-site-sub/80 mb-3">Care groups</p>
            <p class="font-serif text-4xl font-black text-site-text mb-2">{categories.length}</p>
            <p class="text-sm text-site-sub leading-relaxed mb-0">High-level categories to help you narrow the right next step.</p>
          </div>
          <div class="rounded-[1.75rem] border border-border bg-surface p-6">
            <p class="text-xs font-bold uppercase tracking-[0.3em] text-site-sub/80 mb-3">Focus areas</p>
            <p class="font-serif text-4xl font-black text-site-text mb-2">{totalConcerns}</p>
            <p class="text-sm text-site-sub leading-relaxed mb-0">Common concerns already organized into a simpler directory.</p>
          </div>
          <div class="rounded-[1.75rem] border border-border bg-surface p-6">
            <p class="text-xs font-bold uppercase tracking-[0.3em] text-site-sub/80 mb-3">Need help choosing?</p>
            <p class="font-serif text-2xl font-black text-site-text mb-2">Talk with us</p>
            <p class="text-sm text-site-sub leading-relaxed mb-4">
              Contact our administrative team if you want help deciding which service path fits your concern.
            </p>
            <a href={`tel:${PHONE_NUMBER}`} class="text-sm font-bold text-cta no-underline hover:text-cta/80">
              {PHONE_NUMBER_FORMATTED}
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 py-6 sm:py-8">
      <div class="rounded-4xl border border-border bg-surface-soft p-6 md:p-8">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-2xl">
            <p class="text-xs font-bold uppercase tracking-[0.3em] text-cta/80 mb-3">Browse the directory</p>
            <h2 class="font-serif text-2xl md:text-3xl font-black text-site-text mb-3">
              Jump straight to the category that feels closest
            </h2>
            <p class="text-base text-site-sub leading-relaxed mb-0">
              Each section groups common concerns and points you to the service pages most likely to help.
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            {categories.map((category, index) => (
              <a
                href={`#${category.id}`}
                class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-4 py-2 text-sm font-bold text-site-text no-underline transition-colors duration-200 hover:border-cta/40 hover:text-cta"
              >
                <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-surface-soft text-xs text-site-sub">
                  {String(index + 1).padStart(2, '0')}
                </span>
                {category.title}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 py-6 sm:py-8 space-y-8">
      {categories.map((category, categoryIndex) => (
        <article
          id={category.id}
          class="scroll-mt-28 rounded-4xl border border-border bg-surface-soft p-8 md:p-10 shadow-sm shadow-black/5"
        >
          <div class="flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">
            <div class="max-w-3xl">
              <p class="text-xs font-bold uppercase tracking-[0.3em] text-cta/80 mb-3">
                Category {String(categoryIndex + 1).padStart(2, '0')}
              </p>
              <h2 class="font-serif text-3xl md:text-4xl font-black text-site-text mb-3">
                {category.title}
              </h2>
              <p class="text-base md:text-lg text-site-sub leading-relaxed mb-0">
                {category.concerns.length} focus areas in this section.
              </p>
            </div>
            <div class="flex flex-wrap gap-2">
              {category.concerns.slice(0, 3).map((concern) => (
                <span class="rounded-full border border-border bg-surface px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-site-sub">
                  {concern.name}
                </span>
              ))}
            </div>
          </div>

          <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            {category.concerns.map((concern, concernIndex) => (
              <div class="group rounded-3xl border border-border bg-surface p-5 transition-all duration-300 hover:-translate-y-1 hover:border-cta/35 hover:shadow-lg hover:shadow-black/5">
                <div class="flex items-start gap-4">
                  <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-surface-soft font-serif text-sm font-black text-cta">
                    {String(concernIndex + 1).padStart(2, '0')}
                  </span>
                  <p class="mb-0 text-sm md:text-base font-medium leading-relaxed text-site-text">
                    {concern.name}
                  </p>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-8 rounded-3xl border border-border bg-surface p-5">
            <p class="mb-3 text-xs font-bold uppercase tracking-[0.3em] text-cta/80">Recommended pages</p>
            <div class="flex flex-wrap gap-3">
              {category.pathways.map((pathway) => (
                <a
                  href={pathway.href}
                  class="inline-flex items-center gap-2 rounded-full border border-border bg-surface-soft px-4 py-2 text-sm font-bold text-site-text no-underline transition-colors duration-200 hover:border-cta/40 hover:text-cta"
                >
                  {pathway.label}
                </a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </section>

    <section class="max-w-6xl mx-auto px-6 py-8 sm:py-12">
      <div class="rounded-4xl border border-border bg-surface-soft p-8 md:p-10 text-center">
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-cta/80 mb-3">Next step</p>
        <h2 class="font-serif text-3xl md:text-4xl font-black text-site-text mb-4">
          Ready to move from the concern list into care?
        </h2>
        <p class="max-w-3xl mx-auto text-base md:text-lg text-site-sub leading-relaxed mb-6">
          Once you know which concerns fit best, you can explore the service pages in more detail or contact our administrative team for help deciding on the right appointment type.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a
            href="/services"
            class="inline-flex items-center justify-center rounded-full bg-cta px-5 py-3 text-sm font-bold text-cta-fg no-underline transition-transform duration-200 hover:-translate-y-0.5 hover:bg-cta/90"
          >
            Browse services
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-full border border-border bg-surface px-5 py-3 text-sm font-bold text-site-text no-underline transition-colors duration-200 hover:border-cta/40 hover:text-cta"
          >
            Contact the practice
          </a>
          <a
            href={`tel:${PHONE_NUMBER}`}
            class="inline-flex items-center justify-center rounded-full border border-border bg-surface px-5 py-3 text-sm font-bold text-site-text no-underline transition-colors duration-200 hover:border-cta/40 hover:text-cta"
          >
            Call {PHONE_NUMBER_FORMATTED}
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>

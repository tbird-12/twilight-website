---
import Layout from "../layouts/Layout.astro";
import { PHONE_NUMBER, PHONE_NUMBER_FORMATTED } from "../data/resource";
import PageHeroWrapper from "../components/PageHeroWrapper.astro";
import CatalogTabsWrapper from "../components/CatalogTabsWrapper.astro";
import AnimatedSection from "../components/react/primitives/AnimatedSection";

const categories = [
  {
    id: "neurodivergence-learning",
    title: "Neurodivergence & Learning",
    concerns: [
      { name: "High-Masking Autism" },
      { name: "ADHD Across the Lifespan" },
      { name: "PDA Profile Support" },
      { name: "Learning Disabilities, Dyslexia, Dysgraphia, & Dyscalculia" },
      { name: "Psychoeducational & Cognitive Assessments" },
      { name: "Diagnostic Clarification for Overlapping Presentations" },
    ],
  },
  {
    id: "mood-trauma-personality",
    title: "Mood, Trauma & Diagnostic Clarity",
    concerns: [
      { name: "Anxiety, Panic, & Social Anxiety" },
      { name: "Depression, Burnout, & Persistent Low Mood" },
      { name: "Trauma, PTSD, & Religious Trauma" },
      { name: "Bipolar & Mood Disorder Evaluations" },
      { name: "Borderline & Other Personality Patterns" },
      { name: "Substance Use & Recovery-Related Concerns" },
    ],
  },
  {
    id: "identity-relationships",
    title: "Identity, Relationships & Daily Functioning",
    concerns: [
      { name: "LGBTQ+ Affirming Support" },
      { name: "Gender, Racial, & Identity Development" },
      { name: "Body Image, Anti-Fat Bias, & HAES-Aligned Care" },
      { name: "Relationship, Couples, & Family Stress" },
      { name: "Parenting, School Stress, & Adolescent Support" },
      { name: "Self-Esteem, Boundaries, & Life Transitions" },
    ],
  },
  {
    id: "psychiatry-medical",
    title: "Psychiatry & Medical Support",
    concerns: [
      { name: "Medication Support for ADHD" },
      { name: "Medication Support for Anxiety & Depression" },
      { name: "Trauma-Informed Psychiatric Care" },
      { name: "Whole-Person Care with Psychoeducation & Mindfulness" },
      { name: "THC-Friendly Psychiatric Consultation" },
      { name: "Medical Marijuana Evaluations & Renewals" },
    ],
  },
  {
    id: "documentation-advocacy",
    title: "School, Legal & Documentation Needs",
    concerns: [
      { name: "IEP, 504, & School Accommodation Evaluations" },
      { name: "Independent Educational Evaluations (IEEs)" },
      { name: "Guardianship & Benefits Documentation" },
      { name: "Adoption Evaluations" },
      { name: "ESA Documentation Evaluations" },
      { name: "Court, Waiver, & Advocacy-Focused Reports" },
    ],
  },
];
---

<Layout
  title="Conditions & Concerns We Support | Twilight Psychology"
  description="Browse the conditions, concerns, and identity-affirming support areas Twilight Psychology addresses across testing, therapy, and medication management."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">

  <PageHeroWrapper
    title="Areas of Care"
    accentWord="Care"
    subtitle="Use this care directory to browse common concerns and support areas before choosing a service line."
    badge="Care Directory"
    size="lg"
  />

  <section class="max-w-4xl mx-auto px-4 mt-10">
    <div class="rounded-4xl border border-border bg-surface-soft p-6 md:p-8">
      <h2 class="font-serif text-2xl font-black text-site-text mb-3">
        Organized by concern, not appointment type
      </h2>
      <p class="text-site-text leading-relaxed font-medium">
        This page groups care areas by the concerns you want help with. If you already know you need an
        evaluation, therapy, or medication support, visit our <a href="/services" class="text-cta hover:underline">core services</a> page.
        If you need school, legal, or documentation-focused evaluations, go to <a href="/specialties" class="text-cta hover:underline">specialty evaluations</a>.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 mt-20">
    <CatalogTabsWrapper categories={categories} />
  </section>

  <section class="max-w-4xl mx-auto px-4 mt-20 mb-10">
    <AnimatedSection client:visible animation="fadeInUp" delay={200}>
      <div class="bg-surface-2 border p-8 md:p-12 rounded-[2.5rem]" style="border-color: var(--color-border-strong)">
        <h2 class="font-serif text-3xl font-black text-site-text mb-4">
          Our approach is rooted in validation, not pathology.
        </h2>
        <p class="text-site-text leading-relaxed font-medium mb-8">
          Whether you are seeking a formal diagnosis or a safe space to process
          life&apos;s transitions, we prioritize your lived experience. All our
          clinicians are neuro-affirming and trauma-informed, with specialized
          training in the unique challenges faced by marginalized communities.
        </p>
        <div class="pt-6 border-t" style="border-color: var(--color-border)">
          <p class="text-xs font-black text-site-sub uppercase tracking-widest mb-2">
            Ready to start?
          </p>
          <a
            href={`tel:${PHONE_NUMBER}`}
            class="inline-block text-cta font-black text-2xl hover:text-site-text transition-colors"
          >
            &#128222; {PHONE_NUMBER_FORMATTED}
          </a>
        </div>
      </div>
    </AnimatedSection>
  </section>

      </div>
    </div>
  </div>
</Layout>

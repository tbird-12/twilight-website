---
import LandingLayout from "../layouts/LandingLayout.astro";
import "../styles/global.css";
import logo from "../assets/images/logo.png";
---

<LandingLayout
  title="Affordable Mental Health Care in Lexington, Kentucky | Twilight Psychology"
  description="Twilight Psychology provides affordable mental health care in Lexington, Kentucky, including therapy, psychological evaluations, and medication management for new and returning clients."
>
  <section class="relative isolate overflow-hidden px-4 py-16 sm:py-20">
    <div class="relative mx-auto max-w-5xl rounded-4xl border-4 border-amber-400 bg-white/3 p-8 shadow-[0_10px_24px_-20px_rgba(15,23,42,0.85),inset_0_0_20px_rgba(180,83,9,0.15)] sm:p-10 lg:p-12">
      <div class="relative flex flex-col items-center gap-6 text-center sm:gap-8">
        <div class="mx-auto shrink-0">
          <div class="rounded-4xl border border-white/15 bg-site-bg/75 p-2 shadow-[0_8px_20px_-18px_rgba(15,23,42,0.85)]">
            <img
              src={logo.src}
              class="h-28 w-28 rounded-[1.3rem] sm:h-36 sm:w-36"
              alt="Twilight Psychology"
            />
          </div>
        </div>

        <div>

          <h1 class="mx-auto mt-5 max-w-4xl text-4xl leading-[1.05] text-site-text sm:mt-6 sm:text-6xl">
            Top-Tier Mental Health Care in Kentucky
          </h1>

          <p class="mx-auto mt-5 max-w-3xl text-base leading-relaxed text-site-sub sm:mt-6 sm:text-lg">
            Twilight Psychology is focused on delivering neuro-affirming mental health care for individuals
            and families through psychological testing, medication management, and therapy.
          </p>

          <div class="mt-6 flex flex-col gap-3 sm:mt-8 sm:flex-row sm:justify-center">
            <a
              href="/contact"
              class="inline-flex min-h-11 items-center justify-center rounded-full bg-cta px-8 py-3 text-sm font-black text-cta-fg transition-colors duration-150 hover:bg-cta/95"
            >
              Contact Twilight Psychology
            </a>
            <a
              href="/"
              class="inline-flex min-h-11 items-center justify-center rounded-full border border-white/20 bg-site-bg/70 px-8 py-3 text-sm font-black text-site-text transition-colors duration-150 hover:bg-site-bg/72"
            >
              Show Me More
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative px-4 pb-20 sm:pb-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-6 flex flex-col items-start justify-between gap-3 sm:mb-8 sm:flex-row sm:items-end">
        <div>
          <p class="text-xs font-black tracking-[0.16em] text-site-sub uppercase">Your Welcome Path</p>
          <h2 class="mt-2 text-3xl text-site-text sm:text-4xl">Common Next Steps</h2>
        </div>
      </div>

      <ol class="grid gap-3 sm:grid-cols-3 sm:gap-4">
        <li class="rounded-3xl border border-white/10 bg-white/3 p-5 text-sm leading-relaxed text-site-sub transition-colors duration-150 hover:border-white/12 hover:bg-white/4">
          <span class="relative block text-xs font-black tracking-[0.12em] text-site-text uppercase">Step 1</span>
          <p class="relative mt-2.5">
            Review our care options and choose the service that best fits your needs.
          </p>
        </li>

        <li class="rounded-3xl border border-white/10 bg-white/3 p-5 text-sm leading-relaxed text-site-sub transition-colors duration-150 hover:border-white/12 hover:bg-white/4">
          <span class="relative block text-xs font-black tracking-[0.12em] text-site-text uppercase">Step 2</span>
          <p class="relative mt-2.5">
            Check timelines, fees, and insurance details for care.
          </p>
        </li>

        <li class="rounded-3xl border border-white/10 bg-white/3 p-5 text-sm leading-relaxed text-site-sub transition-colors duration-150 hover:border-white/12 hover:bg-white/4">
          <span class="relative block text-xs font-black tracking-[0.12em] text-site-text uppercase">Step 3</span>
          <p class="relative mt-2.5">
            Contact us to start intake and schedule your first appointment.
          </p>
        </li>
      </ol>
    </div>
  </section>
</LandingLayout>

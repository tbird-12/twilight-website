---
import LandingLayout from "../layouts/LandingLayout.astro";
import { Icon } from "astro-icon/components";
import logo from "../assets/images/logo.png";
import { PHONE_NUMBER, PHONE_NUMBER_FORMATTED, EMAIL_ADDRESS, WIDGET_LINK } from "../data/resource";
import { providers } from "../data/staff";
import { Image } from "astro:assets";

const featuredProviders = providers.slice(0, 4);

const services = [
  {
    icon: "mdi:account-heart-outline",
    title: "Therapy",
    desc: "Evidence-based, neuro-affirming individual counseling for teens and adults. Accepted by most insurance plans we carry.",
    link: "/services/therapy",
  },
  {
    icon: "mdi:medication-outline",
    title: "Medication Management",
    desc: "Psychiatric medication support from our in-house Nurse Practitioner. Most clients seen immediately.",
    link: "/services/medication-management",
  },
  {
    icon: "mdi:head-cog-outline",
    title: "Psychological Testing",
    desc: "ADHD, Autism, learning disabilities, personality — comprehensive evaluations with self-pay results in 7 days.",
    link: "/services/psychological-evaluations",
  },
];

const differentiators = [
  { icon: "mdi:shield-check-outline", stat: "18+", label: "Insurance panels accepted" },
  { icon: "mdi:lightning-bolt-outline", stat: "Shortest", label: "Waitlists in KY for insured clients" },
  { icon: "mdi:earth", stat: "43+", label: "States via PSYPACT" },
  { icon: "mdi:clock-fast", stat: "7 days", label: "Self-pay testing turnaround" },
  { icon: "mdi:calendar-check-outline", stat: "2,100+", label: "Evaluations completed" },
];
---

<LandingLayout
  title="Neuro-Affirming Therapy, Medication Management & Testing in Kentucky | Twilight Psychology"
  description="Therapy, psychiatric medication management, and psychological evaluations in Kentucky. We accept 18+ insurance panels including Medicaid. Accepting new clients."
>
  <!-- ══ Theme toggle ══ -->
  <button
    type="button"
    data-theme-toggle
    class="lp-theme-toggle"
    aria-label="Toggle light/dark mode"
  >
    <svg class="lp-toggle-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="4"></circle>
      <path d="M12 2v2"></path>
      <path d="M12 20v2"></path>
      <path d="m4.93 4.93 1.41 1.41"></path>
      <path d="m17.66 17.66 1.41 1.41"></path>
      <path d="M2 12h2"></path>
      <path d="M20 12h2"></path>
      <path d="m6.34 17.66-1.41 1.41"></path>
      <path d="m19.07 4.93-1.41 1.41"></path>
    </svg>
    <svg class="lp-toggle-icon lp-toggle-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
  </button>

  <section class="lp-section lp-hero">
    <div class="lp-hero-glow" aria-hidden="true"></div>
    <div class="mx-auto max-w-6xl px-5 py-16 sm:py-24 lg:py-32">
      <div class="flex flex-col items-center text-center">
        <a href="/" class="lp-reveal mb-8 inline-block" aria-label="Twilight Psychology home">
          <Image
            src={logo}
            class="h-16 w-16 rounded-2xl sm:h-20 sm:w-20"
            alt="Twilight Psychology"
            width={80}
            height={80}
            loading="eager"
          />
        </a>

        <h1 class="lp-reveal lp-reveal-d1 font-serif text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-site-text tracking-tighter leading-[0.92] max-w-4xl">
          <span class="lp-word-reveal">Therapy,</span>{" "}
          <span class="lp-word-reveal" style="--wr-d:1">Meds</span>{" "}
          <span class="lp-word-reveal" style="--wr-d:2">&amp;</span>{" "}
          <span class="lp-word-reveal" style="--wr-d:3">Testing</span>
          <br class="hidden sm:block" />
          <span class="lp-word-reveal text-cta" style="--wr-d:4">All</span>{" "}
          <span class="lp-word-reveal text-cta" style="--wr-d:5">Under</span>{" "}
          <span class="lp-word-reveal text-cta" style="--wr-d:6">One</span>{" "}
          <span class="lp-word-reveal text-cta" style="--wr-d:7">Roof</span>
        </h1>

        <p class="lp-reveal lp-reveal-d2 mt-6 max-w-2xl text-base sm:text-lg md:text-xl text-site-sub leading-relaxed font-medium">
          Neuro-affirming therapy, psychiatric medication management, and comprehensive psychological testing — we accept 17+ insurance panels including Medicaid and Medicare. 
          Self-pay option available for virtual testing across states. New clients currently being accepted.
        </p>

        <div class="lp-reveal lp-reveal-d3 mt-8 flex flex-col sm:flex-row gap-4 items-center">
          <a
            href={WIDGET_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full sm:w-auto px-10 py-4 text-center bg-cta text-cta-fg font-black rounded-full hover:bg-cta/80 transition-all hover:scale-105 shadow-lg shadow-cta/20"
          >
            Request an Appointment
          </a>
          <a
            href={`tel:${PHONE_NUMBER}`}
            class="text-sm font-bold text-site-sub hover:text-cta transition-colors"
          >
            or call {PHONE_NUMBER_FORMATTED}
          </a>
        </div>

        <!-- Trust bar -->
        <div class="lp-trust-bar lp-reveal lp-reveal-d4 mt-14 sm:mt-20 flex flex-wrap items-center justify-center gap-x-8 sm:gap-x-12 gap-y-4">
          {differentiators.map((d, i) => (
            <div class="lp-stagger flex flex-col items-center gap-1 min-w-20" style={`--stagger-i:${i}`}>
              <Icon name={d.icon} class="w-5 h-5 text-icon" />
              <span class="text-xl sm:text-2xl font-serif font-black text-site-text">{d.stat}</span>
              <span class="text-[11px] font-semibold text-site-sub uppercase tracking-wider">{d.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════ SERVICES ════════════════ -->
  <section class="lp-section lp-services relative isolate overflow-hidden">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:py-24">
      <div class="lp-reveal text-center mb-12 sm:mb-16">
        <p class="lp-label">What We Offer</p>
        <h2 class="lp-split-text font-serif text-3xl sm:text-4xl md:text-5xl font-black text-site-text tracking-tighter">
          Three Ways We Can Help You
        </h2>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        {services.map((s, i) => (
          <a href={s.link} class="group lp-reveal lp-card flex flex-col rounded-3xl border border-border p-6 sm:p-8 transition-all duration-300 hover:border-cta/20" style={`--reveal-d:${120 + i * 80}ms`}>
            <Icon name={s.icon} class="w-10 h-10 mb-5 text-icon" />
            <h3 class="font-serif text-xl sm:text-2xl font-black text-site-text mb-3 group-hover:text-cta transition-colors tracking-tight">
              {s.title}
            </h3>
            <p class="text-sm leading-relaxed text-site-sub mb-5 grow">
              {s.desc}
            </p>
            <span class="inline-flex items-center gap-2 text-xs font-black uppercase tracking-widest text-cta/70 group-hover:text-cta transition-colors">
              {`Explore ${s.title}`}
              <span class="w-6 h-px bg-cta/30 group-hover:w-10 group-hover:bg-cta transition-all"></span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════ FREE MASKING INVENTORY ════════════════ -->
  <section class="lp-section">
    <div class="mx-auto max-w-6xl px-5 py-10 sm:py-14">
      <a
        href="/resources/masking-inventory"
        class="group lp-reveal block rounded-3xl border border-cta/20 bg-surface hover:border-cta/50 transition-all duration-300 overflow-hidden"
      >
        <div class="flex flex-col sm:flex-row items-center gap-6 p-6 sm:p-10">
          <div class="text-5xl shrink-0">🎭</div>
          <div class="flex-1 text-center sm:text-left">
            <p class="text-xs font-black uppercase tracking-widest text-cta mb-1">Free · 5 Minutes · Private</p>
            <h2 class="font-serif text-2xl sm:text-3xl font-black text-site-text tracking-tight mb-2">
              Are you masking?
            </h2>
            <p class="text-site-sub text-sm leading-relaxed max-w-lg">
              Many neurodivergent adults work incredibly hard to appear "normal" without realising it.
              Take our free Masking Inventory: 25 questions, instant results, no sign-up.
            </p>
          </div>
          <span class="shrink-0 inline-flex items-center gap-2 px-7 py-3.5 bg-cta text-cta-fg font-bold rounded-full text-sm group-hover:bg-cta/90 transition-colors">
            Take the Quiz
            <span class="w-0 overflow-hidden group-hover:w-4 transition-all duration-200">→</span>
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- ════════════════ WHY US ════════════════ -->
  <section class="lp-section lp-why">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:py-24">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div class="lp-reveal lp-slide-left">
          <p class="lp-label">Why Twilight Psychology</p>
          <h2 class="lp-split-text font-serif text-3xl sm:text-4xl md:text-5xl font-black text-site-text tracking-tighter mb-6">
            Built for People Who've
            <span class="text-cta"> Been Overlooked</span>
          </h2>
          <p class="lp-reveal text-site-sub text-base sm:text-lg leading-relaxed mb-8" style="--reveal-d:100ms">
            Many adults go years without answers because the system wasn't designed for them. We specialize in assessments for ADHD, Autism, and related conditions — using a neuro-affirming approach that centers your experience rather than dismissing it.
          </p>
          <a
            href="/about/twilight-psychology"
            class="lp-reveal inline-flex items-center gap-2 text-sm font-black text-cta hover:text-cta/80 transition-colors"
            style="--reveal-d:200ms"
          >
            Read Our Story
            <Icon name="mdi:arrow-right" class="w-4 h-4" />
          </a>
        </div>

        <div class="space-y-4">
          <div class="lp-reveal lp-slide-right lp-card rounded-2xl border border-border p-5">
            <div class="flex items-start gap-4">
              <Icon name="mdi:speedometer" class="w-7 h-7 shrink-0 text-icon mt-0.5" />
              <div>
                <h3 class="font-serif text-lg font-black text-site-text mb-1">Results in Days, Not Months</h3>
                <p class="text-sm text-site-sub leading-relaxed">Self-pay evaluations can be completed and reports delivered within 7 days of intake. Insurance-based testing starts within weeks.</p>
              </div>
            </div>
          </div>

          <div class="lp-reveal lp-slide-right lp-card rounded-2xl border border-border p-5" style="--reveal-d:100ms">
            <div class="flex items-start gap-4">
              <Icon name="mdi:video-wireless-outline" class="w-7 h-7 shrink-0 text-icon mt-0.5" />
              <div>
                <h3 class="font-serif text-lg font-black text-site-text mb-1">Fully Remote Testing Available</h3>
                <p class="text-sm text-site-sub leading-relaxed">No need to travel. Complete your evaluation from home via secure telehealth — available across 43+ states through PSYPACT.</p>
              </div>
            </div>
          </div>

          <div class="lp-reveal lp-slide-right lp-card rounded-2xl border border-border p-5" style="--reveal-d:200ms">
            <div class="flex items-start gap-4">
              <Icon name="mdi:calendar-weekend-outline" class="w-7 h-7 shrink-0 text-icon mt-0.5" />
              <div>
                <h3 class="font-serif text-lg font-black text-site-text mb-1">Weekend &amp; Flexible Scheduling</h3>
                <p class="text-sm text-site-sub leading-relaxed">We know your schedule is full. We offer evening and weekend appointments so you don't have to choose between work and getting answers.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="lp-section lp-team relative isolate overflow-hidden">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:py-24">
      <div class="lp-reveal text-center mb-12 sm:mb-16">
        <p class="lp-label">Your Clinical Team</p>
        <h2 class="lp-split-text font-serif text-3xl sm:text-4xl md:text-5xl font-black text-site-text tracking-tighter">
          Meet the Clinicians
        </h2>
        <p class="lp-reveal mt-4 max-w-2xl mx-auto text-site-sub text-base leading-relaxed" style="--reveal-d:100ms">
          Our team includes licensed psychologists, licensed psychological associates, and a psychiatric nurse practitioner — each specializing in neurodivergent care.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6">
        {featuredProviders.map((p, i) => (
          <a href={`/about/clinicians/${p.slug}`} class="group lp-reveal lp-scale-in text-center" style={`--reveal-d:${i * 100}ms`}>
            <div class="lp-avatar-ring mx-auto mb-3 w-24 h-24 sm:w-28 sm:h-28 rounded-full overflow-hidden border-2 border-border group-hover:border-cta/40 transition-colors">
              <Image
                src={p.image}
                alt={p.name}
                width={112}
                height={112}
                class="w-full h-full object-cover"
              />
            </div>
            <h3 class="font-serif text-sm sm:text-base font-black text-site-text group-hover:text-cta transition-colors">{p.name}</h3>
            <p class="text-xs text-site-sub mt-0.5">{p.credential} &middot; {p.spec}</p>
          </a>
        ))}
      </div>

      <div class="text-center mt-8">
        <a
          href="/about/clinicians/clinicians-lex-ky"
          class="inline-flex items-center gap-2 text-sm font-black text-cta hover:text-cta/80 transition-colors"
        >
          View All Clinicians
          <Icon name="mdi:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- ════════════════ INSURANCE ════════════════ -->
  <section class="lp-section lp-insurance relative isolate overflow-hidden">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:py-24">
      <div class="lp-reveal text-center mb-10 sm:mb-14">
        <p class="lp-label">Insurance Accepted</p>
        <h2 class="lp-split-text font-serif text-3xl sm:text-4xl font-black text-site-text tracking-tighter">
          We Work With Your Insurance
        </h2>
        <p class="lp-reveal mt-4 max-w-xl mx-auto text-site-sub text-sm sm:text-base leading-relaxed" style="--reveal-d:100ms">
          We accept most major commercial plans, Medicaid, Medicare, Tricare, and CHAMPVA. Out-of-pocket options are also available with faster turnaround.
        </p>
      </div>

      <div class="lp-reveal flex flex-wrap items-center justify-center gap-6 sm:gap-8 opacity-70" style="--reveal-d:150ms">
        <span class="lp-ins-badge">Aetna</span>
        <span class="lp-ins-badge">Cigna</span>
        <span class="lp-ins-badge">UHC</span>
        <span class="lp-ins-badge">Anthem</span>
        <span class="lp-ins-badge">Humana</span>
        <span class="lp-ins-badge">Medicaid</span>
        <span class="lp-ins-badge">Medicare</span>
        <span class="lp-ins-badge">Tricare</span>
        <span class="lp-ins-badge">Ambetter</span> 
        <span class="lp-ins-badge">Passport</span>
        <span class="lp-ins-badge">UMR</span>
      </div>

      <p class="text-center mt-6 text-xs text-site-sub">
        <a href="/resources/insurances-accepted" class="hover:text-cta transition-colors underline underline-offset-2">View full insurance details &rarr;</a>
      </p>
    </div>
  </section>

  <section class="lp-section lp-steps relative isolate overflow-hidden">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:py-24">
      <div class="lp-reveal text-center mb-12 sm:mb-16">
        <p class="lp-label">How It Works</p>
        <h2 class="lp-split-text font-serif text-3xl sm:text-4xl md:text-5xl font-black text-site-text tracking-tighter">
          Three Simple Steps
        </h2>
      </div>

      <div class="grid gap-5 sm:grid-cols-3">
        <div class="lp-reveal lp-step-card relative rounded-3xl border border-border p-6 sm:p-8 text-center">
          <span class="lp-step-number font-serif font-black text-cta/20 text-6xl sm:text-7xl leading-none">1</span>
          <h3 class="font-serif text-lg sm:text-xl font-black text-site-text mt-2 mb-2">Reach Out</h3>
          <p class="text-sm text-site-sub leading-relaxed">
            Contact us online or call. We'll answer your questions and help determine which service fits your needs.
          </p>
        </div>

        <div class="lp-reveal lp-step-card relative rounded-3xl border border-border p-6 sm:p-8 text-center" style="--reveal-d:120ms">
          <span class="lp-step-number font-serif font-black text-cta/20 text-6xl sm:text-7xl leading-none">2</span>
          <h3 class="font-serif text-lg sm:text-xl font-black text-site-text mt-2 mb-2">Complete Intake</h3>
          <p class="text-sm text-site-sub leading-relaxed">
            Fill out our intake forms and schedule your appointment. We'll verify benefits and walk you through what to expect.
          </p>
        </div>

        <div class="lp-reveal lp-step-card relative rounded-3xl border border-border p-6 sm:p-8 text-center" style="--reveal-d:240ms">
          <span class="lp-step-number font-serif font-black text-cta/20 text-6xl sm:text-7xl leading-none">3</span>
          <h3 class="font-serif text-lg sm:text-xl font-black text-site-text mt-2 mb-2">Get Answers</h3>
          <p class="text-sm text-site-sub leading-relaxed">
            Attend your evaluation, therapy, or medication appointment. Receive your results and a clear path forward.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════ FINAL CTA ════════════════ -->
  <section class="lp-section lp-final-cta">
    <div class="lp-cta-glow" aria-hidden="true"></div>
    <div class="mx-auto max-w-4xl px-5 py-20 sm:py-28">
      <div class="lp-reveal lp-scale-in lp-cta-card rounded-4xl border border-border px-6 py-12 sm:px-12 sm:py-16 text-center">
        <h2 class="lp-split-text font-serif text-3xl sm:text-4xl md:text-5xl font-black text-site-text tracking-tighter mb-5">
          You Deserve Answers.
          <br class="hidden sm:block" />
          <span class="text-cta">Let's Find Them.</span>
        </h2>
        <p class="lp-reveal max-w-xl mx-auto text-site-sub text-base sm:text-lg leading-relaxed mb-8" style="--reveal-d:150ms">
          Whether it's an evaluation, therapy, or medication support — our team is ready when you are. New clients are currently being accepted.
        </p>
        <div class="lp-reveal flex flex-col sm:flex-row gap-4 justify-center items-center" style="--reveal-d:250ms">
          <a
            href={WIDGET_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full sm:w-auto px-10 py-4 text-center bg-cta text-cta-fg font-black rounded-full hover:bg-cta/80 transition-all hover:scale-105 shadow-lg shadow-cta/20"
          >
            Request an Appointment
          </a>
          <a
            href={`mailto:${EMAIL_ADDRESS}`}
            class="text-sm font-bold text-site-sub hover:text-cta transition-colors"
          >
            or email {EMAIL_ADDRESS}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════ FOOTER BAR ════════════════ -->
  <footer class="border-t border-border px-5 py-6 text-center">
    <div class="mx-auto max-w-6xl flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-site-sub">
      <p>&copy; {new Date().getFullYear()} Twilight Psychology, PLLC. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="/privacy" class="hover:text-cta transition-colors">Privacy Policy</a>
        <span class="text-site-sub/20">|</span>
        <a href="/" class="hover:text-cta transition-colors">Main Website</a>
      </div>
    </div>
  </footer>
</LandingLayout>

<style>
  /* ── Scoped landing-page styles ── */

  .lp-section {
    position: relative;
    border-top: 1px solid var(--theme-border);
    overflow: hidden;
  }

  .lp-section:first-child {
    border-top: 0;
  }

  /* Hero glow */
  .lp-hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(var(--rgb-accent), 0.07), transparent 70%);
    opacity: 1;
  }

  /* Final CTA glow */
  .lp-cta-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse 70% 60% at 50% 110%, rgba(var(--rgb-accent), 0.06), transparent 70%);
    opacity: 1;
  }

  /* ── Scroll-reveal animations ── */

  .lp-reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: var(--reveal-d, 0ms);
  }
  .lp-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Delay utility classes for hero cascade */
  .lp-reveal-d1 { --reveal-d: 100ms; }
  .lp-reveal-d2 { --reveal-d: 200ms; }
  .lp-reveal-d3 { --reveal-d: 350ms; }
  .lp-reveal-d4 { --reveal-d: 500ms; }

  /* Directional variants */
  .lp-slide-left {
    transform: translateX(-32px);
  }
  .lp-slide-left.is-visible {
    transform: translateX(0);
  }
  .lp-slide-right {
    transform: translateX(32px);
  }
  .lp-slide-right.is-visible {
    transform: translateX(0);
  }
  .lp-scale-in {
    transform: scale(0.95);
  }
  .lp-scale-in.is-visible {
    transform: scale(1);
  }

  /* Word-by-word reveal for hero heading */
  .lp-word-reveal {
    display: inline-block;
    overflow: hidden;
    vertical-align: baseline;
  }
  .lp-word-reveal > span,
  .lp-word-reveal {
    --wr-d: 0;
  }
  .lp-hero .lp-reveal.is-visible .lp-word-reveal {
    animation: wordRevealSlideUp 0.65s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    animation-delay: calc(var(--wr-d, 0) * 65ms + 200ms);
  }

  /* Split-text slide-up for section headings */
  .lp-split-text {
    overflow: hidden;
    clip-path: inset(0 0 0 0);
  }
  .lp-reveal.is-visible .lp-split-text,
  .lp-split-text.lp-reveal.is-visible {
    animation: textSlideReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: var(--reveal-d, 0ms);
  }

  /* Staggered children (trust bar stats) */
  .lp-stagger {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    transition-delay: calc(var(--stagger-i, 0) * 80ms);
  }
  .is-visible .lp-stagger {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes textSlideReveal {
    from { opacity: 0; transform: translateY(40%); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 767px) {
    .lp-hero-glow,
    .lp-cta-glow {
      opacity: 0.5;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-hero-glow,
    .lp-cta-glow {
      display: none;
    }
    .lp-reveal,
    .lp-stagger {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
      animation: none !important;
    }
    .lp-word-reveal {
      animation: none !important;
    }
  }

  /* Cards */
  .lp-card {
    background: rgba(var(--rgb-surface), 0.45);
    backdrop-filter: blur(16px);
    box-shadow: inset 0 1px 0 rgba(var(--rgb-accent), 0.025);
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .lp-card:hover {
    background: rgba(var(--rgb-surface), 0.6);
  }

  .lp-step-card {
    background: rgba(var(--rgb-surface), 0.35);
    box-shadow: inset 0 1px 0 rgba(var(--rgb-accent), 0.025);
  }

  .lp-cta-card {
    background:
      radial-gradient(circle at 50% 0%, rgba(var(--rgb-accent), 0.02), transparent 60%),
      rgba(var(--rgb-surface), 0.5);
    box-shadow: inset 0 1px 0 rgba(var(--rgb-accent), 0.03);
    backdrop-filter: blur(20px);
  }

  /* Label */
  .lp-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--theme-section-label);
  }

  .lp-label::before,
  .lp-label::after {
    content: "";
    width: 2rem;
    height: 1px;
    background: var(--theme-section-label-line);
  }

  /* Insurance badges */
  .lp-ins-badge {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--color-site-sub);
    padding: 0.5rem 1rem;
    border: 1px solid var(--theme-border);
    border-radius: 9999px;
    background: rgba(var(--rgb-surface), 0.4);
  }

  /* Trust bar */
  .lp-trust-bar {
    padding-top: 1.5rem;
    border-top: 1px solid var(--theme-border);
  }

  /* ── Light mode overrides ── */

  :root.light .lp-card {
    background: rgba(var(--rgb-surface), 0.85);
    box-shadow: inset 0 1px 0 rgba(var(--rgb-accent), 0.04);
  }

  :root.light .lp-card:hover {
    background: rgba(var(--rgb-surface), 0.92);
  }

  :root.light .lp-step-card {
    background: rgba(var(--rgb-surface), 0.8);
    box-shadow: inset 0 1px 0 rgba(var(--rgb-accent), 0.03);
    border-color: var(--theme-border-strong);
  }

  :root.light .lp-cta-card {
    background: rgba(var(--rgb-surface), 0.88);
    box-shadow: inset 0 1px 0 rgba(var(--rgb-accent), 0.05);
  }

  :root.light .lp-ins-badge {
    border-color: var(--theme-border-strong);
    background: rgba(var(--rgb-surface), 0.7);
  }

  /* ── Theme toggle ── */

  .lp-theme-toggle {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 110;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 9999px;
    border: 1px solid var(--theme-glass-border);
    background: var(--theme-glass-bg);
    backdrop-filter: blur(12px);
    color: var(--color-site-sub);
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .lp-theme-toggle:hover {
    border-color: var(--theme-border-strong);
    color: var(--color-site-text);
  }

  /* Sun icon visible in dark mode, moon in light mode */
  .lp-toggle-moon {
    display: none;
  }

  :root.light .lp-toggle-icon:not(.lp-toggle-moon) {
    display: none;
  }

  :root.light .lp-toggle-moon {
    display: block;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const root = document.documentElement;

    // ── Theme toggle ──
    const getCurrentTheme = (): string => {
      if (root.classList.contains('light')) return 'light';
      return 'dark';
    };

    const applyTheme = (theme: string) => {
      root.classList.remove('light', 'dark');
      root.classList.add(theme);
      root.style.colorScheme = theme;
      localStorage.setItem('theme', theme);
    };

    document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const next = getCurrentTheme() === 'dark' ? 'light' : 'dark';
        applyTheme(next);
      });
    });

    // ── Scroll-reveal IntersectionObserver ──
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      document.querySelectorAll('.lp-reveal').forEach((el) => el.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.lp-reveal').forEach((el) => observer.observe(el));
  });
</script>

---
import LandingLayout from "../layouts/LandingLayout.astro";
import { Icon } from "astro-icon/components";
import logo from "../assets/images/logo.png";
import { PHONE_NUMBER, PHONE_NUMBER_FORMATTED, WIDGET_LINK } from "../data/resource";
import { Image } from "astro:assets";

const services = [
  { icon: "mdi:head-cog-outline", label: "Psychological Evaluations", href: "/services/psychological-evaluations" },
  { icon: "mdi:account-heart-outline", label: "Therapy · Ages 3–99", href: "/services/therapy" },
  { icon: "mdi:medication-outline", label: "Medication Management", href: "/services/medication-management" },
];

const differentiators = [
  { icon: "mdi:stethoscope", stat: "8+", label: "Years Expertise" },
  { icon: "mdi:earth", stat: "40+", label: "States via PSYPACT" },
  { icon: "mdi:clock-fast", stat: "7 days", label: "Optional self-pay turnaround" },
  { icon: "mdi:calendar-check-outline", stat: "2,100+", label: "Evaluations completed" },
  { icon: "mdi:shield-check-outline", stat: "20+", label: "Insurance panels" },
  
];

const staggerStyle = (index: number) => `--stagger-i:${index}`;
---

<!-- Paid-traffic landing page stays noindex so it does not compete with organic service pages. -->
<LandingLayout
  title="Get Started"
  description="Psychological evaluations, neuro-affirming therapy for ages 3–99, and medication management in Kentucky. Telehealth available across 40+ states via PSYPACT."
  robots="noindex, follow"
>
  <!-- ══ Theme toggle ══ -->
  <button
    type="button"
    data-theme-toggle
    class="lp-theme-toggle"
    aria-label="Toggle light/dark mode"
  >
    <svg class="lp-toggle-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="4"></circle>
      <path d="M12 2v2"></path>
      <path d="M12 20v2"></path>
      <path d="m4.93 4.93 1.41 1.41"></path>
      <path d="m17.66 17.66 1.41 1.41"></path>
      <path d="M2 12h2"></path>
      <path d="M20 12h2"></path>
      <path d="m6.34 17.66-1.41 1.41"></path>
      <path d="m19.07 4.93-1.41 1.41"></path>
    </svg>
    <svg class="lp-toggle-icon lp-toggle-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
  </button>

  <!-- ════════════════ SINGLE-VIEWPORT HERO ════════════════ -->
  <section class="lp-hero lp-viewport">
    <div class="lp-hero-glow" aria-hidden="true"></div>
    <div class="mx-auto max-w-3xl px-5 py-10 sm:py-14">
      <div class="flex flex-col items-center text-center">
        <a href="/" class="lp-reveal mb-6 inline-block" aria-label="Twilight Psychology home">
          <Image
            src={logo}
            class="h-14 w-14 rounded-2xl sm:h-16 sm:w-16"
            alt="Twilight Psychology"
            width={64}
            height={64}
            loading="eager"
          />
        </a>

        <h1 class="lp-reveal lp-reveal-d1 font-serif text-4xl sm:text-5xl md:text-6xl font-black text-site-text tracking-tighter leading-[0.92] max-w-2xl">
          Get Answers.
          <br />
          <span class="text-cta">Move Forward.</span>
        </h1>

        <p class="lp-reveal lp-reveal-d2 mt-5 max-w-xl text-base sm:text-lg text-site-sub leading-relaxed font-medium">
          Twilight Psychology offers clinical-depth evaluations, neuro-affirming therapy, and medication management — serving Kentucky from Lexington, with telehealth available across 40+ states.
        </p>

        <!-- Service badges -->
        <div class="lp-reveal lp-reveal-d3 mt-6 flex flex-wrap items-center justify-center gap-2">
          {services.map((s) => (
            <a href={s.href} class="lp-badge group inline-flex items-center gap-1.5 rounded-full border border-border px-4 py-1.5 text-xs font-bold text-site-sub hover:border-cta/40 hover:text-cta transition-colors">
              <Icon name={s.icon} class="w-3.5 h-3.5 shrink-0" />
              {s.label}
            </a>
          ))}
        </div>

        <!-- CTAs -->
        <div class="lp-reveal lp-reveal-d4 mt-7 flex flex-col sm:flex-row gap-4 items-center">
          <a
            href={WIDGET_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full sm:w-auto px-10 py-4 text-center bg-cta text-cta-fg font-black rounded-full hover:bg-cta/80 transition-all hover:scale-105 shadow-lg shadow-cta/20"
          >
            Request an Appointment
          </a>
          <a
            href={`tel:${PHONE_NUMBER}`}
            class="text-sm font-bold text-site-sub hover:text-cta transition-colors"
          >
            or call {PHONE_NUMBER_FORMATTED}
          </a>
        </div>

        <!-- Trust bar -->
        <div class="lp-trust-bar lp-reveal lp-reveal-d5 mt-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
          {differentiators.map((d, i) => (
            <div class="lp-stagger flex flex-col items-center gap-0.5 min-w-16" style={staggerStyle(i)}>
              <Icon name={d.icon} class="w-4 h-4 text-icon" />
              <span class="text-lg sm:text-xl font-serif font-black text-site-text">{d.stat}</span>
              <span class="text-[10px] font-semibold text-site-sub uppercase tracking-wider text-center">{d.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════ FOOTER BAR ════════════════ -->
  <footer class="border-t border-border px-5 py-5 text-center">
    <div class="mx-auto max-w-6xl flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-site-sub">
      <p>&copy; {new Date().getFullYear()} Twilight Psychology, PLLC. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="/privacy" class="hover:text-cta transition-colors">Privacy Policy</a>
        <span class="text-site-sub/20">|</span>
        <a href="/" class="hover:text-cta transition-colors">Main Website</a>
      </div>
    </div>
  </footer>
</LandingLayout>

<style>
  /* ── Scoped landing-page styles ── */

  /* Full-viewport hero */
  .lp-viewport {
    min-height: calc(100dvh - 2.75rem); /* subtract footer bar */
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Hero glow */
  .lp-hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(var(--rgb-accent), 0.07), transparent 70%);
    opacity: 1;
  }

  /* ── Scroll-reveal animations ── */

  .lp-reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: var(--reveal-d, 0ms);
  }
  .lp-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Delay utility classes for hero cascade */
  .lp-reveal-d1 { --reveal-d: 100ms; }
  .lp-reveal-d2 { --reveal-d: 200ms; }
  .lp-reveal-d3 { --reveal-d: 320ms; }
  .lp-reveal-d4 { --reveal-d: 440ms; }
  .lp-reveal-d5 { --reveal-d: 560ms; }

  /* Staggered children (trust bar stats) */
  .lp-stagger {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    transition-delay: calc(var(--stagger-i, 0) * 80ms);
  }
  .is-visible .lp-stagger {
    opacity: 1;
    transform: translateY(0);
  }

  /* Trust bar */
  .lp-trust-bar {
    padding-top: 1.25rem;
    border-top: 1px solid var(--theme-border);
  }

  /* Service badge */
  .lp-badge {
    background: rgba(var(--rgb-surface), 0.45);
    backdrop-filter: blur(12px);
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .lp-badge:hover {
    background: rgba(var(--rgb-surface), 0.65);
  }

  @media (max-width: 767px) {
    .lp-hero-glow {
      opacity: 0.5;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-hero-glow { display: none; }
    .lp-reveal,
    .lp-stagger {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
      animation: none !important;
    }
  }

  /* ── Light mode overrides ── */

  :root.light .lp-badge {
    background: rgba(var(--rgb-surface), 0.85);
  }

  /* ── Theme toggle ── */

  .lp-theme-toggle {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 110;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 9999px;
    border: 1px solid var(--theme-glass-border);
    background: var(--theme-glass-bg);
    backdrop-filter: blur(12px);
    color: var(--color-site-sub);
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .lp-theme-toggle:hover {
    border-color: var(--theme-border-strong);
    color: var(--color-site-text);
  }

  /* Sun icon visible in dark mode, moon in light mode */
  .lp-toggle-moon {
    display: none;
  }

  :root.light .lp-toggle-icon:not(.lp-toggle-moon) {
    display: none;
  }

  :root.light .lp-toggle-moon {
    display: block;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const root = document.documentElement;

    // ── Theme toggle ──
    const getCurrentTheme = (): string => {
      if (root.classList.contains('light')) return 'light';
      return 'dark';
    };

    const applyTheme = (theme: string) => {
      root.classList.remove('light', 'dark');
      root.classList.add(theme);
      root.style.colorScheme = theme;
      localStorage.setItem('theme', theme);
    };

    document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const next = getCurrentTheme() === 'dark' ? 'light' : 'dark';
        applyTheme(next);
      });
    });

    // ── Scroll-reveal IntersectionObserver ──
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      document.querySelectorAll('.lp-reveal').forEach((el) => el.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.lp-reveal').forEach((el) => observer.observe(el));
  });
</script>

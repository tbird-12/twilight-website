---
import Layout from '../../layouts/Layout.astro';
import { WIDGET_LINK } from '../../data/resource';
import PageHeroWrapper from "../../components/PageHeroWrapper.astro";
import AnimatedSection from "../../components/preact/primitives/AnimatedSection";

const learningDisabilities = [
  {
    title: "Dyslexia",
    specialty: "Reading & Word Recognition",
    desc: "Characterized by difficulty reading or recognizing words, alongside persistent challenges with spelling and phonological processing.",
    icon: "📖"
  },
  {
    title: "Dysgraphia",
    specialty: "Written Expression",
    desc: "Difficulty writing at an appropriate peer level, often involving improper letter size/spacing, spelling errors, or illegible handwriting.",
    icon: "✍️"
  },
  {
    title: "Dyscalculia",
    specialty: "Mathematics & Numeracy",
    desc: "The inability to understand numerical data or math concepts, manifesting as trouble with arithmetic skills or basic math logic.",
    icon: "🔢"
  }
];

const faqs = [
  {
    q: "How do learning disabilities relate to ADHD?",
    a: "Learning disabilities frequently co-occur with ADHD. While they are distinct conditions, the executive functioning challenges of ADHD can complicate how a student manages Dyslexia or Dysgraphia."
  },
  {
    q: "What age is best for testing?",
    a: "Evaluations can be conducted from early childhood through adulthood. Early identification is key for implementing effective IEP or 504 accommodations in school."
  },
  {
    q: "Are these evaluations accepted by Kentucky schools?",
    a: "Yes. Our comprehensive reports are designed to meet clinical and educational standards, providing the 'evidence of need' required for academic support."
  },
  {
    q: "Do you offer 'Twice Exceptional' (2e) testing?",
    a: "Absolutely. We specialize in identifying gifted individuals who also have a learning disability, ensuring their brilliance isn't overshadowed by their challenges."
  },
  {
    q: "How much does it cost for a learning disability evaluation?",
    a: "Learning disability evaluations are tailored to the complexity of the referral question and the assessment battery required. We review the expected scope with families up front so they understand the level of testing and documentation involved."
  }
];
---

<Layout
  title="Learning Disability Testing KY | Twilight Psychology"
  description="Learning disability testing in Kentucky for dyslexia, dysgraphia, and dyscalculia. Assessments for children and adults with IEP and 504 documentation."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
    
    <PageHeroWrapper
      title="Learning Disabilities"
      accentWord="Disabilities"
      badge="Educational Advocacy"
      subtitle="We move beyond broad screening to define the specific learning profile beneath the struggle, so families leave with real clarity, credible documentation, and actionable next steps."
      size="lg"
    />

    <AnimatedSection client:visible animation="fadeInUp" delay={100}>
    <section class="max-w-7xl mx-auto px-4 py-24">
        <h2 class="font-serif text-4xl font-black text-site-text mb-16 text-center lg:text-left">Learning Profiles We <span class="text-cta">Differentiate</span></h2>
        <div class="grid md:grid-cols-3 gap-8">
            {learningDisabilities.map(ld => (
              <div class="p-10 theme-surface-soft border theme-border rounded-[2.5rem] theme-hover-surface transition-all">
                    <h3 class="font-serif text-2xl font-black text-site-text mb-2">{ld.title}</h3>
                    <p class="text-cta text-[10px] font-black uppercase tracking-widest mb-6">{ld.specialty}</p>
                    <p class="text-site-sub text-sm leading-relaxed">{ld.desc}</p>
                </div>
            ))}
        </div>
    </section>
    </AnimatedSection>

    <AnimatedSection client:visible animation="fadeInUp" delay={200}>
    <section class="max-w-7xl mx-auto px-4 mb-24">
          <div class="theme-surface-2 border border-cta/20 p-12 rounded-[3rem] relative overflow-hidden">
            <div class="absolute top-0 right-0 p-12 text-8xl text-site-text/5 font-black">ADHD</div>
            <div class="max-w-2xl relative z-10">
                <h2 class="font-serif text-3xl font-black text-site-text mb-6">Integrated Understanding</h2>
                <p class="text-site-text text-lg leading-relaxed">
                  We believe the strongest evaluations do more than assign a label. They clarify whether a learning disability stands alone or whether it overlaps with <strong>ADHD</strong>, anxiety, giftedness, or another factor that changes how support should be designed.
                </p>
                <p class="mt-4 text-site-text text-lg leading-relaxed">
                  Our goal is a high-resolution picture of performance, not a rushed conclusion. That level of nuance is what makes recommendations more useful to families, schools, and treatment providers.
                </p>
                <div class="mt-8">
                    <a href="/services/adhd-testing" class="text-cta font-black text-sm uppercase tracking-widest">
                        Explore ADHD Testing →
                    </a>
                </div>
            </div>
        </div>
    </section>
    </AnimatedSection>

    <section id="faq" class="max-w-4xl mx-auto px-4 py-24">
        <h2 class="font-serif text-3xl font-black text-site-text mb-12 text-center tracking-tight">Frequently Asked <span class="text-sand italic text-4xl">Questions</span></h2>
        <div class="space-y-6">
            {faqs.map(faq => (
                <div class="p-8 theme-surface-soft border theme-border rounded-3xl group hover:border-cta/30 transition-all">
                    <h3 class="font-serif text-sand font-black mb-3 text-lg">{faq.q}</h3>
                    <p class="text-site-sub text-sm leading-relaxed">{faq.a}</p>
                </div>
            ))}
        </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 py-24 text-center">
        <div class="theme-surface-2 p-16 rounded-[4rem] text-site-text border theme-border">
          <h2 class="font-serif text-3xl md:text-4xl font-bold mb-8 tracking-tight text-site-text">Ready for a clearer learning picture?</h2>
          <p class="text-lg font-medium mb-10 max-w-xl mx-auto text-site-sub italic">Schedule a comprehensive evaluation to better understand strengths, barriers, and the kind of support that will actually fit.</p>
            <a href={WIDGET_LINK} class="inline-block px-10 py-4 bg-cta/90 text-cta-fg font-bold rounded-full hover:bg-cta transition-all">
                Request Appointment
            </a>
        </div>
    </section>

    <nav class="max-w-4xl mx-auto px-6 mt-12 mb-4">
        <a href="/specialities" class="inline-flex items-center gap-2 text-sm font-bold text-cta hover:text-cta/80 transition-colors">
            <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
            View All Specialties
        </a>
    </nav>
      </div>
    </div>
  </div>
</Layout>
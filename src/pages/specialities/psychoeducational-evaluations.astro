---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import '../../styles/global.css';
import { WIDGET_LINK } from '../../data/resource';

const evaluationFocus = [
  {
    title: "Cognitive Assessment",
    detail: "Standardized IQ testing (WISC-V or WAIS-IV) to understand intellectual potential and processing."
  },
  {
    title: "Adaptive Functioning",
    detail: "Measuring daily living skills, communication, and social abilities—crucial for Waiver eligibility."
  },
  {
    title: "Waiver Documentation",
    detail: "Providing the specific clinical documentation required for Kentucky SCL and Michelle P. Waivers."
  },
  {
    title: "Educational Planning",
    detail: "Clear recommendations for IEP/504 plans to ensure success in school and vocational settings."
  }
];
---

<ServiceLayout name="Psychoeducational Evaluations | Twilight Psychology PLLC"
  description="Comprehensive psychoeducational assessments"
  metaDescription="Psychoeducational evaluations in Kentucky for IEP planning, waiver eligibility, and educational accommodations. Comprehensive cognitive and adaptive functioning assessments for all ages."
  >
    
    <section class="relative py-24 px-4 overflow-hidden border-b theme-border">
      <div class="max-w-4xl mx-auto text-center relative z-20">
        <span class="px-4 py-1.5 mb-6 text-[10px] font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full">
          Specialized Diagnostic Services
        </span>
        <h1 class="font-serif text-5xl md:text-7xl font-black text-site-text mb-6 tracking-tight">
          Educational <span class="text-cta">Assessments</span>
        </h1>
        <p class="text-xl text-site-sub font-medium max-w-2xl mx-auto leading-relaxed">
          Comprehensive Intellectual Disability evaluations for children and adults seeking support, waivers, and understanding.
        </p>
      </div>
    </section>

    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">
      
      <div class="lg:col-span-2 space-y-12">
        <section class="theme-surface-soft backdrop-blur-md border theme-border p-10 rounded-[2.5rem]">
          <h2 class="font-serif text-4xl md:text-5xl font-black text-site-text mb-6 tracking-tighter leading-tight">
            Expert Care. <span class="text-cta">Fewer Barriers.</span>
          </h2>
          <div class="space-y-6 text-site-text leading-relaxed text-lg">
            <p>
              Psychoeducational evaluations are a critical step in understanding intellectual functioning and accessing necessary supports,
              whether for IEP planning, accommodations for examinations such as the ACT/SAT, twice exceptional (giftedness) identification, or eligibility for Kentucky Waiver services. 
              A comprehensive evaluation goes beyond an IQ score to assess adaptive functioning, social skills, and daily living abilities, 
              providing a comprehensive look at how an individual processes the world and manages the demands of daily life. 
              Due to the complexity of these assessments, they must be performed by a qualified clinician such as a Licensed Psychologist or Psychiatrist.
            </p>
            <p>
              Whether you are navigating the transition to adulthood, seeking <span class="text-cta">Kentucky Waiver services</span>, or looking for educational clarity, we provide the evidence-based documentation necessary to open doors to support.
            </p>
            <a href="/resources/faq" class="inline-block text-cta font-black text-sm border-b-2 border-cta/20 hover:border-cta transition-all pb-1">
              How our testing process works →
            </a>
          </div>
        </section>

        <section>
          <h2 class="font-serif text-2xl font-black text-site-text mb-10">Evaluation Pillars</h2>
          <div class="grid sm:grid-cols-2 gap-6">
            {evaluationFocus.map((item) => (
              <div class="group p-8 theme-surface-soft border theme-border rounded-4xl hover:border-cta/30 transition-all">
                 <div class="w-10 h-10 rounded-xl bg-cta sm:bg-surface-2 flex items-center justify-center mb-6 border theme-border sm:group-hover:bg-cta transition-all">
                   <span class="text-cta-fg sm:text-cta sm:group-hover:text-cta-fg text-xl">✦</span>
                </div>
                <h3 class="font-serif text-site-text font-black mb-2">{item.title}</h3>
                <p class="text-site-sub/50 text-sm leading-relaxed mb-6">{item.detail}</p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <aside class="space-y-8">
        <div class="theme-surface-soft border theme-border p-8 rounded-[2.5rem]">
          <h3 class="font-serif text-xl font-black text-site-text mb-4">Kentucky Supports</h3>
          <p class="text-site-sub/60 text-sm leading-relaxed mb-4">
            Our reports meet the criteria for:
          </p>
          <ul class="space-y-3 text-sm font-bold text-sand/80">
            <li class="flex items-center gap-2"><span class="text-cta">✓</span> Michelle P. Waiver</li>
            <li class="flex items-center gap-2"><span class="text-cta">✓</span> SCL Waiver</li>
            <li class="flex items-center gap-2"><span class="text-cta">✓</span> Guardianship Proceedings</li>
            <li class="flex items-center gap-2"><span class="text-cta">✓</span> SSI/SSDI Documentation</li>
          </ul>
        </div>

        <div class="theme-surface-soft border theme-border p-10 rounded-[2.5rem] text-center">
          <h3 class="font-serif text-2xl font-black text-site-text mb-4 tracking-tight">Access Support</h3>
          <p class="text-site-sub/60 text-sm mb-8">Professional evaluations with a focus on dignity and clinical precision.</p>
          <a href={WIDGET_LINK} class="block w-full py-4 bg-sand text-cta-fg font-black rounded-full hover:bg-white transition-all shadow-lg shadow-sand/10">
            Request Appointment
          </a>
        </div>

        <div class="p-8 bg-cta rounded-[2.5rem] text-cta-fg">
           <h4 class="font-serif font-black uppercase text-[10px] tracking-widest mb-2">Billing & Insurance</h4>
           <p class="text-sm font-bold leading-tight">Psychoeducational evaluations are self-pay only.</p>
        </div>
      </aside>
    </div>

    <section class="max-w-7xl mx-auto px-4 mt-32">
       <div class="p-12 theme-surface-2 border theme-border rounded-[3rem] flex flex-col md:flex-row items-center justify-between gap-8 text-center md:text-left">
          <div class="max-w-md">
             <h2 class="font-serif text-3xl font-black text-site-text mb-4 italic">Integrated Care.</h2>
             <p class="text-site-sub/60">Following an ID diagnosis, we provide ongoing medication management and specialized therapy support.</p>
          </div>
          <div class="flex flex-wrap justify-center gap-4">
             <a href="/services/medication-management" class="px-6 py-3 theme-surface-soft border theme-border text-site-text font-black rounded-full theme-hover-surface transition-all">Medication Support</a>
             <a href="/services/therapy" class="px-6 py-3 theme-surface-soft border theme-border text-site-text font-black rounded-full theme-hover-surface transition-all">Counseling</a>
          </div>
       </div>
    </section>
</ServiceLayout>
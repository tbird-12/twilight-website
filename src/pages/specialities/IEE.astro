---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import '../../styles/global.css';
import { WIDGET_LINK } from '../../data/resource';

const ieeSteps = [
  {
    title: "Review the School's Evaluation",
    detail: "We obtain and analyze the school district's existing evaluation records—psychoeducational reports, progress monitoring data, and IEP documentation—before beginning our own assessment."
  },
  {
    title: "Comprehensive Independent Testing",
    detail: "Our licensed psychologist administers a full battery of standardized cognitive, academic achievement, and processing tests that are independent of any school-district influence."
  },
  {
    title: "Detailed Written Report",
    detail: "You receive a thorough written report with findings, diagnosis, and concrete IEP/504 recommendations written in plain language for parents and educators alike."
  },
  {
    title: "IEP Meeting Support",
    detail: "We can attend your child's IEP meeting virtually or in person to present findings, answer questions from the school team, and advocate for appropriate services."
  }
];

const faqs = [
  {
    q: "What is an Independent Educational Evaluation (IEE)?",
    a: "An IEE is a comprehensive psychological and educational assessment performed by a qualified examiner who has no affiliation with the school district. Under IDEA, parents who disagree with their school's evaluation have the legal right to request an IEE."
  },
  {
    q: "Can the school be required to pay for the IEE?",
    a: "Yes. Under IDEA, if you disagree with your school district's evaluation and request an IEE at public expense, the district must either fund the independent evaluation or initiate a due-process hearing to defend their own assessment."
  },
  {
    q: "Is Twilight Psychology contract with Kentucky public school system?",
    a: "Yes. Twilight Psychology can contract with Kentucky public school systems to conduct independent educational evaluations. Our reports meet the evidentiary standards required by state and federal special-education law."
  },
  {
    q: "How is an IEE different from a school evaluation?",
    a: "School evaluations are performed by district staff and can be influenced by budgetary constraints or pre-existing assumptions. An IEE is performed by a clinician with no stake in the outcome, providing a truly objective clinical picture."
  },
  {
    q: "What ages do you evaluate?",
    a: "We conduct IEEs for school-aged children and adolescents, typically ages 3 through 21, covering the full eligibility span under IDEA."
  },
  {
    q: "How long does an IEE take?",
    a: "Testing is typically completed over one to two sessions. The written report is delivered within seven days of the final testing session, far faster than most school-district timelines."
  }
];
---

<ServiceLayout
  name="Independent Educational Evaluations (IEE) | Twilight Psychology PLLC"
  description="Independent Educational Evaluations in Kentucky"
  metaDescription="Independent Educational Evaluations (IEE) in Kentucky. Twilight Psychology is contracted with KY public schools and provides objective second-opinion assessments when parents disagree with their school district's evaluation."
>

  <!-- Hero -->
  <section class="relative pt-36 pb-28 px-4 border-b theme-border overflow-hidden">
    <div class="max-w-7xl mx-auto relative z-10">
      <span class="text-cta font-black tracking-[0.3em] uppercase text-[10px] mb-6 block">Educational Advocacy</span>
      <h1 class="font-serif text-5xl md:text-7xl font-black text-site-text mb-8 tracking-tight">
        Independent <span class="text-cta">Educational</span> Evaluations
      </h1>
      <p class="text-site-sub text-lg leading-relaxed max-w-2xl mb-10">
        When you disagree with what your school district found—or didn't find—you have the legal right to an independent second opinion. We provide objective, clinician-led assessments outside the school system, contracted directly with Kentucky public schools.
      </p>
      <a href="#get-started" class="text-sand font-black border-b border-cta/50 pb-1 hover:text-cta transition-colors">
        Get started today ↓
      </a>
    </div>
  </section>

  <!-- What We Do + process steps -->
  <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">

    <div class="lg:col-span-2 space-y-12">

      <section class="theme-surface-soft backdrop-blur-md border theme-border p-10 rounded-[2.5rem]">
        <h2 class="font-serif text-4xl md:text-5xl font-black text-site-text mb-6 tracking-tighter leading-tight">
          A Second Opinion, <span class="text-cta">Done Right.</span>
        </h2>
        <div class="space-y-6 text-site-text leading-relaxed text-lg">
          <p>
            Schools are required under the <strong>Individuals with Disabilities Education Act (IDEA)</strong> to provide a free, appropriate evaluation to identify children with disabilities. 
            However, those evaluations are conducted by employees—people who may be constrained by time, resources, or institutional incentive to limit services.
          </p>
          <p>
            An <strong>Independent Educational Evaluation</strong> is a formal psychological and educational assessment performed by a qualified examiner with <em>no affiliation with the school district</em>. If you disagree with your school's findings, IDEA gives you the right to request an IEE. The district must then either fund the evaluation at public expense, or file for due process to defend its own assessment.
          </p>
          <p>
            Twilight Psychology can <span class="text-cta">contract with Kentucky public school systems</span> to perform these evaluations, meaning our reports carry the legal and clinical weight needed to drive real change in your child's educational plan.
          </p>
          <a href="/resources/faq" class="inline-block text-cta font-black text-sm border-b-2 border-cta/20 hover:border-cta transition-all pb-1">
            How our testing process works →
          </a>
        </div>
      </section>

      <section>
        <h2 class="font-serif text-2xl font-black text-site-text mb-10">Our IEE Process</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {ieeSteps.map((step, idx) => (
            <div class="group p-8 theme-surface-soft border theme-border rounded-4xl hover:border-cta/30 transition-all">
              <div class="w-10 h-10 rounded-xl bg-cta/10 flex items-center justify-center mb-6 border border-cta/20 group-hover:bg-cta transition-all">
                <span class="text-cta group-hover:text-cta-fg font-black text-sm">{String(idx + 1).padStart(2, '0')}</span>
              </div>
              <h3 class="font-serif text-site-text font-black mb-2">{step.title}</h3>
              <p class="text-site-sub/60 text-sm leading-relaxed">{step.detail}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- KY Contract callout -->
      <section class="theme-surface-2 border border-cta/20 p-12 rounded-[3rem] relative overflow-hidden">
        <div class="absolute top-0 right-0 p-12 text-8xl text-site-text/5 font-black select-none">KY</div>
        <div class="max-w-2xl relative z-10">
          <h2 class="font-serif text-3xl font-black text-site-text mb-6">Contract with KY Public Schools</h2>
          <p class="text-site-text text-lg leading-relaxed">
            Twilight Psychology is qualified to be a contracted provider with Kentucky public school systems. 
            We meet the state and federal credentialing requirements to conduct IEEs that are legally recognized in due-process hearings and IEP meetings alike.
          </p>
          <p class="mt-4 text-site-text text-lg leading-relaxed">
            Our reports are written to the evidentiary standard required under <strong>
                <a href="https://www.law.cornell.edu/cfr/text/34/300.502" target="_blank" class="text-cta hover:underline">
                  34 CFR § 300.502
                </a>
              </strong>, ensuring that your family's independent evaluation carries the maximum possible weight in advocating for appropriate
            educational services for your child.
          </p>
        </div>
      </section>
    </div>

    <!-- Sidebar -->
    <aside class="space-y-8">
      <div class="theme-surface-soft border theme-border p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-xl font-black text-site-text mb-4">Your IDEA Rights</h3>
        <p class="text-site-sub/60 text-sm leading-relaxed mb-4">Under federal law, parents are entitled to:</p>
        <ul class="space-y-3 text-sm font-bold text-sand/80">
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Request an IEE at any time</li>
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> IEE funded at public expense (if eligible)</li>
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Present IEE results at IEP meetings</li>
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> IEE considered in placement decisions</li>
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Protection against district retaliation</li>
        </ul>
      </div>

      <div class="theme-surface-soft border theme-border p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-xl font-black text-site-text mb-4">What We Assess</h3>
        <ul class="space-y-3 text-sm font-bold text-sand/80">
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Cognitive &amp; intellectual ability</li>
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Academic achievement</li>
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Processing speed &amp; working memory</li>
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Language &amp; phonological processing</li>
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Attention &amp; executive functioning</li>
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Social-emotional &amp; behavioral functioning</li>
        </ul>
      </div>

      <div class="p-8 bg-cta rounded-[2.5rem] text-cta-fg">
        <h4 class="font-serif font-black uppercase text-[10px] tracking-widest mb-2">Billing &amp; Insurance</h4>
        <p class="text-sm font-bold leading-tight">IEEs funded by the school district are billed directly to the district. Private-pay IEEs are self-pay. Contact us to confirm your district's coverage.</p>
      </div>
    </aside>
  </div>

  <!-- FAQ -->
  <section id="faq" class="max-w-4xl mx-auto px-4 py-24">
    <h2 class="font-serif text-3xl font-black text-site-text mb-12 text-center tracking-tight">
      Frequently Asked <span class="text-sand italic text-4xl">Questions</span>
    </h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <div class="p-8 theme-surface-soft border theme-border rounded-3xl group hover:border-cta/30 transition-all">
          <h3 class="font-serif text-sand font-black mb-3 text-lg">{faq.q}</h3>
          <p class="text-site-sub/50 text-sm leading-relaxed">{faq.a}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Related services -->
  <section class="max-w-7xl mx-auto px-4 mt-8 mb-16">
    <div class="p-12 theme-surface-2 border theme-border rounded-[3rem] flex flex-col md:flex-row items-center justify-between gap-8 text-center md:text-left">
      <div class="max-w-md">
        <h2 class="font-serif text-3xl font-black text-site-text mb-4 italic">Related Evaluations</h2>
        <p class="text-site-sub/60">Our IEEs often overlap with or lead into these specialized assessments.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/specialities/psychoeducational-evaluations" class="px-6 py-3 theme-surface-soft border theme-border text-site-text font-black rounded-full theme-hover-surface transition-all">
          Psychoeducational Evaluations
        </a>
        <a href="/specialities/dyslexia-testing" class="px-6 py-3 theme-surface-soft border theme-border text-site-text font-black rounded-full theme-hover-surface transition-all">
          Dyslexia Testing
        </a>
      </div>
    </div>
  </section>

  <!-- Get Started -->
  <section id="get-started" class="max-w-7xl mx-auto px-4 py-24 text-center">
    <div class="theme-surface-2 p-16 rounded-[4rem] text-site-text border theme-border">
      <span class="text-cta font-black tracking-[0.3em] uppercase text-[10px] mb-6 block">Next Step</span>
      <h2 class="font-serif text-3xl md:text-5xl font-black mb-6 tracking-tight text-site-text">
        Ready for an Independent Second Opinion?
      </h2>
      <p class="text-lg font-medium mb-10 max-w-xl mx-auto text-site-sub leading-relaxed">
        Contact us to discuss your child's situation. We'll confirm whether your district qualifies for public funding and get the process started—quickly.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={WIDGET_LINK} class="inline-block px-10 py-4 bg-cta text-cta-fg font-black rounded-full hover:bg-cta/80 transition-all shadow-lg shadow-cta/20">
          Request an Appointment
        </a>
        <a href="/resources/new-client" class="inline-block px-10 py-4 theme-surface-soft border theme-border text-site-text font-black rounded-full theme-hover-surface transition-all">
          Steps for New Clients
        </a>
      </div>
    </div>
  </section>

</ServiceLayout>

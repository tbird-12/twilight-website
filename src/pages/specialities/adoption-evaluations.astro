---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import { WIDGET_LINK } from '../../data/resource';
import heatherPhoto from '../../assets/images/staff/heather-cornett.png';

const evaluationAreas = [
  {
    title: "Clinical Interview",
    detail: "In-depth interviews with each prospective parent to understand family dynamics, personal history, emotional readiness, and the strengths you bring into the adoption process."
  },
  {
    title: "Psychological Testing",
    detail: "A psychologist-selected testing battery that evaluates personality, emotional regulation, and psychological stability in the level of detail adoption agencies expect."
  },
  {
    title: "Collateral Information",
    detail: "Thoughtful review of records, references, and supporting documents so the final opinion reflects the full context of your family rather than a single appointment."
  },
  {
    title: "Notary & Apostille-Ready Reports",
    detail: "Reports are prepared with agency, court, and international submission requirements in mind, with on-site notarization available for a more seamless process."
  }
];

const countries = [
  "China", "South Korea", "Colombia", "India", "Philippines",
  "Ethiopia", "Haiti", "Guatemala", "Vietnam", "Ukraine", "Bulgaria", "Other Countries"
];

const faqs = [
  {
    q: "What is a psychological adoption evaluation?",
    a: "An adoption evaluation is a clinical assessment conducted by a licensed psychologist that examines the psychological fitness and parenting readiness of prospective adoptive parents. It is required by most domestic and international adoption agencies and courts."
  },
  {
    q: "Who is evaluated — just one parent or both?",
    a: "Dr. Cornett evaluates all prospective adoptive parents in the household. For couples, both partners are individually assessed. The goal is to determine whether adoption is in the best interest of the child."
  },
  {
    q: "Do you cover international adoptions?",
    a: "Yes. We provide evaluations accepted by adoption agencies and authorities for adoptions from many countries, including China, South Korea, Colombia, India, the Philippines, and others. Our reports are formatted to meet international documentation standards."
  },
  {
    q: "Is notarization handled at your facility?",
    a: "Yes. Notary services and licensing are completed on-site at our facility. For international adoptions, reports can be prepared to meet apostille requirements so you are not chasing down third-party notary services."
  },
  {
    q: "How much does the evaluation cost?",
    a: "Adoption evaluations are offered on a self-pay basis at $900 per parent. The fee reflects the full clinical process, including interview, testing, records review, report preparation, and on-site notarization."
  },
  {
    q: "Is there a waitlist?",
    a: "We are currently accepting new clients for adoption evaluations with no waitlist. We encourage you to schedule early, as agency and court timelines can be tight."
  },
  {
    q: "Is the evaluation covered by insurance?",
    a: "Adoption evaluations are offered on a self-pay basis and are not typically billed through health insurance."
  }
];
---

<Layout
  title="Adoption Evaluations | Twilight Psychology"
  description="Adoption evaluations in Kentucky. Comprehensive psychological assessments for prospective adoptive parents. Domestic and international adoptions."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">

  <!-- Hero -->
  <section class="relative pt-36 pb-28 px-4 border-b theme-border overflow-hidden">
    <div class="max-w-7xl mx-auto relative z-10">
      <span class="text-cta font-black tracking-[0.3em] uppercase text-[10px] mb-6 block">Family Formation</span>
      <h1 class="font-serif text-5xl md:text-7xl font-black text-site-text mb-8 tracking-tight">
        Adoption <span class="text-cta">Evaluations</span>
      </h1>
      <p class="text-site-sub text-lg leading-relaxed max-w-2xl mb-10">
        Thoughtful, agency-ready evaluations for prospective adoptive parents who want a process led with precision, warmth, and clinical credibility. We support domestic and international adoptions, with documentation handled carefully from first appointment to final report.
      </p>
      <a href="#get-started" class="text-sand font-black border-b border-cta/50 pb-1 hover:text-cta transition-colors">
        Get started today ↓
      </a>
    </div>
  </section>

  <!-- Main content + sidebar -->
  <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">

    <div class="lg:col-span-2 space-y-12">

      <section class="theme-surface-soft backdrop-blur-md border theme-border p-10 rounded-[2.5rem]">
        <h2 class="font-serif text-4xl md:text-5xl font-black text-site-text mb-6 tracking-tighter leading-tight">
          Trusted Guidance for a <span class="text-cta">High-Stakes Milestone.</span>
        </h2>
        <div class="space-y-6 text-site-text leading-relaxed text-lg">
          <p>
            Adoption evaluations carry real weight. They help agencies, courts, and international authorities understand the readiness, stability, and parenting capacity of prospective families. Dr. Cornett conducts these evaluations personally, bringing an experienced and steady clinical lens to a process that deserves both rigor and care.
          </p>
          <p>
            Our process includes clinical interviews, standardized testing, and careful collateral review. The finished report is written to the standard expected by adoption professionals, with <strong>on-site notarization</strong> available so families can move forward with documentation that feels complete, polished, and professionally prepared.
          </p>

        </div>
      </section>

      <section>
        <h2 class="font-serif text-2xl font-black text-site-text mb-10">What the Evaluation Covers</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {evaluationAreas.map((item, idx) => (
            <div class="group p-8 theme-surface-soft border theme-border rounded-4xl hover:border-cta/30 transition-all">
              <div class="w-10 h-10 rounded-xl bg-cta/10 flex items-center justify-center mb-6 border border-cta/20 group-hover:bg-cta transition-all">
                <span class="text-cta group-hover:text-cta-fg font-black text-sm">{String(idx + 1).padStart(2, '0')}</span>
              </div>
              <h3 class="font-serif text-site-text font-black mb-2">{item.title}</h3>
              <p class="text-site-sub text-sm leading-relaxed">{item.detail}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- International callout -->
      <section class="theme-surface-2 border border-cta/20 p-12 rounded-[3rem] relative overflow-hidden">
        <div class="absolute top-0 right-0 p-12 text-8xl text-site-text/5 font-black select-none">INTL</div>
        <div class="max-w-2xl relative z-10">
          <h2 class="font-serif text-3xl font-black text-site-text mb-6">International Adoptions Covered</h2>
          <p class="text-site-text text-lg leading-relaxed mb-8">
            Families pursuing international adoption often need documentation that is not only clinically strong, but meticulously prepared. Our evaluations are written with international submission standards in mind and can be formatted for apostille-ready processing.
          </p>
          <div class="flex flex-wrap gap-2">
            {countries.map(country => (
              <span class="px-3 py-1.5 text-xs font-bold text-site-sub theme-surface-soft border theme-border rounded-full">
                {country}
              </span>
            ))}
          </div>
        </div>
      </section>

      <!-- Clinician card -->
      <div class="flex flex-col md:flex-row items-center gap-10 p-10 theme-surface-2 border theme-border rounded-[3rem]">
        <div class="w-48 h-48 shrink-0 rounded-2xl overflow-hidden border-2 border-cta/20 shadow-2xl">
          <Image
            src={heatherPhoto}
            alt="Dr. Heather Cornett"
            class="w-full h-full object-cover grayscale"
          />
        </div>
        <div class="space-y-4 text-center md:text-left">
          <p class="text-cta font-black text-[10px] uppercase tracking-[0.4em]">Evaluating Clinician</p>
          <h3 class="font-serif text-3xl font-black text-site-text">Dr. Heather Cornett, <span class="text-sand italic">L.P.</span></h3>
          <p class="text-site-sub leading-relaxed">
            Dr. Cornett leads all adoption evaluations at Twilight Psychology, combining deep clinical experience with the calm, family-centered communication families need during an important transition.
          </p>
          <a href="/about/clinicians/heather-cornett" class="inline-block text-xs font-black uppercase text-cta hover:text-site-text transition-colors">
            Read Full Bio →
          </a>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <aside class="space-y-8">
      <div class="theme-surface-soft border theme-border p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-xl font-black text-site-text mb-4">Current Availability</h3>
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <span class="text-cta font-black mt-0.5">✓</span>
            <div>
              <span class="font-bold text-site-text block">Waitlist</span>
              <span class="text-site-sub">Accepting new clients now</span>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-cta font-black mt-0.5">✓</span>
            <div>
              <span class="font-bold text-site-text block">Evaluating Psychologist</span>
              <span class="text-site-sub">Personally conducted by Dr. Heather Cornett</span>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-cta font-black mt-0.5">✓</span>
            <div>
              <span class="font-bold text-site-text block">Notary Services</span>
              <span class="text-site-sub">Completed on-site at our facility</span>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-cta font-black mt-0.5">✓</span>
            <div>
              <span class="font-bold text-site-text block">Documentation Quality</span>
              <span class="text-site-sub">Prepared for agencies, courts, and international review</span>
            </div>
          </li>
        </ul>
      </div>

      <div class="theme-surface-soft border theme-border p-10 rounded-[2.5rem] text-center">
        <h3 class="font-serif text-2xl font-black text-site-text mb-4 tracking-tight">Schedule an Intake</h3>
        <p class="text-site-sub text-sm mb-8">Reserve an intake for a clinician-led adoption evaluation with documentation handled in one place.</p>
        <a href={WIDGET_LINK} class="block w-full py-4 bg-sand text-cta-fg font-black rounded-full hover:bg-cta transition-all shadow-lg shadow-sand/10">
          Request Appointment
        </a>
      </div>

      <div class="p-8 bg-cta rounded-[2.5rem] text-cta-fg">
        <h4 class="font-serif font-black uppercase text-[10px] tracking-widest mb-2 inverted-text">Self-Pay Service</h4>
        <p class="text-sm font-bold leading-tight inverted-text">This specialty evaluation is offered on a self-pay basis so the process can stay thorough, personalized, and documentation-focused.</p>
      </div>
    </aside>
  </div>

  <!-- FAQ -->
  <section id="faq" class="max-w-4xl mx-auto px-4 py-24">
    <h2 class="font-serif text-3xl font-black text-site-text mb-12 text-center tracking-tight">
      Frequently Asked <span class="text-sand italic text-4xl">Questions</span>
    </h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <div class="p-8 theme-surface-soft border theme-border rounded-3xl group hover:border-cta/30 transition-all">
          <h3 class="font-serif text-sand font-black mb-3 text-lg">{faq.q}</h3>
          <p class="text-site-sub text-sm leading-relaxed">{faq.a}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Get Started -->
  <section id="get-started" class="max-w-7xl mx-auto px-4 py-24 text-center">
    <div class="theme-surface-2 p-16 rounded-[4rem] text-site-text border theme-border">
      <span class="text-cta font-black tracking-[0.3em] uppercase text-[10px] mb-6 block">Next Step</span>
      <h2 class="font-serif text-3xl md:text-5xl font-black mb-6 tracking-tight text-site-text">
        Ready to Begin the Adoption Process?
      </h2>
      <p class="text-lg font-medium mb-10 max-w-xl mx-auto text-site-sub leading-relaxed">
        Schedule an intake with Dr. Cornett and move forward with a polished, professionally managed evaluation process from clinical interview through final documentation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={WIDGET_LINK} class="inline-block px-10 py-4 bg-cta text-cta-fg inverted-text font-black rounded-full hover:bg-cta/80 transition-all shadow-lg shadow-cta/20">
          Request an Appointment
        </a>
        <a href="/resources/new-client" class="inline-block px-10 py-4 theme-surface-soft border theme-border text-site-text font-black rounded-full theme-hover-surface transition-all">
          Steps for New Clients
        </a>
      </div>
      <div class="mt-10 pt-8 border-t theme-border flex flex-wrap justify-center gap-4">
        <a href="/specialities/guardianship-evaluations" class="px-6 py-3 theme-surface-soft border theme-border text-site-text font-black rounded-full theme-hover-surface transition-all text-sm">
          Guardianship Evaluations
        </a>
        <a href="/specialities/esa-evaluations" class="px-6 py-3 theme-surface-soft border theme-border text-site-text font-black rounded-full theme-hover-surface transition-all text-sm">
          ESA Evaluations
        </a>
      </div>
    </div>
  </section>

  <nav class="max-w-4xl mx-auto px-6 mt-12 mb-4">
    <a href="/specialities" class="inline-flex items-center gap-2 text-sm font-bold text-cta hover:text-cta/80 transition-colors">
      <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
      View All Specialties
    </a>
  </nav>
      </div>
    </div>
  </div>
</Layout>
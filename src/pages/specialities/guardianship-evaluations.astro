---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import '../../styles/global.css';
import { WIDGET_LINK } from '../../data/resource';

---

<ServiceLayout name="Guardianship Evaluations | Twilight Psychology"
  description="Guardianship evaluations in Kentucky"
  metaDescription="Expert guardianship evaluations in Kentucky. Comprehensive psychological assessments to support legal guardianship petitions. Licensed psychologists providing thorough, court-approved evaluations."
>
    <section class="max-w-5xl mx-auto px-4 py-24">
        <div class="bg-slate-800/20 p-12 rounded-[4rem] text-site-text border border-white/10 text-center relative overflow-hidden">
            <div class="relative z-10">
                <h2 class="font-serif text-3xl font-bold mb-4 tracking-tight text-site-text">Current Availability</h2>
                <div class="flex flex-col md:flex-row justify-center gap-6 my-8">
                    <div class="bg-white/5 p-6 rounded-2xl border border-white/10">
                        <p class="text-[10px] font-bold uppercase tracking-widest mb-2 text-cta/70">Evaluations</p>
                        <p class="text-lg font-semibold text-site-text">Waitlist of Approx. 3 weeks</p>
                    </div>
                    <div class="bg-white/5 p-6 rounded-2xl border border-white/10">
                        <p class="text-[10px] font-bold uppercase tracking-widest mb-2 text-cta/70">Price</p>
                        <p class="text-lg font-semibold text-site-sub/60 italic">$500 per evaluation</p>
                    </div>
                </div>
                <p class="font-medium text-site-sub mb-10 max-w-xl mx-auto italic leading-relaxed text-sm">
                    Guardianship evaluations are a specialized service that requires a comprehensive assessment of an individual's cognitive, 
                    emotional, and functional abilities. These evaluations are typically conducted by licensed psychologists or other qualified 
                    professionals to determine whether an individual is capable of managing their own affairs or if they require a guardian 
                    to assist them in making decisions. The evaluation process may include interviews, standardized tests, and observations 
                    to gather information about the individual's mental health, decision-making capacity, and overall functioning. 
                    The results of the evaluation can help inform legal decisions regarding guardianship and ensure that the individual's best 
                </p>
                <a href={WIDGET_LINK} class="inline-block px-10 py-4 bg-cta/90 text-cta-fg font-bold rounded-full hover:bg-cta transition-all">
                    Schedule an Intake
                </a>
            </div>
        </div>
    </section>
</ServiceLayout>
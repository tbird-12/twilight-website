---
import Layout from '../../layouts/Layout.astro';
import { WIDGET_LINK } from '../../data/resource';

const evaluationAreas = [
  {
    title: "Decision-Making Capacity",
    detail: "Assessment of the person's ability to understand, appreciate, reason through, and communicate decisions in key life domains."
  },
  {
    title: "Cognitive & Functional Status",
    detail: "Evaluation of memory, executive functioning, judgment, and day-to-day functioning relevant to safety, finances, and medical care."
  },
  {
    title: "Risk & Vulnerability",
    detail: "Clinical review of vulnerabilities such as exploitation risk, self-neglect concerns, and barriers to independent living."
  },
  {
    title: "Court-Ready Report",
    detail: "Clear written findings designed to support the court's understanding of whether guardianship, limited guardianship, or alternatives may be appropriate."
  }
];

const faqs = [
  {
    q: "Who do you evaluate for guardianship?",
    a: "We perform guardianship evaluations for both young adults and older adults. This includes transition-age individuals entering adulthood and older adults with concerns related to neurocognitive decline, psychiatric illness, or complex medical history."
  },
  {
    q: "Do you provide legal representation?",
    a: "No. Twilight Psychology does not provide legal advice or legal representation. We provide independent clinical evaluations and written reports that families and attorneys may use in court proceedings."
  },
  {
    q: "Can your report be used in Kentucky court?",
    a: "Yes. Our evaluations are completed by licensed clinicians and formatted to be clinically clear and useful for legal review in Kentucky guardianship matters."
  },
  {
    q: "Do you only recommend full guardianship?",
    a: "No. Our role is objective. Depending on findings, recommendations may support full guardianship, limited guardianship, or less restrictive alternatives when appropriate."
  },
  {
    q: "How long does a guardianship evaluation take?",
    a: "Most evaluations involve records review, clinical interview, testing as indicated, and report preparation. Timing varies by complexity, but we prioritize timely report delivery once testing is complete."
  }
];
---

<Layout
  title="Guardianship Evaluations | Twilight Psychology PLLC"
  description="Guardianship evaluations in Kentucky for both young adults and older adults. Objective clinical assessments and court-ready reports from licensed psychologists. Twilight Psychology does not provide legal representation."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <section class="relative pt-36 pb-28 px-4 border-b theme-border overflow-hidden">
    <div class="max-w-7xl mx-auto relative z-10">
      <span class="text-cta font-black tracking-[0.3em] uppercase text-[10px] mb-6 block">Forensic & Clinical Clarity</span>
      <h1 class="font-serif text-5xl md:text-7xl font-black text-site-text mb-8 tracking-tight">
        Guardianship <span class="text-cta">Evaluations</span>
      </h1>
      <p class="text-site-sub text-lg leading-relaxed max-w-2xl mb-10">
        Independent psychological evaluations for families, attorneys, and care teams who need clear clinical guidance around decision-making capacity. We evaluate both <strong>young adults</strong> and <strong>older adults</strong> and provide reports built for serious review.
      </p>
      <a href="#get-started" class="text-sand font-black border-b border-cta/50 pb-1 hover:text-cta transition-colors">
        Get started today ↓
      </a>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">
    <div class="lg:col-span-2 space-y-12">
      <section class="theme-surface-soft backdrop-blur-md border theme-border p-10 rounded-[2.5rem]">
        <h2 class="font-serif text-4xl md:text-5xl font-black text-site-text mb-6 tracking-tighter leading-tight">
          Nuanced Clinical Judgment, <span class="text-cta">Clearly Communicated.</span>
        </h2>
        <div class="space-y-6 text-site-text leading-relaxed text-lg">
          <p>
            Guardianship evaluations are among the most consequential assessments in clinical practice because they can affect autonomy, safety, and long-term care decisions. Our process emphasizes objectivity, diagnostic precision, and findings that can be understood by both families and courts.
          </p>
          <p>
            We work with families, case teams, and referring attorneys to evaluate current functioning and decision-making capacity in a way that is clinically rigorous without losing sight of the person behind the referral. Services are available for <strong>young adults</strong> and <strong>older adults</strong> with cognitive, psychiatric, developmental, or medical complexity.
          </p>
          <p>
            <strong>Important:</strong> Twilight Psychology does <span class="text-cta">not</span> provide legal representation. We provide independent clinical evaluation and documentation only.
          </p>

        </div>
      </section>

      <section>
        <h2 class="font-serif text-2xl font-black text-site-text mb-10">What We Evaluate</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {evaluationAreas.map((item, idx) => (
            <div class="group p-8 theme-surface-soft border theme-border rounded-4xl hover:border-cta/30 transition-all">
              <div class="w-10 h-10 rounded-xl bg-cta/10 flex items-center justify-center mb-6 border border-cta/20 group-hover:bg-cta transition-all">
                <span class="text-cta group-hover:text-cta-fg font-black text-sm">{String(idx + 1).padStart(2, '0')}</span>
              </div>
              <h3 class="font-serif text-site-text font-black mb-2">{item.title}</h3>
              <p class="text-site-sub text-sm leading-relaxed">{item.detail}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="theme-surface-2 border border-cta/20 p-12 rounded-[3rem] relative overflow-hidden">
        <div class="absolute top-0 right-0 p-12 text-8xl text-site-text/5 font-black select-none">KY</div>
        <div class="max-w-2xl relative z-10">
          <h2 class="font-serif text-3xl font-black text-site-text mb-6">Young Adults and Older Adults</h2>
          <p class="text-site-text text-lg leading-relaxed">
            We assess guardianship-related concerns across the lifespan. For young adults, this often involves transition planning, adaptive functioning, and readiness for increasing independence. For older adults, referrals commonly center on cognitive decline, safety, financial judgment, and healthcare decision-making.
          </p>
          <p class="mt-4 text-site-text text-lg leading-relaxed">
            Our recommendations are individualized and may include less restrictive alternatives when clinically appropriate.
          </p>
        </div>
      </section>
    </div>

    <aside class="space-y-8">
      <div class="theme-surface-soft border theme-border p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-xl font-black text-site-text mb-4">Common Referral Questions</h3>
        <ul class="space-y-3 text-sm font-bold text-sand/80">
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Can they make informed medical decisions?</li>
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Can they safely manage money and housing?</li>
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Is full or limited guardianship more appropriate?</li>
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Are less restrictive supports sufficient?</li>
        </ul>
      </div>

      <div class="theme-surface-soft border theme-border p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-xl font-black text-site-text mb-4">Scope of Service</h3>
        <p class="text-site-sub text-sm leading-relaxed mb-4">
          We provide independent clinical evaluation and written psychological opinion only.
        </p>
        <ul class="space-y-3 text-sm font-bold text-sand/80">
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Records review and interview</li>
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Psychological testing as indicated</li>
          <li class="flex items-center gap-2"><span class="text-cta">✓</span> Court-ready report</li>
          <li class="flex items-center gap-2"><span class="text-cta">✕</span> No legal representation</li>
        </ul>
      </div>

      <div class="p-8 bg-cta rounded-[2.5rem] text-cta-fg">
        <h4 class="font-serif font-black uppercase text-[10px] tracking-widest mb-2">Referral Fit</h4>
        <p class="text-sm font-bold leading-tight">This service is best suited for cases that require a careful, independent opinion on capacity, vulnerability, and level of support needed.</p>
      </div>
    </aside>
  </div>

  <section id="faq" class="max-w-4xl mx-auto px-4 py-24">
    <h2 class="font-serif text-3xl font-black text-site-text mb-12 text-center tracking-tight">
      Frequently Asked <span class="text-sand italic text-4xl">Questions</span>
    </h2>
    <div class="space-y-6">
      {faqs.map((faq) => (
        <div class="p-8 theme-surface-soft border theme-border rounded-3xl group hover:border-cta/30 transition-all">
          <h3 class="font-serif text-sand font-black mb-3 text-lg">{faq.q}</h3>
          <p class="text-site-sub text-sm leading-relaxed">{faq.a}</p>
        </div>
      ))}
    </div>
  </section>

  <section id="get-started" class="max-w-7xl mx-auto px-4 py-24 text-center">
    <div class="theme-surface-2 p-16 rounded-[4rem] text-site-text border theme-border">
      <span class="text-cta font-black tracking-[0.3em] uppercase text-[10px] mb-6 block">Next Step</span>
      <h2 class="font-serif text-3xl md:text-5xl font-black mb-6 tracking-tight text-site-text">
        Need a Guardianship Evaluation?
      </h2>
      <p class="text-lg font-medium mb-10 max-w-xl mx-auto text-site-sub leading-relaxed">
        Reach out to discuss the situation and whether this level of evaluation is the right fit. We can help you determine the next clinical step and schedule the next available intake.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={WIDGET_LINK} class="inline-block px-10 py-4 bg-cta text-cta-fg font-black rounded-full hover:bg-cta/80 transition-all shadow-lg shadow-cta/20">
          Request an Appointment
        </a>
        <a href="/resources/new-client" class="inline-block px-10 py-4 theme-surface-soft border theme-border text-site-text font-black rounded-full theme-hover-surface transition-all">
          Steps for New Clients
        </a>
      </div>
      <div class="mt-10 pt-8 border-t theme-border flex flex-wrap justify-center gap-4">
        <a href="/specialities/psychoeducational-evaluations" class="px-6 py-3 theme-surface-soft border theme-border text-site-text font-black rounded-full theme-hover-surface transition-all text-sm">
          Psychoeducational Evaluations
        </a>
        <a href="/specialities/adoption-evaluations" class="px-6 py-3 theme-surface-soft border theme-border text-site-text font-black rounded-full theme-hover-surface transition-all text-sm">
          Adoption Evaluations
        </a>
      </div>
    </div>
  </section>

  <nav class="max-w-4xl mx-auto px-6 mt-12 mb-4">
    <a href="/specialities" class="inline-flex items-center gap-2 text-sm font-bold text-cta hover:text-cta/80 transition-colors">
      <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
      View All Specialties
    </a>
  </nav>
      </div>
    </div>
  </div>
</Layout>

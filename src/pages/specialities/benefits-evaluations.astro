---
import ServiceLayout from "../../layouts/ServiceLayout.astro";
import { PHONE_NUMBER, PHONE_NUMBER_FORMATTED } from "../../data/resource";
import "../../styles/global.css";

const notCovered = [
  {
    title: "No Medical Necessity",
    detail: "The evaluation is not being ordered to diagnose or treat a medical or mental health condition. It does not meet the insurance definition of medical necessity.",
  },
  {
    title: "Not for Treatment of a Disease",
    detail: "The purpose of the evaluation is to document functioning for a benefits application — not to guide treatment of a disorder or illness.",
  },
  {
    title: "Not Listed Under Your Plan",
    detail: "Benefits-related evaluations are generally excluded from health insurance coverage because they serve an administrative or legal purpose rather than a clinical one.",
  },
];

const distinctions = [
  {
    title: "SSA Disability Evaluations",
    detail: "Consultative evaluations ordered and paid for by the Social Security Administration as part of the federal disability determination process. These are at no cost to you.",
  },
  {
    title: "VA Compensation & Pension Exams",
    detail: "C&P evaluations ordered by the Department of Veterans Affairs to determine service-connected disability ratings. These are arranged and paid for by the VA.",
  },
  {
    title: "Workers' Compensation Evaluations",
    detail: "Evaluations ordered within the workers' compensation system to assess work-related injuries. These are paid for by the employer's insurance carrier or the workers' comp board.",
  },
];

const faqs = [
  {
    q: "Why won't my insurance cover this evaluation?",
    a: "Health insurance covers services that are medically necessary — meaning they are needed to diagnose or treat a condition. Benefits evaluations are performed for administrative or legal purposes, such as applying for disability benefits through a private insurer or employer program. Because the evaluation is not treating a disease, insurance companies consider it outside the scope of covered services.",
  },
  {
    q: "How is this different from an SSA or VA evaluation?",
    a: "SSA consultative evaluations and VA Compensation & Pension exams are ordered and paid for directly by those government agencies. Benefits evaluations offered here are self-pay services requested by individuals who need documentation for private disability claims, employer benefit programs, or other non-government purposes.",
  },
  {
    q: "What does the final report include?",
    a: "You will receive a comprehensive psychological report documenting your current level of functioning, relevant clinical findings, and any diagnostic impressions. The report is written to support your benefits application with the requesting entity.",
  },
  {
    q: "How long does the evaluation take?",
    a: "Most benefits evaluations require several hours of face-to-face assessment, including a clinical interview and psychological testing. Total time varies depending on the complexity of your case, which is why services are billed at $200 per hour with a $1,300 minimum — whichever amount is lower.",
  },
];
---

<ServiceLayout
  name="Benefits Evaluations | Twilight Psychology"
  description="Self-pay psychological evaluations for benefits applications. These evaluations do not meet the definition of medical necessity and are not covered by health insurance."
  metaDescription="Self-pay psychological evaluations for private disability benefits, employer benefit programs, and other non-government benefits applications. Not covered by insurance. $1,300 or $200/hour, whichever is lower."
>
  <section class="relative pt-36 pb-28 px-4 border-b theme-border overflow-hidden">
    <div class="max-w-4xl mx-auto relative z-10 text-center">
      <span
        class="inline-block px-4 py-1.5 mb-6 text-[10px] font-black tracking-[0.3em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full"
      >
        Self-Pay Only
      </span>
      <h1
        class="font-serif text-5xl md:text-7xl font-black text-site-text mb-8 tracking-tight"
      >
        Benefits <span class="text-cta">Evaluations</span>
      </h1>
      <p
        class="text-site-sub text-lg leading-relaxed max-w-2xl mx-auto mb-10"
      >
        Psychological evaluations for benefits applications that fall outside the scope of health insurance coverage. These evaluations do not meet the definition of medical necessity and are not used to treat a disease.
      </p>
      <a href="#get-started" class="text-sand font-black border-b border-cta/50 pb-1">
        Get started today ↓
      </a>
    </div>
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(circle_at_center,var(--tw-gradient-stops))] from-slate-800/40 via-transparent to-transparent z-0"
    >
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">
    <div class="lg:col-span-2 space-y-12">

      <section
        class="theme-surface-soft backdrop-blur-md border theme-border p-10 rounded-[2.5rem]"
      >
        <h2 class="font-serif text-4xl md:text-5xl font-black text-site-text mb-6 tracking-tighter">
          What Is a Benefits <span class="text-cta">Evaluation</span>?
        </h2>
        <div class="space-y-6 text-site-text leading-relaxed text-lg">
          <p>
            A benefits evaluation is a psychological assessment conducted for the purpose of supporting a benefits application — such as a private disability claim, an employer-sponsored benefit program, or another non-government benefits request.
          </p>
          <p>
            Unlike evaluations ordered to diagnose or treat a mental health condition, these assessments serve an <strong class="text-site-text">administrative or legal purpose</strong>. Because they do not meet the insurance definition of <span class="text-cta font-bold">medical necessity</span> and are not used to treat a disease, they are <strong class="text-site-text">not covered by health insurance</strong>.
          </p>
          <p>
            Benefits evaluations are <strong class="text-site-text">self-pay only</strong>. No insurance will be billed, and no insurance authorization will be sought for this service.
          </p>
        </div>
      </section>

      <section>
        <h2 class="font-serif text-2xl font-black text-site-text mb-10">
          Why Insurance Does Not Cover This
        </h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {
            notCovered.map((item, idx) => (
              <div class="group p-8 theme-surface-soft border theme-border rounded-4xl hover:border-cta/30 transition-all">
                <div class="w-10 h-10 rounded-xl bg-cta/10 flex items-center justify-center mb-6 border border-cta/20 group-hover:bg-cta transition-all">
                  <span class="text-cta group-hover:text-cta-fg font-black text-sm">
                    {idx + 1}
                  </span>
                </div>
                <h3 class="font-serif text-site-text font-black mb-2">{item.title}</h3>
                <p class="text-site-sub/60 text-sm leading-relaxed">{item.detail}</p>
              </div>
            ))
          }
        </div>
      </section>

      <section class="theme-surface-2 border border-cta/20 p-12 rounded-[3rem] relative overflow-hidden">
        <div class="absolute top-0 right-0 p-12 text-8xl text-site-text/5 font-black select-none">
          ≠
        </div>
        <div class="max-w-2xl relative z-10">
          <h2 class="font-serif text-2xl font-black text-site-text mb-6 tracking-tight">
            This Is <span class="text-cta">Not</span> the Same As…
          </h2>
          <p class="text-site-sub/70 text-sm leading-relaxed mb-8">
            It is important to understand that the benefits evaluations offered here are <strong class="text-site-text">completely separate</strong> from government-ordered or government-paid disability evaluations. The following are <em>not</em> what this service provides:
          </p>
          <div class="space-y-6">
            {
              distinctions.map((item) => (
                <div class="flex gap-4">
                  <span class="mt-1.5 w-2.5 h-2.5 rounded-full bg-cta shrink-0"></span>
                  <div>
                    <h3 class="font-black text-site-text mb-1">{item.title}</h3>
                    <p class="text-site-sub/60 text-sm leading-relaxed">{item.detail}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section
        class="theme-surface-soft backdrop-blur-md border theme-border p-10 rounded-[2.5rem]"
      >
        <h2 class="font-serif text-2xl font-black text-site-text mb-6 tracking-tight">
          What to Expect
        </h2>
        <div class="space-y-5 text-site-text leading-relaxed text-lg">
          <p>
            Your evaluation will include a comprehensive clinical interview and psychological testing as warranted by the nature of your benefits application. The length of the evaluation depends on the complexity of your case.
          </p>
          <p>
            Upon completion, you will receive a detailed psychological report documenting your current functioning, clinical findings, and diagnostic impressions. This report is prepared to support your benefits application with the requesting entity.
          </p>
          <p>
            Please bring a <strong class="text-site-text">valid government-issued photo ID</strong>, any <strong class="text-site-text">assistive devices</strong> you regularly use (glasses, hearing aids, etc.), and take all prescribed medications as normal on the day of your appointment.
          </p>
        </div>
      </section>

    </div>

    <aside class="space-y-8">
      <div class="theme-surface-soft border theme-border p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-xl font-black text-site-text mb-2">Self-Pay Only</h3>
        <p class="text-site-sub/60 text-sm mb-6 leading-relaxed">
          This evaluation is not covered by health insurance. Payment is due at the time of service.
        </p>
        <div class="p-5 bg-cta/10 border border-cta/20 rounded-2xl text-center mb-4">
          <p class="text-3xl font-black text-cta">$1,300</p>
          <p class="text-xs text-site-sub/60 uppercase tracking-widest mt-1 font-bold">Minimum Fee</p>
        </div>
        <div class="p-5 bg-cta/10 border border-cta/20 rounded-2xl text-center">
          <p class="text-3xl font-black text-cta">$200<span class="text-lg">/hr</span></p>
          <p class="text-xs text-site-sub/60 uppercase tracking-widest mt-1 font-bold">Hourly Rate</p>
        </div>
        <p class="text-site-sub/50 text-xs mt-4 leading-relaxed text-center">
          You will be charged $1,300 or $200 per hour — whichever amount is lower.
        </p>
      </div>

      <div class="p-8 bg-cta rounded-[2.5rem] text-cta-fg">
        <h3 class="font-serif text-xl font-black mb-3">Important Notice</h3>
        <p class="text-sm leading-relaxed opacity-90">
          No insurance will be billed for this service. This evaluation does not meet the criteria for medical necessity as defined by health insurance providers and is not intended to diagnose or treat a disease.
        </p>
      </div>

      <div class="theme-surface-soft border theme-border p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-xl font-black text-site-text mb-6">Related Services</h3>
        <nav class="space-y-4">
          <a
            href="/services/psychological-evaluations"
            class="flex items-center justify-between p-4 bg-white/5 rounded-2xl hover:bg-white/10 transition-all text-site-text text-sm font-bold group"
          >
            Psychological Evaluations <span class="text-cta group-hover:translate-x-1 transition-transform">→</span>
          </a>
          <a
            href="/specialities/guardianship-evaluations"
            class="flex items-center justify-between p-4 bg-white/5 rounded-2xl hover:bg-white/10 transition-all text-site-text text-sm font-bold group"
          >
            Guardianship Evaluations <span class="text-cta group-hover:translate-x-1 transition-transform">→</span>
          </a>
          <a
            href="/specialities/esa-evaluations"
            class="flex items-center justify-between p-4 bg-white/5 rounded-2xl hover:bg-white/10 transition-all text-site-text text-sm font-bold group"
          >
            ESA Evaluations <span class="text-cta group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </nav>
      </div>
    </aside>
  </div>

  <section id="faq" class="max-w-4xl mx-auto px-4 py-24">
    <h2 class="font-serif text-3xl font-black text-site-text mb-12 text-center">
      Frequently Asked <span class="text-sand italic text-4xl">Questions</span>
    </h2>
    <div class="space-y-6">
      {
        faqs.map((faq) => (
          <div class="p-8 theme-surface-soft border theme-border rounded-3xl group hover:border-cta/30 transition-all">
            <h3 class="font-serif text-sand font-black mb-3 text-lg">{faq.q}</h3>
            <p class="text-site-sub/50 text-sm leading-relaxed">{faq.a}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section id="get-started" class="max-w-7xl mx-auto px-4 py-24 text-center">
    <div class="theme-surface-2 p-16 rounded-[4rem] text-site-text border theme-border">
      <span class="text-cta font-black tracking-[0.3em] uppercase text-[10px]">
        Next Step
      </span>
      <h2 class="font-serif text-3xl md:text-5xl font-black mb-6 mt-4">
        Ready to Schedule?
      </h2>
      <p class="text-site-sub mb-10 max-w-2xl mx-auto">
        Contact our office to schedule your benefits evaluation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="inline-block px-8 py-3 bg-cta text-cta-fg font-black rounded-full hover:bg-cta/80 transition-all"
        >
          Contact Us
        </a>
        <a
          href={`tel:${PHONE_NUMBER}`}
          class="inline-block px-8 py-3 border border-cta/30 text-cta font-black rounded-full hover:bg-cta/10 transition-all"
        >
          {PHONE_NUMBER_FORMATTED}
        </a>
      </div>
    </div>
  </section>
</ServiceLayout>

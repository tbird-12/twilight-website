---
import ServiceLayout from "../../layouts/ServiceLayout.astro";
import "../../styles/global.css";
import { WIDGET_LINK } from "../../data/resource";

const therapyFocus = [
  {
    title: "Neuro-Identity",
    detail:
      "Moving from 'masking' to authenticity. Understanding your neuro-type as a vital part of who you are.",
    link: "/services/identity-work", // Placeholder
  },
  {
    title: "Executive Support",
    detail:
      "Collaborative strategies for task management, burnout prevention, and sensory regulation.",
    link: "/services/executive-functioning", // Placeholder
  },
  {
    title: "Social Connection",
    detail:
      "Developing communication styles that honor your comfort level rather than forcing social norms.",
    link: "/services/social-advocacy", // Placeholder
  },
  {
    title: "Burnout Recovery",
    detail:
      "Specialized support for 'Autistic Burnout'—restoring energy and setting sustainable boundaries.",
    link: "/services/burnout-prevention", // Placeholder
  },
];
---

<ServiceLayout name="Neuro-Affirming Therapy KY | Twilight Psychology"
  description="Compassionate, evidence-based therapy for autistic adults in Kentucky. 
  No 'fixing'—just support that honors your unique way of being."
  metaDescription="Neuro-affirming therapy services in Kentucky for autistic adults. Individual counseling using evidence-based, compassionate practices that honor your unique neurodivergent identity. Telehealth available."
>  
  <section class="relative py-24 px-4 text-center border-b border-white/5 overflow-hidden">
    <div class="max-w-4xl mx-auto relative z-10">
      <span
        class="px-4 py-1.5 mb-6 text-[10px] font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full"
      >
        Neuro-Affirming Counseling
      </span>
      <h1
        class="font-serif text-5xl md:text-7xl font-black text-site-text mb-6 tracking-tight leading-[0.9]"
      >
        Therapy for <br /><span
          class="text-cta"
          >Adults.</span
        >
      </h1>
      <p
        class="text-xl text-site-sub font-medium max-w-2xl mx-auto leading-relaxed"
      >
        No "fixing." No "curing." Just compassionate, evidence-based therapy
        that honors your unique way of being.
      </p>
    </div>
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(circle_at_center,var(--tw-gradient-stops))] from-slate-800/40 via-transparent to-transparent z-0"
    >
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">
    <div class="lg:col-span-2 space-y-12">
      <section
        class="bg-white/3 backdrop-blur-md border border-white/10 p-10 rounded-[2.5rem]"
      >
        <h2 class="font-serif text-3xl font-black text-site-text mb-6 tracking-tight">
          Support That Validates
        </h2>
        <div class="space-y-6 text-site-text leading-relaxed text-lg">
          <p>
            Traditional therapy often focuses on making neurodivergent people
            "act neurotypical." At Twilight Psychology, we do the opposite. Our
            goal is to help you build a life that accommodates <span
              class="text-cta">your nervous system</span
            >.
          </p>
          <p>
            Whether you were diagnosed yesterday or have known your whole life,
            we provide a safe space to process the challenges of a world not
            built for you.
          </p>
          <a
            href="/about/twilight-psychology"
            class="inline-block text-cta font-black text-sm border-b-2 border-cta/20 hover:border-cta transition-all pb-1"
          >
            Read our Neuro-Affirming Promise →
          </a>
        </div>
      </section>

      <section>
        <h2 class="font-serif text-2xl font-black text-site-text mb-10 tracking-tight">Focus Areas</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {
            therapyFocus.map((item) => (
              <a
                href={item.link}
                class="group p-8 bg-white/5 hover:bg-white/10 border border-white/10 sm:border-white/5 hover:border-cta/30 rounded-3xl transition-all duration-300 block"
              >
                <div class="w-10 h-10 rounded-xl bg-cta sm:bg-slate-800/50 flex items-center justify-center mb-6 border border-white/5 sm:group-hover:bg-cta transition-all">
                  <span class="text-cta-fg sm:text-cta sm:group-hover:text-cta-fg text-xl">
                    ✦
                  </span>
                </div>
                <h3 class="font-serif text-site-text font-black mb-2">{item.title}</h3>
                <p class="text-site-sub/50 text-sm leading-relaxed mb-6">
                  {item.detail}
                </p>
                <span class="text-xs font-black text-cta block sm:opacity-0 sm:group-hover:opacity-100 transition-opacity uppercase tracking-[0.2em]">
                  Learn More →
                </span>
              </a>
            ))
          }
        </div>
      </section>
    </div>

    <aside class="space-y-8">
      <div class="bg-white/5 border border-white/10 p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-xl font-black text-site-text mb-6">Continuum of Care</h3>
        <nav class="space-y-4">
          <a
            href="/services/autism-testing"
            class="flex items-center justify-between p-4 bg-white/5 rounded-2xl hover:bg-white/10 transition-all text-site-text text-sm font-bold group"
          >
            Need a Diagnosis? <span
              class="text-cta group-hover:translate-x-1 transition-transform"
              >→</span
            >
          </a>
          <a
            href="/services/medication-management"
            class="flex items-center justify-between p-4 bg-white/5 rounded-2xl hover:bg-white/10 transition-all text-site-text text-sm font-bold group"
          >
            Medication Support <span
              class="text-cta group-hover:translate-x-1 transition-transform"
              >→</span
            >
          </a>
        </nav>
      </div>

      <div
        class="bg-white/5 border border-white/10 p-10 rounded-[2.5rem] text-center"
      >
        <h3 class="font-serif text-2xl font-black text-site-text mb-4">Find Your Balance</h3>
        <p class="text-site-sub/60 text-sm mb-8 leading-relaxed">
          Accepting Medicaid, Medicare, and Commercial Insurances in Kentucky.
        </p>
        <a
          href={WIDGET_LINK}
          class="block w-full py-4 bg-sand text-cta-fg font-black rounded-xl hover:bg-white hover:scale-105 transition-all duration-300 shadow-lg shadow-sand/10"
        >
          Schedule Intake
        </a>
        <p
          class="mt-6 text-[10px] font-black text-site-sub/60 uppercase tracking-widest"
        >
          Telehealth & In-Person Available
        </p>
      </div>

      <div class="p-6 bg-slate-800/10 rounded-3xl border border-white/5">
        <p class="text-xs text-site-sub/60 leading-relaxed italic">
          "All our therapists are neuroaffirming; we focus on creating an
          environment that asks the world to meet you where you're at."
        </p>
      </div>
    </aside>
  </div>

  <section class="max-w-7xl mx-auto px-4 mt-32 mb-12">
    <div
      class="p-10 bg-linear-to-r from-cta/10 to-cta/10 border border-cta/20 rounded-[3rem] text-center"
    >
      <h2 class="font-serif text-3xl font-black text-site-text mb-4">
        Ready to Start Therapy?
      </h2>
      <p class="text-site-sub mb-8 max-w-2xl mx-auto">
        Learn about our intake process, what to expect at your first appointment, and how to get started with neuro-affirming care.
      </p>
      <a
        href="/resources/new-client"
        class="inline-block px-8 py-3 bg-cta text-cta-fg font-black rounded-xl hover:bg-cta/80 transition-all"
      >
        New Client Guide
      </a>
    </div>
  </section>
</ServiceLayout>

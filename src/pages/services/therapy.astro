---
import Layout from "../../layouts/Layout.astro";
import { WIDGET_LINK } from "../../data/resource";
import PageHeroWrapper from "../../components/PageHeroWrapper.astro";
import AnimatedSection from "../../components/react/primitives/AnimatedSection";
import SidebarCta from "../../components/react/composites/SidebarCta";

const therapyFocus = [
  {
    title: "Neuro-Identity",
    detail:
      "Moving from 'masking' to authenticity. Understanding your neuro-type as a vital part of who you are.",
  },
  {
    title: "Executive Support",
    detail:
      "Collaborative strategies for task management, burnout prevention, and sensory regulation.",
  },
  {
    title: "Social Connection",
    detail:
      "Developing communication styles that honor your comfort level rather than forcing social norms.",
  },
  {
    title: "Burnout Recovery",
    detail:
      "Specialized support for 'Autistic Burnout'—restoring energy and setting sustainable boundaries.",
  },
];
---

<Layout
  title="Neuro-Affirming Therapy KY | Twilight Psychology"
  description="Neuro-affirming therapy in Kentucky for neurodivergent adults. Evidence-based individual counseling honoring your unique identity. Telehealth available."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">  
  <PageHeroWrapper
    title="Talk Therapy"
    accentWord="Therapy"
    badge="Neuro-Affirming Counseling"
    subtitle="No &quot;fixing.&quot; No &quot;curing.&quot; Just compassionate, evidence-based therapy that honors your unique way of being."
    size="lg"
  />

  <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">
    <div class="lg:col-span-2 space-y-12">
      <AnimatedSection client:visible animation="fadeInUp" delay={100}>
        <section
          class="bg-surface-soft backdrop-blur-md border border-border p-10 rounded-[2.5rem]"
        >
        <h2 class="font-serif text-3xl font-black text-site-text mb-6 tracking-tight">
          Support That Validates
        </h2>
        <div class="space-y-6 text-site-text leading-relaxed text-lg">
          <p>
            Traditional therapy often focuses on making neurodivergent people
            "act neurotypical." At Twilight Psychology, we do the opposite. Our
            goal is to help you build a life that accommodates <span
              class="text-cta">your nervous system</span
            >.
          </p>
          <p>
            Whether you were diagnosed yesterday or have known your whole life,
            we provide a safe space to process the challenges of a world not
            built for you.
          </p>
          <a
            href="/about/twilight-psychology"
            class="inline-block text-cta font-black text-sm border-b-2 border-cta/20 hover:border-cta transition-all pb-1"
          >
            Read our Neuro-Affirming Promise →
          </a>
        </div>
      </section>
      </AnimatedSection>

      <AnimatedSection client:visible animation="fadeInUp" delay={200}>
      <section>
        <h2 class="font-serif text-2xl font-black text-site-text mb-10 tracking-tight">Focus Areas</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {
            therapyFocus.map((item) => (
              <div
                class="p-8 bg-surface-soft border border-border rounded-3xl"
              >
                <div class="w-10 h-10 rounded-xl bg-cta sm:bg-surface-2 flex items-center justify-center mb-6 border border-border">
                  <span class="text-cta-fg sm:text-cta text-xl">
                    ✦
                  </span>
                </div>
                <h3 class="font-serif text-site-text font-black mb-2">{item.title}</h3>
                <p class="text-site-sub text-sm leading-relaxed">
                  {item.detail}
                </p>
              </div>
            ))
          }
        </div>
      </section>
      </AnimatedSection>
    </div>

    <aside class="space-y-8">
      <AnimatedSection client:visible animation="slideInRight" delay={200}>
        <div class="bg-surface-soft border border-border p-8 rounded-[2.5rem]">
          <h3 class="font-serif text-xl font-black text-site-text mb-6">Continuum of Care</h3>
        <nav class="space-y-4">
          <a
            href="/services/psychological-evaluations"
            class="flex items-center justify-between p-4 bg-surface-soft rounded-2xl hover:bg-surface-2/30 transition-all text-site-text text-sm font-bold group"
          >
            Need a Diagnosis? <span
              class="text-cta group-hover:translate-x-1 transition-transform"
              >→</span
            >
          </a>
          <a
            href="/services/medication-management"
            class="flex items-center justify-between p-4 bg-surface-soft rounded-2xl hover:bg-surface-2/30 transition-all text-site-text text-sm font-bold group"
          >
            Medication Support <span
              class="text-cta group-hover:translate-x-1 transition-transform"
              >→</span
            >
          </a>
        </nav>
      </div>
      </AnimatedSection>

      <SidebarCta
        client:visible
        title="Begin Your Care"
        description="Accepting Medicaid, Medicare, and commercial insurances in Kentucky."
        buttonLabel="Schedule Intake"
        buttonHref={WIDGET_LINK}
        target="_blank"
        rel="noopener noreferrer"
      />

      <div class="p-6 bg-surface-soft rounded-3xl border border-border">
        <p class="text-xs text-site-sub leading-relaxed italic">
          "All our therapists practice from a neuroaffirming framework—creating a
          clinical space that meets you where you are, rather than asking you to conform."
        </p>
      </div>

      <div class="bg-surface-soft border border-border p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-lg font-black text-site-text mb-4">From Our Blog</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href="/blog/announcements/wellcare-kentucky-in-network" class="text-cta hover:underline font-semibold">Now In-Network with Wellcare of Kentucky</a>
            <p class="text-site-sub text-xs mt-0.5">Therapy is now available under Wellcare benefits.</p>
          </li>
          <li>
            <a href="/blog/clinical/what-is-pda-profile" class="text-cta hover:underline font-semibold">What Is a PDA Profile?</a>
            <p class="text-site-sub text-xs mt-0.5">A clinical look at a commonly missed autism spectrum profile.</p>
          </li>
          <li>
            <a href="/blog/insurance/understanding-health-insurance" class="text-cta hover:underline font-semibold">Understanding Health Insurance</a>
            <p class="text-site-sub text-xs mt-0.5">How different plan types cover therapy services.</p>
          </li>
        </ul>
      </div>
    </aside>
  </div>

  <section class="max-w-7xl mx-auto px-4 mt-32 mb-12">
    <AnimatedSection client:visible animation="fadeInUp" delay={300}>
      <div
      class="p-10 bg-linear-to-r from-cta/10 to-cta/10 border border-cta/20 rounded-[3rem] text-center"
    >
      <h2 class="font-serif text-3xl font-black text-site-text mb-4">
        Ready to Start Therapy?
      </h2>
      <p class="text-site-sub mb-8 max-w-2xl mx-auto">
        Learn about our intake process, what to expect at your first appointment, and how to get started with neuro-affirming care.
      </p>
      <a
        href="/resources/new-client"
        class="inline-block px-8 py-3 bg-cta text-cta-fg font-black rounded-full hover:bg-cta/80 transition-all"
      >
        New Client Guide
      </a>
    </div>
    </AnimatedSection>
  </section>

  <nav class="max-w-4xl mx-auto px-6 mt-12 mb-4">
    <a href="/services" class="inline-flex items-center gap-2 text-sm font-bold text-cta hover:text-cta/80 transition-colors">
      <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
      View All Services
    </a>
  </nav>
      </div>
    </div>
  </div>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { WIDGET_LINK } from '../../data/resource';

const evaluationSteps = [
  {
    title: "Clinical Intake",
    detail: "A deep dive into developmental milestones, medical history, and lived experiences."
  },
  {
    title: "Comprehensive Testing",
    detail: "A 3-4 hour battery assessing cognitive, executive, and adaptive functioning."
  },
  {
    title: "Clinical Observation",
    detail: "Evidence-based tools including ADOS-2 and the neuro-affirming MIGDAS-2."
  },
  {
    title: "Feedback & Report",
    detail: "A detailed diagnostic report with tailored recommendations for support."
  }
];
---

<Layout
  title="Autism Testing | Twilight Psychology"
  description="Autism spectrum evaluations for children and adults in Kentucky. Neuro-affirming assessments by experienced psychologists. Telehealth available."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
    
    <section class="relative py-24 px-4 text-center border-b border-border overflow-hidden">
      <div class="max-w-4xl mx-auto relative z-10">
        <span class="px-4 py-1.5 mb-6 text-[10px] font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full">
          Comprehensive Evaluations
        </span>
        <h1 class="font-serif text-5xl md:text-7xl font-black text-site-text mb-6 tracking-tight">
          Autism <span class="text-cta">Testing</span>
        </h1>
        <p class="text-xl text-site-sub font-medium max-w-2xl mx-auto leading-relaxed">
          One of the shortest waitlists in Kentucky for comprehensive, evidence-based diagnostic evaluations.
        </p>
      </div>
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(circle_at_center,var(--tw-gradient-stops))] from-surface-2/60 via-transparent to-transparent z-0"
      >
      </div>
    </section>

    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">
      
      <div class="lg:col-span-2 space-y-12">
        
        <section class="bg-surface-soft backdrop-blur-md border border-border p-10 rounded-[2.5rem]">
          <h2 class="font-serif text-3xl font-black text-site-text mb-6 tracking-tight">Beyond the Label</h2>
          <div class="space-y-6 text-site-text leading-relaxed text-lg">
            <p>
              Autism Spectrum Disorder (ASD) is a developmental condition where the brain processes information differently. At Twilight Psychology, we recognize that autism is not a mental illness—it is a vital part of a person's identity.
            </p>
            <p>
              We specialize in identifying individuals who have learned to <span class="text-cta">"mask"</span> or hide their traits, particularly women and girls, ensuring they finally feel heard and understood.
            </p>
          </div>
        </section>

        <section class="bg-surface-soft border border-border-strong p-10 rounded-[2.5rem]">
          <h2 class="font-serif text-2xl font-black text-site-text mb-8 tracking-tight">Our Diagnostic Approach</h2>
          <p class="text-site-sub mb-8">
            A diagnosis should never rely on a single test. We provide a holistic view using gold-standard tools tailored to your needs:
          </p>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="p-6 bg-surface-soft rounded-3xl border border-border">
              <h3 class="font-serif text-cta font-black text-sm uppercase mb-2">ADOS-2</h3>
              <p class="text-xs text-site-sub leading-relaxed">Standardized behavioral observation used widely for traditional presentations.</p>
            </div>
            <div class="p-6 bg-surface-soft rounded-3xl border border-border">
              <h3 class="font-serif text-cta font-black text-sm uppercase mb-2">MIGDAS-2</h3>
              <p class="text-xs text-site-sub leading-relaxed">A sensory-based, neuro-affirming interview style ideal for high-masking individuals.</p>
            </div>
          </div>
        </section>

        <section>
          <h2 class="font-serif text-2xl font-black text-site-text mb-10 text-center lg:text-left tracking-tight">The Testing Timeline</h2>
          <div class="grid sm:grid-cols-2 gap-6">
            {evaluationSteps.map((step, i) => (
              <div class="group p-8 bg-surface-soft hover:bg-surface-2/50 border border-border hover:border-cta/30 rounded-3xl transition-all duration-300">
                <div class="text-4xl font-black text-site-text/10 mb-4 group-hover:text-cta/20 transition-colors">0{i + 1}</div>
                <h3 class="font-serif text-site-text font-black mb-2">{step.title}</h3>
                <p class="text-site-sub text-sm leading-relaxed">{step.detail}</p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <aside class="space-y-8">
        
        <div class="bg-surface-soft border border-border p-8 rounded-[2.5rem]">
          <h3 class="font-serif text-xl font-black text-site-text mb-6">Insurance Accepted</h3>
          <p class="text-sm text-site-sub leading-relaxed mb-4">
            We accept KY Medicaid, Medicare, and most major commercial plans so testing remains accessible.
          </p>
          <a
            href="/resources/insurances-accepted"
            class="text-cta font-black text-xs uppercase tracking-widest hover:text-site-text transition-colors"
          >
            View All Accepted Plans →
          </a>
        </div>

        <div class="bg-cta p-10 rounded-[2.5rem] text-cta-fg shadow-2xl shadow-cta/10">
          <h3 class="font-serif text-2xl font-black mb-4 tracking-tight">Ready for clarity?</h3>
          <p class="font-bold text-sm mb-8 opacity-80 italic">
            "For evaluations offered on a self-pay basis, full reports are often completed within one week."
          </p>
          <a href={WIDGET_LINK} 
             class="block w-full py-4 bg-site-bg text-site-text text-center font-black rounded-xl hover:scale-105 transition-all duration-300 shadow-lg shadow-black/10">
            Book Evaluation
          </a>
        </div>

        <div class="px-4 py-8 border-l border-border italic text-site-sub text-sm">
          "Early identification is critical for optimizing quality of life. We ensure you don't have to wait years for answers."
        </div>
      </aside>
    </div>

  <nav class="max-w-4xl mx-auto px-6 mt-12 mb-4">
    <a href="/services" class="inline-flex items-center gap-2 text-sm font-bold text-cta hover:text-cta/80 transition-colors">
      <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
      View All Services
    </a>
  </nav>
      </div>
    </div>
  </div>
</Layout>

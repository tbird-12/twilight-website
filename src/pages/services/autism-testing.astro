---
import Layout from '../../layouts/Layout.astro';
import Schema from '../../components/Schema.astro';
import { WIDGET_LINK } from '../../data/resource';
import PageHeroWrapper from "../../components/PageHeroWrapper.astro";
import AnimatedSection from "../../components/react/primitives/AnimatedSection";

const siteUrl = Astro.site || new URL("https://www.twilightpsychology.com");
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;

const autismSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Autism Testing at Twilight Psychology",
  url: pageUrl,
  keywords: [
    "autism testing Lexington KY",
    "autism evaluation Lexington KY",
    "autism testing Kentucky",
    "autism diagnosis Lexington",
    "adult autism testing Lexington KY",
    "autism evaluation for children Kentucky",
    "autism testing near me",
    "ASD evaluation Lexington KY",
  ],
  description:
    "Neuro-affirming autism evaluations in Lexington, KY at Twilight Psychology. Comprehensive ASD testing for children, teens, and adults, including high-masking presentations.",
  provider: {
    "@type": "MedicalOrganization",
    name: "Twilight Psychology",
    url: "https://www.twilightpsychology.com",
  },
  areaServed: [
    { "@type": "City", name: "Lexington", containedIn: { "@type": "State", name: "Kentucky" } },
    { "@type": "State", name: "Kentucky" },
  ],
};

const evaluationSteps = [
  {
    title: "Clinical Intake",
    detail: "A deep dive into developmental milestones, medical history, and lived experiences."
  },
  {
    title: "Comprehensive Testing",
    detail: "A 3-4 hour battery assessing cognitive, executive, and adaptive functioning."
  },
  {
    title: "Clinical Observation",
    detail: "Evidence-based tools including ADOS-2 and the neuro-affirming MIGDAS-2."
  },
  {
    title: "Feedback & Report",
    detail: "A detailed diagnostic report with tailored recommendations for support."
  }
];
---

<Layout
  title="Autism Testing Lexington KY"
  description="Neuro-affirming autism evaluations in Lexington, KY for children, teens, and adults, with careful assessment for nuanced and high-masking presentations."
>
  <Schema slot="page-schema" schema={autismSchema} />
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
    
    <PageHeroWrapper
      title="Autism Testing"
      accentWord="Testing"
      badge="Comprehensive Evaluations"
      subtitle="Neuro-affirming autism evaluations in Lexington, KY for children, teens, and adults — designed for nuanced presentations, diagnostic depth, and clear reporting."
      size="lg"
    />

    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">
      
      <div class="lg:col-span-2 space-y-12">
        
        <AnimatedSection client:visible animation="fadeInUp" delay={100}>
        <section class="bg-surface-soft backdrop-blur-md border border-border p-10 rounded-[2.5rem]">
          <h2 class="font-serif text-3xl font-black text-site-text mb-6 tracking-tight">Autism testing in Lexington, KY</h2>
          <div class="space-y-6 text-site-text leading-relaxed text-lg">
            <p>
              Twilight Psychology provides comprehensive autism evaluations in Lexington, KY for
              children, teens, and adults. Our evaluators are trained to identify autism spectrum
              disorder (ASD) across the full range of presentations — including nuanced, late-diagnosed,
              and high-masking cases that are frequently missed by less thorough assessments.
            </p>
            <p>
              We recognize that autism is not a mental illness but a vital part of a person's
              identity. We are especially experienced with individuals who have learned to{" "}
              <span class="text-cta">"mask"</span> or hide their traits, particularly women and
              girls, ensuring the evaluation reflects the person in front of us rather than a
              narrow stereotype.
            </p>
          </div>
        </section>
        </AnimatedSection>

        <AnimatedSection client:visible animation="fadeInUp" delay={200}>
        <section class="bg-surface-soft border border-border-strong p-10 rounded-[2.5rem]">
          <h2 class="font-serif text-2xl font-black text-site-text mb-8 tracking-tight">Our Diagnostic Approach</h2>
          <p class="text-site-sub mb-8">
            While ADOS-2 is available for diagnosis, we prefer to use state-of-the-art testing tools including but not
            limited to ADOS-2, ADI-R, MIGDAS-2, CARS-2, or a tailored combination depending on presenting concerns, age,
            developmental milestones, and the diagnostic question we need to answer.
          </p>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="p-6 bg-surface-soft rounded-3xl border border-border">
              <h3 class="font-serif text-cta font-black text-sm uppercase mb-2">ADOS-2</h3>
              <p class="text-xs text-site-sub leading-relaxed">Available when a structured behavioral observation is the best fit for the referral question and presentation.</p>
            </div>
            <div class="p-6 bg-surface-soft rounded-3xl border border-border">
              <h3 class="font-serif text-cta font-black text-sm uppercase mb-2">ADI-R, MIGDAS-2, CARS-2</h3>
              <p class="text-xs text-site-sub leading-relaxed">Additional state-of-the-art tools we may use, alone or in combination, depending on developmental history, masking, age, and clinical presentation.</p>
            </div>
          </div>
        </section>
        </AnimatedSection>

        <AnimatedSection client:visible animation="fadeInUp" delay={300}>
        <section>
          <h2 class="font-serif text-2xl font-black text-site-text mb-10 text-center lg:text-left tracking-tight">The Testing Timeline</h2>
          <div class="grid sm:grid-cols-2 gap-6">
            {evaluationSteps.map((step, i) => (
              <div class="group p-8 bg-surface-soft hover:bg-surface-2/50 border border-border hover:border-cta/30 rounded-3xl transition-all duration-300">
                <div class="text-4xl font-black text-site-text/10 mb-4 group-hover:text-cta/20 transition-colors">0{i + 1}</div>
                <h3 class="font-serif text-site-text font-black mb-2">{step.title}</h3>
                <p class="text-site-sub text-sm leading-relaxed">{step.detail}</p>
              </div>
            ))}
          </div>
        </section>
        </AnimatedSection>
      </div>

      <aside class="space-y-8">
        
        <div class="bg-surface-soft border border-border p-8 rounded-[2.5rem]">
          <h3 class="font-serif text-xl font-black text-site-text mb-6">Choosing the Right Pathway</h3>
          <p class="text-sm text-site-sub leading-relaxed mb-4">
            We participate with many commercial plans, Kentucky Medicaid plans, and Medicare for covered behavioral
            health services, with therapy and medication management being the clearest in-network paths.
          </p>
          <p class="text-sm text-site-sub leading-relaxed mb-4">
            For autism evaluations, insurance coverage depends on medical necessity and the number of testing units a
            plan approves. Those hours include records review, collateral information, interviews, test administration,
            scoring, interpretation, consultation, and documentation, so we focus on the most clinically relevant tools
            within the time authorized. Self-pay is available when a referral needs broader testing or more
            documentation than insurance allows, and Medicaid evaluations are limited to approved hours because
            Medicaid clients cannot be charged beyond covered amounts.
          </p>
          <a
            href="/resources/insurances-accepted"
            class="text-cta font-black text-xs uppercase tracking-widest hover:text-site-text transition-colors"
          >
            Review Accepted Plans →
          </a>
        </div>

        <div class="bg-surface-soft border border-border p-8 rounded-[2.5rem]">
          <h3 class="font-serif text-lg font-black text-site-text mb-4">From Our Blog</h3>
          <ul class="space-y-3 text-sm">
            <li>
              <a href="/specialties/pda-profile" class="text-cta hover:underline font-semibold">PDA Profile Evaluations</a>
              <p class="text-site-sub text-xs mt-0.5">Explore our specialty page for demand-avoidant autism presentations and differential assessment.</p>
            </li>
            <li>
              <a href="/blog/clinical/what-is-pda-profile" class="text-cta hover:underline font-semibold">What Is a PDA Profile and How We Assess It</a>
              <p class="text-site-sub text-xs mt-0.5">A frequently missed autism spectrum profile and our assessment approach.</p>
            </li>
            <li>
              <a href="/blog/clinical/autism-evaluation-lexington-ky" class="text-cta hover:underline font-semibold">Autism Evaluation in Lexington, KY — Children and Adults</a>
              <p class="text-site-sub text-xs mt-0.5">What the autism evaluation process involves, including high-masking adults, AuDHD presentations, and the ADOS-2.</p>
            </li>
            <li>
              <a href="/blog/clinical/how-to-understand-your-cat-q-masking-results" class="text-cta hover:underline font-semibold">How to Understand Your CAT-Q Masking Results</a>
              <p class="text-site-sub text-xs mt-0.5">Learn how masking scores can deepen the picture when autism has been missed or misunderstood.</p>
            </li>
          </ul>
        </div>

        <div class="bg-cta p-10 rounded-[2.5rem] text-cta-fg shadow-2xl shadow-cta/10">
          <h3 class="font-serif text-2xl inverted-text font-black mb-4 tracking-tight">Ready for clarity?</h3>
          <p class="font-bold inverted-text text-sm mb-8 opacity-80 italic">
            "Self-pay autism evaluations can often be completed with a full report within seven days of intake. Insurance timelines depend on authorization and the testing hours your plan approves."
          </p>
          <a href={WIDGET_LINK} 
             class="block w-full py-4 bg-site-bg text-site-text text-center font-black rounded-xl hover:scale-105 transition-all duration-300 shadow-lg shadow-black/10">
            Book Evaluation
          </a>
        </div>

        <div class="px-4 py-8 border-l border-border italic text-site-sub text-sm">
          "Early identification is critical for optimizing quality of life. We ensure you don't have to wait years for answers."
        </div>
      </aside>
    </div>

  <div class="max-w-4xl mx-auto px-6 mt-8 mb-2">
    <div class="bg-surface border border-border rounded-2xl p-5 flex items-center justify-between gap-4 flex-wrap">
      <div>
        <p class="text-site-sub text-sm">Curious whether you might be masking?</p>
        <p class="text-xs text-site-sub opacity-70">High masking is a common sign of undiagnosed autism.</p>
      </div>
      <a href="/resources/masking-inventory" class="text-cta font-semibold text-sm hover:underline whitespace-nowrap">
        Take our free 3-min Masking Inventory →
      </a>
    </div>
  </div>

  <nav class="max-w-4xl mx-auto px-6 mt-4 mb-4">
    <a href="/services" class="inline-flex items-center gap-2 text-sm font-bold text-cta hover:text-cta/80 transition-colors">
      <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
      View All Services
    </a>
  </nav>
      </div>
    </div>
</Layout>

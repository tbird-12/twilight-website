---
import Layout from "../../layouts/Layout.astro";
import Schema from "../../components/Schema.astro";
import PageLinksSection from "../../components/PageLinksSection.astro";
import { WIDGET_LINK } from "../../data/resource";
import PageHeroWrapper from "../../components/PageHeroWrapper.astro";
import AnimatedSection from "../../components/react/primitives/AnimatedSection";

const evaluationTypes = [
  {
    title: "Diagnostic Clarity",
    detail:
      "Distinguishing between complex presentations of Anxiety, Depression, Bipolar Disorder, and PTSD.",
    link: "/services/personality-profiles",
  },
  {
    title: "Learning & Cognitive",
    detail:
      "Identifying dyslexia, giftedness, and psychoeducational needs when school and accommodation decisions depend on depth.",
    link: "/specialties/psychoeducational-evaluations",
  },
  {
    title: "Personality Profiles",
    detail:
      "Exploring long-term patterns of relating to the self and others for therapeutic breakthroughs.",
    link: "/services/personality-profiles",
  },
  {
    title: "Treatment Planning",
    detail:
      "Providing the clinical documentation needed for specialized therapy or workplace accommodations.",
    link: "/services/therapy",
  },
];

const siteUrl = Astro.site || new URL("https://www.twilightpsychology.com");
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;

const evalSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Psychological Testing & Evaluations at Twilight Psychology",
  url: pageUrl,
  keywords: [
    "psychological testing near me",
    "psychological testing Lexington KY",
    "psychological evaluations Lexington KY",
    "psychological testing Kentucky",
    "psychological evaluation near me",
    "psych testing Lexington KY",
    "psychological testing for ADHD near me",
    "psychological testing for autism near me",
  ],
  description:
    "Comprehensive psychological testing and evaluations in Lexington, KY at Twilight Psychology, covering ADHD, autism, personality, learning disabilities, and complex diagnostic questions.",
  provider: {
    "@type": "MedicalOrganization",
    name: "Twilight Psychology",
    url: "https://www.twilightpsychology.com",
  },
  areaServed: [
    { "@type": "City", name: "Lexington", containedIn: { "@type": "State", name: "Kentucky" } },
    { "@type": "State", name: "Kentucky" },
  ],
};

const specialtyEvaluationLinks = [
  {
    href: "/specialties/psychoeducational-evaluations",
    label: "Psychoeducational evaluations",
    description: "School, accommodation, and gifted/2e testing for documentation-heavy referrals.",
  },
  {
    href: "/specialties/dyslexia-testing",
    label: "Learning disability testing",
    description: "Clarify dyslexia, dysgraphia, dyscalculia, and overlapping school concerns.",
  },
  {
    href: "/specialties/iee",
    label: "IEE in Kentucky",
    description: "Independent Educational Evaluations for families seeking a second school opinion.",
  },
];
---

<Layout
  title="Psychological Evaluations Lexington KY"
  description="Psychological evaluations in Lexington, KY with specialty depth in psychoeducational, PDA, and ADHD referrals. Self-pay reports often in 7 days. Insurance accepted for covered referrals."
>
  <Schema slot="page-schema" schema={evalSchema} />
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <PageHeroWrapper
    title="Psychological Evaluations"
    accentWord="Evaluations"
    badge="Comprehensive Evaluations"
    subtitle="Specialty-depth evaluations in Kentucky for ADHD, autism, psychoeducational, and complex referrals — with self-pay reports often delivered in 7 days and insurance accepted for covered services."
    size="lg"
  />

  <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">
    <div class="lg:col-span-2 space-y-12">
      <AnimatedSection client:visible animation="fadeInUp" delay={100}>
      <section
        class="bg-surface-soft backdrop-blur-md border border-border p-10 rounded-[2.5rem]"
      >
        <h2 class="font-serif text-3xl font-black text-site-text mb-6 tracking-tight">
          Specialty Depth, Faster Access, Clearer Reports
        </h2>
        <p class="text-site-text leading-relaxed text-lg mb-6">
          A psychological evaluation should do more than confirm a label. It
          should clarify the full clinical picture with enough depth to guide
          treatment, school, work, and life decisions that carry real weight —
          and deliver that clarity in a timeframe that actually helps.
        </p>
        <p class="text-site-text leading-relaxed text-lg mb-0">
          For self-pay clients, reports are typically completed within seven days
          of the intake appointment — without an expedited fee. Our process
          covers the full range of referral questions: ADHD and autism including
          high-masking and PDA presentations, psychoeducational evaluations for
          school and accommodation needs, personality and diagnostic complexity,
          and documentation-heavy referrals that general practices often refer
          out. Insurance is accepted for covered evaluations.
        </p>

      </section>
      </AnimatedSection>

      <AnimatedSection client:visible animation="fadeInUp" delay={200}>
      <section>
        <h2 class="font-serif text-2xl font-black text-site-text mb-10 tracking-tight">
          Areas of Specialization
        </h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {
            evaluationTypes.map((item) => (
              <a
                href={item.link}
                class="group p-8 bg-surface-soft hover:bg-surface-2/50 border border-border hover:border-cta/30 rounded-3xl transition-all duration-300 block"
              >
                <div class="w-10 h-10 rounded-xl bg-cta sm:bg-surface-2 flex items-center justify-center mb-6 border border-border sm:group-hover:bg-cta transition-all">
                  <span class="text-cta-fg sm:text-cta sm:group-hover:text-cta-fg">
                    ✦
                  </span>
                </div>

                <h3 class="font-serif text-site-text font-black mb-2">{item.title}</h3>
                <p class="text-site-sub text-sm leading-relaxed mb-4">
                  {item.detail}
                </p>

                <span class="text-xs font-black text-cta block sm:opacity-0 sm:group-hover:opacity-100 transition-opacity uppercase tracking-widest">
                  View Details →
                </span>
              </a>
            ))
          }
        </div>
      </section>
      </AnimatedSection>

      <AnimatedSection client:visible animation="fadeInUp" delay={300}>
      <section class="bg-surface-2 border border-border-strong p-10 rounded-[2.5rem]">
        <h2 class="font-serif text-2xl font-black text-site-text mb-6 tracking-tight">
          When insurance may apply
        </h2>
        <div class="space-y-5 text-site-text leading-relaxed">
          <p>
            We do accept insurance for select treatment-driven referrals when
            there is a <span class="font-bold">specific clinical question</span>
            tied to diagnosis or treatment planning and the results are
            expected to change care.
          </p>
          <p>
            Insurance typically approves only a limited number of testing
            units, and those hours include record collection, collateral
            information, interviewing clients and parents, test administration,
            reviewing and integrating data, researching concerns, consulting
            with other providers, and documentation. When we bill insurance, we
            use the most clinically relevant tests within the hours approved.
            Self-pay is available when a referral needs a broader battery or
            more documentation than insurance allows. Medicaid clients cannot
            be charged beyond covered amounts, so Medicaid evaluations are
            limited to the hours approved by the plan.
          </p>
          <p>
            If the referral is primarily for school planning, court use,
            disability or benefits paperwork, waiver eligibility, or another
            third-party decision, we will usually direct you to the specialty
            path that matches that purpose instead of presenting it as covered
            treatment.
          </p>
        </div>
      </section>
      </AnimatedSection>
    </div>

    <aside class="space-y-8">
      <div class="bg-surface-soft border border-border p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-xl font-black text-site-text mb-6">Related Services</h3>
        <nav class="space-y-4">
          <a
            href="/services/autism-testing"
            class="flex items-center justify-between p-4 bg-surface-soft rounded-2xl hover:bg-surface-2/30 transition-colors text-site-text text-sm font-bold"
          >
            Autism Evaluations <span class="text-cta">→</span>
          </a>
          <a
            href="/services/adhd-testing"
            class="flex items-center justify-between p-4 bg-surface-soft rounded-2xl hover:bg-surface-2/30 transition-colors text-site-text text-sm font-bold"
          >
            ADHD Evaluations <span class="text-cta">→</span>
          </a>
          <a
            href="/services/personality-profiles"
            class="flex items-center justify-between p-4 bg-surface-soft rounded-2xl hover:bg-surface-2/30 transition-colors text-site-text text-sm font-bold"
          >
            Personality Evaluations <span class="text-cta">→</span>
          </a>
        </nav>
      </div>

      <div
        class="bg-surface-soft border border-border p-10 rounded-[2.5rem] text-center"
      >
        <h3 class="font-serif text-2xl font-black text-site-text mb-4">Ready for Clinical Clarity?</h3>
        <p class="text-site-sub text-sm mb-8 leading-relaxed">
          Request an intake consultation to determine whether insurance or self-pay is the best fit for your referral question, documentation needs, and the level of specialty depth you want from the evaluation.
        </p>
        <a
          href={WIDGET_LINK}
          class="block w-full py-4 bg-cta text-cta-fg font-black rounded-xl hover:bg-cta/80 hover:scale-105 transition-all duration-300 shadow-lg shadow-cta/10"
        >
          Request Evaluation Consultation
        </a>
      </div>

      <div class="bg-surface-soft border border-border p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-lg font-black text-site-text mb-4">From Our Blog</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href="/blog/clinical/neuropsychological-vs-psychoeducational-evaluation" class="text-cta hover:underline font-semibold">Neuropsychological vs. Psychoeducational Evaluation — What's the Difference?</a>
            <p class="text-site-sub text-xs mt-0.5">How to choose the right evaluation type for your referral question and documentation needs.</p>
          </li>
          <li>
            <a href="/blog/clinical/adhd-testing-lexington-ky" class="text-cta hover:underline font-semibold">ADHD Testing in Lexington, KY</a>
            <p class="text-site-sub text-xs mt-0.5">What a comprehensive ADHD evaluation covers, from intake through the feedback session.</p>
          </li>
          <li>
            <a href="/blog/clinical/autism-evaluation-lexington-ky" class="text-cta hover:underline font-semibold">Autism Evaluation in Lexington, KY — Children and Adults</a>
            <p class="text-site-sub text-xs mt-0.5">What autism evaluation involves at Twilight, including high-masking adults and AuDHD presentations.</p>
          </li>
        </ul>
      </div>
    </aside>
  </div>

  <section class="max-w-7xl mx-auto px-4 mt-32">
    <div
      class="p-12 bg-surface-soft border border-border rounded-[3rem] flex flex-col md:flex-row items-center justify-between gap-8"
    >
      <div class="max-w-md">
        <h2 class="font-serif text-3xl font-black text-site-text mb-4 italic">
          The Journey Doesn't End at Diagnosis.
        </h2>
        <p class="text-site-sub">
          Once you have clarity, we offer the therapeutic and medical support to
          help you move forward.
        </p>
      </div>
      <div class="flex flex-wrap gap-4">
        <a
          href="/services/therapy"
          class="px-6 py-3 bg-surface-soft border border-border text-site-text font-black rounded-xl hover:bg-surface-2/50 transition-all"
          >Find a Therapist</a
        >
        <a
          href="/services/medication-management"
          class="px-6 py-3 bg-surface-soft border border-border text-site-text font-black rounded-xl hover:bg-surface-2/50 transition-all"
          >Medication Support</a
        >
      </div>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-6 mt-8 mb-2">
    <div class="bg-surface border border-border rounded-2xl p-5 flex items-center justify-between gap-4 flex-wrap">
      <div>
        <p class="text-site-sub text-sm">Not sure if you need an evaluation?</p>
        <p class="text-xs text-site-sub opacity-70">Our free Masking Inventory can help clarify next steps.</p>
      </div>
      <a href="/resources/masking-inventory" class="text-cta font-semibold text-sm hover:underline whitespace-nowrap">
        Take our free 3-min Masking Inventory →
      </a>
    </div>
  </div>

  <PageLinksSection
    title="Need a specialty evaluation instead?"
    description="These pages are the best next step when the referral question is school-, accommodation-, or documentation-focused."
    links={specialtyEvaluationLinks}
  />

  <nav class="max-w-4xl mx-auto px-6 mt-4 mb-4">
    <a href="/services" class="inline-flex items-center gap-2 text-sm font-bold text-cta hover:text-cta/80 transition-colors">
      <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
      View All Services
    </a>
  </nav>
      </div>
    </div>
</Layout>

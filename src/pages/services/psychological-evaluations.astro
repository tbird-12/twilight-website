---
import ServiceLayout from "../../layouts/ServiceLayout.astro";
import "../../styles/global.css";
import { WIDGET_LINK } from "../../data/resource";

const evaluationTypes = [
  {
    title: "Diagnostic Clarity",
    detail:
      "Distinguishing between complex presentations of Anxiety, Depression, Bipolar Disorder, and PTSD.",
    link: "/services/therapy", // Placeholder
  },
  {
    title: "Learning & Cognitive",
    detail:
      "Identifying Dyslexia, Dysgraphia, or intellectual giftedness to support academic success.",
    link: "/specialities/dyslexia-testing", // Placeholder
  },
  {
    title: "Personality Profiles",
    detail:
      "Exploring long-term patterns of relating to the self and others for therapeutic breakthroughs.",
    link: "/specialities/personality-profiles", // Placeholder
  },
  {
    title: "Treatment Planning",
    detail:
      "Providing the clinical documentation needed for specialized therapy or workplace accommodations.",
    link: "/services/medication-management", // Placeholder
  },
];
---

<ServiceLayout
  name="Psychological Evaluations Lexington KY | Twilight Psychology"
  description="Comprehensive psychological assessments for children, teens, and adults"
  metaDescription="Comprehensive psychological evaluations in Lexington, KY for ADHD, autism, learning disabilities, and more. Expert assessments for children, teens, and adults. Insurance accepted."
>
  <section class="relative py-24 px-4 text-center border-b border-white/5 overflow-hidden">
    <div class="max-w-4xl mx-auto relative z-10">
      <span
        class="px-4 py-1.5 mb-6 text-[10px] font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full"
      >
        Comprehensive Diagnostic Services
      </span>
      <h1
        class="font-serif text-5xl md:text-7xl font-black text-site-text mb-6 tracking-tight"
      >
        Psychological <span
          class="text-cta"
          >Evaluations</span
        >
      </h1>
      <p
        class="text-xl text-site-sub font-medium max-w-2xl mx-auto leading-relaxed"
      >
        When symptoms overlap and answers are unclear, we provide the
        evidence-based lens needed to move forward.
      </p>
    </div>
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(circle_at_center,var(--tw-gradient-stops))] from-slate-800/40 via-transparent to-transparent z-0"
    >
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">
    <div class="lg:col-span-2 space-y-12">
      <section
        class="bg-white/3 backdrop-blur-md border border-white/10 p-10 rounded-[2.5rem]"
      >
        <h2 class="font-serif text-3xl font-black text-site-text mb-6 tracking-tight">
          Answers Within Reach
        </h2>
        <p class="text-site-text leading-relaxed text-lg mb-6">
          A psychological evaluation helps us understand the "why" behind your
          emotional or behavioral experiences. Much like medical labs help a
          doctor treat a physical ailment, a psychological evaluation is 
          the first step to understanding your mental health.
        </p>
        <a
          href="/resources/faq"
          class="text-cta font-black text-sm hover:underline decoration-2 underline-offset-8"
        >
          Learn more about our evidence-based approach →
        </a>
      </section>

      <section>
        <h2 class="font-serif text-2xl font-black text-site-text mb-10 tracking-tight">
          Areas of Specialization
        </h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {
            evaluationTypes.map((item) => (
              <a
                href={item.link}
                class="group p-8 bg-white/5 hover:bg-white/10 border border-white/10 sm:border-white/5 hover:border-cta/30 rounded-3xl transition-all duration-300 block"
              >
                <div class="w-10 h-10 rounded-xl bg-cta sm:bg-slate-800/50 flex items-center justify-center mb-6 border border-white/5 sm:group-hover:bg-cta transition-all">
                  <span class="text-cta-fg sm:text-cta sm:group-hover:text-cta-fg">
                    ✦
                  </span>
                </div>

                <h3 class="font-serif text-site-text font-black mb-2">{item.title}</h3>
                <p class="text-site-sub/50 text-sm leading-relaxed mb-4">
                  {item.detail}
                </p>

                <span class="text-xs font-black text-cta block sm:opacity-0 sm:group-hover:opacity-100 transition-opacity uppercase tracking-widest">
                  View Details →
                </span>
              </a>
            ))
          }
        </div>
      </section>
    </div>

    <aside class="space-y-8">
      <div class="bg-white/5 border border-white/10 p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-xl font-black text-site-text mb-6">Related Services</h3>
        <nav class="space-y-4">
          <a
            href="/services/autism-testing"
            class="flex items-center justify-between p-4 bg-white/5 rounded-2xl hover:bg-white/10 transition-colors text-site-text text-sm font-bold"
          >
            Autism Evaluations <span class="text-cta">→</span>
          </a>
          <a
            href="/services/adhd-testing"
            class="flex items-center justify-between p-4 bg-white/5 rounded-2xl hover:bg-white/10 transition-colors text-site-text text-sm font-bold"
          >
            ADHD Evaluations <span class="text-cta">→</span>
          </a>
          <a
            href="/services/medication-management"
            class="flex items-center justify-between p-4 bg-white/5 rounded-2xl hover:bg-white/10 transition-colors text-site-text text-sm font-bold"
          >
            Medication Mgmt <span class="text-cta">→</span>
          </a>
        </nav>
      </div>

      <div
        class="bg-white/5 border border-white/10 p-10 rounded-[2.5rem] text-center"
      >
        <h3 class="font-serif text-2xl font-black text-site-text mb-4">Need Answers?</h3>
        <p class="text-site-sub/60 text-sm mb-8 leading-relaxed">
          Schedule an initial intake to see if testing is the right fit.
        </p>
        <a
          href={WIDGET_LINK}
          class="block w-full py-4 bg-sand text-cta-fg font-black rounded-xl hover:bg-white hover:scale-105 transition-all duration-300 shadow-lg shadow-sand/10"
        >
          Begin Evaluation
        </a>
      </div>
    </aside>
  </div>

  <section class="max-w-7xl mx-auto px-4 mt-32">
    <div
      class="p-12 bg-slate-800/20 border border-white/5 rounded-[3rem] flex flex-col md:flex-row items-center justify-between gap-8"
    >
      <div class="max-w-md">
        <h2 class="font-serif text-3xl font-black text-site-text mb-4 italic">
          The Journey Doesn't End at Diagnosis.
        </h2>
        <p class="text-site-sub/60">
          Once you have clarity, we offer the therapeutic and medical support to
          help you move forward.
        </p>
      </div>
      <div class="flex flex-wrap gap-4">
        <a
          href="/services/therapy"
          class="px-6 py-3 bg-white/5 border border-white/10 text-site-text font-black rounded-xl hover:bg-white/10 transition-all"
          >Find a Therapist</a
        >
        <a
          href="/services/medication-management"
          class="px-6 py-3 bg-white/5 border border-white/10 text-site-text font-black rounded-xl hover:bg-white/10 transition-all"
          >Medication Support</a
        >
      </div>
    </div>
  </section>
</ServiceLayout>

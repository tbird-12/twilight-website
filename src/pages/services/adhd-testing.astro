---
import Layout from "../../layouts/Layout.astro";
import { PHONE_NUMBER } from "../../data/resource";
import PageHeroWrapper from "../../components/PageHeroWrapper.astro";
import AnimatedSection from "../../components/react/primitives/AnimatedSection";

const adhdInsights = [
  {
    title: "Executive Functioning",
    detail:
      "Analyzing working memory, task initiation, and emotional regulation beyond just 'attention'.",
  },
  {
    title: "Differential Diagnosis",
    detail:
      "Carefully distinguishing ADHD from anxiety, PTSD, or sensory processing differences.",
  },
  {
    title: "Adult & Late Diagnosis",
    detail:
      "Specialized focus on high-masking adults who have navigated life without support.",
  },
  {
    title: "Holistic Recommendations",
    detail:
      "Detailed roadmaps for workplace accommodations, therapy, and medication management.",
  },
];
---

<Layout
  title="ADHD Testing KY"
  description="ADHD evaluations in Kentucky for children, teens, and adults, with careful assessment for complex cases and self-pay available when broader documentation is needed."
>
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <PageHeroWrapper
    title="ADHD Evaluations"
    accentWord="Evaluations"
    badge="Comprehensive ADHD Testing"
    subtitle="ADHD evaluations for children, teens, and adults in Lexington and across Kentucky — designed for nuanced diagnosis, clear recommendations, and actionable next steps."
    size="lg"
  />

  <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">
    <div class="lg:col-span-2 space-y-12">
      <AnimatedSection client:visible animation="fadeInUp" delay={100}>
      <section
        class="bg-surface-soft backdrop-blur-md border border-border p-10 rounded-[2.5rem]"
      >
        <h2 class="font-serif text-3xl font-black text-site-text mb-6 tracking-tight">
          Focus Redefined
        </h2>
        <div class="space-y-6 text-site-text leading-relaxed text-lg">
          <p>
            ADHD is more than just "hyperactivity" or "distractibility." It is a
            complex neurological difference in how the brain manages executive
            functions. Many individuals—especially adults—spend years feeling
            "lazy" or "unmotivated" when they are actually struggling with an
            undiagnosed neuro-type.
          </p>
          <p>
            We perform a comprehensive <span class="text-cta">evaluation</span>,
            clarifying executive functioning, cognitive strengths, and possible
            overlapping conditions rather than reducing the process to a quick
            checklist. Our goal is to provide clarity and actionable insight,
            not just answer a single yes-or-no question.
          </p>
        </div>
      </section>
      </AnimatedSection>

      <AnimatedSection client:visible animation="fadeInUp" delay={200}>
      <section>
        <h2
          class="font-serif text-2xl font-black text-site-text mb-10 text-center lg:text-left tracking-tight"
        >
          What We Measure
        </h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {
            adhdInsights.map((insight) => (
              <div class="group p-8 bg-surface-soft hover:bg-surface-2/50 border border-border hover:border-cta/30 rounded-3xl transition-all duration-300">
                <div class="w-10 h-10 rounded-xl bg-surface-2 flex items-center justify-center mb-6 border border-border group-hover:bg-cta group-hover:scale-110 transition-all">
                  <span class="text-cta group-hover:text-cta-fg">
                    ✦
                  </span>
                </div>
                <h3 class="font-serif text-site-text font-black mb-2">{insight.title}</h3>
                <p class="text-site-sub text-sm leading-relaxed">
                  {insight.detail}
                </p>
              </div>
            ))
          }
        </div>
      </section>
      </AnimatedSection>

      <AnimatedSection client:visible animation="fadeInUp" delay={300}>
      <section
        class="bg-surface-soft border border-border-strong p-10 rounded-[2.5rem]"
      >
        <h2 class="font-serif text-2xl font-black text-site-text mb-6 tracking-tight">
          The Assessment Battery
        </h2>
        <p class="text-site-sub mb-8 leading-relaxed">
          We use a multi-informant approach to ensure accuracy. Depending on
          your needs, your evaluation may include:
        </p>
        <div class="space-y-4">
          {
            [
              "Standardized rating scales (Brown, Conners, etc.)",
              "Continuous Performance Tests (CPT) for objective data",
              "Cognitive assessment (IQ) to rule out learning differences",
              "In-depth developmental and clinical interviews",
            ].map((item) => (
              <div class="flex items-center gap-4 text-site-text font-medium">
                <div class="w-2 h-2 bg-cta rounded-full" />
                {item}
              </div>
            ))
          }
        </div>
      </section>
      </AnimatedSection>

      <AnimatedSection client:visible animation="fadeInUp" delay={400}>
      <section class="bg-surface-2 border border-border-strong p-10 rounded-[2.5rem]">
        <h2 class="font-serif text-2xl font-black text-site-text mb-6 tracking-tight">
          How insurance works for ADHD testing
        </h2>
        <div class="space-y-5 text-site-text leading-relaxed">
          <p>
            We do accept insurance for some ADHD testing referrals when the
            clinical question is more specific than
            <span class="font-bold">"Does this person have ADHD?"</span>
            and the evaluation is needed for treatment-focused diagnostic
            clarification that cannot be resolved through interview, rating
            scales, record review, or routine assessment alone.
          </p>
          <p>
            Insurance typically approves only a limited number of testing
            units, and those hours include record collection, collateral
            information, interviewing clients and parents, test administration,
            reviewing and integrating data, researching concerns, consulting
            with other providers, and documentation. When we bill insurance, we
            use the most clinically relevant ADHD measures within the hours
            approved. Self-pay is available when a referral needs a broader
            battery or more documentation than insurance allows. Medicaid
            clients cannot be charged beyond covered amounts, so Medicaid
            evaluations are limited to the hours approved by the plan.
          </p>
          <p>
            When the main need is school documentation, accommodations, or
            educational planning, we usually recommend a psychoeducational or
            other private specialty evaluation instead of trying to force the
            referral through insurance.
          </p>
        </div>
      </section>
      </AnimatedSection>
    </div>

    <aside class="space-y-8">
      <div class="bg-surface-soft border border-border p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-xl font-black text-site-text mb-6">Evaluation Details</h3>
        <div class="space-y-6">
          <div>
            <p
              class="text-xs font-black uppercase text-cta tracking-widest mb-1"
            >
              Duration
            </p>
            <p class="text-sand font-bold">2–4 hours of direct testing</p>
          </div>
          <div>
            <p
              class="text-xs font-black uppercase text-cta tracking-widest mb-1"
            >
              Timeline
            </p>
            <p class="text-sand font-bold">Self-pay reports often in 7 days</p>
          </div>
          <div>
            <p
              class="text-xs font-black uppercase text-cta tracking-widest mb-1"
            >
              Ages
            </p>
            <p class="text-sand font-bold">
              Children (6+), Teens, & Adults
            </p>
          </div>
        </div>
      </div>

      <div
        class="bg-surface-soft border border-border p-10 rounded-[2.5rem] text-center"
      >
        <h3 class="font-serif text-2xl font-black text-site-text mb-4 tracking-tight">
          Schedule a Consultation
        </h3>
        <p class="text-site-sub text-sm mb-8 leading-relaxed">
          Begin with a clinician who understands ADHD across the lifespan and can map the right pathway before testing begins.
        </p>
        <a
          href={`tel:${PHONE_NUMBER}`}
          class="block w-full py-4 bg-sand text-cta-fg text-center font-black rounded-xl hover:bg-cta hover:scale-105 transition-all duration-300 shadow-lg shadow-sand/10"
        >
          Contact Our Office
        </a>
        <p
          class="mt-6 text-xs font-black text-site-sub uppercase tracking-widest"
        >
          Self-pay evaluation availability: Currently 3 Weeks
        </p>
      </div>

      <div class="bg-surface-soft border border-border p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-lg font-black text-site-text mb-4">From Our Blog</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href="/blog/clinical/adhd-testing-lexington-ky" class="text-cta hover:underline font-semibold">ADHD Testing in Lexington, KY — Children and Adults</a>
            <p class="text-site-sub text-xs mt-0.5">What to expect from a comprehensive ADHD evaluation, from intake through the feedback session.</p>
          </li>
          <li>
            <a href="/blog/clinical/child-psychological-evaluations-lexington-ky" class="text-cta hover:underline font-semibold">Child Psychological Evaluations in Kentucky</a>
            <p class="text-site-sub text-xs mt-0.5">What families should know about a comprehensive evaluation process for children.</p>
          </li>
        </ul>
      </div>

    </aside>
  </div>

  <div class="max-w-4xl mx-auto px-6 mt-8 mb-2">
    <div class="bg-surface border border-border rounded-2xl p-5 flex items-center justify-between gap-4 flex-wrap">
      <div>
        <p class="text-site-sub text-sm">Curious whether you might be masking?</p>
        <p class="text-xs text-site-sub opacity-70">Many adults with ADHD mask without realising it.</p>
      </div>
      <a href="/resources/masking-inventory" class="text-cta font-semibold text-sm hover:underline whitespace-nowrap">
        Take our free 3-min Masking Inventory →
      </a>
    </div>
  </div>

  <nav class="max-w-4xl mx-auto px-6 mt-4 mb-4">
    <a href="/services" class="inline-flex items-center gap-2 text-sm font-bold text-cta hover:text-cta/80 transition-colors">
      <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
      View All Services
    </a>
  </nav>
      </div>
    </div>
</Layout>

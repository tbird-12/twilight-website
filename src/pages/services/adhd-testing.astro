---
import ServiceLayout from "../../layouts/ServiceLayout.astro";
import "../../styles/global.css";
import { PHONE_NUMBER } from "../../data/resource";

const adhdInsights = [
  {
    title: "Executive Functioning",
    detail:
      "Analyzing working memory, task initiation, and emotional regulation beyond just 'attention'.",
  },
  {
    title: "Differential Diagnosis",
    detail:
      "Carefully distinguishing ADHD from anxiety, PTSD, or sensory processing differences.",
  },
  {
    title: "Adult & Late Diagnosis",
    detail:
      "Specialized focus on high-masking adults who have navigated life without support.",
  },
  {
    title: "Holistic Recommendations",
    detail:
      "Detailed roadmaps for workplace accommodations, therapy, and medication management.",
  },
];
---

<ServiceLayout
  name="ADHD Testing | Twilight Psychology"
  description="Comprehensive ADHD assessments and diagnostics for children, teens, and adults"
  metaDescription="Professional ADHD testing and assessment services in Kentucky for children, teens, and adults. Comprehensive evaluations using evidence-based testing protocols. Telehealth available."
>
  <section class="relative py-24 px-4 text-center border-b border-border overflow-hidden">
    <div class="max-w-4xl mx-auto relative z-10">
      <span
        class="px-4 py-1.5 mb-6 text-[10px] font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full"
      >
        Comprehensive ADHD Testing
      </span>
      <h1
        class="font-serif text-5xl md:text-7xl font-black text-site-text mb-6 tracking-tight"
      >
        ADHD <span class="text-cta">Evaluations</span>
      </h1>
      <p
        class="text-xl text-site-sub font-medium max-w-2xl mx-auto leading-relaxed"
      >
        Evidence-based testing for children and adults in Lexington and across Kentucky.
      </p>
    </div>
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(circle_at_center,var(--tw-gradient-stops))] from-surface-2/60 via-transparent to-transparent z-0"
    >
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">
    <div class="lg:col-span-2 space-y-12">
      <section
        class="bg-surface-soft backdrop-blur-md border border-border p-10 rounded-[2.5rem]"
      >
        <h2 class="font-serif text-3xl font-black text-site-text mb-6 tracking-tight">
          Focus Redefined
        </h2>
        <div class="space-y-6 text-site-text leading-relaxed text-lg">
          <p>
            ADHD is more than just "hyperactivity" or "distractibility." It is a
            complex neurological difference in how the brain manages executive
            functions. Many individuals—especially adults—spend years feeling
            "lazy" or "unmotivated" when they are actually struggling with an
            undiagnosed neuro-type.
          </p>
          <p>
            We always perform a comprehensive <span class="text-cta"
              >evaluation</span
            >, identifying your unique cognitive strengths and to rule out other
            learning disabilities. Our goal is to provide clarity and actionable insights,
            not just evaluate for ADHD.
          </p>
        </div>
      </section>

      <section>
        <h2
          class="font-serif text-2xl font-black text-site-text mb-10 text-center lg:text-left tracking-tight"
        >
          What We Measure
        </h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {
            adhdInsights.map((insight) => (
              <div class="group p-8 bg-surface-soft hover:bg-surface-2/50 border border-border hover:border-cta/30 rounded-3xl transition-all duration-300">
                <div class="w-10 h-10 rounded-xl bg-surface-2 flex items-center justify-center mb-6 border border-border group-hover:bg-cta group-hover:scale-110 transition-all">
                  <span class="text-cta group-hover:text-cta-fg">
                    ✦
                  </span>
                </div>
                <h3 class="font-serif text-site-text font-black mb-2">{insight.title}</h3>
                <p class="text-site-sub/75 text-sm leading-relaxed">
                  {insight.detail}
                </p>
              </div>
            ))
          }
        </div>
      </section>

      <section
        class="bg-surface-soft border border-border-strong p-10 rounded-[2.5rem]"
      >
        <h2 class="font-serif text-2xl font-black text-site-text mb-6 tracking-tight">
          The Assessment Battery
        </h2>
        <p class="text-site-sub mb-8 leading-relaxed">
          We use a multi-informant approach to ensure accuracy. Depending on
          your needs, your evaluation may include:
        </p>
        <div class="space-y-4">
          {
            [
              "Standardized rating scales (Brown, Conners, etc.)",
              "Continuous Performance Tests (CPT) for objective data",
              "Cognitive assessment (IQ) to rule out learning differences",
              "In-depth developmental and clinical interviews",
            ].map((item) => (
              <div class="flex items-center gap-4 text-site-text font-medium">
                <div class="w-2 h-2 bg-cta rounded-full" />
                {item}
              </div>
            ))
          }
        </div>
      </section>
    </div>

    <aside class="space-y-8">
      <div class="bg-surface-soft border border-border p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-xl font-black text-site-text mb-6">Evaluation Details</h3>
        <div class="space-y-6">
          <div>
            <p
              class="text-[10px] font-black uppercase text-cta tracking-widest mb-1"
            >
              Duration
            </p>
            <p class="text-sand font-bold">2–4 hours of direct testing</p>
          </div>
          <div>
            <p
              class="text-[10px] font-black uppercase text-cta tracking-widest mb-1"
            >
              Timeline
            </p>
            <p class="text-sand font-bold">Feedback within 2–4 weeks</p>
          </div>
          <div>
            <p
              class="text-[10px] font-black uppercase text-cta tracking-widest mb-1"
            >
              Ages
            </p>
            <p class="text-sand font-bold">
              Children (6+), Teens, & Adults
            </p>
          </div>
        </div>
      </div>

      <div
        class="bg-surface-soft border border-border p-10 rounded-[2.5rem] text-center"
      >
        <h3 class="font-serif text-2xl font-black text-site-text mb-4 tracking-tight">
          Schedule a Consultation
        </h3>
        <p class="text-site-sub/80 text-sm mb-8 leading-relaxed">
          Begin the evaluation process with a clinician who understands the nuances of ADHD across the lifespan.
        </p>
        <a
          href={`tel:${PHONE_NUMBER}`}
          class="block w-full py-4 bg-sand text-cta-fg text-center font-black rounded-xl hover:bg-cta hover:scale-105 transition-all duration-300 shadow-lg shadow-sand/10"
        >
          Contact Our Office
        </a>
        <p
          class="mt-6 text-[10px] font-black text-site-sub/80 uppercase tracking-widest"
        >
          Self-pay availability: Currently 2-4 Weeks
        </p>
      </div>


    </aside>
  </div>

  <nav class="max-w-4xl mx-auto px-6 mt-12 mb-4">
    <a href="/services" class="inline-flex items-center gap-2 text-sm font-bold text-cta hover:text-cta/80 transition-colors">
      <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
      View All Services
    </a>
  </nav>
</ServiceLayout>

---
import Layout from "../../layouts/Layout.astro";
import { services } from "../../data/services";
import { PHONE_NUMBER, PHONE_NUMBER_FORMATTED } from "../../data/resource";
import PageHeroWrapper from "../../components/PageHeroWrapper.astro";
import ServiceCardGrid from "../../components/preact/composites/ServiceCardGrid";
import AnimatedSection from "../../components/preact/primitives/AnimatedSection";
---

<Layout
  title="Our Services | Twilight Psychology"
  description="Psychological evaluations, ADHD and autism testing, neuro-affirming therapy, medication management, and personality testing at Twilight Psychology."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <PageHeroWrapper
    title="Our Services"
    accentWord="Services"
    subtitle="We provide comprehensive psychological services tailored to your unique needs and often meet the definition of medical necessity. From diagnostic evaluations to ongoing therapy, our neuro-affirming team is here to support you."
    size="lg"
  />

  <section class="max-w-5xl mx-auto px-4 mt-16 mb-10">
    <ServiceCardGrid
      client:visible
      items={services.map((s) => ({ name: s.name, slug: s.slug, description: s.desc }))}
      basePath="/services"
    />
  </section>

  <section class="max-w-4xl mx-auto px-4 mt-12 mb-10">
    <AnimatedSection client:visible animation="fadeInUp" delay={200}>
      <div class="bg-surface-2 border p-8 md:p-12 rounded-[2.5rem]" style="border-color: var(--color-border-strong)">
        <h2 class="font-serif text-3xl font-black text-site-text mb-4">
          Not sure which service is right for you?
        </h2>
        <p class="text-site-text leading-relaxed font-medium mb-6">
          Our team can help you determine the best path forward. Whether you need a comprehensive
          evaluation, therapy, or medication support, we&apos;ll work together to find the right fit.
        </p>
        <div class="flex flex-wrap gap-4 items-center">
          <a
            href="/contact"
            class="inline-block bg-cta text-cta-fg px-6 py-3 rounded-full font-black text-sm hover:bg-cta/80 hover:ring-4 hover:ring-cta/30 transition-all shadow-lg shadow-cta/20 active:scale-95"
          >
            Contact Us
          </a>
          <a
            href={`tel:${PHONE_NUMBER}`}
            class="inline-block text-cta font-black text-sm hover:text-site-text transition-colors"
          >
            &#128222; {PHONE_NUMBER_FORMATTED}
          </a>
        </div>
      </div>
    </AnimatedSection>
  </section>
      </div>
    </div>
  </div>
</Layout>

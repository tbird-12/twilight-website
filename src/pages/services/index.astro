---
import Layout from "../../layouts/Layout.astro";
import { services } from "../../data/services";
import { PHONE_NUMBER, PHONE_NUMBER_FORMATTED } from "../../data/resource";
import PageHeroWrapper from "../../components/PageHeroWrapper.astro";
import ServiceCardGrid from "../../components/react/composites/ServiceCardGrid";
import AnimatedSection from "../../components/react/primitives/AnimatedSection";
---

<Layout
  title="Psychological Services in Kentucky"
  description="Compare evaluations, neuro-affirming therapy for ages 3-99, and medication management in Kentucky, with telehealth and insurance-supported care."
>
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <PageHeroWrapper
    title="Our Services"
    accentWord="Services"
    subtitle="Psychological services tailored to your goals — evaluations, neuro-affirming therapy, and psychiatric medication management, including specialty pathways for psychoeducational and nuanced autism referrals."
    badge="Insurance & Medicaid Accepted"
    size="lg"
  />

  <section class="max-w-5xl mx-auto px-4 mt-16 mb-10">
    <ServiceCardGrid
      client:visible
      items={services.map((s) => ({ name: s.name, slug: s.slug, description: s.desc }))}
      basePath="/services"
    />
  </section>

  <section class="max-w-4xl mx-auto px-4 mt-10">
    <div class="rounded-[2.5rem] border border-border bg-surface-soft p-8 md:p-10">
      <h2 class="font-serif text-3xl font-black text-site-text mb-4">
        Start with the service format that matches your goal
      </h2>
      <p class="text-site-text leading-relaxed font-medium">
        Use this page when you already know you need an evaluation, ongoing therapy, or medication support.
        Twilight now offers neuro-affirming therapy across ages 3-99, so child, teen, and adult clients
        can start in the same practice.
        For evaluations, the best path often depends on the referral question, whether insurance will authorize enough
        testing hours, how much documentation is needed, and whether the referral calls for specialty depth in areas like
        psychoeducational testing or high-masking autism assessment.
        If you are looking for school-based, legal, or documentation-specific assessments such as IEEs,
        guardianship, adoption, or ESA evaluations, explore our{" "}
        <a href="/specialties" class="text-cta hover:underline">specialty evaluations</a>.
      </p>
      <div class="flex flex-wrap gap-2 mt-6">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold bg-surface-2 border border-border rounded-full text-site-text">
          <span class="text-cta">✓</span> Medicaid
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold bg-surface-2 border border-border rounded-full text-site-text">
          <span class="text-cta">✓</span> Medicare
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold bg-surface-2 border border-border rounded-full text-site-text">
          <span class="text-cta">✓</span> Commercial Insurance
        </span>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 mt-12 mb-10">
    <AnimatedSection client:visible animation="fadeInUp" delay={200}>
      <div class="bg-surface-2 border p-8 md:p-12 rounded-[2.5rem]" style="border-color: var(--color-border-strong)">
        <h2 class="font-serif text-3xl font-black text-site-text mb-4">
          Not sure which service is right for you?
        </h2>
        <p class="text-site-text leading-relaxed font-medium mb-6">
          Our team can help you determine the best path forward. Evaluation referrals often start with a
          conversation about whether insurance-approved testing hours are enough for the question being asked
          or whether self-pay is a better fit for broader testing or documentation.
          Some clients also come to Twilight specifically because they need specialty psychoeducational work or an
          autism evaluation that can account for masking and PDA traits.
          Therapy and medication support are where our insurance participation is broadest, including therapy
          options for neurodivergent clients ages 3-99.
        </p>
        <div class="flex flex-wrap gap-4 items-center">
          <a
            href="/contact"
            class="inline-block bg-cta text-cta-fg px-6 py-3 rounded-full font-black text-sm hover:bg-cta/80 hover:ring-4 hover:ring-cta/30 transition-all shadow-lg shadow-cta/20 active:scale-95"
          >
            Contact Us
          </a>
          <a
            href={`tel:${PHONE_NUMBER}`}
            class="inline-block text-cta font-black text-sm hover:text-site-text transition-colors"
          >
            &#128222; {PHONE_NUMBER_FORMATTED}
          </a>
        </div>
      </div>
    </AnimatedSection>
  </section>
      </div>
    </div>
</Layout>

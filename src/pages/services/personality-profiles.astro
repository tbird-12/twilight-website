---
import Layout from "../../layouts/Layout.astro";
import { WIDGET_LINK } from "../../data/resource";
import PageHeroWrapper from "../../components/PageHeroWrapper.astro";
import AnimatedSection from "../../components/react/primitives/AnimatedSection";

const diagnosticAreas = [
	{
		title: "Bipolar Spectrum Clarification",
		detail:
			"Differentiating Bipolar I, Bipolar II, cyclothymic patterns, and mood instability from trauma- or personality-related shifts.",
	},
	{
		title: "Borderline Personality Features",
		detail:
			"Assessing emotion regulation, attachment distress, identity disruption, and interpersonal sensitivity with a trauma-informed lens.",
	},
	{
		title: "Schizophrenia-Spectrum Screening",
		detail:
			"Clarifying psychosis-spectrum symptoms while ruling out medical, developmental, substance, and trauma-related contributors.",
	},
	{
		title: "Cluster A Profiles",
		detail:
			"Evaluating suspiciousness, social detachment, and eccentric cognitive styles associated with paranoid, schizoid, and schizotypal patterns.",
	},
	{
		title: "Cluster B Profiles",
		detail:
			"Characterizing emotional intensity, impulsivity, and relationship instability across borderline, narcissistic, antisocial, and histrionic patterns.",
	},
	{
		title: "Cluster C Profiles",
		detail:
			"Assessing chronic anxiety-based personality organization, including avoidant, dependent, and obsessive-compulsive personality styles.",
	},
	{
		title: "C-PTSD and Personality Overlap",
		detail:
			"Identifying when prolonged trauma drives symptoms that may resemble personality pathology, so treatment can target the true source.",
	},
];

const processSteps = [
	"Comprehensive clinical interview and symptom history",
	"Structured measures for personality, trauma, mood, and psychosis",
	"Differential diagnosis to separate overlapping conditions",
	"Written report with treatment recommendations and referrals",
];
---

<Layout
  title="Personality Disorder Evaluations KY | Twilight Psychology"
  description="Personality disorder evaluations in Kentucky. Assessments for bipolar, borderline, schizophrenia-spectrum, and complex trauma overlap profiles."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
	<PageHeroWrapper
		title="Personality Evaluations"
		accentWord="Evaluations"
		badge="Advanced Diagnostic Services"
		subtitle="When symptoms are complex or long-standing, we provide a structured evaluation to identify potential underlying personality and trauma patterns."
		size="lg"
	/>

	<div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">
		<div class="lg:col-span-2 space-y-12">
			<AnimatedSection client:visible animation="fadeInUp" delay={100}>
			<section class="bg-surface-soft backdrop-blur-md border border-border p-10 rounded-[2.5rem]">
				<h2 class="font-serif text-3xl font-black text-site-text mb-6 tracking-tight">
					Diagnostic Depth, Not Labels Alone
				</h2>
				<div class="space-y-6 text-site-text leading-relaxed text-lg">
					<p>
						Personality and trauma presentations can look similar on the surface.
						Our clinicians use evidence-based assessment to sort out overlap,
						reduce misdiagnosis risk, and build a practical treatment roadmap.
					</p>
					<p>
						We routinely evaluate for bipolar and borderline presentations,
						schizophrenia-spectrum concerns, cluster A/B/C patterns, and
						<strong> C-PTSD-related complexity</strong>.
					</p>
					<p class="text-site-sub">
						Need care after results? We can connect your recommendations to
						<a href="/services/therapy" class="text-cta font-black hover:underline"> therapy</a>,
						refer to <a href="/services/autism-testing" class="text-cta font-black hover:underline"> autism testing</a>
						when neurodevelopmental overlap is suspected, and align treatment goals with services in our
						<a href="/catalog" class="text-cta font-black hover:underline"> full catalog</a>.
					</p>
				</div>
			</section>
			</AnimatedSection>

			<AnimatedSection client:visible animation="fadeInUp" delay={200}>
			<section>
				<h2 class="font-serif text-2xl font-black text-site-text mb-10 tracking-tight">
					Areas We Evaluate
				</h2>
				<div class="grid sm:grid-cols-2 gap-6">
					{
						diagnosticAreas.map((item) => (
							<div class="group p-8 bg-surface-soft hover:bg-surface-2/50 border border-border hover:border-cta/30 rounded-3xl transition-all duration-300 block">
								<div class="w-10 h-10 rounded-xl bg-cta sm:bg-surface-2 flex items-center justify-center mb-6 border border-border sm:group-hover:bg-cta transition-all">
									<span class="text-cta-fg sm:text-cta sm:group-hover:text-cta-fg text-xl">
										✦
									</span>
								</div>
								<h3 class="font-serif text-site-text font-black mb-3">{item.title}</h3>
								<p class="text-site-sub text-sm leading-relaxed">{item.detail}</p>
							</div>
						))
					}
				</div>
			</section>
			</AnimatedSection>
		</div>

		<aside class="space-y-8">
			<div class="bg-surface-soft border border-border p-8 rounded-[2.5rem]">
				<h3 class="font-serif text-xl font-black text-site-text mb-6">Evaluation Process</h3>
				<ul class="space-y-3 text-sm text-site-sub leading-relaxed">
					{
						processSteps.map((step) => (
							<li class="flex items-start gap-3">
								<span class="mt-0.5 text-cta">•</span>
								<span>{step}</span>
							</li>
						))
					}
				</ul>
			</div>

			<div class="bg-surface-soft border border-border p-8 rounded-[2.5rem]">
				<h3 class="font-serif text-xl font-black text-site-text mb-6">Related Services</h3>
				<nav class="space-y-4">
					<a
						href="/services/therapy"
						class="flex items-center justify-between p-4 bg-surface-soft rounded-2xl hover:bg-surface-2/30 transition-colors text-site-text text-sm font-bold"
					>
						Therapy <span class="text-cta">→</span>
					</a>
					<a
						href="/services/autism-testing"
						class="flex items-center justify-between p-4 bg-surface-soft rounded-2xl hover:bg-surface-2/30 transition-colors text-site-text text-sm font-bold"
					>
						Autism Testing <span class="text-cta">→</span>
					</a>
					<a
						href="/catalog"
						class="flex items-center justify-between p-4 bg-surface-soft rounded-2xl hover:bg-surface-2/30 transition-colors text-site-text text-sm font-bold"
					>
						Full Service Catalog <span class="text-cta">→</span>
					</a>
				</nav>
			</div>

			<div class="bg-surface-soft border border-border p-10 rounded-[2.5rem] text-center">
				<h3 class="font-serif text-2xl font-black text-site-text mb-4">Need Diagnostic Clarity?</h3>
				<p class="text-site-sub text-sm mb-8 leading-relaxed">
					Start with an intake to determine whether a personality or trauma-focused evaluation is right for you.
				</p>
				<a
					href={WIDGET_LINK}
					class="block w-full py-4 bg-sand text-cta-fg font-black rounded-xl hover:bg-cta hover:scale-105 transition-all duration-300 shadow-lg shadow-sand/10"
				>
					Request Evaluation
				</a>
			</div>
		</aside>
	</div>

	<section class="max-w-7xl mx-auto px-4 mt-32 mb-12">
		<div class="p-10 bg-linear-to-r from-cta/10 to-cta/10 border border-cta/20 rounded-[3rem] text-center">
			<h2 class="font-serif text-3xl font-black text-site-text mb-4">
				Looking for Trauma-Focused Support Too?
			</h2>
			<p class="text-site-sub mb-8 max-w-2xl mx-auto">
				Complex trauma can influence personality expression. We help translate
				findings into a treatment plan that connects evaluation, therapy, and
				coordinated ongoing care.
			</p>
			<div class="flex flex-wrap justify-center gap-4">
				<a
					href="/services/therapy"
					class="inline-block px-8 py-3 bg-cta text-cta-fg font-black rounded-full hover:bg-cta/80 transition-all"
				>
					Explore Therapy
				</a>
				<a
					href="/catalog"
					class="inline-block px-8 py-3 bg-surface-soft border border-border text-site-text font-black rounded-full hover:bg-surface-2/50 transition-all"
				>
					Browse Catalog
				</a>
			</div>
		</div>
	</section>

	<nav class="max-w-4xl mx-auto px-6 mt-12 mb-4">
		<a href="/services" class="inline-flex items-center gap-2 text-sm font-bold text-cta hover:text-cta/80 transition-colors">
			<svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
			View All Services
		</a>
	</nav>

---
import ServiceLayout from "../../../layouts/ServiceLayout.astro";
import "../../../styles/global.css";
import { WIDGET_LINK } from "../../../data/resource";
---

<ServiceLayout
  name="Neuro-Affirming Therapy | Twilight Psychology"
  description="Neuro-affirming therapy focused on identity, self-understanding, and reducing masking pressure."
>
  <section class="max-w-5xl mx-auto px-4 pt-20">
    <a href="/services/therapy" class="text-xs font-black uppercase tracking-[0.2em] text-cta hover:underline">
      Back to Therapy
    </a>
    <h1 class="mt-4 font-serif text-4xl md:text-6xl font-black text-site-text">Neuro-Affirming Therapy</h1>
    <p class="mt-6 text-lg text-site-sub leading-relaxed max-w-3xl">
      This track supports people who are exploring who they are beyond masking. Sessions focus on understanding
      your neurotype, identifying internalized stigma, and building a life that aligns with your values.
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-4 mt-12 grid gap-6 md:grid-cols-2">
    <div class="rounded-3xl border theme-border p-8 theme-surface-soft">
      <h2 class="font-serif text-2xl font-black text-site-text mb-4">What We Work On</h2>
      <ul class="space-y-3 text-site-sub">
        <li>Understanding identity after late diagnosis</li>
        <li>Reducing burnout caused by constant masking</li>
        <li>Building sustainable boundaries in work and relationships</li>
      </ul>
    </div>
    <div class="rounded-3xl border theme-border p-8 theme-surface-soft">
      <h2 class="font-serif text-2xl font-black text-site-text mb-4">Who This Helps</h2>
      <p class="text-site-sub leading-relaxed">
        Adults and older teens who want affirming support around identity formation, self-trust, and self-advocacy.
      </p>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 mt-14 mb-10">
    <div class="rounded-4xl border theme-border p-10 text-center theme-surface-soft">
      <h2 class="font-serif text-3xl font-black text-site-text mb-4">Ready to Begin?</h2>
      <p class="text-site-sub mb-8">Schedule an intake and let us match you with the right therapist.</p>
      <a href={WIDGET_LINK} class="inline-block px-8 py-3 bg-cta text-cta-fg font-black rounded-full hover:bg-cta/80 transition-all">
        Schedule Intake
      </a>
    </div>
  </section>
</ServiceLayout>

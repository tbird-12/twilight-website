---
import Layout from "../../layouts/Layout.astro";
import { WIDGET_LINK } from "../../data/resource";
import PageHeroWrapper from "../../components/PageHeroWrapper.astro";
import AnimatedSection from "../../components/preact/primitives/AnimatedSection";

const medicationApproach = [
  {
    title: "Collaborative Choice",
    detail:"We discuss the risks and benefits openly. You are the expert on your body; we are the experts on the medicine."
  },
  {
    title: "Symptom Tracking",
    detail:"Regular follow-ups to monitor effectiveness and adjust dosages to minimize side effects."
  },
  {
    title: "Holistic Integration",
    detail:
      "Coordinating care with your therapist and testing psychologist for a 360-degree view of your health."
  },
  {
    title: "GeneSight® Testing",
    detail:
      "Optional pharmacogenomic testing to see how your DNA may affect your response to certain medications."
  },
];
---

<Layout
  title="Medication Management in KY | Twilight Psychology"
  description="Psychiatric medication management in Kentucky. Board-certified nurse practitioner for ADHD, anxiety, depression, and more. Telehealth available."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <PageHeroWrapper
    title="Medication Management"
    accentWord="Management"
    badge="Psychiatric Care"
    subtitle="Thoughtful, measured, and supportive psychiatric care led by our specialized Nurse Practitioner."
    size="lg"
  />

  <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">
    <div class="lg:col-span-2 space-y-12">
      <AnimatedSection client:visible animation="fadeInUp" delay={100}>
      <section
        class="bg-surface-soft backdrop-blur-md border border-border p-10 rounded-[2.5rem]"
      >
        <h2 class="font-serif text-3xl font-black text-site-text mb-6 tracking-tight">
          A Balanced Approach
        </h2>
        <div class="space-y-6 text-site-text leading-relaxed text-lg">
          <p>
            Medication can be a powerful tool in managing symptoms of ADHD,
            anxiety, depression, and other neurological differences. However, it
            is never a "one-size-fits-all" solution.
          </p>
          <p>
            Our <span class="text-cta"
              >Psychiatric Nurse Practitioner</span
            > works closely with you to find the right balance, ensuring that any
            treatment plan respects your lifestyle, your values, and your long-term
            wellness goals.
          </p>
        </div>
      </section>
      </AnimatedSection>

      <AnimatedSection client:visible animation="fadeInUp" delay={200}>
      <section>
        <h2 class="font-serif text-2xl font-black text-site-text mb-10 tracking-tight">
          Our Clinical Framework
        </h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {
            medicationApproach.map((item) => (
                <div class="group p-8 bg-surface-soft hover:bg-surface-2/50 border border-border hover:border-cta/30 rounded-3xl transition-all duration-300">
                <div class="text-4xl font-black text-site-text/10 mb-4 group-hover:text-cta/20 transition-colors">✦</div>
                <h3 class="font-serif text-site-text font-black mb-2">{item.title}</h3>
                <p class="text-site-sub text-sm leading-relaxed">{item.detail}</p>
              </div>
            ))
          }
        </div>
      </section>
      </AnimatedSection>

      <AnimatedSection client:visible animation="fadeInUp" delay={300}>
      <section
        class="bg-surface-soft border border-border-strong p-10 rounded-[2.5rem]"
      >
        <h2 class="font-serif text-2xl font-black text-site-text mb-6 tracking-tight">
          Your First Appointment
        </h2>
        <p class="text-site-sub mb-8 leading-relaxed">
          To provide the safest care, please ensure you have the following ready
          for your intake:
        </p>
        <div class="grid md:grid-cols-2 gap-4">
          {
            [
              "Previous psychiatric records",
              "A list of all current supplements",
              "Recent blood work (if available)",
              "Your pharmacy contact information",
            ].map((item) => (
              <div class="flex items-center gap-3 text-site-text text-sm font-bold">
                <div class="w-1.5 h-1.5 bg-cta rounded-full" />
                {item}
              </div>
            ))
          }
        </div>
      </section>
      </AnimatedSection>
    </div>

    <aside class="space-y-8">
      <div class="bg-surface-soft border border-border p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-xl font-black text-site-text mb-4">Meet the Provider</h3>
        <div class="space-y-4">
          <p class="text-site-sub text-sm leading-relaxed">
            Our medication management is led by experienced psychiatric
            professionals specializing in neuro-affirming care.
          </p>
          <a
            href="/about/clinicians/nicola-allen"
            class="text-cta font-black text-xs uppercase tracking-widest hover:text-site-text transition-colors"
          >
            View Provider Profile →
          </a>
        </div>
      </div>

      <div
        class="bg-surface-soft border border-border p-10 rounded-[2.5rem] text-center"
      >
        <h3 class="font-serif text-2xl font-black text-site-text mb-4">Take the Next Step</h3>
        <p class="text-site-sub text-sm mb-8 leading-relaxed">
          Book a psychiatric intake session to discuss your options.
        </p>
        <a
          href={WIDGET_LINK}
          class="block w-full py-4 bg-sand text-cta-fg font-black rounded-xl hover:bg-cta hover:scale-105 transition-all duration-300 shadow-lg shadow-sand/10"
        >
          Request Intake
        </a>
      </div>

      <div class="p-8 bg-cta rounded-[2.5rem] text-cta-fg">
        <h4 class="font-serif font-black uppercase inverted-text text-xs tracking-widest mb-2">
          Insurance Covered
        </h4>
        <p class="text-sm inverted-text font-bold leading-tight">
          Medication management is covered by KY Medicaid, Medicare, and most major
          insurance providers.
        </p>
      </div>

      <div class="bg-surface-soft border border-border p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-lg font-black text-site-text mb-4">From Our Blog</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href="/blog/announcements/wellcare-kentucky-in-network" class="text-cta hover:underline font-semibold">Now In-Network with Wellcare of Kentucky</a>
            <p class="text-site-sub text-xs mt-0.5">Therapy and medication management now available under Wellcare.</p>
          </li>
          <li>
            <a href="/blog/insurance/understanding-health-insurance" class="text-cta hover:underline font-semibold">Understanding Health Insurance</a>
            <p class="text-site-sub text-xs mt-0.5">Deductibles, copays, and coverage types explained.</p>
          </li>
          <li>
            <a href="/blog/billing/understanding-your-eob" class="text-cta hover:underline font-semibold">Understanding Your EOB</a>
            <p class="text-site-sub text-xs mt-0.5">How to read your insurance explanation of benefits.</p>
          </li>
        </ul>
      </div>
    </aside>
  </div>

  <section class="max-w-7xl mx-auto px-4 mt-32">
    <div
      class="p-12 bg-surface-soft border border-border rounded-[3rem] flex flex-col md:flex-row items-center justify-between gap-8"
    >
      <div class="max-w-md">
        <h2 class="font-serif text-3xl font-black text-site-text mb-4 italic">
          Complete Support.
        </h2>
        <p class="text-site-sub">
          We frequently recommend an integrated approach combining therapy and medication for
          optimal clinical outcomes.
        </p>
      </div>
      <div class="flex flex-wrap gap-4">
        <a
          href="/services/therapy"
          class="px-6 py-3 bg-surface-soft border border-border text-site-text font-black rounded-xl hover:bg-surface-2/50 transition-all"
          >Individual Therapy</a
        >
        <a
          href="/services/psychological-evaluations"
          class="px-6 py-3 bg-surface-soft border border-border text-site-text font-black rounded-xl hover:bg-surface-2/50 transition-all"
          >Testing & Diagnosis</a
        >
      </div>
    </div>
  </section>

  <nav class="max-w-4xl mx-auto px-6 mt-12 mb-4">
    <a href="/services" class="inline-flex items-center gap-2 text-sm font-bold text-cta hover:text-cta/80 transition-colors">
      <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
      View All Services
    </a>
  </nav>
      </div>
    </div>
  </div>
</Layout>

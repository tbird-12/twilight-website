---
import ServiceLayout from "../../layouts/ServiceLayout.astro";
import "../../styles/global.css";
import { WIDGET_LINK } from "../../data/resource";

const medicationApproach = [
  {
    title: "Collaborative Choice",
    detail:"We discuss the risks and benefits openly. You are the expert on your body; we are the experts on the medicine."
  },
  {
    title: "Symptom Tracking",
    detail:"Regular follow-ups to monitor effectiveness and adjust dosages to minimize side effects."
  },
  {
    title: "Holistic Integration",
    detail:
      "Coordinating care with your therapist and testing psychologist for a 360-degree view of your health."
  },
  {
    title: "GeneSight® Testing",
    detail:
      "Optional pharmacogenomic testing to see how your DNA may affect your response to certain medications."
  },
];
---

<ServiceLayout 
name="Medication Management in KY | Twilight Psychology"
description="Comprehensive medication management services at Twilight Psychology"
metaDescription="Expert psychiatric medication management in Kentucky. Board-certified psychiatric nurse practitioner providing comprehensive medication services for ADHD, anxiety, depression, and more. Telehealth available.">
  <section class="relative py-24 px-4 text-center border-b border-white/5 overflow-hidden">
    <div class="max-w-4xl mx-auto relative z-10">
      <span
        class="px-4 py-1.5 mb-6 text-[10px] font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full"
      >
        Psychiatric Care
      </span>
      <h1
        class="font-serif text-5xl md:text-7xl font-black text-site-text mb-6 tracking-tight"
      >
        Medication <span
          class="text-cta"
          >Management</span
        >
      </h1>
      <p
        class="text-xl text-site-sub font-medium max-w-2xl mx-auto leading-relaxed"
      >
        Thoughtful, measured, and supportive psychiatric care led by our
        specialized Nurse Practitioner.
      </p>
    </div>
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(circle_at_center,var(--tw-gradient-stops))] from-slate-800/40 via-transparent to-transparent z-0"
    >
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12 mt-20">
    <div class="lg:col-span-2 space-y-12">
      <section
        class="bg-white/3 backdrop-blur-md border border-white/10 p-10 rounded-[2.5rem]"
      >
        <h2 class="font-serif text-3xl font-black text-site-text mb-6 tracking-tight">
          A Balanced Approach
        </h2>
        <div class="space-y-6 text-site-text leading-relaxed text-lg">
          <p>
            Medication can be a powerful tool in managing symptoms of ADHD,
            anxiety, depression, and other neurological differences. However, it
            is never a "one-size-fits-all" solution.
          </p>
          <p>
            Our <span class="text-cta"
              >Psychiatric Nurse Practitioner</span
            > works closely with you to find the right balance, ensuring that any
            treatment plan respects your lifestyle, your values, and your long-term
            wellness goals.
          </p>
        </div>
      </section>

      <section>
        <h2 class="font-serif text-2xl font-black text-site-text mb-10 tracking-tight">
          Our Clinical Framework
        </h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {
            medicationApproach.map((item) => (
                <div class="group p-8 bg-white/5 hover:bg-white/10 border border-white/5 hover:border-cta/30 rounded-3xl transition-all duration-300">
                <div class="text-4xl font-black text-site-text/10 mb-4 group-hover:text-cta/20 transition-colors">✦</div>
                <h3 class="font-serif text-site-text font-black mb-2">{item.title}</h3>
                <p class="text-site-sub/50 text-sm leading-relaxed">{item.detail}</p>
              </div>
            ))
          }
        </div>
      </section>

      <section
        class="bg-slate-800/20 border border-slate-700/50 p-10 rounded-[2.5rem]"
      >
        <h2 class="font-serif text-2xl font-black text-site-text mb-6 tracking-tight">
          Your First Appointment
        </h2>
        <p class="text-site-sub mb-8 leading-relaxed">
          To provide the safest care, please ensure you have the following ready
          for your intake:
        </p>
        <div class="grid md:grid-cols-2 gap-4">
          {
            [
              "Previous psychiatric records",
              "A list of all current supplements",
              "Recent blood work (if available)",
              "Your pharmacy contact information",
            ].map((item) => (
              <div class="flex items-center gap-3 text-site-text text-sm font-bold">
                <div class="w-1.5 h-1.5 bg-cta rounded-full" />
                {item}
              </div>
            ))
          }
        </div>
      </section>
    </div>

    <aside class="space-y-8">
      <div class="bg-white/5 border border-white/10 p-8 rounded-[2.5rem]">
        <h3 class="font-serif text-xl font-black text-site-text mb-4">Meet the Provider</h3>
        <div class="space-y-4">
          <p class="text-site-sub/60 text-sm leading-relaxed">
            Our medication management is led by experienced psychiatric
            professionals specializing in neuro-affirming care.
          </p>
          <a
            href="/about/clinicians/nicola-allen"
            class="text-cta font-black text-xs uppercase tracking-widest hover:text-site-text transition-colors"
          >
            View Provider Profile →
          </a>
        </div>
      </div>

      <div
        class="bg-white/5 border border-white/10 p-10 rounded-[2.5rem] text-center"
      >
        <h3 class="font-serif text-2xl font-black text-site-text mb-4">Take the Next Step</h3>
        <p class="text-site-sub/60 text-sm mb-8 leading-relaxed">
          Book a psychiatric intake session to discuss your options.
        </p>
        <a
          href={WIDGET_LINK}
          class="block w-full py-4 bg-sand text-cta-fg font-black rounded-xl hover:bg-white hover:scale-105 transition-all duration-300 shadow-lg shadow-sand/10"
        >
          Request Intake
        </a>
      </div>

      <div class="p-8 bg-cta rounded-[2.5rem] text-cta-fg">
        <h4 class="font-serif font-black uppercase text-xs tracking-widest mb-2">
          Insurance Covered
        </h4>
        <p class="text-sm font-bold leading-tight">
          Medication management is covered by KY Medicaid, Medicare, and most major
          insurance providers.
        </p>
      </div>
    </aside>
  </div>

  <section class="max-w-7xl mx-auto px-4 mt-32">
    <div
      class="p-12 bg-slate-800/20 border border-white/5 rounded-[3rem] flex flex-col md:flex-row items-center justify-between gap-8"
    >
      <div class="max-w-md">
        <h2 class="font-serif text-3xl font-black text-site-text mb-4 italic">
          Complete Support.
        </h2>
        <p class="text-site-sub/60">
          We frequently recommend an integrated approach combining therapy and medication for
          optimal clinical outcomes.
        </p>
      </div>
      <div class="flex flex-wrap gap-4">
        <a
          href="/services/therapy"
          class="px-6 py-3 bg-white/5 border border-white/10 text-site-text font-black rounded-xl hover:bg-white/10 transition-all"
          >Individual Therapy</a
        >
        <a
          href="/services/psychological-evaluations"
          class="px-6 py-3 bg-white/5 border border-white/10 text-site-text font-black rounded-xl hover:bg-white/10 transition-all"
          >Testing & Diagnosis</a
        >
      </div>
    </div>
  </section>
</ServiceLayout>

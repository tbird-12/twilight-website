    background: rgba(79, 70, 229, 0.06);
  }

  :root.light .care-tab.active {
    border-color: rgba(79, 70, 229, 0.25);
    border-left-color: var(--color-cta);
    background: rgba(79, 70, 229, 0.1);
  }

  :root.light .care-panels {
    border-color: rgba(79, 70, 229, 0.15);
    background: rgba(255, 255, 255, 0.75);
    box-shadow: inset 0 1px 0 rgba(79, 70, 229, 0.12);
  }

  :root.light .care-hint,
  :root.light .care-panel-eyebrow {
    color: rgba(91, 82, 148, 0.65);
  }

  @media (prefers-reduced-motion: reduce) {
    .homepage-shell::before,
    .homepage-panel-glow {
      animation: none;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tabs = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-care-tab]"),
    );
    const panels = Array.from(
      document.querySelectorAll<HTMLElement>("[data-care-panel]"),
    );
    const statValues = Array.from(
      document.querySelectorAll<HTMLElement>(".homepage-stat-value"),
    );
    const trustBar = document.querySelector<HTMLElement>(".homepage-trust-bar");
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const setActiveTab = (activeIndex: number) => {
      tabs.forEach((tab, index) => {
        const isActive = index === activeIndex;
        tab.classList.toggle("active", isActive);
        tab.setAttribute("aria-selected", isActive ? "true" : "false");
      });

      panels.forEach((panel, index) => {
        const isActive = index === activeIndex;
        panel.classList.toggle("active", isActive);
        panel.setAttribute("aria-hidden", isActive ? "false" : "true");
      });
    };

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const activeIndex = Number(tab.dataset.careTab);
        if (Number.isFinite(activeIndex)) {
          setActiveTab(activeIndex);
        }
      });
    });

    const statCounterMeta = statValues
      .map((element) => {
        const rawValue = element.textContent?.trim() ?? "";
        const target = Number(rawValue.replace(/[^\d]/g, ""));
        const suffix = rawValue.replace(/[\d,]/g, "");
        if (!Number.isFinite(target) || target <= 0) {
          return null;
        }
        return { element, target, suffix };
      })
      .filter(
        (
          entry,
        ): entry is { element: HTMLElement; target: number; suffix: string } =>
          Boolean(entry),
      );

    const animateStatValue = (
      element: HTMLElement,
      target: number,
      suffix: string,
    ) => {
      if (prefersReducedMotion) {
        element.textContent = `${target}${suffix}`;
        return;
      }

      const durationMs = 1300;
      const start = performance.now();

      const tick = (now: number) => {
        const progress = Math.min((now - start) / durationMs, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.floor(target * eased);

        element.textContent = `${current}${suffix}`;

        if (progress < 1) {
          requestAnimationFrame(tick);
        }
      };

      requestAnimationFrame(tick);
    };

    const runStatCounters = () => {
      statCounterMeta.forEach(({ element, target, suffix }) => {
        animateStatValue(element, target, suffix);
      });
    };

    if (
      trustBar &&
      statCounterMeta.length > 0 &&
      "IntersectionObserver" in window
    ) {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              runStatCounters();
              obs.disconnect();
            }
          });
        },
        { threshold: 0.35 },
      );

      observer.observe(trustBar);
    } else if (statCounterMeta.length > 0) {
      runStatCounters();
    }
  });
</script>

---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { Icon } from "astro-icon/components";
import { REFERRAL_LINK } from "../data/resource";
import heroBg from "../assets/hero-background.svg?raw";
import heroBgMobile from "../assets/hero-mobile.svg?raw";

const services = [
  {
    title: "Psychological Evaluations",
    desc: "Comprehensive evaluations for ADHD, Autism, and Learning Disorders with a neuro-affirming lens.",
    icon: "mdi:calendar-star-outline",
    link: "/services/psychological-evaluations",
  },
  {
    title: "Medication Management",
    desc: "Personalized medication management with our dedicated Psychiatric Nurse Practitioner.",
    icon: "mdi:calendar-star-outline",
    link: "/services/medication-management",
  },
  {
    title: "Therapy",
    desc: "Individual counseling using evidence-based, neuro-affirming practices.",
    icon: "mdi:calendar-star-outline",
    link: "/services/therapy",
  },
];

const qualityCareItems = [
  {
    icon: "mdi:earth",
    title: "Nationwide access through Psypact",
    desc: "Get evaluated from almost anywhere. Our Psychologist can assess Autism, ADHD, personality disorders, intellectual disabilities, and more across most U.S. states.",
  },
  {
    icon: "mdi:clock-outline",
    title: "Fast, clear answers in 7 days",
    desc: "No long waits for clarity. Self-pay testing is completed and written report is shared within seven days of your intake appointment.",
  },
  {
    icon: "mdi:shield-check-outline",
    title: "Insurance-friendly testing",
    desc: "We accept most commercial insurances, Medicaid, and Medicare—unlike many practices that are cash-pay only for psychological testing.",
  },
  {
    icon: "mdi:medication-outline",
    title: "Integrated medication support",
    desc: "When testing indicates that medication may help, our in-house provider can step in to support your ongoing care.",
  },
  {
    icon: "mdi:video-wireless-outline",
    title: "Flexible & remote appointments",
    desc: "Weekend availability and fully remote testing options make it easier to get care, even if travel or scheduling is a concern.",
    cardClass: "sm:col-span-2 lg:col-span-1",
  },
];
---

<Layout
  title="Twilight Psychology | Neuro-Affirming Care in Kentucky"
  description="Twilight Psychology offers neuro-affirming psychological evaluations, medication management, and therapy services 
  in Kentucky."
>
  <div class="homepage-shell bg-site-bg">
    <section class="homepage-panel homepage-panel-hero relative isolate overflow-hidden px-4">
      <!-- SVG Background -->
      <div class="absolute inset-0 md:hidden opacity-70" aria-hidden="true">
        <Fragment set:html={heroBgMobile} />
      </div>
      <div class="absolute inset-0 hidden md:block opacity-80" aria-hidden="true">
        <Fragment set:html={heroBg} />
      </div>

      <div class="homepage-panel-glow homepage-panel-glow-top" aria-hidden="true"></div>
      <div class="homepage-panel-glow homepage-panel-glow-bottom" aria-hidden="true"></div>

      <div class="homepage-panel-inner mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[1.25fr_0.75fr]">
        <div class="relative z-10 text-center lg:text-left">
          <span
            class="inline-block px-4 py-1.5 mb-8 text-[10px] font-black tracking-[0.3em] text-sand uppercase theme-surface-soft border theme-border rounded-full backdrop-blur"
          >
            Neuro-Affirming Care in KY
          </span>

          <h1
            class="font-serif text-5xl md:text-7xl xl:text-8xl font-black text-site-text mb-8 tracking-tighter leading-[0.9]"
          >
            For 
            <span class="italic">Every</span> Way of Being
          </h1>

          <p
            class="max-w-2xl text-lg md:text-xl text-site-sub mb-12 leading-relaxed font-medium mx-auto lg:mx-0"
          >
          Find support through psychological testing, therapy, and medication management. We have immediate openings for new clients seeking top-tier health care.  
        </p>

          <div
            class="flex flex-col md:flex-row gap-6 items-center justify-center lg:justify-start"
          >
            <a
              href="/catalog"
              class="w-full px-10 py-4 md:w-72 lg:w-80 text-center bg-cta text-cta-fg font-black rounded-full hover:bg-cta/80 transition-all hover:scale-105 shadow-lg shadow-cta/20"
            >
              Explore Our Services
            </a>
            <a
              href={REFERRAL_LINK}
              target="_blank"
              rel="noopener noreferrer"
              class="w-full px-10 py-4 md:w-72 lg:w-80 text-center bg-transparent text-site-text border border-button-border font-black rounded-full theme-hover-surface transition-all"
            >
              Submit Client Referral
            </a>
          </div>

          <div class="mt-10 flex items-center justify-center gap-4 text-site-sub/80 lg:justify-start">
            <span class="h-px w-12 theme-divider"></span>
            <p class="text-[11px] uppercase tracking-[0.32em]">Scroll to explore</p>
          </div>
        </div>

        <aside class="relative z-10">
          <div class="homepage-feature-card rounded-4xl border theme-border p-6 sm:p-8 backdrop-blur-xl shadow-2xl shadow-slate-950/30">
            <p class="text-[11px] font-black uppercase tracking-[0.35em] text-site-sub/80">Expertise by Numbers</p>
            <div class="mt-8 space-y-1">
              <div class="homepage-stat-card">
                <h2 class="text-3xl sm:text-4xl font-serif font-black text-site-text leading-tight tracking-tight"><span class="text-cta">2100<sup>+</sup></span> Evaluations</h2>
              </div>
              <div class="homepage-stat-card">
                <h2 class="text-3xl sm:text-4xl font-serif font-black text-site-text leading-tight tracking-tight"><span class="text-cta">8<sup>+</sup></span> Years Experience</h2>
              </div>
              <div class="homepage-stat-card">
                <h2 class="text-3xl sm:text-4xl font-serif font-black text-site-text leading-tight tracking-tight"><span class="text-cta">15<sup>+</sup></span> Insurance Panels</h2>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="homepage-panel homepage-panel-care relative isolate overflow-hidden px-4">
      <div class="homepage-panel-glow homepage-panel-glow-left" aria-hidden="true"></div>
      <div class="homepage-panel-inner mx-auto max-w-6xl">
        <header class="mx-auto mb-12 max-w-3xl text-center">
          <p class="homepage-section-label">Designed for clarity</p>
          <h2
            class="font-serif text-4xl md:text-5xl lg:text-6xl font-black text-site-text mb-5"
          >
            Quality Care, <span class="text-cta">Five</span> Fewer Hurdles
          </h2>
          <p class="text-site-sub text-lg max-w-2xl mx-auto text-center leading-relaxed">
            We designed our evaluation process to be faster, more accessible, and affordable to navigate—so you can get clear answers without adding an additional stressor.
          </p>
        </header>

        <div class="care-two-panel">
          <!-- Left: selectable tab list -->
          <nav class="care-tab-list" aria-label="Quality care highlights" role="tablist">
            <p class="care-hint">Select a topic to learn more</p>
            {
              qualityCareItems.map((item, idx) => (
                <button
                  class={`care-tab${idx === 0 ? " active" : ""}`}
                  data-care-tab={String(idx)}
                  type="button"
                  aria-selected={idx === 0 ? "true" : "false"}
                  role="tab"
                >
                  <Icon
                    name={item.icon}
                    class="care-tab-icon w-5 h-5 shrink-0"
                    style="color: var(--color-icon);"
                  />
                  <span class="care-tab-title font-serif font-black text-sm leading-snug">
                    {item.title}
                  </span>
                  <Icon
                    name="mdi:chevron-right"
                    class="care-tab-arrow ml-auto w-4 h-4 shrink-0"
                  />
                </button>
              ))
            }
          </nav>

          <!-- Right: stacked content panels (one visible at a time) -->
          <div class="care-panels">
            {
              qualityCareItems.map((item, idx) => (
                <div
                  class={`care-panel${idx === 0 ? " active" : ""}`}
                  data-care-panel={String(idx)}
                  role="tabpanel"
                  aria-hidden={idx !== 0 ? "true" : "false"}
                >
                  <p class="care-panel-eyebrow">
                    {String(idx + 1).padStart(2, "0")} / {String(qualityCareItems.length).padStart(2, "0")}
                  </p>
                  <Icon
                    name={item.icon}
                    class="w-12 h-12 mb-5"
                    style="color: var(--color-icon);"
                  />
                  <h3 class="font-serif text-2xl sm:text-3xl font-black text-site-text mb-4 leading-tight">
                    {item.title}
                  </h3>
                  <p class="text-site-sub text-sm sm:text-base leading-relaxed max-w-md">
                    {item.desc}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="homepage-panel homepage-panel-services relative isolate overflow-hidden px-4">
      <div class="homepage-panel-glow homepage-panel-glow-right" aria-hidden="true"></div>
      <div class="homepage-panel-inner mx-auto max-w-6xl">
        <div
          class="mb-14 flex flex-col gap-6 md:flex-row md:items-end md:justify-between"
        >
          <div>
            <p class="homepage-section-label">Core services</p>
            <h2
              class="font-serif text-4xl md:text-5xl lg:text-6xl font-black text-site-text tracking-tighter"
            >
              How We Can Help
            </h2>
          </div>
          <p
            class="max-w-md text-sm md:text-base leading-relaxed text-site-sub"
          >
            "Twilight Psychology provides the clinical clarity to navigate the journey."
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {
            services.map((service) => (
              <div class="group homepage-service-card relative flex h-full flex-col rounded-4xl border theme-border p-7 sm:p-9 transition-all duration-500 overflow-hidden">
                <div class="relative z-10 flex h-full flex-col">
                  <div class="mb-5 flex items-center gap-3">
                    <Icon
                      name={service.icon}
                      class="w-9 h-9 text-site-sub shrink-0"
                      style="color: var(--color-icon);"
                    />
                    <h3 class="font-serif text-xl sm:text-2xl font-black text-site-text tracking-tight group-hover:text-cta transition-colors">
                      {service.title}
                    </h3>
                  </div>
                  <p class="mb-7 text-sm sm:text-base leading-relaxed text-site-sub">
                    {service.desc}
                  </p>

                  <a
                    href={service.link}
                    class="mt-auto inline-flex items-center gap-3 text-xs font-black uppercase tracking-widest text-cta/80 group-hover:text-cta transition-colors"
                  >
                    Explore Service
                    <span class="w-8 h-px bg-cta/30 group-hover:w-12 group-hover:bg-cta transition-all"></span>
                  </a>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="homepage-panel homepage-panel-cta relative isolate overflow-hidden px-4">
      <div class="homepage-panel-inner mx-auto max-w-5xl">
      <div class="homepage-cta-shell rounded-[2.5rem] border theme-border px-6 py-10 sm:px-10 sm:py-14 text-center">
          <p class="homepage-section-label justify-center">Next step</p>
          <h2
            class="font-serif text-4xl md:text-5xl lg:text-6xl font-black mb-6 tracking-tighter text-site-text"
          >
            Ready to Get Started
          </h2>
          <p class="mx-auto mb-10 max-w-2xl text-base sm:text-lg leading-relaxed text-site-sub">
            We’re here to support you at every step of your journey. Whether you’re seeking clarity through testing, personalized therapy, or medication management, we have a clear path forward for you.
          </p>
          <div
            class="flex flex-col sm:flex-row gap-6 justify-center relative z-10"
          >
            <a
              href="/resources/new-client"
              class="px-10 py-4 theme-surface-2 text-site-text border theme-border-strong font-black rounded-full theme-hover-surface transition-all hover:scale-105 shadow-lg"
            >
              Steps for New Clients
            </a>
            <a
              href="/about/clinicians/clinicians-lex-ky"
              class="px-10 py-4 bg-transparent text-site-text border border-button-border font-black rounded-full theme-hover-surface transition-all"
            >
              Meet Our Clinicians
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  @keyframes ambientDrift {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(0, -10px, 0) scale(1.03);
    }
  }

  @keyframes panelGlowBreath {
    0%,
    100% {
      opacity: 0.6;
    }
    50% {
      opacity: 0.85;
    }
  }

  :global(body:has(.homepage-shell)) {
    scroll-snap-type: y proximity;
  }

  .homepage-shell {
    position: relative;
  }

  .homepage-shell::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at top, rgba(165, 180, 252, 0.08), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent 20%, transparent 80%, rgba(255, 255, 255, 0.02));
    z-index: 0;
    animation: ambientDrift 14s ease-in-out infinite;
  }

  .homepage-panel {
    position: relative;
    min-height: calc(100svh - var(--homepage-chrome-offset));
    display: flex;
    align-items: center;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .homepage-panel:first-child {
    border-top: 0;
  }

  .homepage-panel-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-top: 4.5rem;
    padding-bottom: 4.5rem;
  }

  .homepage-panel-hero {
    --homepage-chrome-offset: 6.5rem;
    background:
      radial-gradient(circle at 15% 20%, rgba(223, 202, 170, 0.12), transparent 26%),
      radial-gradient(circle at 80% 75%, rgba(165, 180, 252, 0.14), transparent 28%),
      linear-gradient(180deg, rgba(2, 6, 23, 0.72), rgba(2, 6, 23, 0.92));
  }

  .homepage-panel-care {
    --homepage-chrome-offset: 6.5rem;
    background:
      linear-gradient(135deg, rgba(7, 14, 32, 0.96), rgba(15, 23, 42, 0.88)),
      radial-gradient(circle at 20% 15%, rgba(223, 202, 170, 0.08), transparent 24%);
  }

  .homepage-panel-services {
    --homepage-chrome-offset: 6.5rem;
    background:
      radial-gradient(circle at 85% 20%, rgba(223, 202, 170, 0.1), transparent 20%),
      linear-gradient(180deg, rgba(2, 6, 23, 0.94), rgba(10, 18, 36, 0.98));
  }

  .homepage-panel-cta {
    --homepage-chrome-offset: 6.5rem;
    background:
      linear-gradient(160deg, rgba(11, 17, 34, 0.98), rgba(2, 6, 23, 0.98)),
      radial-gradient(circle at 50% 0%, rgba(165, 180, 252, 0.14), transparent 32%);
  }

  .homepage-panel-glow {
    position: absolute;
    border-radius: 9999px;
    filter: blur(80px);
    opacity: 0.7;
    pointer-events: none;
    animation: panelGlowBreath 8s ease-in-out infinite;
  }

  .homepage-panel-glow-top {
    top: 8%;
    right: 10%;
    width: 18rem;
    height: 18rem;
    background: rgba(165, 180, 252, 0.2);
  }

  .homepage-panel-glow-bottom {
    bottom: 10%;
    left: 8%;
    width: 14rem;
    height: 14rem;
    background: rgba(223, 202, 170, 0.18);
    animation-delay: 1.8s;
  }

  .homepage-panel-glow-left {
    top: 18%;
    left: 0;
    width: 16rem;
    height: 16rem;
    background: rgba(223, 202, 170, 0.12);
    animation-delay: 2.6s;
  }

  .homepage-panel-glow-right {
    right: 2%;
    bottom: 12%;
    width: 20rem;
    height: 20rem;
    background: rgba(165, 180, 252, 0.12);
    animation-delay: 3.4s;
  }

  .homepage-feature-card,
  .homepage-glass-card,
  .homepage-service-card,
  .homepage-cta-shell {
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.6), rgba(2, 6, 23, 0.78));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(20px);
  }

  .homepage-stat-card {
    padding: 1.25rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .homepage-stat-card:first-of-type {
    border-top: 0;
    padding-top: 0.25rem;
  }

  .homepage-section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(148, 163, 184, 0.9);
  }

  .homepage-section-label::before,
  .homepage-section-label::after {
    content: "";
    width: 2.5rem;
    height: 1px;
    background: rgba(255, 255, 255, 0.15);
  }

  .homepage-service-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(165, 180, 252, 0.08), transparent 40%, rgba(223, 202, 170, 0.06));
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .homepage-service-card:hover::before {
    opacity: 1;
  }

  @media (min-width: 768px) {
    :global(body:has(.homepage-shell)) {
      scroll-snap-type: y mandatory;
    }

    .homepage-shell::before {
      animation-duration: 12s;
    }

    .homepage-panel-glow {
      animation-duration: 7s;
    }

    .homepage-panel,
    .homepage-panel-hero,
    .homepage-panel-care,
    .homepage-panel-services,
    .homepage-panel-cta {
      --homepage-chrome-offset: 7.25rem;
    }
  }

  @media (max-width: 767px) {
    .homepage-panel {
      min-height: auto;
    }

    .homepage-shell::before {
      animation-duration: 22s;
      opacity: 0.78;
    }

    .homepage-panel-glow {
      animation-duration: 12s;
      opacity: 0.5;
      filter: blur(66px);
    }

    .homepage-panel-inner {
      padding-top: 3.75rem;
      padding-bottom: 3.75rem;
    }

    .homepage-section-label::before,
    .homepage-section-label::after {
      width: 1.5rem;
    }
  }

  @media (min-width: 1280px) {
    .homepage-shell::before {
      animation-duration: 10.5s;
    }

    .homepage-panel-glow {
      opacity: 0.8;
      filter: blur(88px);
    }
  }

  /* ── Care two-panel (Scrapy-style interactive tabs) ── */

  .care-two-panel {
    display: grid;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 2rem;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.5), rgba(2, 6, 23, 0.7));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  @media (min-width: 1024px) {
    .care-two-panel {
      grid-template-columns: minmax(240px, 5fr) 7fr;
    }
  }

  .care-hint {
    padding: 1.25rem 1.5rem 0.5rem;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(148, 163, 184, 0.35);
  }

  .care-tab-list {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  @media (min-width: 1024px) {
    .care-tab-list {
      border-bottom: none;
      border-right: 1px solid rgba(255, 255, 255, 0.06);
    }
  }

  .care-tab {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    padding: 1rem 1.5rem;
    text-align: left;
    border: none;
    border-left: 2px solid transparent;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    background: transparent;
    cursor: pointer;
    transition: background 0.15s ease, border-left-color 0.15s ease;
  }

  .care-tab:last-child {
    border-bottom: none;
  }

  .care-tab:hover:not(.active) {
    background: rgba(255, 255, 255, 0.03);
  }

  .care-tab-icon {
    opacity: 0.4;
    transition: opacity 0.2s ease;
  }

  .care-tab-title {
    color: var(--color-site-sub);
    transition: color 0.2s ease;
  }

  .care-tab-arrow {
    opacity: 0;
    color: var(--color-cta);
    transform: translateX(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .care-tab.active {
    border-left-color: var(--color-cta);
    background: rgba(165, 180, 252, 0.05);
  }

  .care-tab.active .care-tab-icon {
    opacity: 1;
  }

  .care-tab.active .care-tab-title {
    color: var(--color-site-text);
  }

  .care-tab.active .care-tab-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .care-panels {
    display: grid;
    min-height: 22rem;
  }

  .care-panel {
    grid-row: 1;
    grid-column: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2.5rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .care-panel.active {
    opacity: 1;
    pointer-events: auto;
  }

  .care-panel-eyebrow {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(148, 163, 184, 0.35);
    margin-bottom: 1.25rem;
  }

  :root.light .homepage-shell::before {
    background:
      radial-gradient(circle at top, rgba(79, 70, 229, 0.1), transparent 34%),
      linear-gradient(180deg, rgba(79, 70, 229, 0.03), transparent 20%, transparent 80%, rgba(15, 23, 42, 0.02));
  }

  :root.light .homepage-panel-glow-top {
    background: rgba(79, 70, 229, 0.22);
  }

  :root.light .homepage-panel-glow-bottom,
  :root.light .homepage-panel-glow-left,
  :root.light .homepage-panel-glow-right {
    background: rgba(99, 102, 241, 0.16);
  }

  :root.light .homepage-panel {
    border-top-color: rgba(100, 116, 139, 0.25);
  }

  :root.light .homepage-panel-hero {
    background:
      radial-gradient(circle at 15% 20%, rgba(67, 56, 202, 0.12), transparent 26%),
      radial-gradient(circle at 80% 75%, rgba(99, 102, 241, 0.14), transparent 28%),
      linear-gradient(180deg, rgba(248, 250, 252, 0.92), rgba(241, 245, 249, 0.98));
  }

  :root.light .homepage-panel-care {
    background:
      linear-gradient(135deg, rgba(248, 250, 252, 0.95), rgba(238, 242, 255, 0.88)),
      radial-gradient(circle at 20% 15%, rgba(79, 70, 229, 0.08), transparent 24%);
  }

  :root.light .homepage-panel-services {
    background:
      radial-gradient(circle at 85% 20%, rgba(79, 70, 229, 0.1), transparent 20%),
      linear-gradient(180deg, rgba(248, 250, 252, 0.94), rgba(241, 245, 249, 0.98));
  }

  :root.light .homepage-panel-cta {
    background:
      linear-gradient(160deg, rgba(248, 250, 252, 0.98), rgba(238, 242, 255, 0.98)),
      radial-gradient(circle at 50% 0%, rgba(99, 102, 241, 0.12), transparent 32%);
  }

  :root.light .homepage-feature-card,
  :root.light .homepage-glass-card,
  :root.light .homepage-service-card,
  :root.light .homepage-cta-shell {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(238, 242, 255, 0.85));
    box-shadow: inset 0 1px 0 rgba(148, 163, 184, 0.25);
  }

  :root.light .homepage-stat-card {
    border-top-color: rgba(100, 116, 139, 0.2);
  }

  :root.light .homepage-section-label {
    color: rgba(71, 85, 105, 0.85);
  }

  :root.light .homepage-section-label::before,
  :root.light .homepage-section-label::after {
    background: rgba(100, 116, 139, 0.35);
  }

  :root.light .care-two-panel {
    border-color: rgba(100, 116, 139, 0.28);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(238, 242, 255, 0.78));
    box-shadow: inset 0 1px 0 rgba(148, 163, 184, 0.25);
  }

  :root.light .care-tab-list {
    border-color: rgba(100, 116, 139, 0.22);
  }

  :root.light .care-tab {
    border-bottom-color: rgba(100, 116, 139, 0.18);
  }

  :root.light .care-tab:hover:not(.active) {
    background: rgba(79, 70, 229, 0.06);
  }

  :root.light .care-tab.active {
    background: rgba(79, 70, 229, 0.12);
  }

  :root.light .care-hint,
  :root.light .care-panel-eyebrow {
    color: rgba(71, 85, 105, 0.65);
  }

  @media (prefers-reduced-motion: reduce) {
    .homepage-shell::before,
    .homepage-panel-glow {
      animation: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-care-tab]'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-care-panel]'));
    const statValues = Array.from(document.querySelectorAll<HTMLElement>('.homepage-stat-card .text-cta'));
    const statsCard = document.querySelector<HTMLElement>('.homepage-feature-card');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const setActiveTab = (activeIndex: number) => {
      tabs.forEach((tab, index) => {
        const isActive = index === activeIndex;
        tab.classList.toggle('active', isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      panels.forEach((panel, index) => {
        const isActive = index === activeIndex;
        panel.classList.toggle('active', isActive);
        panel.setAttribute('aria-hidden', isActive ? 'false' : 'true');
      });
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const activeIndex = Number(tab.dataset.careTab);
        if (Number.isFinite(activeIndex)) {
          setActiveTab(activeIndex);
        }
      });
    });

    const statCounterMeta = statValues
      .map((element) => {
        const rawValue = element.textContent?.trim() ?? '';
        const target = Number(rawValue.replace(/[^\d]/g, ''));
        const suffix = rawValue.replace(/[\d,]/g, '');
        if (!Number.isFinite(target) || target <= 0) {
          return null;
        }
        return { element, target, suffix };
      })
      .filter((entry): entry is { element: HTMLElement; target: number; suffix: string } => Boolean(entry));

    const animateStatValue = (element: HTMLElement, target: number, suffix: string) => {
      if (prefersReducedMotion) {
        element.textContent = `${target}${suffix}`;
        return;
      }

      const durationMs = 1300;
      const start = performance.now();

      const tick = (now: number) => {
        const progress = Math.min((now - start) / durationMs, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.floor(target * eased);

        element.textContent = `${current}${suffix}`;

        if (progress < 1) {
          requestAnimationFrame(tick);
        }
      };

      requestAnimationFrame(tick);
    };

    const runStatCounters = () => {
      statCounterMeta.forEach(({ element, target, suffix }) => {
        animateStatValue(element, target, suffix);
      });
    };

    if (statsCard && statCounterMeta.length > 0 && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              runStatCounters();
              obs.disconnect();
            }
          });
        },
        { threshold: 0.35 }
      );

      observer.observe(statsCard);
    } else if (statCounterMeta.length > 0) {
      runStatCounters();
    }
  });
</script>

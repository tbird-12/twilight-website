---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { Icon } from "astro-icon/components";
import { REFERRAL_LINK } from "../data/resource";
import heroBg from "../assets/hero-background.svg?raw";
import heroBgMobile from "../assets/hero-mobile.svg?raw";

const services = [
  {
    title: "Psychological Evaluations",
    desc: "Comprehensive evaluations for ADHD, Autism, and Learning Disorders through a neuro-affirming, evidence-based lens.",
    icon: "mdi:calendar-star-outline",
    link: "/services/psychological-evaluations",
  },
  {
    title: "Medication Management",
    desc: "Individualized medication management with our dedicated Psychiatric Nurse Practitioner.",
    icon: "mdi:calendar-star-outline",
    link: "/services/medication-management",
  },
  {
    title: "Therapy",
    desc: "Individual counseling grounded in evidence-based, neuro-affirming clinical practice.",
    icon: "mdi:calendar-star-outline",
    link: "/services/therapy",
  },
];

const qualityCareItems = [
  {
    icon: "mdi:earth",
    title: "Nationwide access through Psypact",
    desc: "Receive evaluation services from nearly anywhere. Our Psychologist can assess Autism, ADHD, personality disorders, intellectual disabilities, and more across most U.S. states.",
  },
  {
    icon: "mdi:clock-outline",
    title: "Rapid diagnostic clarity in 7 days",
    desc: "No prolonged wait for answers and no expedited fees. For evaluations offered on a self-pay basis, testing can often be completed and the written report delivered within seven days of your intake appointment.",
  },
  {
    icon: "mdi:shield-check-outline",
    title: "Insurance-accepted evaluations",
    desc: "We are credentialed with most major commercial insurances, Medicaid, and Medicare—and offer among the shortest waitlists in Kentucky for clients seeking a diagnosis with insurance. Most practices limit psychological testing to self-pay; we don't.",
  },
  {
    icon: "mdi:medication-outline",
    title: "Integrated psychiatric support",
    desc: "When evaluation results indicate that medication may be beneficial, our in-house psychiatric provider can step in to support your ongoing care.",
  },
  {
    icon: "mdi:video-wireless-outline",
    title: "Flexible scheduling & remote access",
    desc: "Weekend availability and fully remote testing options accommodate demanding schedules and eliminate barriers to receiving care.",
    cardClass: "sm:col-span-2 lg:col-span-1",
  },
];
---

<Layout
  title="Twilight Psychology | Neuro-Affirming Care in Lexington, Kentucky"
  description="Twilight Psychology in Lexington, KY offers neuro-affirming psychological evaluations, therapy, and medication management. Among the shortest waitlists in Kentucky for clients seeking a diagnosis with Medicaid or health insurance. Accepting 15+ insurance panels."
>
  <div class="homepage-shell bg-site-bg">
    <section
      class="homepage-panel homepage-panel-hero relative isolate overflow-hidden px-4"
    >
      <!-- SVG Background -->
      <div class="absolute inset-0 md:hidden opacity-70" aria-hidden="true">
        <Fragment set:html={heroBgMobile} />
      </div>
      <div
        class="absolute inset-0 hidden md:block opacity-80"
        aria-hidden="true"
      >
        <Fragment set:html={heroBg} />
      </div>
      <div
        class="homepage-panel-inner homepage-hero-inner relative z-10 mx-auto max-w-5xl text-center"
      >
        <h1
          class="font-serif text-[2.25rem] sm:text-5xl md:text-7xl xl:text-8xl font-black text-site-text mb-4 sm:mb-8 tracking-tighter leading-[0.9]"
        >
          Answers You Deserve,
          <br class="hidden sm:block" />
          <span class="italic">Care&nbsp;</span>You Can Trust
        </h1>

        <p
          class="max-w-2xl mx-auto text-base sm:text-lg md:text-xl text-site-sub mb-8 sm:mb-12 leading-relaxed font-medium"
        >
          Whether you're seeking an evaluation for ADHD, Autism, or a learning
          disorder — or looking for therapy and medication support — our
          neuro-affirming team in Lexington, Kentucky is here to help.
          Now accepting new clients.
        </p>

        <div
          class="flex flex-col sm:flex-row gap-4 sm:gap-5 items-center justify-center"
        >
          <a
            href="/catalog"
            class="w-full sm:w-auto px-10 py-3 sm:px-12 sm:py-4 text-center bg-cta text-cta-fg font-black rounded-full hover:bg-cta/80 transition-all hover:scale-105 shadow-lg shadow-cta/20"
          >
            Explore Our Services
          </a>
          <a
            href={REFERRAL_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-bold text-site-sub hover:text-icon transition-colors underline underline-offset-4 decoration-site-sub/30 hover:decoration-cta/50"
          >
            Referring a client? Submit a referral &rarr;
          </a>
        </div>

        <div
          class="homepage-trust-bar mt-8 sm:mt-16 flex flex-wrap items-center justify-center gap-x-8 sm:gap-x-10 gap-y-3"
        >
          <span class="flex items-center gap-2">
            <span
              class="text-xl sm:text-2xl font-serif font-black text-icon homepage-stat-value"
              >2100<sup>+</sup></span
            >
            <span class="text-xs sm:text-sm font-semibold text-cta"
              >Evaluations</span
            >
          </span>
          <span
            class="hidden sm:block w-px h-6 bg-site-sub/20"
            aria-hidden="true"></span>
          <span class="flex items-center gap-2">
            <span
              class="text-xl sm:text-2xl font-serif font-black text-icon homepage-stat-value"
              >8<sup>+</sup></span
            >
            <span class="text-xs sm:text-sm font-semibold text-cta"
              >Years Experience</span
            >
          </span>
          <span
            class="hidden sm:block w-px h-6 bg-site-sub/20"
            aria-hidden="true"></span>
          <span class="flex items-center gap-2">
            <span
              class="text-xl sm:text-2xl font-serif font-black text-icon homepage-stat-value"
              >15<sup>+</sup></span
            >
            <span class="text-xs sm:text-sm font-semibold text-cta"
              >Insurance Panels</span
            >
          </span>
          <span
            class="hidden sm:block w-px h-6 bg-site-sub/20"
            aria-hidden="true"></span>
          <span class="flex items-center gap-2">
            <a
              href="/resources/faq#wait-times"
              class="flex items-center gap-2 hover:opacity-80 transition-opacity"
              title="Self-pay waitlist — see FAQ for insurance wait times"
            >
              <span
                class="text-xl sm:text-2xl font-serif font-black text-icon homepage-stat-value"
                >3</span
              >
              <span class="text-xs sm:text-sm font-semibold text-cta"
                >Weeks Waitlist<span class="block text-[10px] text-site-sub/60 font-medium normal-case tracking-normal">Self-pay clients</span></span
              >
            </a>
          </span>
        </div>
      </div>
    </section>

    <section
      id="quality-care"
      class="homepage-panel homepage-panel-care relative isolate overflow-hidden px-4"
    >
      <div
        class="homepage-panel-glow homepage-panel-glow-left"
        aria-hidden="true"
      >
      </div>
      <div class="homepage-panel-inner mx-auto max-w-6xl">
        <header class="mx-auto mb-12 max-w-3xl text-center">
          <p class="homepage-section-label">Designed for clarity</p>
          <h2
            class="font-serif text-4xl md:text-5xl lg:text-6xl font-black text-site-text mb-5"
          >
            Elevated Care, <span class="text-cta">Five</span> Fewer Barriers
          </h2>
          <p
            class="text-site-sub text-lg max-w-2xl mx-auto text-center leading-relaxed"
          >
            Our evaluation process is built for precision and
            efficiency—delivering clinically grounded answers without
            unnecessary delays or complexity.
          </p>
        </header>

        <div class="care-two-panel">
          <!-- Left: selectable tab list -->
          <nav
            class="care-tab-list"
            aria-label="Quality care highlights"
            role="tablist"
          >
            <p class="care-hint">Select to learn more</p>
            {
              qualityCareItems.map((item, idx) => (
                <button
                  class={`care-tab${idx === 0 ? " active" : ""}`}
                  data-care-tab={String(idx)}
                  type="button"
                  aria-selected={idx === 0 ? "true" : "false"}
                  role="tab"
                >
                  <Icon
                    name={item.icon}
                    class="care-tab-icon w-5 h-5 shrink-0"
                    style="color: var(--color-icon);"
                  />
                  <span class="care-tab-title font-serif font-black text-sm leading-snug">
                    {item.title}
                  </span>
                  <Icon
                    name="mdi:chevron-right"
                    class="care-tab-arrow ml-auto w-4 h-4 shrink-0"
                  />
                </button>
              ))
            }
          </nav>

          <!-- Right: stacked content panels (one visible at a time) -->
          <div class="care-panels">
            {
              qualityCareItems.map((item, idx) => (
                <div
                  class={`care-panel${idx === 0 ? " active" : ""}`}
                  data-care-panel={String(idx)}
                  role="tabpanel"
                  aria-hidden={idx !== 0 ? "true" : "false"}
                >
                  <p class="care-panel-eyebrow">
                    {String(idx + 1).padStart(2, "0")} /{" "}
                    {String(qualityCareItems.length).padStart(2, "0")}
                  </p>
                  <Icon
                    name={item.icon}
                    class="w-12 h-12 mb-5"
                    style="color: var(--color-icon);"
                  />
                  <h3 class="font-serif text-2xl sm:text-3xl font-black text-site-text mb-4 leading-tight">
                    {item.title}
                  </h3>
                  <p class="text-site-sub text-sm sm:text-base leading-relaxed max-w-md">
                    {item.desc}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section
      class="homepage-panel homepage-panel-services relative isolate overflow-hidden px-4"
    >
      <div
        class="homepage-panel-glow homepage-panel-glow-right"
        aria-hidden="true"
      >
      </div>
      <div class="homepage-panel-inner mx-auto max-w-6xl">
        <div
          class="mb-14 flex flex-col gap-6 md:flex-row md:items-end md:justify-between"
        >
          <div>
            <p class="homepage-section-label">Core services</p>
            <h2
              class="font-serif text-4xl md:text-5xl lg:text-6xl font-black text-site-text tracking-tighter"
            >
              How We Can Help
            </h2>
          </div>
          <p
            class="max-w-md text-sm md:text-base leading-relaxed text-site-sub"
          >
            "Twilight Psychology delivers the clinical depth to guide confident,
            informed decisions."
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {
            services.map((service) => (
              <div class="group homepage-service-card relative flex h-full flex-col rounded-4xl border theme-border p-7 sm:p-9 transition-all duration-500 overflow-hidden">
                <div class="relative z-10 flex h-full flex-col">
                  <div class="mb-5 flex items-center gap-3">
                    <Icon
                      name={service.icon}
                      class="w-9 h-9 text-site-sub shrink-0"
                      style="color: var(--color-icon);"
                    />
                    <h3 class="font-serif text-xl sm:text-2xl font-black text-site-text tracking-tight group-hover:text-cta transition-colors">
                      {service.title}
                    </h3>
                  </div>
                  <p class="mb-7 text-sm sm:text-base leading-relaxed text-site-sub">
                    {service.desc}
                  </p>

                  <a
                    href={service.link}
                    class="mt-auto inline-flex items-center gap-3 text-xs font-black uppercase tracking-widest text-cta/80 group-hover:text-cta transition-colors"
                  >
                    Explore Service
                    <span class="w-8 h-px bg-cta/30 group-hover:w-12 group-hover:bg-cta transition-all" />
                  </a>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section
      class="homepage-panel homepage-panel-cta relative isolate overflow-hidden px-4"
    >
      <div class="homepage-panel-inner mx-auto max-w-5xl">
        <div
          class="homepage-cta-shell rounded-[2.5rem] border theme-border px-6 py-10 sm:px-10 sm:py-14 text-center"
        >
          <p class="homepage-section-label justify-center">Next step</p>
          <h2
            class="font-serif text-4xl md:text-5xl lg:text-6xl font-black mb-6 tracking-tighter text-site-text"
          >
            Ready to Get Started
          </h2>
          <p
            class="mx-auto mb-10 max-w-2xl text-base sm:text-lg leading-relaxed text-site-sub"
          >
            Whether you are pursuing diagnostic clarity, individualized therapy,
            or psychiatric medication management, our team is prepared to guide
            you through a structured, seamless process.
          </p>
          <div
            class="flex flex-col sm:flex-row gap-6 justify-center relative z-10"
          >
            <a
              href="/resources/new-client"
              class="px-10 py-4 theme-surface-2 text-site-text border theme-border-strong font-black rounded-full theme-hover-surface transition-all hover:scale-105 shadow-lg"
            >
              Steps for New Clients
            </a>
            <a
              href="/about/clinicians/clinicians-lex-ky"
              class="px-10 py-4 bg-cta text-cta-fg border border-button-border font-black rounded-full theme-hover-surface transition-all"
            >
              Meet Our Clinicians
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  @keyframes ambientDrift {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(0, -10px, 0) scale(1.03);
    }
  }

  @keyframes panelGlowBreath {
    0%,
    100% {
      opacity: 0.6;
    }
    50% {
      opacity: 0.85;
    }
  }

  :global(body:has(.homepage-shell)) {
    scroll-snap-type: y proximity;
  }

  .homepage-shell {
    position: relative;
  }

  .homepage-shell::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at top, rgba(199, 210, 254, 0.1), transparent 34%),
      linear-gradient(
        180deg,
        rgba(199, 210, 254, 0.04),
        transparent 20%,
        transparent 80%,
        rgba(199, 210, 254, 0.02)
      );
    z-index: 0;
    animation: ambientDrift 14s ease-in-out infinite;
  }

  .homepage-panel {
    position: relative;
    min-height: calc(100svh - var(--homepage-chrome-offset));
    display: flex;
    align-items: center;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    border-top: 1px solid rgba(199, 210, 254, 0.08);
  }

  .homepage-panel:first-child {
    border-top: 0;
  }

  .homepage-panel-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-top: 4.5rem;
    padding-bottom: 4.5rem;
  }

  .homepage-panel-hero {
    --homepage-chrome-offset: 4rem;
    background:
      radial-gradient(
        circle at 15% 20%,
        rgba(103, 232, 249, 0.08),
        transparent 26%
      ),
      linear-gradient(180deg, rgba(var(--rgb-bg), 0.72), rgba(var(--rgb-bg), 0.92));
  }

  @media (min-width: 640px) {
    .homepage-panel-hero {
      --homepage-chrome-offset: 5rem;
    }
  }

  @media (min-width: 768px) {
    .homepage-panel-hero {
      --homepage-chrome-offset: 6.5rem;
    }
  }

  .homepage-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: calc(100svh - var(--homepage-chrome-offset, 4rem));
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  @media (min-width: 640px) {
    .homepage-hero-inner {
      min-height: auto;
      padding-top: 4.5rem;
      padding-bottom: 4.5rem;
    }
  }

  .homepage-panel-care {
    --homepage-chrome-offset: 6.5rem;
    background:
      radial-gradient(
        circle at 20% 16%,
        rgba(199, 210, 254, 0.06),
        transparent 30%
      ),
      linear-gradient(180deg, rgba(var(--rgb-bg), 0.93), rgba(var(--rgb-bg), 0.97));
  }

  .homepage-panel-services {
    --homepage-chrome-offset: 6.5rem;
    background:
      radial-gradient(
        circle at 80% 20%,
        rgba(199, 210, 254, 0.06),
        transparent 30%
      ),
      linear-gradient(180deg, rgba(var(--rgb-bg), 0.97), rgba(var(--rgb-surface-2), 0.985));
  }

  .homepage-panel-cta {
    --homepage-chrome-offset: 6.5rem;
    background: linear-gradient(
      180deg,
      rgba(var(--rgb-surface-2), 0.985),
      rgba(var(--rgb-bg), 0.995)
    );
  }

  .homepage-panel-glow {
    position: absolute;
    border-radius: 9999px;
    filter: blur(80px);
    opacity: 0.7;
    pointer-events: none;
    animation: panelGlowBreath 8s ease-in-out infinite;
  }

  .homepage-panel-glow-top {
    top: 8%;
    right: 10%;
    width: 18rem;
    height: 18rem;
    background: rgba(199, 210, 254, 0.2);
  }

  .homepage-panel-glow-bottom {
    bottom: 10%;
    left: 8%;
    width: 14rem;
    height: 14rem;
    background: rgba(199, 210, 254, 0.1);
    animation-delay: 1.8s;
  }

  .homepage-panel-glow-left {
    top: 20%;
    left: 4%;
    width: 16rem;
    height: 16rem;
    background: rgba(199, 210, 254, 0.1);
    animation-delay: 2.6s;
  }

  .homepage-panel-glow-right {
    right: 4%;
    top: 20%;
    width: 16rem;
    height: 16rem;
    background: rgba(199, 210, 254, 0.1);
    animation-delay: 3.4s;
  }

  .homepage-feature-card,
  .homepage-glass-card,
  .homepage-service-card {
    background: linear-gradient(
      180deg,
      rgba(199, 210, 254, 0.06),
      rgba(109, 206, 249, 0.08)
    );
    box-shadow: inset 0 1px 0 rgba(199, 210, 254, 0.08);
    backdrop-filter: blur(20px);
  }

  .homepage-cta-shell {
    background: rgba(var(--rgb-surface), 0.55);
    box-shadow: none;
    backdrop-filter: none;
  }

  .homepage-stat-card {
    padding: 1.25rem 0;
    border-top: 1px solid rgba(199, 210, 254, 0.1);
  }

  .homepage-stat-card:first-of-type {
    border-top: 0;
    padding-top: 0.25rem;
  }

  .homepage-section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(165, 180, 252, 0.9);
  }

  .homepage-section-label::before,
  .homepage-section-label::after {
    content: "";
    width: 2.5rem;
    height: 1px;
    background: rgba(199, 210, 254, 0.2);
  }

  .homepage-service-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(199, 210, 254, 0.08),
      transparent 40%,
      rgba(103, 232, 249, 0.05)
    );
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .homepage-service-card:hover::before {
    opacity: 1;
  }

  @media (min-width: 768px) {
    :global(body:has(.homepage-shell)) {
      scroll-snap-type: y mandatory;
    }

    .homepage-shell::before {
      animation-duration: 12s;
    }

    .homepage-panel-glow {
      animation-duration: 7s;
    }

    .homepage-panel,
    .homepage-panel-hero,
    .homepage-panel-care,
    .homepage-panel-services,
    .homepage-panel-cta {
      --homepage-chrome-offset: 7.25rem;
    }
  }

  @media (max-width: 767px) {
    .homepage-panel {
      min-height: auto;
    }

    .homepage-shell::before {
      animation-duration: 22s;
      opacity: 0.78;
    }

    .homepage-panel-glow {
      animation-duration: 12s;
      opacity: 0.5;
      filter: blur(66px);
    }

    .homepage-panel-inner {
      padding-top: 2rem;
      padding-bottom: 2rem;
    }

    .homepage-panel-hero .homepage-panel-inner {
      padding-top: 1.5rem;
      padding-bottom: 1.5rem;
    }

    .homepage-section-label::before,
    .homepage-section-label::after {
      width: 1.5rem;
    }
  }

  @media (min-width: 1280px) {
    .homepage-shell::before {
      animation-duration: 10.5s;
    }

    .homepage-panel-glow {
      opacity: 0.8;
      filter: blur(88px);
    }
  }

  /* ── Care two-panel (highlight blocks + display panel) ── */

  .care-two-panel {
    display: grid;
    gap: 1.5rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .care-two-panel {
      grid-template-columns: minmax(240px, 5fr) 7fr;
      gap: 2.5rem;
    }
  }

  .care-hint {
    padding: 0 0.25rem 0.75rem;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(165, 180, 252, 0.35);
  }

  .care-tab-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .care-tab {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    padding: 0.875rem 1.25rem;
    text-align: left;
    border: 1px solid rgba(199, 210, 254, 0.1);
    border-left: 3px solid transparent;
    border-radius: 0.875rem;
    background: rgba(199, 210, 254, 0.15);
    cursor: pointer;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.15s ease;
  }

  .care-tab:hover:not(.active) {
    background: rgba(199, 210, 254, 0.06);
    transform: translateX(2px);
  }

  .care-tab-icon {
    opacity: 0.4;
    transition: opacity 0.2s ease;
  }

  .care-tab-title {
    color: var(--color-site-sub);
    transition: color 0.2s ease;
  }

  .care-tab-arrow {
    opacity: 0;
    color: var(--color-cta);
    transform: translateX(-6px);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .care-tab.active {
    border-color: rgba(199, 210, 254, 0.2);
    border-left-color: var(--color-cta);
    background: rgba(4, 88, 84, 0.09);
  }

  .care-tab.active .care-tab-icon {
    opacity: 1;
  }

  .care-tab.active .care-tab-title {
    color: var(--color-site-text);
  }

  .care-tab.active .care-tab-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .care-panels {
    display: grid;
    min-height: 22rem;
    border: 1px solid rgba(199, 210, 254, 0.12);
    border-radius: 1.25rem;
    background: rgba(199, 210, 254, 0.12);
    box-shadow: inset 0 1px 0 rgba(199, 210, 254, 0.06);
  }

  .care-panel {
    grid-row: 1;
    grid-column: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2.5rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .care-panel.active {
    opacity: 1;
    pointer-events: auto;
  }

  .care-panel-eyebrow {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(165, 180, 252, 0.35);
    margin-bottom: 1.25rem;
  }

  :root.light .homepage-shell::before {
    background:
      radial-gradient(circle at top, rgba(79, 70, 229, 0.1), transparent 34%),
      linear-gradient(
        180deg,
        rgba(79, 70, 229, 0.03),
        transparent 20%,
        transparent 80%,
        rgba(15, 23, 42, 0.02)
      );
  }

  :root.light .homepage-panel-glow-top {
    background: rgba(79, 70, 229, 0.22);
  }

  :root.light .homepage-panel-glow-bottom,
  :root.light .homepage-panel-glow-left,
  :root.light .homepage-panel-glow-right {
    background: rgba(8, 145, 178, 0.14);
  }

  :root.light .homepage-panel {
    border-top-color: rgba(79, 70, 229, 0.15);
  }

  :root.light .homepage-panel-hero {
    background:
      radial-gradient(
        circle at 15% 20%,
        rgba(67, 56, 202, 0.12),
        transparent 26%
      ),
      linear-gradient(
        180deg,
        rgba(var(--rgb-bg), 0.92),
        rgba(var(--rgb-surface-2), 0.98)
      );
  }

  :root.light .homepage-panel-care {
    background:
      radial-gradient(
        circle at 20% 16%,
        rgba(79, 70, 229, 0.06),
        transparent 26%
      ),
      linear-gradient(
        180deg,
        rgba(var(--rgb-bg), 0.95),
        rgba(var(--rgb-surface-2), 0.97)
      );
  }

  :root.light .homepage-panel-services {
    background:
      radial-gradient(
        circle at 82% 20%,
        rgba(79, 70, 229, 0.08),
        transparent 24%
      ),
      linear-gradient(
        180deg,
        rgba(var(--rgb-surface-2), 0.97),
        rgba(var(--rgb-surface-2), 0.985)
      );
  }

  :root.light .homepage-panel-cta {
    background: linear-gradient(
      180deg,
      rgba(var(--rgb-surface-2), 0.985),
      rgba(var(--rgb-bg), 0.995)
    );
  }

  :root.light .homepage-feature-card,
  :root.light .homepage-glass-card,
  :root.light .homepage-service-card {
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92),
      rgba(238, 242, 255, 0.85)
    );
    box-shadow: inset 0 1px 0 rgba(79, 70, 229, 0.15);

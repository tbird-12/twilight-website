---
import Layout from "../layouts/Layout.astro";
import HeroSectionWrapper from "../components/HeroSectionWrapper.astro";
import { Icon } from "astro-icon/components";
import heroBg from "../assets/hero-background.svg?raw";
import heroBgMobile from "../assets/hero-mobile.svg?raw";

import QualityCareTabsWrapper from "../components/QualityCareTabsWrapper.astro";
import AnimatedSection from "../components/preact/primitives/AnimatedSection";

const services = [
  {
    title: "Psychological Evaluations",
    desc: "Comprehensive evaluations for ADHD, Autism, and Learning Disorders through a neuro-affirming, evidence-based lens.",
    icon: "mdi:calendar-star-outline",
    link: "/services/psychological-evaluations",
  },
  {
    title: "Medication Management",
    desc: "Individualized medication management with our dedicated Psychiatric Nurse Practitioner.",
    icon: "mdi:calendar-star-outline",
    link: "/services/medication-management",
  },
  {
    title: "Therapy",
    desc: "Individual counseling grounded in evidence-based, neuro-affirming clinical practice.",
    icon: "mdi:calendar-star-outline",
    link: "/services/therapy",
  },
];

const problemPoints = [
  {
    title: "Long waits for testing",
    desc: "Wait times for insured psychological evaluations in Kentucky can stretch years — making it hard to get the answers you need when you need them.",
  },
  {
    title: "Limited insurance options",
    desc: "Comprehensive evaluations are often only available on a self-pay basis, which can mean thousands of dollars out of pocket — even when you have insurance.",
  },
  {
    title: "Adults can be harder to assess",
    desc: "Many assessment approaches were originally developed for children. Adults who've adapted over time may need a more nuanced, experienced evaluation.",
  },
  {
    title: "What comes after the diagnosis?",
    desc: "A diagnosis is just the starting point. Having therapy, medication management, and ongoing support available in one place makes all the difference.",
  },
];

const qualityCareItems = [
  {
    title: "Nationwide access through Psypact",
    desc: "Receive evaluation services from nearly anywhere. Our Psychologist can assess Autism, ADHD, personality disorders, intellectual disabilities, and more across most U.S. states.",
    link: "/about/locations",
  },
  {
    title: "Rapid diagnostic clarity in 7 days",
    desc: "No prolonged wait for answers and no expedited fees. For evaluations offered on a self-pay basis, testing can often be completed and the written report delivered within seven days of your intake appointment.",
    link: "/resources/waitlist-times",
  },
  {
    title: "Insurance-accepted evaluations",
    desc: "We are credentialed with most major commercial insurances, Medicaid, and Medicare—and offer among the shortest waitlists in Kentucky for clients seeking a diagnosis with insurance. Most practices limit psychological testing to self-pay; we don't.",
    link: "/resources/insurances-accepted",
  },
  {
    title: "Integrated psychiatric support",
    desc: "When evaluation results indicate that medication may be beneficial, our in-house psychiatric provider can step in to support your ongoing care.",
    link: "/services/medication-management",
  },
  {
    title: "Flexible scheduling & remote access",
    desc: "Weekend availability and fully remote testing options accommodate demanding schedules and eliminate barriers to receiving care.",
    cardClass: "sm:col-span-2 lg:col-span-1",
    link: "/contact",
  },
];
---

<Layout
  title="Twilight Psychology | Neuro-Affirming Care in Lexington, Kentucky"
  description="Neuro-affirming psychological evaluations, therapy, and medication management in Lexington, KY. Short waitlists. 17+ insurance panels accepted."
>
  <div class="homepage-shell bg-site-bg">
    <section
      class="homepage-panel homepage-panel-hero relative isolate overflow-hidden px-4"
    >
      <!-- SVG Background -->
      <div class="absolute inset-0 md:hidden opacity-70" aria-hidden="true">
        <Fragment set:html={heroBgMobile} />
      </div>
      <div
        class="absolute inset-0 hidden md:block opacity-80"
        aria-hidden="true"
      >
        <Fragment set:html={heroBg} />
      </div>
      <div
        class="homepage-panel-inner homepage-hero-inner relative z-10 mx-auto max-w-4xl text-center px-4 sm:px-6"
      >
        <HeroSectionWrapper />
      </div>
    </section>

    <!-- ════════════════ THE PROBLEM ════════════════ -->
    <section
      class="homepage-panel homepage-panel-problem relative isolate overflow-hidden px-4"
    >
      <div
        class="homepage-panel-glow homepage-panel-glow-left"
        aria-hidden="true"
      >
      </div>
      <div class="homepage-panel-inner mx-auto max-w-5xl px-4 sm:px-6">
        <div class="problem-grid">
          <!-- Left: bold statement -->
          <div class="problem-statement">
            <p class="homepage-section-label">The Reality</p>
            <h2
              class="font-serif text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-site-text tracking-tighter leading-[1.05] mb-6"
            >
              Getting Answers
              <span class="text-cta block sm:inline"> Should Not Be This Hard</span>
            </h2>
            <p class="text-site-sub text-base sm:text-lg leading-relaxed max-w-lg font-medium">
              Twilight Psychology provides specialized evaluations for ADHD, Autism, and learning disorders, 
              specifically tailored to the adult experience. 
              Unlike insurance-constrained or pediatric-focused models, our expertise also includes adoption 
              evaluations, ESA letters, guardianship assessments, and psychoeducational testing.
              <a href="/specialities" class="text-cta font-semibold hover:underline">
                Explore our specialty evaluations
              </a>
            </p>
          </div>

          <!-- Right: staggered pain points -->
          <div class="problem-points" role="list">
            {problemPoints.map((point) => (
              <div class="problem-point" role="listitem">
                <span class="problem-point-marker" aria-hidden="true"></span>
                <div>
                  <h3 class="font-sans text-base sm:text-lg font-bold text-site-text mb-1">
                    {point.title}
                  </h3>
                  <p class="text-sm text-site-sub leading-relaxed">
                    {point.desc}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section
      class="homepage-panel homepage-panel-services relative isolate overflow-hidden px-4"
    >
      <div
        class="homepage-panel-glow homepage-panel-glow-right"
        aria-hidden="true"
      >
      </div>
      <div class="homepage-panel-inner mx-auto max-w-5xl px-4 sm:px-6">
        <div
          class="mb-14 flex flex-col gap-6 md:flex-row md:items-end md:justify-between"
        >
          <div>
            <p class="homepage-section-label">Core services</p>
            <h2
              class="font-serif text-4xl md:text-5xl lg:text-6xl font-black text-site-text tracking-tighter"
            >
              How We Can Help
            </h2>
          </div>
          <p
            class="max-w-md text-sm md:text-base leading-relaxed text-site-sub"
          >
            "Twilight Psychology delivers the clinical depth to guide confident,
            informed decisions."
          </p>
        </div>

        <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
          {
            services.map((service, idx) => (
              <div class="group homepage-service-card relative flex h-full flex-col rounded-4xl border theme-border p-9 sm:p-11 transition-all duration-500 overflow-hidden min-h-56 hover:border-cta/20 active:scale-[0.98] hover:shadow-lg hover:shadow-cta/10">
                <div class="relative z-10 flex h-full flex-col">
                  <div class="mb-5 flex items-center gap-3">
                    <Icon
                      name={service.icon}
                      class="w-9 h-9 text-site-sub shrink-0"
                      style="color: var(--color-icon);"
                    />
                    <h3 class="font-serif text-xl sm:text-2xl font-black text-site-text tracking-tight group-hover:text-cta transition-colors">
                      {service.title}
                    </h3>
                  </div>
                  <p class="mb-7 text-sm sm:text-base leading-relaxed text-site-sub">
                    {service.desc}
                  </p>

                  <a
                    href={service.link}
                    class="mt-auto inline-flex items-center gap-3 text-xs font-black uppercase tracking-widest text-cta/80 group-hover:text-cta transition-colors"
                  >
                    Explore Service
                    <span class="w-8 h-px bg-cta/30 group-hover:w-12 group-hover:bg-cta transition-all" />
                  </a>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="quality-care"
      class="homepage-panel homepage-panel-care relative isolate overflow-hidden px-4"
    >
      <div
        class="homepage-panel-glow homepage-panel-glow-left"
        aria-hidden="true"
      >
      </div>
      <div class="homepage-panel-inner mx-auto max-w-5xl px-4 sm:px-6">
        <header class="mx-auto mb-12 max-w-3xl text-center">
          <p class="homepage-section-label">Designed for clarity</p>
          <h2
            class="font-serif text-4xl md:text-5xl lg:text-6xl font-black text-site-text mb-5"
          >
            Elevated Care, <span class="text-cta">Five</span> Fewer Barriers
          </h2>
          <p
            class="text-site-sub text-lg max-w-2xl mx-auto text-center leading-relaxed"
          >
            Our evaluation process is built for precision and
            efficiency—delivering clinically grounded answers without
            unnecessary delays or complexity.
          </p>
        </header>

        <!-- ── Quality Care interactive panel (Preact) ── -->
        <QualityCareTabsWrapper
          items={qualityCareItems.map((item) => ({
            title: item.title,
            description: item.desc,
            link: item.link,
          }))}
        />
      </div>
    </section>

    <section
      class="homepage-panel homepage-panel-cta relative isolate overflow-hidden px-4"
    >
      <div class="homepage-panel-inner mx-auto max-w-5xl">
        <div
          class="homepage-cta-shell rounded-[2.5rem] border theme-border px-6 py-10 sm:px-10 sm:py-14 text-center"
        >
          <p class="homepage-section-label justify-center">Next step</p>
          <h2
            class="font-serif text-4xl md:text-5xl lg:text-6xl font-black mb-6 tracking-tighter text-site-text"
          >
            Ready to Get Started
          </h2>
          <p
            class="mx-auto mb-10 max-w-2xl text-base sm:text-lg leading-relaxed text-site-sub"
          >
            Whether you are pursuing diagnostic clarity, individualized therapy,
            or psychiatric medication management, our team is prepared to guide
            you through a structured, seamless process.
          </p>
          <div
            class="flex flex-col sm:flex-row gap-6 justify-center relative z-10"
          >
            <a
              href="/resources/new-client"
              class="px-10 py-4 theme-surface-2 text-site-text border theme-border-strong font-black rounded-full theme-hover-surface transition-all hover:scale-105 shadow-lg"
            >
              Steps for New Clients
            </a>
            <a
              href="/about/clinicians/clinicians-lex-ky"
              class="px-10 py-4 bg-cta text-cta-fg border border-button-border font-black rounded-full theme-hover-surface transition-all"
            >
              Meet Our Clinicians
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  @keyframes panelGlowBreath {
    0%,
    100% {
      opacity: 0.6;
    }
    50% {
      opacity: 0.85;
    }
  }

  :global(body:has(.homepage-shell)) {
    scroll-snap-type: y proximity;
  }

  .homepage-shell {
    position: relative;
  }

  .homepage-shell::before {
    /* Top radial glow removed to prevent movement while scrolling */
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background: none;
    z-index: 0;
  }

  .homepage-panel {
    position: relative;
    min-height: calc(100svh - var(--homepage-chrome-offset));
    display: flex;
    align-items: center;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    border-top: 1px solid rgba(var(--rgb-accent), 0.08);
  }

  .homepage-panel:first-child {
    border-top: 0;
  }

  .homepage-panel-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  .homepage-panel-hero {
    --homepage-chrome-offset: 4rem;
    background: rgba(var(--rgb-bg), 0.85);
  }

  @media (min-width: 640px) {
    .homepage-panel-hero {
      --homepage-chrome-offset: 5rem;
    }
    .homepage-panel-inner {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }
  }

  @media (min-width: 768px) {
    .homepage-panel-hero {
      --homepage-chrome-offset: 6.5rem;
    }
    .homepage-panel-inner {
      padding-top: 7.5rem;
      padding-bottom: 7.5rem;
    }
  }

  .homepage-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: calc(100svh - var(--homepage-chrome-offset, 4rem));
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  @media (min-width: 640px) {
    .homepage-hero-inner {
      min-height: auto;
      padding-top: 4.5rem;
      padding-bottom: 4.5rem;
    }
  }

  .homepage-panel-care {
    --homepage-chrome-offset: 6.5rem;
    background:
      radial-gradient(
        ellipse 50% 60% at 12% 50%,
        rgba(var(--rgb-accent), 0.05),
        transparent
      ),
      rgba(var(--rgb-bg), 0.95);
  }

  .homepage-panel-problem {
    --homepage-chrome-offset: 6.5rem;
    background:
      radial-gradient(
        ellipse 50% 60% at 12% 50%,
        rgba(var(--rgb-accent), 0.05),
        transparent
      ),
      rgba(var(--rgb-bg), 0.94);
  }

  .problem-grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .problem-grid {
      grid-template-columns: 5fr 6fr;
      gap: 4rem;
      align-items: center;
    }
  }

  .problem-statement {
    position: sticky;
    top: 6rem;
  }

  @media (max-width: 1023px) {
    .problem-statement {
      position: static;
      text-align: center;
    }

    .problem-statement p:last-child {
      margin-left: auto;
      margin-right: auto;
    }
  }

  .problem-points {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .problem-point {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid rgba(var(--rgb-accent), 0.1);
    position: relative;
  }

  .problem-point:first-child {
    border-top: 1px solid rgba(var(--rgb-accent), 0.1);
  }

  .problem-point-marker {
    position: relative;
    flex-shrink: 0;
    width: 0.625rem;
    height: 0.625rem;
    margin-top: 0.45rem;
    border-radius: 9999px;
    background: var(--color-cta);
    opacity: 0.6;
  }

  .problem-point-marker::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 9999px;
    border: 1.5px solid var(--color-cta);
    opacity: 0.25;
  }

  .homepage-panel-services {
    --homepage-chrome-offset: 6.5rem;
    background:
      radial-gradient(
        ellipse 50% 60% at 88% 50%,
        rgba(var(--rgb-accent), 0.05),
        transparent
      ),
      rgba(var(--rgb-bg), 0.97);
  }

  .homepage-panel-cta {
    --homepage-chrome-offset: 6.5rem;
    background:
      radial-gradient(
        ellipse 40% 50% at 50% 40%,
        rgba(var(--rgb-accent), 0.04),
        transparent
      ),
      rgba(var(--rgb-bg), 0.99);
  }

  .homepage-panel-glow {
    position: absolute;
    border-radius: 9999px;
    filter: blur(80px);
    opacity: 0.7;
    pointer-events: none;
    animation: panelGlowBreath 8s ease-in-out infinite;
  }

  .homepage-panel-glow-top {
    top: 8%;
    right: 10%;
    width: 18rem;
    height: 18rem;
    background: rgba(var(--rgb-accent), 0.2);
  }

  .homepage-panel-glow-bottom {
    bottom: 10%;
    left: 8%;
    width: 14rem;
    height: 14rem;
    background: rgba(var(--rgb-accent), 0.1);
    animation-delay: 1.8s;
  }

  .homepage-panel-glow-left {
    top: 40%;
    left: 2%;
    width: 18rem;
    height: 18rem;
    background: rgba(var(--rgb-accent), 0.07);
    animation-delay: 2.6s;
  }

  .homepage-panel-glow-right {
    right: 2%;
    top: 40%;
    width: 18rem;
    height: 18rem;
    background: rgba(var(--rgb-accent), 0.07);
    animation-delay: 3.4s;
  }

  .homepage-feature-card,
  .homepage-glass-card,
  .homepage-service-card {
    background: rgba(var(--rgb-accent), 0.06);
    box-shadow: inset 0 1px 0 rgba(var(--rgb-accent), 0.08);
    backdrop-filter: blur(20px);
  }

  .homepage-cta-shell {
    background: rgba(var(--rgb-surface), 0.55);
    box-shadow: none;
    backdrop-filter: none;
  }

  .homepage-stat-card {
    padding: 1.25rem 0;
    border-top: 1px solid rgba(var(--rgb-accent), 0.1);
  }

  .homepage-stat-card:first-of-type {
    border-top: 0;
    padding-top: 0.25rem;
  }

  .homepage-section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--theme-section-label);
  }

  .homepage-section-label::before,
  .homepage-section-label::after {
    content: "";
    width: 2.5rem;
    height: 1px;
    background: var(--theme-section-label-line);
  }

  .homepage-service-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(var(--rgb-accent), 0.08),
      transparent 40%,
      rgba(var(--rgb-accent-alt), 0.05)
    );
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .homepage-service-card:hover::before {
    opacity: 1;
  }

  @media (min-width: 768px) {
    :global(body:has(.homepage-shell)) {
      scroll-snap-type: y mandatory;
    }

    /* Removed homepage-shell::before animation-duration */

    .homepage-panel-glow {
      animation-duration: 7s;
    }

    .homepage-panel,
    .homepage-panel-hero,
    .homepage-panel-care,
    .homepage-panel-services,
    .homepage-panel-cta {
      --homepage-chrome-offset: 7.25rem;
    }
  }

  @media (max-width: 767px) {
    .homepage-panel {
      min-height: 100svh;
    }

    /* Removed homepage-shell::before animation-duration and opacity */

    .homepage-panel-glow {
      animation-duration: 12s;
      opacity: 0.5;
      filter: blur(66px);
    }

    .homepage-panel-inner {
      padding-top: 2rem;
      padding-bottom: 2rem;
    }

    .homepage-panel-hero .homepage-panel-inner {
      padding-top: 1.5rem;
      padding-bottom: 1.5rem;
    }

    .homepage-section-label::before,
    .homepage-section-label::after {
      width: 1.5rem;
    }
  }

  @media (min-width: 1280px) {
    /* Removed homepage-shell::before animation-duration */

    .homepage-panel-glow {
      opacity: 0.8;
      filter: blur(88px);
    }
  }

  /* ── Mobile accordion (< lg) ── */

  .care-accordion {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  @media (min-width: 1024px) {
    .care-accordion {
      display: none;
    }
  }

  .care-accordion-item {
    border: 1px solid rgba(var(--rgb-accent), 0.12);
    border-radius: 1rem;
    background: rgba(var(--rgb-accent), 0.04);
    overflow: hidden;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .care-accordion-item.open {
    border-color: rgba(var(--rgb-accent), 0.22);
    background: rgba(var(--rgb-accent), 0.08);
  }

  .care-accordion-trigger {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    padding: 1rem 1.25rem;
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    color: inherit;
  }

  .care-accordion-trigger:focus-visible {
    outline: 2px solid rgba(var(--rgb-accent), 0.85);
    outline-offset: -2px;
    border-radius: 1rem;
  }

  .care-accordion-icon {
    opacity: 0.5;
    transition: opacity 0.2s ease;
  }

  .care-accordion-item.open .care-accordion-icon {
    opacity: 1;
  }

  .care-accordion-title {
    color: var(--color-site-sub);
    transition: color 0.2s ease;
  }

  .care-accordion-item.open .care-accordion-title {
    color: var(--color-site-text);
  }

  .care-accordion-chevron {
    color: var(--color-site-sub);
    transition: transform 0.3s ease, color 0.2s ease;
  }

  .care-accordion-item.open .care-accordion-chevron {
    transform: rotate(180deg);
    color: var(--color-cta);
  }

  .care-accordion-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }

  .care-accordion-item.open .care-accordion-body {
    grid-template-rows: 1fr;
  }

  .care-accordion-content {
    overflow: hidden;
    padding: 0 1.25rem;
    min-height: 0;
  }

  .care-accordion-item.open .care-accordion-content {
    padding-bottom: 1.25rem;
  }

  :root.light .care-accordion-item {
    background: rgba(var(--rgb-surface), 0.5);
  }

  :root.light .care-accordion-item.open {
    background: rgba(var(--rgb-surface), 0.8);
  }

  /* ── Desktop tab/panel (visible lg+) ── */

  .care-two-panel {
    display: none;
  }

  @media (min-width: 1024px) {
    .care-two-panel {
      display: grid;
      gap: 2.5rem;
      align-items: start;
      grid-template-columns: minmax(240px, 5fr) 7fr;
    }
  }

  .care-hint {
    padding: 0 0.25rem 0.75rem;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--theme-section-label);
    opacity: 0.4;
  }

  .care-tab-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .care-tab {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    padding: 0.875rem 1.25rem;
    text-align: left;
    border: 1px solid rgba(var(--rgb-accent), 0.1);
    border-left: 3px solid transparent;
    border-radius: 0.875rem;
    background: rgba(var(--rgb-accent), 0.15);
    cursor: pointer;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.15s ease;
  }

  .care-tab:hover:not(.active) {
    background: rgba(var(--rgb-accent), 0.06);
    transform: translateX(2px);
  }

  .care-tab:focus-visible {
    outline: 2px solid rgba(var(--rgb-accent), 0.85);
    outline-offset: 2px;
  }

  .care-tab-icon {
    opacity: 0.4;
    transition: opacity 0.2s ease;
  }

  .care-tab-title {

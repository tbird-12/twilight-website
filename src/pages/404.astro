---
import Layout from '../layouts/Layout.astro';
import { Image } from "astro:assets";
import { PHONE_NUMBER, PHONE_NUMBER_FORMATTED } from "../data/resource";
import logo from "../assets/images/logo.png";
---

<Layout
  title="404 Not Found | Twilight Psychology"
  description="The page you're looking for doesn't exist. Explore Twilight Psychology's services and resources to find the support you need."
  robots="noindex, follow"
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <section class="relative py-24 px-4 overflow-hidden border-b border-border min-h-screen flex items-center">
    <div class="absolute inset-0 z-0 opacity-5">
      <Image
        src={logo}
        class="w-full h-full object-cover"
        alt="Background"
        loading="lazy"
        widths={[400, 800]}
        sizes="100vw"
      />
    </div>
    <div class="max-w-4xl mx-auto text-center relative z-20 w-full">
      <span class="px-4 py-1.5 mb-6 text-[10px] font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full inline-block">
        Page Not Found
      </span>
      
      <h1 class="font-serif text-8xl md:text-9xl font-black text-site-text mb-6 tracking-tighter leading-[0.9]">
        <span class="text-cta">
          404
        </span>
      </h1>
      
      <h2 class="font-serif text-4xl md:text-5xl font-black text-site-text mb-6 tracking-tight">
        Lost in the Twilight
      </h2>
      
      <p class="text-xl text-site-sub font-medium max-w-2xl mx-auto leading-relaxed mb-12">
        The page you're looking for doesn't exist or has been moved to another location.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href="/"
          class="inline-block bg-cta text-cta-fg px-8 py-4 rounded-full font-black text-sm hover:bg-cta/80 hover:ring-4 hover:ring-cta/30 transition-all shadow-lg shadow-cta/20 active:scale-95"
        >
          Back to Home
        </a>
        
        <a
          href="/about/twilight-psychology"
          class="inline-block bg-surface-soft text-sand px-8 py-4 rounded-full font-black text-sm border border-border-strong hover:bg-surface-2/30 hover:border-cta/40 transition-all"
        >
          About Twilight Psychology
        </a>
      </div>

      <div class="mt-16 pt-12 border-t border-border">
        <p class="text-site-sub text-sm mb-6 font-bold">Need Help?</p>
        <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
          <a
            href={`tel:${PHONE_NUMBER}`}
            class="flex items-center gap-2 text-cta font-black hover:text-cta transition-colors"
          >
            <span>📞</span> {PHONE_NUMBER_FORMATTED}
          </a>
          <a
            href="/resources/faq"
            class="flex items-center gap-2 text-cta font-black hover:text-cta transition-colors"
          >
            <span>❓</span> FAQ
          </a>
        </div>
      </div>
    </div>
  </section>
      </div>
    </div>
  </div>
</Layout>

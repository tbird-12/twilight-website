---
import ServiceLayout from "../layouts/ServiceLayout.astro";
import "../styles/global.css";
import {
  PHONE_NUMBER,
  PHONE_NUMBER_FORMATTED,
  FAX_NUMBER_FORMATTED,
  EMAIL_ADDRESS,
  SIGN_IN_LINK,
  WIDGET_LINK,
  REFERRAL_LINK,
} from "../data/resource";
---

<ServiceLayout
  name="Contact Us"
  description="Reach Twilight Psychology by phone, email, or our intake widget"
  metaDescription="Contact Twilight Psychology by phone, email, or online widget. For emergencies, call 911 or 988."
>
  <section class="bg-site-bg min-h-screen py-16 md:py-24 px-4">
    <div class="max-w-5xl mx-auto">
      <header class="text-center mb-10 md:mb-14">
        <div class="inline-block px-3 md:px-4 py-1.5 mb-5 md:mb-6 rounded-full bg-slate-800/50 border border-slate-700 text-cta text-[11px] md:text-xs font-black uppercase tracking-widest">
          Contact Twilight Psychology
        </div>
        <h1 class="font-serif text-3xl sm:text-4xl md:text-6xl font-black text-site-text mb-4 leading-tight">
          How To <span class="text-cta">Reach Us</span>
        </h1>
        <p class="text-site-sub text-base md:text-lg font-medium max-w-2xl mx-auto leading-relaxed px-2 sm:px-0">
          We are here to help you get started. Reach out by form, phone, or email and our team will guide your next step.
        </p>
      </header>

      <section class="mb-8 md:mb-10 rounded-4xl border border-amber-300/30 bg-linear-to-br from-amber-300/25 to-slate-800/20 p-6 sm:p-8 md:p-10">
        <h2 class="font-serif text-2xl md:text-3xl font-black text-site-text mb-3 md:mb-4">Emergency Support</h2>
        <p class="text-site-text leading-relaxed mb-5 md:mb-6 text-sm sm:text-base">
          If you are in immediate danger or need urgent help, do not wait for office response.
        </p>
        <div class="grid gap-4 md:grid-cols-3">
          <a
            href="tel:911"
            class="rounded-2xl border border-white/20 bg-white/5 px-4 sm:px-5 py-4 hover:bg-white/10 transition-colors"
          >
            <p class="text-xs font-black uppercase tracking-widest text-cta">Immediate Emergency</p>
            <p class="text-xl sm:text-2xl font-black text-site-text mt-1">Call 911</p>
          </a>
          <a
            href="tel:988"
            class="rounded-2xl border border-white/20 bg-white/5 px-4 sm:px-5 py-4 hover:bg-white/10 transition-colors"
          >
            <p class="text-xs font-black uppercase tracking-widest text-cta">Mental Health Crisis</p>
            <p class="text-xl sm:text-2xl font-black text-site-text mt-1">Call 988</p>
          </a>
          <div class="rounded-2xl border border-white/20 bg-white/5 px-4 sm:px-5 py-4">
            <p class="text-xs font-black uppercase tracking-widest text-cta">Important Note</p>
            <p class="text-site-sub text-sm mt-2 leading-relaxed">
              Messages sent through email, phone, or forms are not monitored for emergency response.
            </p>
          </div>
        </div>
      </section>

      <section class="mt-10 md:mt-12 rounded-4xl border border-slate-700 bg-slate-800/20 p-6 sm:p-8 md:p-10" data-contact-tabs-root>
        <div class="mb-3 flex items-center justify-between px-1 text-xs text-site-sub/80">
          <p class="font-semibold uppercase tracking-wider">Select the path that fits you</p>
          <p class="hidden lg:block">Scroll to explore</p>
        </div>

        <div class="relative mb-6">
          <div class="pointer-events-none absolute inset-y-0 left-0 w-8 bg-linear-to-r from-site-bg to-transparent hidden lg:block"></div>
          <div class="pointer-events-none absolute inset-y-0 right-0 w-8 bg-linear-to-l from-site-bg to-transparent hidden lg:block"></div>
          <div
            class="flex flex-col lg:flex-row gap-3 pb-2 lg:overflow-x-auto lg:snap-x lg:snap-mandatory"
            role="tablist"
            aria-label="Contact pathways"
          >
            <button
              type="button"
              id="contact-tab-providers"
              role="tab"
              aria-controls="contact-panel-providers"
              aria-selected="true"
              data-contact-tab-trigger
              data-target="contact-panel-providers"
              class="w-full lg:w-auto snap-start px-5 py-4 rounded-2xl border transition-all duration-200 font-serif font-black text-sm tracking-wide bg-cta text-site-bg border-cta shadow-lg shadow-cta/20"
            >
              <span class="flex items-center gap-3 text-left">
                <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-site-bg/20 text-[11px] font-black">1</span>
                <span class="leading-tight">
                  <span class="block">Providers</span>
                  <span class="block text-[10px] uppercase tracking-wider opacity-80">Referrals and Records</span>
                </span>
              </span>
            </button>

            <button
              type="button"
              id="contact-tab-existing"
              role="tab"
              aria-controls="contact-panel-existing"
              aria-selected="false"
              data-contact-tab-trigger
              data-target="contact-panel-existing"
              class="w-full lg:w-auto snap-start px-5 py-4 rounded-2xl border transition-all duration-200 font-serif font-black text-sm tracking-wide bg-white/5 text-site-text border-white/10 hover:border-cta/50 hover:text-cta opacity-80"
            >
              <span class="flex items-center gap-3 text-left">
                <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10 text-[11px] font-black">2</span>
                <span class="leading-tight">
                  <span class="block">Existing Clients</span>
                  <span class="block text-[10px] uppercase tracking-wider opacity-80">Portal and support</span>
                </span>
              </span>
            </button>

            <button
              type="button"
              id="contact-tab-future"
              role="tab"
              aria-controls="contact-panel-future"
              aria-selected="false"
              data-contact-tab-trigger
              data-target="contact-panel-future"
              class="w-full lg:w-auto snap-start px-5 py-4 rounded-2xl border transition-all duration-200 font-serif font-black text-sm tracking-wide bg-white/5 text-site-text border-white/10 hover:border-cta/50 hover:text-cta opacity-80"
            >
              <span class="flex items-center gap-3 text-left">
                <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10 text-[11px] font-black">3</span>
                <span class="leading-tight">
                  <span class="block">Future Clients</span>
                  <span class="block text-[10px] uppercase tracking-wider opacity-80">Start care with us</span>
                </span>
              </span>
            </button>
          </div>
        </div>

        

        <article
          id="contact-panel-existing"
          role="tabpanel"
          aria-labelledby="contact-tab-existing"
          data-contact-tab-panel
          class="hidden rounded-3xl border border-slate-700 bg-site-bg/40 p-6 sm:p-8"
        >
          <h2 class="font-serif text-2xl md:text-3xl font-black text-site-text mb-3 leading-tight">Existing Client Portal</h2>
          <p class="text-site-sub leading-relaxed text-sm sm:text-base mb-6">
            Already a client? Sign in to your secure portal to message your provider, review documents, and manage upcoming appointments.
          </p>
          <div class="flex flex-col gap-3">
            <a
              href={SIGN_IN_LINK}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex self-start items-center rounded-md bg-cta px-4 py-2 text-sm font-black text-cta-fg hover:bg-cta/80 transition-colors duration-300"
            >
              Portal Sign In
            </a>
            <p class="text-sm text-site-sub">
              Need immediate assistance? Call <a href={`tel:${PHONE_NUMBER}`} class="text-cta underline hover:text-site-text transition-colors">{PHONE_NUMBER_FORMATTED}</a>.
            </p>
          </div>
        </article>

        <article
          id="contact-panel-future"
          role="tabpanel"
          aria-labelledby="contact-tab-future"
          data-contact-tab-panel
          class="hidden"
        >
          <article class="rounded-3xl border border-slate-700 bg-site-bg/40 p-6 sm:p-8">
            <h2 class="font-serif text-2xl md:text-3xl font-black text-site-text mb-3">Start As A Future Client</h2>
            <p class="text-site-sub leading-relaxed text-sm sm:text-base mb-6">
              Use our secure intake form to request an appointment and share what kind of support you are looking for.
            </p>
            <div class="flex flex-col gap-3">
              <a
                href={WIDGET_LINK}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex self-start items-center rounded-md bg-cta px-4 py-2 text-sm font-black text-cta-fg hover:bg-cta/80 transition-colors duration-300"
              >
                Open Intake Form
              </a>
              <p class="text-sm text-site-sub">
                Prefer direct contact? Call <a href={`tel:${PHONE_NUMBER}`} class="text-cta underline hover:text-site-text transition-colors">{PHONE_NUMBER_FORMATTED}</a> or email <a href={`mailto:${EMAIL_ADDRESS}`} class="text-cta underline hover:text-site-text transition-colors">{EMAIL_ADDRESS}</a>.
              </p>
            </div>
          </article>
        </article>
      
        <article
          id="contact-panel-providers"
          role="tabpanel"
          aria-labelledby="contact-tab-providers"
          data-contact-tab-panel
          class="rounded-3xl border border-slate-700 bg-site-bg/40 p-6 sm:p-8"
        >
          <h2 class="font-serif text-2xl md:text-3xl font-black text-site-text mb-3">Referral Information</h2>
          <p class="text-site-sub leading-relaxed text-sm sm:text-base mb-6">
            Providers and care teams can submit a referral using our referral form and fax it to {FAX_NUMBER_FORMATTED}. Include relevant records and contact details so we can follow up quickly.
          </p>
          <div class="flex flex-col gap-3">
            <a
              href={REFERRAL_LINK}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex self-start items-center rounded-md bg-cta px-4 py-2 text-sm font-black text-cta-fg hover:bg-cta/80 transition-colors duration-300"
            >
              Submit Referral
            </a>
            <p class="text-sm text-site-sub">
              Questions before referring? Call <a href={`tel:${PHONE_NUMBER}`} class="text-cta underline hover:text-site-text transition-colors">{PHONE_NUMBER_FORMATTED}</a>.
            </p>
          </div>
        </article>
      </section>

      <section class="mt-10 md:mt-12 rounded-4xl border border-slate-700 bg-slate-800/20 p-6 sm:p-8 text-center">
        <h2 class="font-serif text-2xl font-black text-site-text mb-3">Clinical Hours</h2>
        <p class="text-site-sub text-sm sm:text-base mb-1">Mon - Fri: 8:00 AM - 7:00 PM</p>
        <p class="text-site-sub">Sat - Sun: By appointment</p>
      </section>
    </div>
  </section>

  <script is:inline>
    const contactTabsRoot = document.querySelector("[data-contact-tabs-root]");

    if (contactTabsRoot) {
      const triggers = Array.from(
        contactTabsRoot.querySelectorAll("[data-contact-tab-trigger]"),
      );
      const panels = Array.from(
        contactTabsRoot.querySelectorAll("[data-contact-tab-panel]"),
      );

      const activateContactTab = (targetId) => {
        triggers.forEach((trigger) => {
          const isActive = trigger.dataset.target === targetId;
          trigger.setAttribute("aria-selected", String(isActive));
          trigger.classList.toggle("bg-cta", isActive);
          trigger.classList.toggle("text-site-bg", isActive);
          trigger.classList.toggle("border-cta", isActive);
          trigger.classList.toggle("shadow-lg", isActive);
          trigger.classList.toggle("shadow-cta/20", isActive);
          trigger.classList.toggle("opacity-100", isActive);
          trigger.classList.toggle("bg-white/5", !isActive);
          trigger.classList.toggle("text-site-text", !isActive);
          trigger.classList.toggle("border-white/10", !isActive);
          trigger.classList.toggle("opacity-80", !isActive);
        });

        panels.forEach((panel) => {
          panel.classList.toggle("hidden", panel.id !== targetId);
        });
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener("click", () => {
          const targetId = trigger.dataset.target;
          if (targetId) {
            activateContactTab(targetId);
          }
        });
      });
    }
  </script>
</ServiceLayout>
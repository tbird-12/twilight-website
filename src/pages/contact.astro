---
import ServiceLayout from "../layouts/ServiceLayout.astro";
import "../styles/global.css";
import {
  PHONE_NUMBER,
  PHONE_NUMBER_FORMATTED,
  FAX_NUMBER_FORMATTED,
  EMAIL_ADDRESS,
  WIDGET_LINK,
  REFERRAL_LINK,
} from "../data/resource";

const contactMethods = [
  {
    title: "Online Intake Form",
    description:
      "Use our secure contact form to request an appointment, complete forms, and share what support you need.",
    href: WIDGET_LINK,
    cta: "Open Intake Form",
    external: true,
  },
  {
    title: "Call Our Office",
    description:
      "Speak with our team about scheduling, referrals, insurance questions, or next steps.",
    href: `tel:${PHONE_NUMBER}`,
    cta: PHONE_NUMBER_FORMATTED,
  },
  {
    title: "Email Our Team",
    description:
      "Send us your questions and we will respond as soon as possible during business hours.",
    href: `mailto:${EMAIL_ADDRESS}`,
    cta: "Email Us",
  },
];
---

<ServiceLayout
  name="Contact Us"
  description="Reach Twilight Psychology by phone, email, or our intake widget"
  metaDescription="Contact Twilight Psychology by phone, email, or online widget. For emergencies, call 911 or 988."
>
  <section class="bg-site-bg min-h-screen py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <header class="text-center mb-14">
        <div class="inline-block px-4 py-1.5 mb-6 rounded-full bg-slate-800/50 border border-slate-700 text-cta text-xs font-black uppercase tracking-widest">
          Contact Twilight Psychology
        </div>
        <h1 class="font-serif text-4xl md:text-6xl font-black text-site-text mb-4">
          How To <span class="text-cta">Reach Us</span>
        </h1>
        <p class="text-sand text-lg max-w-2xl mx-auto">
          We are here to help you get started. Reach out by form, phone, or email and our team will guide your next step.
        </p>
      </header>

      <section class="mb-10 rounded-4xl border border-amber-300/30 bg-linear-to-br from-amber-300/25 to-slate-800/20 p-8 md:p-10">
        <h2 class="font-serif text-2xl md:text-3xl font-black text-site-text mb-4">Emergency Support</h2>
        <p class="text-site-text leading-relaxed mb-6">
          If you are in immediate danger or need urgent help, do not wait for an office response.
        </p>
        <div class="grid gap-4 md:grid-cols-3">
          <a
            href="tel:911"
            class="rounded-2xl border border-white/20 bg-white/5 px-5 py-4 hover:bg-white/10 transition-colors"
          >
            <p class="text-xs font-black uppercase tracking-widest text-cta">Immediate Emergency</p>
            <p class="text-2xl font-black text-site-text mt-1">Call 911</p>
          </a>
          <a
            href="tel:988"
            class="rounded-2xl border border-white/20 bg-white/5 px-5 py-4 hover:bg-white/10 transition-colors"
          >
            <p class="text-xs font-black uppercase tracking-widest text-cta">Mental Health Crisis</p>
            <p class="text-2xl font-black text-site-text mt-1">Call 988</p>
          </a>
          <div class="rounded-2xl border border-white/20 bg-white/5 px-5 py-4">
            <p class="text-xs font-black uppercase tracking-widest text-cta">Important Note</p>
            <p class="text-site-sub text-sm mt-2 leading-relaxed">
              Messages sent through email, phone, or forms are not monitored for emergency response.
            </p>
          </div>
        </div>
      </section>

      <section class="grid gap-6 md:grid-cols-3">
        {
          contactMethods.map((method) => (
            <article class="rounded-4xl border border-slate-700 bg-slate-800/20 p-7 backdrop-blur-sm hover:border-cta/50 transition-colors">
              <h2 class="font-serif text-2xl font-black text-site-text mb-3">{method.title}</h2>
              <p class="text-site-sub leading-relaxed mb-6">{method.description}</p>
              <a
                href={method.href}
                target={method.external ? "_blank" : undefined}
                rel={method.external ? "noopener noreferrer" : undefined}
                class="inline-flex items-center justify-center w-full rounded-xl bg-cta px-4 py-3 text-sm font-black text-cta-fg hover:bg-cta/80 transition-colors"
              >
                {method.cta}
              </a>
            </article>
          ))
        }
      </section>

      <section class="mt-12 rounded-4xl border border-slate-700 bg-slate-800/20 p-8 md:p-10">
        <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
          <div class="max-w-2xl">
            <h2 class="font-serif text-2xl md:text-3xl font-black text-site-text mb-3">
              Referral Information
            </h2>
            <p class="text-site-sub leading-relaxed">
              Providers and care teams can submit a referral using our referral form and fax it to {FAX_NUMBER_FORMATTED}.
              Include relevant records and contact details so we can follow up quickly.
            </p>
          </div>
          <a
            href={REFERRAL_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-xl bg-cta px-6 py-3 text-sm font-black text-cta-fg hover:bg-cta/80 transition-colors"
          >
            Open Referral Form
          </a>
        </div>
      </section>

      <section class="mt-12 rounded-4xl border border-slate-700 bg-slate-800/20 p-8 text-center">
        <h2 class="font-serif text-2xl font-black text-site-text mb-3">Clinical Hours</h2>
        <p class="text-site-sub mb-1">Mon - Fri: 8:00 AM - 7:00 PM</p>
        <p class="text-site-sub">Sat - Sun: By appointment</p>
      </section>
    </div>
  </section>
</ServiceLayout>
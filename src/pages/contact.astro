---
import Layout from "../layouts/Layout.astro";
import PageHeroWrapper from "../components/PageHeroWrapper.astro";
import AnimatedSection from "../components/react/primitives/AnimatedSection";
import ContactTabsWrapper from "../components/ContactTabsWrapper.astro";
import PageLinksSection from "../components/PageLinksSection.astro";

const emergencyContacts = [
  { href: "tel:911", label: "Immediate Emergency", action: "Call 911" },
  { href: "tel:988", label: "Mental Health Crisis", action: "Call 988" },
];

const emergencyActionClass =
  "rounded-2xl border border-cta/30 bg-cta/10 px-4 py-5 sm:px-5 transition-all duration-200 hover:scale-[1.02] hover:border-cta/60 hover:bg-cta/20 active:scale-[0.98]";

const contactLinks = [
  {
    href: "/services",
    label: "Compare services",
    description:
      "Review evaluations, therapy, and medication support before you reach out.",
  },
  {
    href: "/resources/new-client",
    label: "New client guide",
    description:
      "See intake steps, required paperwork, and what to expect first.",
  },
  {
    href: "/resources/faq",
    label: "FAQ",
    description:
      "Get quick answers about insurance, wait times, and evaluation coverage.",
  },
];
---

<Layout
  title="Contact Twilight Psychology in Lexington, KY"
  description="Call, email, or request an appointment with Twilight Psychology in Lexington, KY for evaluations, therapy, medication management, and intake support."
>
    <section class="bg-site-bg py-16 md:py-24 px-4">
      <div class="max-w-5xl mx-auto">

        <PageHeroWrapper
          title="How To Reach Us"
          accentWord="Reach Us"
          subtitle="Contact Twilight Psychology in Lexington, KY for evaluations, therapy, medication management, scheduling, paperwork, and intake questions."
          badge="Contact Twilight Psychology"
          size="lg"
        />

        <AnimatedSection client:visible animation="fadeInUp" delay={100}>
          <section class="contact-emergency-shell mb-8 md:mb-10 rounded-4xl border-2 border-cta/40 p-6 sm:p-8 md:p-10 relative overflow-hidden">
            <div class="pointer-events-none absolute top-0 left-0 right-0 h-0.5 bg-linear-to-r from-transparent via-cta to-transparent"></div>
            <div class="inline-block px-3 py-1 mb-4 rounded-full bg-cta/10 border border-cta/30 text-cta text-xs font-black uppercase tracking-widest">
              Emergencies Only
            </div>
            <h2 class="font-serif text-2xl md:text-3xl font-black text-site-text mb-3 md:mb-4">Emergency Support</h2>
            <p class="text-site-text leading-relaxed mb-5 md:mb-6 text-sm sm:text-base">
              If you are in immediate danger or need urgent help, do not wait for office response.
            </p>
            <div class="grid gap-4 md:grid-cols-3">
              {emergencyContacts.map((contact) => (
                <a href={contact.href} class={emergencyActionClass}>
                  <p class="text-xs font-black uppercase tracking-widest text-cta">{contact.label}</p>
                  <p class="mt-1 text-2xl font-black text-site-text sm:text-3xl">{contact.action}</p>
                </a>
              ))}
              <div class="rounded-2xl border border-border bg-surface px-4 py-5 sm:px-5">
                <p class="text-xs font-black uppercase tracking-widest text-site-sub">Important Note</p>
                <p class="text-site-sub text-sm mt-2 leading-relaxed">
                  Messages sent through email, phone, or forms are not monitored for emergency response.
                </p>
              </div>
            </div>
          </section>
        </AnimatedSection>

        <section class="mt-10 md:mt-12 rounded-4xl border border-border-strong bg-surface-2 p-6 sm:p-8 md:p-10">
          <ContactTabsWrapper />
        </section>

        <AnimatedSection client:visible animation="fadeInUp" delay={200}>
          <section class="mt-10 md:mt-12 rounded-4xl border border-border-strong bg-surface-2 p-6 text-center sm:p-8">
            <h2 class="font-serif text-2xl font-black text-site-text mb-3">Clinical Hours</h2>
            <p class="text-site-sub text-sm sm:text-base mb-1">Mon - Fri: 8:00 AM - 7:00 PM</p>
            <p class="text-site-sub">Sat - Sun: By appointment</p>
          </section>
        </AnimatedSection>

        <PageLinksSection
          title="Need context before you reach out?"
          description="These pages answer the questions most people are deciding between right before contacting the office."
          links={contactLinks}
        />
      </div>
    </section>
</Layout>

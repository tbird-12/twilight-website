---
import Layout from "../layouts/Layout.astro";
import {
  PHONE_NUMBER,
  PHONE_NUMBER_FORMATTED,
  FAX_NUMBER_FORMATTED,
  EMAIL_ADDRESS,
  SIGN_IN_LINK,
  WIDGET_LINK,
  REFERRAL_LINK,
} from "../data/resource";
import PageHeroWrapper from "../components/PageHeroWrapper.astro";
import AnimatedSection from "../components/preact/primitives/AnimatedSection";
import Tabs from "../components/preact/primitives/Tabs";
---

<Layout
  title="Contact Us | Twilight Psychology"
  description="Contact Twilight Psychology by phone, email, or online widget. For emergencies, call 911 or 988."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <section class="bg-site-bg min-h-screen py-16 md:py-24 px-4">
    <div class="max-w-5xl mx-auto">

      <PageHeroWrapper
        title="How To Reach Us"
        accentWord="Reach Us"
        subtitle="Our team is ready to assist you. Reach out by form, phone, or email, and we will guide you through the appropriate next step."
        badge="Contact Twilight Psychology"
        size="lg"
      />

      <AnimatedSection client:visible animation="fadeInUp" delay={100}>
        <section class="contact-emergency-shell mb-8 md:mb-10 rounded-4xl border-2 border-cta/40 p-6 sm:p-8 md:p-10 relative overflow-hidden">
          <div class="pointer-events-none absolute top-0 left-0 right-0 h-0.5 bg-linear-to-r from-transparent via-cta to-transparent"></div>
          <div class="inline-block px-3 py-1 mb-4 rounded-full bg-cta/10 border border-cta/30 text-cta text-[11px] font-black uppercase tracking-widest">
            Emergencies Only
          </div>
          <h2 class="font-serif text-2xl md:text-3xl font-black text-site-text mb-3 md:mb-4">Emergency Support</h2>
          <p class="text-site-text leading-relaxed mb-5 md:mb-6 text-sm sm:text-base">
            If you are in immediate danger or need urgent help, do not wait for office response.
          </p>
          <div class="grid gap-4 md:grid-cols-3">
            <a
              href="tel:911"
              class="rounded-2xl border border-cta/30 bg-cta/10 px-4 sm:px-5 py-5 transition-all duration-200 hover:bg-cta/20 hover:border-cta/60 hover:scale-[1.02] active:scale-[0.98]"
            >
              <p class="text-xs font-black uppercase tracking-widest text-cta">Immediate Emergency</p>
              <p class="text-2xl sm:text-3xl font-black text-site-text mt-1">Call 911</p>
            </a>
            <a
              href="tel:988"
              class="rounded-2xl border border-cta/30 bg-cta/10 px-4 sm:px-5 py-5 transition-all duration-200 hover:bg-cta/20 hover:border-cta/60 hover:scale-[1.02] active:scale-[0.98]"
            >
              <p class="text-xs font-black uppercase tracking-widest text-cta">Mental Health Crisis</p>
              <p class="text-2xl sm:text-3xl font-black text-site-text mt-1">Call 988</p>
            </a>
            <div class="rounded-2xl border p-4 sm:px-5 py-5" style="border-color: var(--color-border); background: var(--color-surface)">
              <p class="text-xs font-black uppercase tracking-widest text-site-sub">Important Note</p>
              <p class="text-site-sub text-sm mt-2 leading-relaxed">
                Messages sent through email, phone, or forms are not monitored for emergency response.
              </p>
            </div>
          </div>
        </section>
      </AnimatedSection>

      <section class="mt-10 md:mt-12 rounded-4xl border p-6 sm:p-8 md:p-10" style="border-color: var(--color-border-strong); background: var(--color-surface-2)">
        <Tabs
          client:visible
          scrollOnChange
          tabs={[
            { id: "providers", label: "Providers", sublabel: "Referrals and Records" },
            { id: "existing", label: "Existing Clients", sublabel: "Portal and Support" },
            { id: "future", label: "Future Clients", sublabel: "Start Care with Us" },
            { id: "careers", label: "Careers", sublabel: "Opportunities with Us", isLink: true, href: "/about/careers" },
          ]}
          defaultTab="providers"
        >
          <div id="providers">
            <article class="rounded-3xl border p-6 sm:p-8" style="border-color: var(--color-border-strong); background: var(--color-surface-soft)">
              <h2 class="font-serif text-2xl md:text-3xl font-black text-site-text mb-3">Referral Information</h2>
              <p class="text-site-sub leading-relaxed text-sm sm:text-base mb-6">
                Providers and care teams can submit a referral using our referral form and fax it to {FAX_NUMBER_FORMATTED}. Include relevant records and contact details so we can follow up quickly.
              </p>
              <div class="flex flex-col gap-3">
                <a
                  href={REFERRAL_LINK}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex self-start items-center rounded-md bg-cta px-4 py-2 text-sm font-black text-cta-fg hover:bg-cta/80 transition-colors duration-300"
                >
                  Submit Referral
                </a>
                <p class="text-sm text-site-sub">
                  Questions before referring? Call <a href={`tel:${PHONE_NUMBER}`} class="text-cta underline hover:text-site-text transition-colors">{PHONE_NUMBER_FORMATTED}</a>.
                </p>
              </div>
            </article>
          </div>

          <div id="existing">
            <article class="rounded-3xl border p-6 sm:p-8" style="border-color: var(--color-border-strong); background: var(--color-surface-soft)">
              <h2 class="font-serif text-2xl md:text-3xl font-black text-site-text mb-3 leading-tight">Existing Client Portal</h2>
              <p class="text-site-sub leading-relaxed text-sm sm:text-base mb-6">
                Already a client? Sign in to your secure portal to message your provider, review documents, and manage upcoming appointments.
              </p>
              <div class="flex flex-col gap-3">
                <a
                  href={SIGN_IN_LINK}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex self-start items-center rounded-md bg-cta px-4 py-2 text-sm font-black text-cta-fg hover:bg-cta/80 transition-colors duration-300"
                >
                  Portal Sign In
                </a>
                <p class="text-sm text-site-sub">
                  Need immediate assistance? Call <a href={`tel:${PHONE_NUMBER}`} class="text-cta underline hover:text-site-text transition-colors">{PHONE_NUMBER_FORMATTED}</a>.
                </p>
              </div>
            </article>
          </div>

          <div id="future">
            <article class="rounded-3xl border p-6 sm:p-8" style="border-color: var(--color-border-strong); background: var(--color-surface-soft)">
              <h2 class="font-serif text-2xl md:text-3xl font-black text-site-text mb-3">Begin as a New Client</h2>
              <p class="text-site-sub leading-relaxed text-sm sm:text-base mb-6">
                Use our secure intake form to request an appointment and indicate the type of clinical service you are seeking.
              </p>
              <div class="flex flex-col gap-3">
                <a
                  href={WIDGET_LINK}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex self-start items-center rounded-md bg-cta px-4 py-2 text-sm font-black text-cta-fg hover:bg-cta/80 transition-colors duration-300"
                >
                  Open Intake Form
                </a>
                <p class="text-sm text-site-sub">
                  Prefer direct contact? Call <a href={`tel:${PHONE_NUMBER}`} class="text-cta underline hover:text-site-text transition-colors">{PHONE_NUMBER_FORMATTED}</a> or email <a href={`mailto:${EMAIL_ADDRESS}`} class="text-cta underline hover:text-site-text transition-colors">{EMAIL_ADDRESS}</a>.
                </p>
              </div>
            </article>
          </div>
        </Tabs>
      </section>

      <AnimatedSection client:visible animation="fadeInUp" delay={200}>
        <section class="mt-10 md:mt-12 rounded-4xl border p-6 sm:p-8 text-center" style="border-color: var(--color-border-strong); background: var(--color-surface-2)">
          <h2 class="font-serif text-2xl font-black text-site-text mb-3">Clinical Hours</h2>
          <p class="text-site-sub text-sm sm:text-base mb-1">Mon - Fri: 8:00 AM - 7:00 PM</p>
          <p class="text-site-sub">Sat - Sun: By appointment</p>
        </section>
      </AnimatedSection>
    </div>
  </section>
      </div>
    </div>
  </div>
</Layout>

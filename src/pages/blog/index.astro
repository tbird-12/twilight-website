---
import { getCollection } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import Schema from "../../components/Schema.astro";
import PostCard from "../../components/blog/PostCard.astro";
import { blogCategories, getCategoryMeta } from "../../data/blogCategories";
import { getDisplayBlogDate } from "../../utils/blogDates";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Featured post: most recent
const featuredPost = allPosts[0];
const remainingPosts = allPosts.slice(1);

const featuredCategory = featuredPost ? getCategoryMeta(featuredPost.data.category) : null;
const featuredDateInfo = featuredPost
  ? getDisplayBlogDate(featuredPost.data.pubDate, featuredPost.data.updatedDate)
  : undefined;

const siteUrl = Astro.site || new URL("https://www.twilightpsychology.com");
const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Twilight Psychology Blog",
  description: "Clinical updates, billing guidance, insurance news, and practice announcements from Twilight Psychology.",
  url: new URL("/blog/", siteUrl).href,
  publisher: {
    "@type": "Organization",
    name: "Twilight Psychology",
    url: "https://www.twilightpsychology.com",
  },
};
---

<BlogLayout
  title="Clinical Resources & Updates"
  description="Insights, updates, and clinical resources from Twilight Psychology — covering billing, insurance, clinical practices, and more."
>
  <Schema slot="page-schema" schema={blogSchema} />
  <div class="max-w-5xl mx-auto px-4 sm:px-6">

    <!-- Hero + Featured Post -->
    <section class="aurora-panel rounded-[2rem] border border-border bg-surface-soft px-6 py-10 sm:px-8 sm:py-12">
      <p class="text-xs font-semibold uppercase tracking-widest text-site-sub mb-3">
        Twilight Psychology
      </p>
      <h1 class="blog-gradient-text fluid-display-lg font-heading font-bold mb-3">
        Blog &amp; Resources
      </h1>
      <p class="fluid-lead text-site-sub max-w-2xl mb-10">
        Clinical updates, billing guidance, insurance news, and practice
        announcements from our team.
      </p>

      {featuredPost && featuredDateInfo && (
        <a
          href={`/blog/${featuredPost.id}`}
          class="group block rounded-2xl border border-border bg-surface p-6 sm:p-8 hover:border-border-strong hover:shadow-lg transition-all duration-200"
        >
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="text-xs font-black uppercase tracking-widest text-icon">
              Latest
            </span>
            <span class="text-xs text-site-sub">·</span>
            <span class="text-xs font-medium text-site-sub bg-surface-soft rounded-full px-2.5 py-0.5">
              {featuredCategory?.label}
            </span>
            <span class="text-xs text-site-sub">·</span>
            <time datetime={featuredDateInfo.displayDate.toISOString()} class="text-xs text-site-sub">
              {featuredDateInfo.isUpdated
                ? `Updated ${featuredDateInfo.formattedDate}`
                : featuredDateInfo.formattedDate}
            </time>
          </div>
          <h2 class="font-heading text-[clamp(1.65rem,1.35rem+1.5vw,2.4rem)] font-bold text-site-text group-hover:text-icon transition-colors leading-snug mb-3">
            {featuredPost.data.title}
          </h2>
          <p class="text-base text-site-sub leading-relaxed max-w-3xl mb-4">
            {featuredPost.data.description}
          </p>
          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-icon group-hover:gap-2.5 transition-all">
            Read article
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      )}
    </section>

    <!-- Category pills -->
    <section class="pb-8 border-b border-border">
      <div class="flex flex-wrap gap-2">
        {blogCategories.map((cat) => {
          const count = allPosts.filter((p) => p.data.category === cat.slug).length;
          return (
            <a
              href={`/blog/category/${cat.slug}`}
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium border border-border bg-surface text-site-text hover:border-border-strong hover:bg-surface-soft hover:shadow-sm transition-all duration-200 group"
            >
              <span class="group-hover:text-icon transition-colors">{cat.label}</span>
              <span class="text-xs text-site-sub bg-surface-soft rounded-full px-1.5 py-0.5 min-w-5 text-center">
                {count}
              </span>
            </a>
          );
        })}
      </div>
    </section>

    <!-- All Posts grid -->
    {remainingPosts.length > 0 && (
      <section class="py-10">
        <div class="bento-grid reveal-children">
          {remainingPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </section>
    )}

    {allPosts.length === 0 && (
      <section class="py-20 text-center">
        <p class="text-site-sub">No blog posts published yet. Check back soon.</p>
      </section>
    )}
  </div>
</BlogLayout>

---
import { getCollection, render } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import CategoryBadge from "../../components/blog/CategoryBadge.astro";
import PostCard from "../../components/blog/PostCard.astro";
import { getCategoryMeta } from "../../data/blogCategories";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, category, author, tags } = post.data;
const { Content } = await render(post);

const categoryMeta = getCategoryMeta(category);

const formattedPubDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Related posts: same category, excluding current
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sameCategoryPosts = allPosts
  .filter((p) => p.id !== post.id && p.data.category === category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// If fewer than 3 same-category posts, fill with recent posts from other categories
const otherCategoryPosts = sameCategoryPosts.length < 3
  ? allPosts
      .filter((p) => p.id !== post.id && p.data.category !== category)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
      .slice(0, 3 - sameCategoryPosts.length)
  : [];

const relatedPosts = [...sameCategoryPosts, ...otherCategoryPosts];

// Contextual site links based on blog category
const categoryResourceLinks: Record<string, Array<{ label: string; href: string; desc: string }>> = {
  billing: [
    { label: "Fees & Pricing", href: "/resources/fees", desc: "Current self-pay rates" },
    { label: "Accepted Insurances", href: "/resources/insurances-accepted", desc: "View our insurance panels" },
    { label: "Contact Us", href: "/contact", desc: "Billing questions" },
  ],
  insurance: [
    { label: "Accepted Insurances", href: "/resources/insurances-accepted", desc: "Full provider list" },
    { label: "Fees & Pricing", href: "/resources/fees", desc: "Self-pay options" },
    { label: "New Client Guide", href: "/resources/new-client", desc: "Start the intake process" },
  ],
  clinical: [
    { label: "Our Services", href: "/services", desc: "Evaluations, therapy & more" },
    { label: "Autism Testing", href: "/services/autism-testing", desc: "Comprehensive evaluations" },
    { label: "New Client Guide", href: "/resources/new-client", desc: "Schedule an intake" },
  ],
  business: [
    { label: "Our Locations", href: "/about/locations", desc: "Office addresses & hours" },
    { label: "Contact Us", href: "/contact", desc: "Reach our team" },
    { label: "New Client Guide", href: "/resources/new-client", desc: "Start the intake process" },
  ],
  announcements: [
    { label: "Our Services", href: "/services", desc: "Explore what we offer" },
    { label: "Accepted Insurances", href: "/resources/insurances-accepted", desc: "Insurance panels" },
    { label: "New Client Guide", href: "/resources/new-client", desc: "Get started" },
  ],
};

const resourceLinks = categoryResourceLinks[category] || categoryResourceLinks.announcements;
---

<BlogLayout
  title={title}
  description={description}
  pubDate={pubDate}
  updatedDate={updatedDate}
  author={author}
  category={categoryMeta.label}
>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-xs text-site-sub mb-8" aria-label="Breadcrumb">
      <a href="/blog" class="hover:text-site-text transition-colors">Blog</a>
      <span>/</span>
      <a href={`/blog/category/${category}`} class="hover:text-site-text transition-colors">
        {categoryMeta.label}
      </a>
      <span>/</span>
      <span class="text-site-text truncate max-w-50">{title}</span>
    </nav>

    <!-- Post header -->
    <header class="mb-10">
      <CategoryBadge category={category} size="md" />

      <h1 class="font-['Playfair_Display'] text-3xl sm:text-4xl font-bold text-site-text mt-4 mb-5 leading-tight">
        {title}
      </h1>

      <p class="text-lg text-site-sub leading-relaxed mb-6">
        {description}
      </p>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-site-sub border-y border-border py-3">
        <span>By <strong class="text-site-text">{author}</strong></span>
        <span>·</span>
        <time datetime={pubDate.toISOString()}>Published {formattedPubDate}</time>
        {updatedDate && (
          <>
            <span>·</span>
            <time datetime={updatedDate.toISOString()}>Updated {formattedUpdatedDate}</time>
          </>
        )}
        {tags && tags.length > 0 && (
          <>
            <span>·</span>
            <div class="flex gap-1 flex-wrap">
              {tags.map((tag) => (
                <span class="bg-surface-2 text-site-sub rounded px-1.5 py-0.5">
                  #{tag}
                </span>
              ))}
            </div>
          </>
        )}
      </div>
    </header>

    <!-- Post body -->
    <div class="prose prose-lg max-w-none
      prose-headings:font-['Playfair_Display'] prose-headings:text-site-text
      prose-p:text-site-text prose-p:leading-relaxed
      prose-a:text-icon prose-a:no-underline hover:prose-a:underline
      prose-strong:text-site-text
      prose-li:text-site-text
      prose-blockquote:border-l-border-strong prose-blockquote:text-site-sub
      prose-code:text-site-text prose-code:bg-surface-2 prose-code:rounded prose-code:px-1
      prose-hr:border-border">
      <Content />
    </div>

    <!-- Post footer -->
    <footer class="mt-12 pt-8 border-t border-border">
      <a
        href={`/blog/category/${category}`}
        class="inline-flex items-center gap-1.5 text-sm text-site-sub hover:text-site-text transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4">
          <path fill-rule="evenodd" d="M14 8a.75.75 0 0 1-.75.75H4.56l3.22 3.22a.75.75 0 1 1-1.06 1.06l-4.5-4.5a.75.75 0 0 1 0-1.06l4.5-4.5a.75.75 0 0 1 1.06 1.06L4.56 7.25H13.25A.75.75 0 0 1 14 8Z" clip-rule="evenodd" />
        </svg>
        More in {categoryMeta.label}
      </a>
    </footer>
  </article>

  <!-- Related posts -->
  {relatedPosts.length > 0 && (
    <section class="border-t border-border bg-surface-soft py-12 px-4">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-site-sub mb-6">
          You May Also Be Interested In
        </h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {relatedPosts.map((p) => (
            <PostCard post={p} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Contextual site resource links -->
  <section class="border-t border-border py-10 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-site-sub mb-6">
        Resources on Our Main Site
      </h2>
      <div class="grid gap-3 sm:grid-cols-3">
        {resourceLinks.map((link) => (
          <a
            href={link.href}
            class="group flex flex-col p-4 bg-surface-soft border border-border rounded-2xl hover:border-cta/30 transition-all"
          >
            <span class="text-sm font-bold text-site-text group-hover:text-cta transition-colors">{link.label}</span>
            <span class="text-xs text-site-sub mt-0.5">{link.desc}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BlogLayout>

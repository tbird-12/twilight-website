---
import Layout from '../layouts/Layout.astro';
import { EMAIL_ADDRESS } from '../data/resource';

const policyPoints = [
  {
    title: "Information Collection",
    desc: "This website does not collect any personal information from users. Any information you provide via our contact form widget is sent directly to our client portal and is not stored on this website."
  },
  {
    title: "Analytics & Cookies",
    desc: "We use standard web analytics to see how visitors interact with our site. This uses 'cookies' to track non-identifiable data like browser type."
  },
  {
    title: "Third-Party Links",
    desc: "Our site contains links to secure portals (like SimplePractice). Once you leave our domain, their specific privacy policies apply."
  }
];
---

<Layout
  title="Website Privacy Policy | Twilight Psychology"
  description="Read Twilight Psychology's website privacy policy, including how we handle analytics, cookies, and website form submissions."
>

   <main class="bg-site-bg min-h-screen pb-24 text-site-text">
    <section class="py-24 px-4 border-b border-border bg-surface-soft">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="font-serif text-4xl md:text-6xl font-black mb-4 tracking-tighter">
          Website <span class="text-cta">Privacy Policy.</span>
        </h1>
        <p class="text-site-sub font-medium">Last Updated: February 20, 2026</p>
      </div>
    </section>

    <div class="max-w-4xl mx-auto px-4 mt-12">
      
      <div class="bg-cta/10 border border-cta/30 p-8 rounded-4xl mb-16 relative overflow-hidden">
        <div class="absolute top-0 right-0 p-4 opacity-20">
            <span class="text-4xl">⚠️</span>
        </div>
        <h2 class="font-serif text-cta font-black uppercase text-xs tracking-[0.2em] mb-4">Important Notice</h2>
        <p class="text-site-text text-lg font-bold leading-relaxed">
          This policy applies <span class="italic underline">only</span> to your interaction with this website. 
        </p>
        <p class="text-site-sub mt-4 text-sm leading-relaxed">
          It does not cover your clinical records or Protected Health Information (PHI). Clinical privacy is governed by HIPAA and our Notice of Privacy Practices, which is provided to all clients during the intake process via our secure portal.
        </p>
      </div>

      <div class="space-y-12">
        <section>
          <h2 class="font-serif text-2xl font-black text-site-text mb-6">How We Handle Online Data</h2>
          <div class="grid gap-6">
            {policyPoints.map(point => (
              <div class="p-4 sm:p-8 bg-surface-soft border border-border rounded-3xl">
                <h3 class="font-serif text-sand font-black mb-2">{point.title}</h3>
                <p class="text-site-sub text-sm leading-relaxed">{point.desc}</p>
              </div>
            ))}
          </div>
        </section>

        <article class="prose max-w-none text-site-sub">
          <h2 class="font-serif text-site-text font-black">Data Security</h2>
          <p>
            We do not collect any personal information on this website. We take reasonable measures to protect the information submitted through our email, but we cannot guarantee its security.
            Please note that no email transmission is 100% secure. We recommend using our encrypted client portal for sharing sensitive clinical information.
          </p>

          <h2 class="font-serif text-site-text font-black">Your Consent</h2>
          <p>
            By using our site, you consent to this website-specific privacy policy.
          </p>
        </article>
      </div>

      <div class="mt-20 p-10 bg-surface-soft border border-border rounded-[2.5rem] text-center">
        <h3 class="font-serif text-xl font-black text-site-text mb-2">Web Privacy Questions?</h3>
        <p class="text-site-sub text-sm">For questions regarding this website policy, contact:</p>
        <p class="text-cta font-black mt-4"></p>
          <a href={`mailto:${EMAIL_ADDRESS}`} class="text-cta hover:text-cta transition-colors duration-200">{EMAIL_ADDRESS}</a>
        </p>
      </div>
    </div>
</main>
</Layout>
---
import Layout from "../../layouts/Layout.astro";
import { PHONE_NUMBER } from "../../data/resource";
import PageHeroWrapper from "../../components/PageHeroWrapper.astro";
import AnimatedSection from "../../components/react/primitives/AnimatedSection";
import PageLinksSection from "../../components/PageLinksSection.astro";

type OpeningStatus = "open" | "filled";
type CtaVariant = "solid" | "outline";

interface CareerOpening {
  active: boolean; // ← flip to true to show this posting
  status: OpeningStatus;
  heroLabel: string;
  titleLines: [string, string];
  badgeLabel: string;
  badgeClass: string;
  summary: string;
  highlights?: readonly {
    label: string;
    value: string;
  }[];
  benefits?: readonly string[];
  ctaLabel: string;
  ctaVariant: CtaVariant;
}

/**
 * Hiring pause notice — flip `show` to false when openings resume.
 * This banner replaces the job-card grid whenever no postings are active.
 */
const HIRING_PAUSE_NOTICE = {
  show: true, // ← flip to false when hiring resumes
  heading: "We're Not Hiring Right Now",
  body: "We have welcomed new clinicians joining the practice in July and August 2026 and are not currently anticipating additional openings. Please check back later — we appreciate your interest in Twilight Psychology.",
};

const clinicianBenefits = [
  "Compensation Based on Provider Experience",
  "W2 or 1099 Options",
  "Health & Disability Packages",
  "Latest HIPAA-Compliant EHR",
  "Current Testing Suite & Protocols",
  "Assessment-Focused Referral Stream",
  "Automated Billing & Support",
];


const careerOpenings: CareerOpening[] = [
  {
    active: false, // ← flip to true to publish this posting
    status: "filled",
    heroLabel: "licensed psychologists",
    titleLines: ["Licensed", "Psychologist"],
    badgeLabel: "W2/1099",
    badgeClass: "text-site-text border border-border-strong",
    summary:
      "Seeking Kentucky-licensed psychologists (LP or LPP) for a role centered on psychological and psychoeducational assessments in Lexington and surrounding counties. This opportunity is designed for clinicians who want to focus primarily on testing, diagnostic clarification, and report writing rather than ongoing therapy services.",
    benefits: clinicianBenefits,
    ctaLabel: "Apply to Practice",
    ctaVariant: "solid",
  },
  {
    active: false, // ← flip to true to publish this posting
    status: "filled",
    heroLabel: "doctoral practicum students",
    titleLines: ["Doctoral", "Practicum"],
    badgeLabel: "Clinical",
    badgeClass: "text-cta-fg bg-cta",
    summary:
      "Seeking KY-licensed doctoral Psychology students for 15-20 hours of assessment and therapy work per week. Gain hands-on experience with a diverse caseload from ages 2 and above.",
    highlights: [
      {
        label: "Eligible Licenses",
        value: "T-LPA, LPCA, LCSW, CSW, LMFT",
      },
      {
        label: "Focus Area",
        value:
          "Comprehensive testing, diagnostic review, and clinical consultation.",
      },
      {
        label: "Compensation",
        value:
          "Fixed stipend per pay cycle, as agreed upon and within program guidelines.",
      },
    ],
    ctaLabel: "Request Placement",
    ctaVariant: "outline",
  },
];

const openCareerOpenings = careerOpenings.filter(({ active }) => active);

const formatOpeningList = (labels: readonly string[]) => {
  if (labels.length === 0) {
    return "We do not have any active openings at the moment, but we welcome introductions from clinicians who align with our neuro-affirming practice.";
  }

  if (labels.length === 1) {
    return `We are currently hiring ${labels[0]} — with W2/1099 flexibility and industry-leading support.`;
  }

  if (labels.length === 2) {
    return `We are currently hiring ${labels[0]} and ${labels[1]} — with W2/1099 flexibility and industry-leading support.`;
  }

  return `We are currently hiring ${labels.slice(0, -1).join(", ")}, and ${labels[labels.length - 1]} — with W2/1099 flexibility and industry-leading support.`;
};

const heroSubtitle = formatOpeningList(
  openCareerOpenings.map(({ heroLabel }) => heroLabel),
);

const openingsGridClass =
  openCareerOpenings.length === 1
    ? "max-w-2xl md:grid-cols-1"
    : "max-w-6xl md:grid-cols-2 lg:grid-cols-3";

const careerPageLinks = [
  {
    href: "/about/twilight-psychology",
    label: "About the practice",
    description:
      "Review Twilight's mission, values, and the kind of clinical environment we are building.",
  },
  {
    href: "/about/clinicians/clinicians-lex-ky",
    label: "Meet the team",
    description:
      "See the clinicians and staff who shape the practice day to day.",
  },
  {
    href: "/about/locations",
    label: "See our offices",
    description:
      "Get a feel for the Lexington spaces where therapy, testing, and medication visits happen.",
  },
];
---

<Layout
  title="Careers | Join the Team at Twilight Psychology"
  description="Career opportunities at Twilight Psychology in Lexington, KY. Explore current openings and learn how we support therapists and clinicians."
>
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <PageHeroWrapper
    title="Build Your Career"
    accentWord="Career"
    badge="Join Our Practice"
    subtitle={heroSubtitle}
    size="lg"
  />

    <AnimatedSection client:visible animation="fadeInUp" delay={100}>
    <div class:list={["mx-auto px-4 grid gap-6 -mt-12 relative z-30", openingsGridClass]}>
      {openCareerOpenings.length > 0 ? (
        openCareerOpenings.map((opening) => (
          <div class="bg-surface-soft backdrop-blur-xl border border-border p-6 sm:p-8 rounded-[2.5rem] flex flex-col justify-between hover:border-cta/30 active:scale-[0.98] transition-all">
            <div>
              <div class="flex justify-between items-center gap-4 mb-6">
                <h2 class="font-serif text-2xl font-black text-site-text leading-tight">
                  {opening.titleLines[0]} <br /> {opening.titleLines[1]}
                </h2>
                <span
                  class:list={[
                    "text-[9px] font-black px-2 py-1 rounded uppercase",
                    opening.badgeClass,
                  ]}
                >
                  {opening.badgeLabel}
                </span>
              </div>
              <p class="text-site-sub mb-6 text-xs leading-relaxed">
                {opening.summary}
              </p>
              {opening.highlights && (
                <div
                  class:list={[
                    "space-y-4",
                    opening.benefits?.length ? "mb-4" : "mb-8",
                  ]}
                >
                  {opening.highlights.map((highlight) => (
                    <div class="bg-surface-soft p-4 rounded-xl border border-border">
                      <p class="text-xs font-black text-cta uppercase mb-1">
                        {highlight.label}
                      </p>
                      <p class="text-site-text text-xs font-bold leading-relaxed">
                        {highlight.value}
                      </p>
                    </div>
                  ))}
                </div>
              )}
              {opening.benefits && (
                <ul class="space-y-3 mb-8">
                  {opening.benefits.map((benefit) => (
                    <li class="flex items-center gap-2 text-xs font-black text-sand uppercase tracking-wider">
                      <span class="text-cta">✦</span> {benefit}
                    </li>
                  ))}
                </ul>
              )}
            </div>
            <a
              href="mailto:info@twilightpsychology.com"
              class:list={[
                "block w-full py-4 text-center font-black rounded-full transition-all text-sm",
                opening.ctaVariant === "solid"
                  ? "bg-cta text-cta-fg hover:bg-cta/80 active:scale-95"
                  : "border border-border-strong text-sand hover:bg-surface-2 italic",
              ]}
            >
              {opening.ctaLabel}
            </a>
          </div>
        ))
      ) : (
        <div class="bg-surface-soft backdrop-blur-xl border border-border p-6 sm:p-8 rounded-[2.5rem] text-center">
          {HIRING_PAUSE_NOTICE.show ? (
            <>
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-surface-2 border border-border text-xs font-black text-site-sub uppercase tracking-widest mb-5">
                <span class="w-2 h-2 rounded-full bg-cta inline-block"></span>
                Positions Filled
              </div>
              <h2 class="font-serif text-2xl font-black text-site-text mb-4">
                {HIRING_PAUSE_NOTICE.heading}
              </h2>
              <p class="text-site-sub text-sm leading-relaxed mb-6 max-w-lg mx-auto">
                {HIRING_PAUSE_NOTICE.body}
              </p>
              <a
                href="mailto:info@twilightpsychology.com"
                class="inline-flex items-center justify-center rounded-full border border-border-strong px-5 py-2.5 text-sm font-black text-site-sub hover:bg-surface-2 transition-colors"
              >
                Introduce Yourself for Future Roles
              </a>
            </>
          ) : (
            <>
              <h2 class="font-serif text-2xl font-black text-site-text mb-4">
                No active openings right now
              </h2>
              <p class="text-site-sub text-sm leading-relaxed mb-6">
                We still welcome introductions from clinicians who align with our
                neuro-affirming practice and may be a fit for future roles.
              </p>
              <a
                href="mailto:info@twilightpsychology.com"
                class="inline-flex items-center justify-center rounded-full bg-cta px-5 py-2.5 text-sm font-black text-cta-fg hover:bg-cta/80 transition-colors"
              >
                Introduce Yourself
              </a>
            </>
          )}
        </div>
      )}
    </div>

  <section class="max-w-7xl mx-auto px-4 py-24 border-t border-border">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="font-serif text-4xl font-black text-site-text mb-6 tracking-tighter">
          Clinical <span
            class="text-cta"
            >Support.</span
          >
        </h2>
        <p class="text-site-sub text-lg leading-relaxed mb-8">
          We invest in consultation, training, and operational support so new
          team members can focus on thoughtful, neuro-affirming care from the
          start.
        </p>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 rounded-2xl bg-surface-soft border border-border flex items-center justify-center shrink-0"
            >
              <span class="text-cta text-xl"> * </span>
            </div>
            <div>
              <h4 class="font-serif text-site-text font-bold">Case Consultation</h4>
              <p class="text-site-sub text-sm">
                Collaborative review for complex child, teen, and
                neurodivergent presentations so clinicians have room to think
                through treatment and assessment decisions.
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 rounded-2xl bg-surface-soft border border-border flex items-center justify-center shrink-0"
            >
              <span class="text-cta text-xl"> * </span>
            </div>
            <div>
              <h4 class="font-serif text-site-text font-bold">Assessment Training</h4>
              <p class="text-site-sub text-sm">
                Exposure to testing workflows, diagnostic clarification, and
                polished documentation with support from experienced evaluators
                and therapists.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div
        class="bg-surface-2 border border-border p-10 rounded-[3rem] shadow-2xl shadow-site-bg/50"
      >
        <h3
          class="font-serif text-sand font-black text-xs uppercase tracking-widest mb-6 text-center"
        >
          What Team Members Can Expect
        </h3>
        <p class="text-2xl font-black text-site-text leading-tight text-center mb-8">
          Structured onboarding, responsive support, and a clinical environment
          that values collaboration as much as excellent care.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          {
            [
              "Case Consultation",
              "EHR Training",
              "Scheduling Support",
              "Billing Support",
            ].map((tag) => (
              <span class="px-4 py-2 bg-surface-soft border border-border rounded-full text-xs font-black text-site-sub uppercase tracking-tighter">
                {tag}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <PageLinksSection
    title="Learn more about the practice"
    description="If you are considering a future role, these pages give the clearest sense of how Twilight works."
    links={careerPageLinks}
  />

  

  <section class="max-w-4xl mx-auto px-4 pb-8">
    <div class="rounded-3xl border theme-border-strong theme-surface-2 p-6 sm:p-8 flex flex-col sm:flex-row items-center gap-6">
      <div class="flex-1">
        <h2 class="font-serif text-xl sm:text-2xl font-black text-site-text mb-2 tracking-tight">
          Ready to Join Our Team?
        </h2>
        <p class="text-site-sub text-sm leading-relaxed">
          Beautiful office space in Lexington with free parking and easy transit access. We value the unique perspectives you bring.
        </p>
      </div>
      <div class="flex items-center gap-4 shrink-0">
        <a href="mailto:info@twilightpsychology.com" class="inline-flex items-center rounded-full bg-cta px-5 py-2.5 text-sm font-black text-cta-fg hover:bg-cta/80 transition-colors">
          Get in Touch
        </a>
        <a href={`tel:${PHONE_NUMBER}`} class="text-sm font-black text-site-sub hover:text-cta transition-colors whitespace-nowrap">
          859-687-5843
        </a>
      </div>
    </div>
  </section>
      </div>
    </div>
</Layout>

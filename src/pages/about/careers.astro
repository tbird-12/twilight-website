---
import Layout from "../../layouts/Layout.astro";
import { PHONE_NUMBER } from "../../data/resource";
import PageHeroWrapper from "../../components/PageHeroWrapper.astro";
import AnimatedSection from "../../components/react/primitives/AnimatedSection";

const clinicianBenefits = [
  "Competitive Pay (W2 or 1099)",
  "Health & Disability Packages",
  "Targeted Patient Marketing",
  "Latest HIPAA-Compliant EHR",
  "Current Testing Suite & Protocols",
  "Automated Billing & Support",
];

const therapistBenefits = [
  "Industry-Leading Compensation",
  "Health & Medical Benefits",
  "W2 or 1099 Options",
  "Targeted Patient Marketing",
  "Latest HIPAA-Compliant EHR",
  "Automated Billing & Support",
];
---

<Layout
  title="Careers | Join the Team at Twilight Psychology"
  description="Career opportunities at Twilight Psychology in Lexington, KY. Join our team of psychologists, therapists, and support staff."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <PageHeroWrapper
    title="Build Your Career"
    accentWord="Career"
    badge="Join Our Practice"
    subtitle="From doctoral students to seasoned clinicians, we provide the environment you need to thrive."
    size="lg"
  />

    <AnimatedSection client:visible animation="fadeInUp" delay={100}>
    <div class="max-w-6xl mx-auto px-4 grid md:grid-cols-2 lg:grid-cols-3 gap-6 -mt-12 relative z-30">
      
      <div class="bg-surface-soft backdrop-blur-xl border border-border p-6 sm:p-8 rounded-[2.5rem] flex flex-col justify-between hover:border-cta/30 active:scale-[0.98] transition-all">
        <div>
            <div class="flex justify-between items-center mb-6">
                <h2 class="font-serif text-2xl font-black text-site-text leading-tight">Licensed <br/>Provider</h2>
                <span class="text-[9px] font-black text-site-text border border-border-strong px-2 py-1 rounded uppercase">W2/1099</span>
            </div>
            <p class="text-site-sub mb-6 text-xs leading-relaxed">
              Seeking Doctoral or Master’s level clinicians (LP, T-LP, LPA, T-LPA, LPP) for therapy and assessments in Lexington and surrounding counties.
            </p>
            <ul class="space-y-3 mb-8">
              {clinicianBenefits.map(benefit => (
                <li class="flex items-center gap-2 text-xs font-black text-sand uppercase tracking-wider">
                  <span class="text-cta">✦</span> {benefit}
                </li>
              ))}
            </ul>
        </div>
        <a href="mailto:info@twilightpsychology.com" class="block w-full py-4 bg-cta text-cta-fg text-center font-black rounded-full hover:bg-cta/80 active:scale-95 transition-all text-sm">Apply to Practice</a>
      </div>

      <div class="bg-surface-soft backdrop-blur-xl border border-border p-6 sm:p-8 rounded-[2.5rem] flex flex-col justify-between hover:border-cta/30 active:scale-[0.98] transition-all">
        <div>
            <div class="flex justify-between items-center mb-6">
                <h2 class="font-serif text-2xl font-black text-site-text leading-tight">Doctoral <br/>Practicum</h2>
                <span class="text-[9px] font-black text-cta-fg bg-sand px-2 py-1 rounded uppercase">Clinical</span>
            </div>
            <p class="text-site-sub mb-6 text-xs leading-relaxed">
              Seeking KY-licensed doctoral Psychology students for 10–15 hours of assessment work per week.
              Gain hands-on experience with a diverse caseload from ages 2 and above.
            </p>
            <div class="space-y-4 mb-8">
                <div class="bg-surface-soft p-4 rounded-xl border border-border">
                    <p class="text-xs font-black text-cta uppercase mb-1">Eligible Licenses</p>
                    <p class="text-site-text text-xs font-bold leading-relaxed">T-LPA, LPCA, LCSW, CSW, LMFT</p>
                </div>
                <div class="bg-surface-soft p-4 rounded-xl border border-border">
                    <p class="text-xs font-black text-cta uppercase mb-1">Focus Area</p>
                    <p class="text-site-text text-xs font-bold leading-relaxed">Comprehensive testing, diagnostic review, and clinical consultation.</p>
                </div>
            </div>
        </div>
        <a href="mailto:info@twilightpsychology.com" class="block w-full py-4 border border-border-strong text-sand text-center font-black rounded-full hover:bg-surface-2 transition-all text-sm italic">Request Placement</a>
      </div>

      <div class="bg-surface-soft backdrop-blur-xl border border-border p-6 sm:p-8 rounded-[2.5rem] flex flex-col justify-between hover:border-cta/30 active:scale-[0.98] transition-all">
        <div>
            <div class="flex justify-between items-center mb-6">
                <h2 class="font-serif text-2xl font-black text-site-text leading-tight">Child &amp; Teen <br/>Therapist</h2>
                <span class="text-[9px] font-black text-site-text border border-border-strong px-2 py-1 rounded uppercase">W2/1099</span>
            </div>
            <p class="text-site-sub mb-6 text-xs leading-relaxed">
              Seeking a Kentucky-licensed therapist passionate about working with children and adolescents, with a focus on neurodivergent populations including autism, ADHD, and related profiles.
            </p>
            <div class="space-y-4 mb-4">
                <div class="bg-surface-soft p-4 rounded-xl border border-border">
                    <p class="text-xs font-black text-cta uppercase mb-1">Requirements</p>
                    <p class="text-site-text text-xs font-bold leading-relaxed">Active KY license (LPCC, LCSW, LMFT, or equivalent). Experience or training in neurodivergence-affirming care for ages 4–17.</p>
                </div>
            </div>
            <ul class="space-y-3 mb-8">
              {therapistBenefits.map(benefit => (
                <li class="flex items-center gap-2 text-xs font-black text-sand uppercase tracking-wider">
                  <span class="text-cta">✦</span> {benefit}
                </li>
              ))}
            </ul>
        </div>
        <a href="mailto:info@twilightpsychology.com" class="block w-full py-4 bg-cta text-cta-fg text-center font-black rounded-full hover:bg-cta/80 active:scale-95 transition-all text-sm">Apply Now</a>
      </div>


    </div>

  <section class="max-w-7xl mx-auto px-4 py-24 border-t border-border">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="font-serif text-4xl font-black text-site-text mb-6 tracking-tighter">
          Clinical <span
            class="text-cta"
            >Mentorship.</span
          >
        </h2>
        <p class="text-site-sub text-lg leading-relaxed mb-8">
          We believe that the next generation of psychologists deserves
          supervision that is as neuro-affirming as the care we deliver to our
          clients. At Twilight Psychology, mentorship is a collaborative partnership.
        </p>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 rounded-2xl bg-surface-soft border border-border flex items-center justify-center shrink-0"
            >
              <span class="text-cta text-xl"> * </span>
            </div>
            <div>
              <h4 class="font-serif text-site-text font-bold">Postdoctoral Supervision</h4>
              <p class="text-site-sub text-sm">
                Full support for candidates seeking licensure in Kentucky,
                focusing on advanced diagnostic reporting and practice
                management.
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 rounded-2xl bg-surface-soft border border-border flex items-center justify-center shrink-0"
            >
              <span class="text-cta text-xl"> * </span>
            </div>
            <div>
              <h4 class="font-serif text-site-text font-bold">Assessment Specialization</h4>
              <p class="text-site-sub text-sm">
                Master the ADOS-2, MIGDAS-2, and complex differential diagnosis
                under the guidance of seasoned evaluators.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div
        class="bg-surface-2 border border-border p-10 rounded-[3rem] shadow-2xl shadow-site-bg/50"
      >
        <h3
          class="font-serif text-sand font-black text-xs uppercase tracking-widest mb-6 text-center"
        >
          The Practicum Experience
        </h3>
        <blockquote
          class="text-2xl font-black text-site-text italic leading-tight text-center mb-8"
        >
          "We not only teach you how to test but also a lot of details
          not taught in the classroom".
        </blockquote>
        <div class="flex flex-wrap justify-center gap-3">
          {
            [
              "Doctoral Hours",
              "Case Consultation",
              "EHR Training",
              "Insurance Insight",
            ].map((tag) => (
              <span class="px-4 py-2 bg-surface-soft border border-border rounded-full text-xs font-black text-site-sub uppercase tracking-tighter">
                {tag}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  

  <section class="max-w-4xl mx-auto px-4 pb-8">
    <div class="rounded-3xl border theme-border-strong theme-surface-2 p-6 sm:p-8 flex flex-col sm:flex-row items-center gap-6">
      <div class="flex-1">
        <h2 class="font-serif text-xl sm:text-2xl font-black text-site-text mb-2 tracking-tight">
          Ready to Join Our Team?
        </h2>
        <p class="text-site-sub text-sm leading-relaxed">
          Beautiful office space in Lexington with free parking and easy transit access. We value the unique perspectives you bring.
        </p>
      </div>
      <div class="flex items-center gap-4 shrink-0">
        <a href="mailto:info@twilightpsychology.com" class="inline-flex items-center rounded-full bg-cta px-5 py-2.5 text-sm font-black text-cta-fg hover:bg-cta/80 transition-colors">
          Get in Touch
        </a>
        <a href={`tel:${PHONE_NUMBER}`} class="text-sm font-black text-site-sub hover:text-cta transition-colors whitespace-nowrap">
          859-687-5843
        </a>
      </div>
    </div>
  </section>
      </div>
    </div>
  </div>
</Layout>

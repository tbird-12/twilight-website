---
import Layout from "../../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { WIDGET_LINK } from "../../../data/resource";
import { providers } from "../../../data/staff";

const jatana = providers.find(person => person.slug === 'jatana-boggs')!;

const specialties = [
  "Adult ADHD",
  "Bipolar Disorder",
  "Substance Use",
  "Psychological Testing",
  "Clinical Supervision",
];
---

<Layout
  title="Jatana Boggs, M.A., LPCA | Licensed Psychological Counselor Associate | Twilight Psychology"
  description="Jatana Boggs, M.A., LPCA — Licensed counselor at Twilight Psychology. 10+ years in community mental health and private practice."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <section
    class="relative pt-32 pb-24 px-4 border-b theme-border bg-linear-to-b from-site-ann/35 to-transparent"
  >
    <div class="max-w-7xl mx-auto mb-10">
      <a
        href="/about/clinicians/clinicians-lex-ky"
        class="inline-flex items-center gap-2 text-sm font-semibold text-cta/90 hover:text-cta/90"
      >
        <span aria-hidden="true">←</span>
        Back to all clinicians
      </a>
    </div>
    
    <div
      class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16"
    >
      <div class="relative group not-prose">
        <div
          class="absolute -inset-1 bg-linear-to-r from-cta to-cta rounded-[3rem] blur opacity-25 group-hover:opacity-50 transition duration-1000"
        >
        </div>
        <div
          class="relative w-72 h-96 theme-surface-2 rounded-[2.5rem] overflow-hidden border theme-border shadow-2xl"
        >
          <Image
            src={jatana.image}
            alt={jatana.name}
            widths={[288, 576]}
            sizes="18rem"
            class="absolute inset-0 w-full h-full object-cover object-top rounded-[2.5rem]"
            loading={"eager"}
          />
        </div>
      </div>
      <div class="flex-1 text-center lg:text-left">
        <span
          class="px-4 py-1.5 mb-6 text-xs font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full inline-block"
          >Licensed Psychological Counselor Associate</span
        >
        <h1
          class="font-serif text-5xl md:text-7xl font-black text-site-text mb-4 tracking-tighter"
        >
          Jatana Boggs, <span
            class="text-cta"
            >M.A., LPCA.</span>
        </h1>
        <div class="flex flex-wrap justify-center lg:justify-start gap-3 mt-6">
          {
            specialties.map((s) => (
              <span class="px-4 py-2 theme-surface-soft border theme-border rounded-full text-xs font-black text-sand uppercase tracking-tighter">
                {s}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section
    class="max-w-4xl mx-auto px-4 py-24 space-y-8 text-site-text text-lg"
  >
    <h2 class="font-serif text-3xl font-black text-site-text italic">
      Evidence-Based Care with a Human Connection.
    </h2>
    <p>
      With over a decade of experience in community mental health and private
      practice, I focus on providing diagnostic clarity for complex
      presentations. I specialize in Adult ADHD and mood disorders, ensuring
      that my clients leave with a concrete understanding of their mental health
      landscape.
    </p>
    <p>
      I earned my Master's degree from Morehead State University and have
      dedicated my career to serving the Kentucky community through
      comprehensive testing and supervision of upcoming clinical professionals.
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-4 pb-24">
    <div
      class="theme-surface-2 p-12 rounded-[4rem] text-site-text border theme-border text-center"
    >
      <h2 class="font-serif text-3xl font-bold mb-4 tracking-tight text-site-text">
        Schedule a Psychological Evaluation
      </h2>
      <p
        class="font-medium text-site-sub mb-10 max-w-2xl mx-auto italic leading-relaxed text-sm"
      >
        Jatana offers comprehensive psychological testing for ages under 21 in Lexington, KY.
        Use the link below to contact our team and schedule an intake.
      </p>
      <a
        href={WIDGET_LINK}
        class="inline-block px-10 py-4 bg-cta/90 text-cta-fg font-bold rounded-full hover:bg-cta transition-all"
      >
        Schedule an Intake
      </a>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-6 mt-8 mb-8">
    <div class="bg-surface border border-border rounded-2xl p-5 flex items-center justify-between gap-4 flex-wrap">
      <div>
        <p class="text-site-sub text-sm">Curious whether you might be masking?</p>
        <p class="text-xs text-site-sub opacity-70">Take our free 3-minute self-reflection tool.</p>
      </div>
      <a href="/resources/masking-inventory" class="text-cta font-semibold text-sm hover:underline whitespace-nowrap">
        Free Masking Inventory →
      </a>
    </div>
  </div>
      </div>
    </div>
  </div>
</Layout>

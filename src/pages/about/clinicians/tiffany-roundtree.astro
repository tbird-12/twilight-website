---
import Layout from "../../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { providers } from "../../../data/staff";

const tiffany = providers.find(person => person.slug === 'tiffany-roundtree')!;

const specialties = [
  "Adolescent Therapy",
  "Parenting Support",
  "Anxiety Disorders",
  "School-Based Advocacy",
  "Developmental Testing",
];
---

<Layout
  title="Tiffany Roundtree, M.A.Ed, M.A., LPCA | Child & Adolescent Specialist | Twilight Psychology"
  description="Tiffany Roundtree, M.A.Ed, M.A., LPCA — Licensed counselor at Twilight Psychology. Child and adolescent therapy in Kentucky."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <section
    class="relative pt-32 pb-24 px-4 border-b theme-border bg-linear-to-b from-site-ann/35 to-transparent"
  >
    <div class="max-w-7xl mx-auto mb-10">
      <a
        href="/about/clinicians/clinicians-lex-ky"
        class="inline-flex items-center gap-2 text-sm font-semibold text-cta/90 hover:text-cta/90"
      >
        <span aria-hidden="true">←</span>
        Back to all clinicians
      </a>
    </div>
    <div
      class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16"
    >
      <div class="relative group not-prose">
        <div
          class="absolute -inset-1 bg-linear-to-r from-cta to-cta rounded-[3rem] blur opacity-25 group-hover:opacity-50 transition duration-1000"
        >
        </div>
        <div
          class="relative w-72 h-96 theme-surface-2 rounded-[2.5rem] overflow-hidden border theme-border shadow-2xl"
        >
          <Image
            src={tiffany.image}
            alt={tiffany.name}
            class="absolute inset-0 w-full h-full object-cover object-top rounded-[2.5rem]"
            loading={"eager"}
          />
        </div>
      </div>
      <div class="flex-1 text-center lg:text-left">
        <span
          class="px-4 py-1.5 mb-6 text-[10px] font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full inline-block"
          >Licensed Professional Counselor Associate</span
        >
        <h1
          class="font-serif text-5xl md:text-7xl font-black text-site-text mb-4 tracking-tighter leading-none"
        >
          Tiffany <br /><span
            class="text-cta"
            >Roundtree, M.A.Ed, M.A., LPCA</span>
        </h1>
        <div class="flex flex-wrap justify-center lg:justify-start gap-3 mt-6">
          {
            specialties.map((s) => (
              <span class="px-4 py-2 theme-surface-soft border theme-border rounded-full text-[10px] font-black text-sand uppercase tracking-tighter">
                {s}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section
    class="max-w-4xl mx-auto px-4 py-24 space-y-8 text-site-text text-lg"
  >
    <h2 class="font-serif text-3xl font-black text-site-text italic">
      Supporting the Next Generation.
    </h2>
    <p>
      I go by Tree. I recently graduated in December 2025 from Lindsey Wilson
      College with my Master of Arts in Counseling degree, and am licensed as a
      Licensed Professional Counselor Associate (LPCA), supervised by Delmetria
      Cayson-Combs, LPCC-S. My work centers on adolescents and adults navigating
      the complexities of modern development. I help clients explore how
      societal norms, family dynamics, and life experiences have shaped their
      personal stories about self worth, competence, and authenticity.
    </p>
    <p>
      I specialize support clients in deconstructing harmful or limiting beliefs
      in these stories and rewriting them from a more compassionate and
      neuroaffirmng understanding of themselves.
    </p>
  </section>

  <div
      class="p-8 theme-surface-2 border theme-border rounded-[2.5rem] text-center"
    >
      <p
        class="text-cta font-black text-xs uppercase tracking-widest mb-4"
      >
        Availability
      </p>
      <p class="text-2xl font-black text-site-text">
        Immediate Openings for Therapy with Neurodivergent Adults
      </p>
      <a
        href="tel:859-687-5843"
        class="mt-8 inline-block px-10 py-4 bg-sand text-cta-fg font-black rounded-xl hover:bg-cta transition-all"
        >Request Appointment</a
      >
    </div>

    <div class="mt-12 bg-linear-to-r from-cta/10 to-cta/10 border border-cta/20 rounded-3xl p-8 text-center">
      <h3 class="font-serif text-2xl font-black text-site-text mb-4">First Time Here?</h3>
      <p class="text-site-sub mb-6">Learn about our intake process and what to expect as a new client at Twilight Psychology.</p>
      <a
        href="/resources/new-client"
        class="inline-block px-8 py-3 bg-cta text-cta-fg font-black rounded-full hover:bg-cta/80 transition-all"
      >
        New Client Guide
      </a>
    </div>

  <div class="max-w-4xl mx-auto px-6 mt-8 mb-8">
    <div class="bg-surface border border-border rounded-2xl p-5 flex items-center justify-between gap-4 flex-wrap">
      <div>
        <p class="text-site-sub text-sm">Curious whether you might be masking?</p>
        <p class="text-xs text-site-sub opacity-70">Take our free 3-minute self-reflection tool.</p>
      </div>
      <a href="/resources/masking-inventory" class="text-cta font-semibold text-sm hover:underline whitespace-nowrap">
        Free Masking Inventory →
      </a>
    </div>
  </div>
      </div>
    </div>
  </div>
</Layout>

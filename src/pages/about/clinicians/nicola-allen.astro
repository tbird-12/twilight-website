---
import Layout from "../../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { providers } from "../../../data/staff";

const nicola = providers.find((person) => person.slug === "nicola-allen")!;

const specialties = [
  "Psychiatry",
  "Medication Management",
  "ADHD & PTSD",
  "Trauma-Informed Care",
  "Lifestyle Mindfulness",
];
---

<Layout
  title="Nicola Allen, PMHNP-BC | Medication Management Lexington | Twilight Psychology"
  description="Nicola Allen, PMHNP-BC — Psychiatric nurse practitioner at Twilight Psychology. 19+ years providing medication management in Lexington, KY."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <section
    class="relative pt-32 pb-24 px-4 border-b theme-border bg-linear-to-b from-site-ann/35 to-transparent"
  >
    <div class="max-w-7xl mx-auto mb-10">
      <a
        href="/about/clinicians/clinicians-lex-ky"
        class="inline-flex items-center gap-2 text-sm font-semibold text-cta/90 hover:text-cta/90"
      >
        <span aria-hidden="true">←</span>
        Back to all clinicians
      </a>
    </div>
    <div
      class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16"
    >
      <div class="relative group not-prose">
        <div
          class="absolute -inset-1 bg-linear-to-r from-cta to-cta rounded-[3rem] blur opacity-25 group-hover:opacity-50 transition duration-1000"
        >
        </div>
        <div
          class="relative w-72 h-96 theme-surface-2 rounded-[2.5rem] overflow-hidden border theme-border shadow-2xl"
        >
          <Image
            src={nicola.image}
            alt={`Professional Portrait of ${nicola.name}`}
            widths={[288, 576]}
            sizes="18rem"
            class="absolute inset-0 w-full h-full object-cover object-top rounded-[2.5rem]"
            loading={"eager"}
          />
        </div>
      </div>
      <div class="flex-1 text-center lg:text-left">
        <span
          class="px-4 py-1.5 mb-6 text-xs font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full inline-block"
          >Psychiatric Nurse Practitioner</span
        >
        <h1
          class="font-serif text-5xl md:text-7xl font-black text-site-text mb-4 tracking-tighter"
        >
          Nicola Allen, <span
            class="text-cta"
            >MSN, PMHNP-BC</span
          >
        </h1>
        <div class="flex flex-wrap justify-center lg:justify-start gap-3 mt-6">
          {
            specialties.map((s) => (
              <span class="px-4 py-2 theme-surface-soft border theme-border rounded-full text-xs font-black text-sand uppercase tracking-tighter">
                {s}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-24 space-y-8 text-site-text">
    <h2 class="font-serif text-3xl font-black text-site-text italic">
      Comprehensive, Patient-Centered Psychiatry.
    </h2>

    <p class="max-w-3xl text-lg text-site-sub leading-relaxed">
      With over 20 years of experience in nursing and psychiatry, I provide a
      compassionate, judgment-free environment focused on comprehensive
      medication management and whole-person care. Raised in Eastern Kentucky,
      I value a grounded, down-to-earth approach and strive to meet patients
      where they are through a combination of in-person and telehealth visits.
      My practice integrates evidence-based prescribing with lifestyle
      modifications, psychoeducation, and mindfulness strategies to support
      long-term mental wellness.
    </p>

    <div class="not-prose grid gap-6 md:grid-cols-2">
      <div class="theme-surface-soft border theme-border rounded-4xl p-6 sm:p-7">
        <p class="mb-4 text-xs font-black uppercase tracking-widest text-cta">
          Education & Training
        </p>
        <ul class="space-y-3 text-sm leading-relaxed text-site-text sm:text-base">
          <li>Associate Degree in Nursing from Hazard Community and Technical College</li>
          <li>Bachelor of Science in Nursing from Eastern Kentucky University</li>
          <li>Master of Science in Nursing from Indiana Wesleyan University</li>
        </ul>
      </div>

      <div class="theme-surface-soft border theme-border rounded-4xl p-6 sm:p-7">
        <p class="mb-4 text-xs font-black uppercase tracking-widest text-cta">
          Clinical Focus
        </p>
        <ol class="space-y-3 text-sm leading-relaxed text-site-text sm:text-base">
          <li>Passionate about working with individuals with autism, ADHD, anxiety, and depression</li>
          <li>Creates individualized treatment plans tailored to each patient&apos;s needs</li>
          <li>Embraces a neurodiversity-affirming approach that respects each person&apos;s strengths, perspectives, and needs</li>
        </ol>
      </div>

      <div class="theme-surface-2 border theme-border rounded-4xl p-6 sm:p-8 md:col-span-2">
        <div class="grid gap-6 lg:grid-cols-2">
          <div>
            <p class="mb-3 text-xs font-black uppercase tracking-widest text-cta">
              Care Delivery
            </p>
            <p class="text-sm leading-relaxed text-site-text sm:text-base">
              I offer care through in-person and telehealth visits, pairing
              comprehensive medication management with evidence-based
              prescribing, lifestyle modifications, psychoeducation, and
              mindfulness strategies.
            </p>
          </div>

          <div>
            <p class="mb-3 text-xs font-black uppercase tracking-widest text-cta">
              Additional Services & Safety
            </p>
            <p class="text-sm leading-relaxed text-site-text sm:text-base">
              I am a THC-friendly provider and offer medical cannabis
              certification evaluations when clinically appropriate. At
              Twilight Psychology, we follow all Drug Enforcement
              Administration regulations and utilize Prescription Drug
              Monitoring Program (PDMP) checks to support safe, informed,
              individualized care.
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="not-prose border-l-4 border-cta py-2 pl-6 sm:pl-8">
      <p class="text-base leading-relaxed text-site-text sm:text-lg">
        My goal is to create a collaborative, supportive partnership where
        patients feel heard, respected, and empowered in their care. I strive
        to foster a safe and inclusive environment where individuals can openly
        discuss their concerns without fear of judgment while building trust,
        promoting long-term stability, improving daily functioning, enhancing
        quality of life, and supporting meaningful, sustainable progress in
        their mental health journey.
      </p>
    </div>

    <div
      class="p-8 theme-surface-2 border theme-border rounded-[2.5rem] text-center"
    >
      <p
        class="text-cta font-black text-xs uppercase tracking-widest mb-4"
      >
        Availability
      </p>
      <p class="text-2xl font-black text-site-text">
        Immediate Openings for Medication Management
      </p>
      <a
        href="tel:859-687-5843"
        class="mt-8 inline-block px-10 py-4 bg-sand text-cta-fg font-black rounded-xl hover:bg-cta transition-all"
        >Request Appointment</a
      >
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-6 mt-8 mb-8">
    <div class="bg-surface border border-border rounded-2xl p-5 flex items-center justify-between gap-4 flex-wrap">
      <div>
        <p class="text-site-sub text-sm">Curious whether you might be masking?</p>
        <p class="text-xs text-site-sub opacity-70">Take our free 3-minute self-reflection tool.</p>
      </div>
      <a href="/resources/masking-inventory" class="text-cta font-semibold text-sm hover:underline whitespace-nowrap">
        Free Masking Inventory →
      </a>
    </div>
  </div>
      </div>
    </div>
  </div>
</Layout>

---
import ServiceLayout from "../../../layouts/ServiceLayout.astro";
import "../../../styles/global.css";
import { Image } from "astro:assets";
import { providers } from "../../../data/staff";

const nicola = providers.find((person) => person.slug === "nicola-allen")!;

const specialties = [
  "Psychiatry",
  "Medication Management",
  "ADHD & PTSD",
  "Trauma-Informed Care",
  "Lifestyle Mindfulness",
];
---

<ServiceLayout
  name="Nicola Allen, PMHNP-BC | Medication Management Lexington"
  description="Nicola Allen is a Board-Certified Psychiatric Nurse Practitioner with 19 years of experience in psychiatry. Specializing in comprehensive medication management, Nicola provides compassionate, patient-centered care for individuals facing Depression, Anxiety, Sleep Disorders, and Trauma."
  metaDescription="Nicola Allen, PMHNP-BC - Board-certified psychiatric nurse practitioner at Twilight Psychology in Lexington, KY. 19+ years experience providing medication management for depression, anxiety, ADHD, and trauma."
>
  <section
    class="relative pt-32 pb-24 px-4 border-b theme-border bg-linear-to-b from-site-ann/35 to-transparent"
  >
    <div class="max-w-7xl mx-auto mb-10">
      <a
        href="/about/clinicians/clinicians-lex-ky"
        class="inline-flex items-center gap-2 text-sm font-semibold text-cta/90 hover:text-cta/90"
      >
        <span aria-hidden="true">←</span>
        Back to all clinicians
      </a>
    </div>
    <div
      class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16"
    >
      <div class="relative group">
        <div
          class="absolute -inset-1 bg-linear-to-r from-cta to-indigo-500 rounded-[3rem] blur opacity-25 group-hover:opacity-50 transition duration-1000"
        >
        </div>
        <div
          class="relative w-72 h-96 theme-surface-2 rounded-[2.5rem] overflow-hidden border theme-border shadow-2xl"
        >
          <Image
            src={nicola.image}
            alt={`Professional Portrait of ${nicola.name}`}
            class="object-cover w-full h-full rounded-[2.5rem]"
            loading={"eager"}
          />
        </div>
      </div>
      <div class="flex-1 text-center lg:text-left">
        <span
          class="px-4 py-1.5 mb-6 text-[10px] font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full inline-block"
          >Psychiatric Nurse Practitioner</span
        >
        <h1
          class="font-serif text-5xl md:text-7xl font-black text-site-text mb-4 tracking-tighter"
        >
          Nicola Allen, <span
            class="text-cta"
            >MSN, PMHNP-BC</span
          >
        </h1>
        <div class="flex flex-wrap justify-center lg:justify-start gap-3 mt-6">
          {
            specialties.map((s) => (
              <span class="px-4 py-2 theme-surface-soft border theme-border rounded-full text-[10px] font-black text-sand uppercase tracking-tighter">
                {s}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section
    class="max-w-4xl mx-auto px-4 py-24 space-y-8 text-site-text text-lg"
  >
    <h2 class="font-serif text-3xl font-black text-site-text italic">
      Comprehensive, Patient-Centered Psychiatry.
    </h2>
    <p>
      With 19 years of nursing experience in psychiatry, I provide a
      compassionate, judgment-free space for medication management. My training
      encompasses lifestyle modifications and mindfulness alongside
      evidence-based prescribing.
    </p>
    <p>
      I began my journey at Hazard Community and Technical College, later
      earning my Master of Science in Nursing from Indiana Wesleyan University.
      I am deeply passionate about supporting individuals facing Depression,
      Anxiety, Sleep Disorders, and Trauma.
    </p>
    <p>
      Depending on the patient's needs, I am qualified to prescribe stimulant
      medications for ADHD, and controlled substances for PTSD and sleep
      disorders, with a strong emphasis on <strong class="text-cta"
        >safety and monitoring</strong
      >. At Twilight Psychology, we follow DEA guidelines and PDMP checks for
      prescribing controlled substances, ensuring that all patients receive the
      highest standard of care.
    </p>

    <div
      class="p-8 theme-surface-2 border theme-border rounded-[2.5rem] text-center"
    >
      <p
        class="text-cta font-black text-xs uppercase tracking-widest mb-4"
      >
        Availability
      </p>
      <p class="text-2xl font-black text-site-text">
        Immediate Openings for Medication Management
      </p>
      <a
        href="tel:859-687-5843"
        class="mt-8 inline-block px-10 py-4 bg-sand text-cta-fg font-black rounded-xl hover:bg-cta transition-all"
        >Request Appointment</a
      >
    </div>
  </section>
</ServiceLayout>

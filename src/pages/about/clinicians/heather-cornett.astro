---
import ServiceLayout from "../../../layouts/ServiceLayout.astro";
import "../../../styles/global.css";
import { Image } from "astro:assets";
import { WIDGET_LINK } from "../../../data/resource";
import { providers } from "../../../data/staff";

const heather = providers.find(person => person.slug === 'heather-cornett')!;

const specialties = [
  "High-Masking Autism & ADHD",
  "Learning Disability Evaluations",
  "Personality Disorders (BPD/SPMI)",
  "Guardianship & Disability Claims",
  "PsyPact Telehealth (40+ States)",
];

const education = [
  {
    degree: "Ph.D. in Counseling Psychology",
    school: "Texas Woman's University",
    year: "2019",
  },
  {
    degree: "M.S. in Counseling Psychology",
    school: "University of Kentucky",
    year: "2014",
  },
  {
    degree: "APA-Accredited Internship",
    school: "Wichita Collaborative (WCPIP)",
    location: "Wichita, KS",
  },
];
---

<ServiceLayout
  name="Dr. Heather Cornett, Ph.D. | Founder & Licensed Psychologist"
  description="Meet Dr. Heather Cornett, Ph.D., the founder of Twilight Psychology. Specializing in comprehensive psychological evaluations for high-masking neurodivergent adults and complex diagnostic clarification."
  metaDescription="Dr. Heather Cornett, Ph.D. - Founder and licensed psychologist at Twilight Psychology in Lexington, KY. Specializing in comprehensive psychological evaluations for neurodivergent adults, ADHD, autism, and complex diagnostics."
>
  <section
    class="relative pt-32 pb-24 px-4 border-b theme-border bg-linear-to-b from-site-ann/35 to-transparent"
  >
    <div class="max-w-7xl mx-auto mb-10">
      <a
        href="/about/clinicians/clinicians-lex-ky"
        class="inline-flex items-center gap-2 text-sm font-semibold text-cta/90 hover:text-cta/90"
      >
        <span aria-hidden="true">←</span>
        Back to all clinicians
      </a>
    </div>
    <div
      class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16"
    >
      <div class="relative group">
        <div
          class="absolute -inset-1 bg-linear-to-r from-cta to-cta rounded-[3rem] blur opacity-25 group-hover:opacity-50 transition duration-1000"
        >
        </div>
        <div
          class="relative w-72 h-96 theme-surface-2 rounded-[2.5rem] overflow-hidden border theme-border shadow-2xl"
        >
          <div
            class="relative w-72 h-96 theme-surface-2 rounded-[2.5rem] overflow-hidden border theme-border shadow-2xl"
          >
            <Image
              src={heather.image}
              alt={`Professional Portrait of ${heather.name}`}
              class="object-cover w-full h-full rounded-[2.5rem]"
              loading={"eager"}
            />
          </div>
        </div>
      </div>

      <div class="flex-1 text-center lg:text-left">
        <span
          class="px-4 py-1.5 mb-6 text-[10px] font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full inline-block"
        >
          Founder & Licensed Psychologist
        </span>
        <h1
          class="font-serif text-5xl md:text-7xl font-black text-site-text mb-4 tracking-tighter leading-none"
        >
          Heather Cornett, <br />
          <span
            class="text-cta"
            >Ph.D., LP.</span
          >
        </h1>
        <p class="text-site-sub text-lg leading-relaxed max-w-2xl mb-8">
          Specializing in comprehensive psychological evaluations for
          high-masking neurodivergent adults and complex diagnostic
          clarification.
        </p>
        <div class="flex flex-wrap justify-center lg:justify-start gap-3">
          {
            specialties.map((s) => (
              <span class="px-4 py-2 theme-surface-soft border theme-border rounded-full text-[10px] font-black text-sand uppercase tracking-tighter">
                {s}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 py-24 grid lg:grid-cols-12 gap-16">
    <div
      class="lg:col-span-8 space-y-8 text-site-text text-lg leading-relaxed"
    >
      <h2 class="font-serif text-3xl font-black text-site-text italic tracking-tight">
        A Neuro-Affirming Approach to Clarity.
      </h2>
      <p>
        Hello! I am a Kentucky native and the founder of Twilight Psychology. My
        clinical expertise lies in working with individuals who have often been
        overlooked or misdiagnosed—particularly those who have learned to "mask"
        behaviors to fit into neurotypical environments.
      </p>
      <p>
        Whether you are an adult seeking answers about Autism or ADHD for the
        first time, or a parent navigating a complex learning disability, I
        provide a thorough, evidence-based, and compassionate evaluation
        process. I believe that a diagnosis isn't a deficit; it's a vital piece
        of your identity that provides the roadmap for profound purpose and
        fulfillment.
      </p>
      <p
        class="border-l-4 border-cta pl-8 italic theme-surface-soft py-8 rounded-r-3xl"
      >
        "We don't just test using a checklist of concerns; we test with an
        intention to understand the person beyond the measures. My goal is to
        ensure you feel heard, understood, and empowered during our sessions."
      </p>
      <p>
        Beyond my clinical work, I have served as an Assistant Professor of
        Psychology for three years and hold a PsyPact certificate, allowing me
        to provide psychological services via telehealth to clients in over 40
        states.
      </p>
    </div>

    <div class="lg:col-span-4 space-y-8">
      <div class="theme-surface-soft border theme-border p-8 rounded-[2.5rem]">
        <h3
          class="font-serif text-cta font-black text-xs uppercase tracking-widest mb-6"
        >
          Education & Credentials
        </h3>
        <div class="space-y-6">
          {
            education.map((item) => (
              <div class="border-b theme-border pb-4 last:border-0">
                <p class="text-site-text font-bold text-sm">{item.degree}</p>
                <p class="text-site-sub text-xs">{item.school}</p>
                {item.location && (
                  <p class="text-site-sub text-[10px] mt-1 uppercase">
                    {item.location}
                  </p>
                )}
              </div>
            ))
          }
        </div>
      </div>

      <div class="p-8 theme-surface-2 border theme-border rounded-[2.5rem]">
        <h3
          class="font-serif text-cta font-black text-xs uppercase tracking-widest mb-4"
        >
          Outside the Clinic
        </h3>
        <p class="text-sm text-site-sub leading-relaxed italic">
          When I'm not in the office, you’ll likely find me diving into a true
          crime documentary, playing video games, or spending time with my large
          orange tabby cat. I am a dedicated BIPOC and LGBTQ+ ally.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-24">
    <div
      class="theme-surface-2 p-12 rounded-[4rem] text-site-text border theme-border text-center relative overflow-hidden"
    >
      <div class="relative z-10">
        <h2 class="font-serif text-3xl font-bold mb-4 tracking-tight text-site-text">
          Current Availability
        </h2>
        <div class="flex flex-col md:flex-row justify-center gap-6 my-8">
          <div
            class="theme-surface-soft p-6 rounded-2xl border theme-border"
          >
            <p
              class="text-[10px] font-bold uppercase tracking-widest mb-2 text-cta/70"
            >
              Evaluations
            </p>
            <p class="text-lg font-semibold text-site-text">Accepting New Clients</p>
          </div>
          <div
            class="theme-surface-soft p-6 rounded-2xl border theme-border"
          >
            <p
              class="text-[10px] font-bold uppercase tracking-widest mb-2 text-cta/70"
            >
              Individual Therapy
            </p>
            <p class="text-lg font-semibold text-site-sub italic">Waitlist Only</p>
          </div>
        </div>
        <p
          class="font-medium text-site-sub mb-10 max-w-xl mx-auto italic leading-relaxed text-sm"
        >
          Dr. Cornett provides evaluations for ages 2 and up in Lexington, KY
          and nationwide for adults via Telehealth.
        </p>
        <a
          href={WIDGET_LINK}
          class="inline-block px-10 py-4 bg-cta/90 text-cta-fg font-bold rounded-full hover:bg-cta transition-all"
        >
          Schedule an Intake
        </a>
      </div>
      <div
        class="absolute -bottom-10 -right-10 text-[12rem] font-black text-site-text/5 select-none uppercase"
      >
        PsyPact
      </div>
    </div>
  </section>
</ServiceLayout>

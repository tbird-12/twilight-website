---
import ServiceLayout from "../../../layouts/ServiceLayout.astro";
import "../../../styles/global.css";
import { Image } from "astro:assets";
import { providers } from "../../../data/staff";

const jonica = providers.find(person => person.slug === 'jonica-davis')!;

const specialties = [
  "Neuro-Affirming Therapy",
  "Autism & ADHD Support",
  "Adult Therapy",
  "Family Systems",
  "Identity Exploration",
];
---

<ServiceLayout
  name="Jonica Davis, M.S., T-LPA | Trainee Licensed Psychological Associate "
  description="Jonica Davis is a Trainee Licensed Psychological Associate specializing in supportive, neuro-affirming therapy for individuals and families"
  metaDescription="Jonica Davis, M.S., T-LPA - Trainee licensed psychological associate at Twilight Psychology in Kentucky. Specializing in neuro-affirming therapy for individuals and families."
>
  <section
    class="relative pt-32 pb-24 px-4 border-b theme-border bg-linear-to-b from-site-ann/35 to-transparent"
  >
    <div class="max-w-7xl mx-auto mb-10">
      <a
        href="/about/clinicians/clinicians-lex-ky"
        class="inline-flex items-center gap-2 text-sm font-semibold text-cta/90 hover:text-cta/90"
      >
        <span aria-hidden="true">←</span>
        Back to all clinicians
      </a>
    </div>
    <div
      class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16"
    >
      <div class="relative group">
        <div
          class="absolute -inset-1 bg-linear-to-r from-cta to-indigo-500 rounded-[3rem] blur opacity-25 group-hover:opacity-50 transition duration-1000"
        >
        </div>
        <div
          class="relative w-72 h-96 theme-surface-2 rounded-[2.5rem] overflow-hidden border theme-border shadow-2xl"
        >
          <Image
            src={jonica.image}
            alt={jonica.name}
            class="object-cover w-full h-full rounded-[2.5rem]"
            loading={"eager"}
          />
        </div>
      </div>

      <div class="flex-1 text-center lg:text-left">
        <span
          class="px-4 py-1.5 mb-6 text-[10px] font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full inline-block"
        >
          Licensed Psychological Associate Trainee
        </span>
        <h1
          class="font-serif text-5xl md:text-7xl font-black text-site-text mb-4 tracking-tighter leading-none"
        >
          Jonica <br />
          <span
            class="text-cta"
            >Davis, M.S., T-LPA.</span
          >
        </h1>
        <p class="text-site-sub text-lg leading-relaxed max-w-2xl mb-8">
          Specializing in supportive, neuro-affirming therapy for individuals
          and families navigating neurodivergent identities.
        </p>
        <div class="flex flex-wrap justify-center lg:justify-start gap-3">
          {
            specialties.map((item) => (
              <span class="px-4 py-2 theme-surface-soft border theme-border rounded-full text-[10px] font-black text-sand uppercase tracking-tighter">
                {item}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 py-24 grid lg:grid-cols-12 gap-16">
    <div
      class="lg:col-span-8 space-y-8 text-site-text text-lg leading-relaxed"
    >
      <h2 class="font-serif text-3xl font-black text-site-text italic tracking-tight">
        Authentic Connection in Clinical Care.
      </h2>
      <p>
        Jonica is currently completing her postdoctoral fellowship under the
        supervision of Dr. Heather Cornett, PhD. She is currently a doctoral
        candidate at Radford University, Virginia, in Counseling Psychology, and
        completed her Master’s in Science in Counseling Psychology at the
        University of Kentucky.
      </p>
      <p>
        Jonica is passionate about providing therapy that meets people where
        they currently are in their lives. She works to provide her clients a
        safe and affirming place to process anything that they may have going on
        in their lives.
      </p>
      <div
        class="theme-surface-2 border-l-4 border-cta p-8 rounded-r-3xl italic font-medium"
      >
        " I enjoy seeing clients who want to explore their relationship with
        their bodies or explore their how anti-fat bias has impacted their
        life."
      </div>
    </div>

    <div class="lg:col-span-4 space-y-8">
      <div class="theme-surface-soft border theme-border p-8 rounded-[2.5rem]">
        <h3
          class="font-serif text-cta font-black text-xs uppercase tracking-widest mb-4"
        >
          Primary Office
        </h3>
        <p class="text-site-sub text-xs mt-1">
          525 Darby Creek Rd., Suite 27<br />
          Lexington, KY 40509
        </p>
      </div>

      <div class="p-8 theme-surface-2 border theme-border rounded-[2.5rem]">
        <h3
          class="font-serif text-site-text font-black text-xs uppercase tracking-widest mb-4"
        >
          Education
        </h3>
        <p class="text-sm text-site-sub leading-relaxed font-bold">
          Master of Science (M.S.) in Psychology
        </p>
        <p class="text-xs text-site-sub mt-1 uppercase">
          Licensed Psychological Associate Trainee (T-LPA)
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-24">
    <div class="bg-linear-to-r from-cta/10 to-cta/10 border border-cta/20 rounded-3xl p-8 text-center">
      <h3 class="font-serif text-2xl font-black text-site-text mb-4">Ready to Get Started?</h3>
      <p class="text-site-sub mb-6">Learn what to expect at your first appointment and get all the information you need as a new client.</p>
      <a
        href="/resources/new-client"
        class="inline-block px-8 py-3 bg-cta text-cta-fg font-black rounded-full hover:bg-cta/80 transition-all"
      >
        New Client Information
      </a>
    </div>
  </section>
</ServiceLayout>

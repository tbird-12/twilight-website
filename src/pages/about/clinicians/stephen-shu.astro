---
import Layout from "../../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { WIDGET_LINK } from "../../../data/resource";
import { providers } from "../../../data/staff";

const stephen = providers.find((person) => person.slug === "stephen-shu")!;

const specialties = [
  "Neuropsychological Assessments",
  "Psychological Testing",
  "Marriage & Family Therapy",
  "Cognitive Behavioral Functioning",
];
---

<Layout
  title="Stephen Shu, M.A., LPA | Psychological Assessments Lexington | Twilight Psychology"
  description="Stephen Shu, M.A., LPA — Licensed psychological associate at Twilight Psychology. Neuropsychological assessments for ages 12+ in Lexington, KY."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <section
    class="relative pt-32 pb-24 px-4 border-b theme-border bg-linear-to-b from-site-ann/35 to-transparent"
  >
    <div class="max-w-7xl mx-auto mb-10">
      <a
        href="/about/clinicians/clinicians-lex-ky"
        class="inline-flex items-center gap-2 text-sm font-semibold text-cta/90 hover:text-cta/90"
      >
        <span aria-hidden="true">←</span>
        Back to all clinicians
      </a>
    </div>
    <div
      class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16"
    >
      <div class="relative group">
        <div
          class="absolute -inset-1 bg-linear-to-r from-cta to-cta rounded-[3rem] blur opacity-25 group-hover:opacity-50 transition duration-1000"
        >
        </div>
        <div
          class="relative w-72 h-96 theme-surface-2 rounded-[2.5rem] overflow-hidden border theme-border shadow-2xl"
        >
          <Image
            src={stephen.image}
            alt={`Professional Portrait of ${stephen.name}`}
            class="object-cover w-full h-full rounded-[2.5rem]"
            loading={"eager"}
          />
        </div>
      </div>
      <div class="flex-1 text-center lg:text-left">
        <span
          class="px-4 py-1.5 mb-6 text-[10px] font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full inline-block"
          >Licensed Psychological Associate</span
        >
        <h1
          class="font-serif text-5xl md:text-7xl font-black text-site-text mb-4 tracking-tighter"
        >
          Stephen Shu, <span
            class="text-cta"
            >M.A., LPA.</span>
        </h1>
        <div class="flex flex-wrap justify-center lg:justify-start gap-3 mt-6">
          {
            specialties.map((s) => (
              <span class="px-4 py-2 theme-surface-soft border theme-border rounded-full text-[10px] font-black text-sand uppercase tracking-tighter">
                {s}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section
    class="max-w-4xl mx-auto px-4 py-24 space-y-8 text-site-text text-lg"
  >
    <h2 class="font-serif text-3xl font-black text-site-text italic">
      Clarity Through Comprehensive Evaluation.
    </h2>
    <p>
      I am a Licensed Psychological Associate practicing under the supervision
      of Dr. Heather Cornett. Currently completing my doctoral degree at the
      University of Hartford, I earned my master's from Pepperdine University
      with an emphasis in Marriage and Family Therapy.
    </p>
    <p>
      I am passionate about neuropsychology and providing assessments that
      empower individuals to navigate their lives with greater confidence and
      insight. I strive to create a calm, supportive environment where everyone
      feels safe and respected throughout the evaluation process.
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-24">
    <div
      class="bg-cta p-12 rounded-[4rem] text-cta-fg text-center relative overflow-hidden"
    >
      <div class="relative z-10">
        <h2 class="font-serif text-4xl font-black mb-4 tracking-tighter">
          Current Availability
        </h2>
        <div class="flex flex-col md:flex-row justify-center gap-8 my-8">
          <div
            class="bg-site-bg/10 p-6 rounded-2xl border border-cta-fg/10"
          >
            <p
              class="text-[10px] font-black uppercase tracking-widest mb-1 opacity-60"
            >
              Evaluations
            </p>
            <p class="text-xl font-black">Not accepting new clients</p>
          </div>
          <div
            class="bg-site-bg/10 p-6 rounded-2xl border border-cta-fg/10"
          >
            <p
              class="text-[10px] font-black uppercase tracking-widest mb-1 opacity-60"
            >
              Individual Therapy
            </p>
            <p class="text-xl font-black opacity-40 italic">Waitlist Only</p>
          </div>
        </div>
        <p
          class="font-bold opacity-80 mb-10 max-w-xl mx-auto italic leading-relaxed"
        >
          Stephen provides evaluations for ages 12 and up in Lexington, KY.
        </p>
        <a
          href={WIDGET_LINK}
          class="inline-block px-12 py-5 bg-site-bg text-site-text font-black rounded-2xl hover:scale-105 transition-all"
        >
          Schedule an Intake
        </a>
      </div>
    </div>
  </section>
      </div>
    </div>
  </div>
</Layout>

---
import Layout from "../../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { providers } from "../../../data/staff";

const emeli = providers.find((person) => person.slug === "emeli-evans")!;

const specialties = [
  "AuDHD Identity",
  "PDA (Pathological Demand Avoidance)",
  "High-Masking Support",
  "LGBTQ+ Affirming",
  "Neuro-Affirming Therapy",
];
---

<Layout
  title="Emeli Evans, M.S., LPA | Neuro-Affirming Therapy Lexington | Twilight Psychology"
  description="Emeli Evans, M.S., LPA - Psychological associate at Twilight Psychology in Lexington, KY. Specializing in neuro-affirming therapy for neurodivergent individuals. AuDHD lived experience."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <section
    class="relative pt-32 pb-24 px-4 border-b theme-border bg-linear-to-b from-site-ann/35 to-transparent"
  >
    <div class="max-w-7xl mx-auto mb-10">
      <a
        href="/about/clinicians/clinicians-lex-ky"
        class="inline-flex items-center gap-2 text-sm font-semibold text-cta/90 hover:text-cta/90"
      >
        <span aria-hidden="true">←</span>
        Back to all clinicians
      </a>
    </div>
    <div
      class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16"
    >
      <div class="relative group">
        <div
          class="absolute -inset-1 bg-linear-to-r from-cta to-cta rounded-[3rem] blur opacity-25 group-hover:opacity-50 transition duration-1000"
        >
        </div>
        <div
          class="relative w-72 h-96 theme-surface-2 rounded-[2.5rem] overflow-hidden border theme-border shadow-2xl"
        >
          <Image
            src={emeli.image}
            alt={`Professional Portrait of ${emeli.name}`}
            class="object-cover w-full h-full rounded-[2.5rem]"
            loading={"eager"}
          />
        </div>
      </div>
      <div class="flex-1 text-center lg:text-left">
        <span
          class="px-4 py-1.5 mb-6 text-[10px] font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full inline-block"
          >Psychological Associate</span
        >
        <h1
          class="font-serif text-5xl md:text-7xl font-black text-site-text mb-4 tracking-tighter leading-none"
        >
          Emeli Evans, <br /><span
            class="text-cta"
            >M.S., LPA.</span
          >
        </h1>
        <div class="flex flex-wrap justify-center lg:justify-start gap-3 mt-6">
          {
            specialties.map((s) => (
              <span class="px-4 py-2 theme-surface-soft border theme-border rounded-full text-[10px] font-black text-sand uppercase tracking-tighter">
                {s}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section
    class="max-w-4xl mx-auto px-4 py-24 space-y-8 text-site-text text-lg"
  >
    <h2 class="font-serif text-3xl font-black text-site-text italic">
      Lived Experience meets Clinical Expertise.
    </h2>
    <p>
      As an AuDHD person myself, I am passionate about helping neurodiverse
      kids, adolescents, and adults find their identity. I take a
      neuro-affirming approach to both assessment and therapy, moving away from
      "stereotypical" views of autism.
    </p>
    <p>
      I specialize in identifying <strong
        >Pathological Demand Avoidance (PDA)</strong
      > and working with high-masking individuals. My goal is to support clients in
      unmasking and advocating for their sensory and regulation needs.
    </p>
    <div class="bg-cta/10 border border-cta/30 p-8 rounded-3xl">
      <p class="text-site-text font-bold italic">
        "I am passionate about fostering understanding of the autism spectrum
        and promoting neuroaffirmative practices among other professionals."
      </p>
    </div>
  </section>
      </div>
    </div>
  </div>
</Layout>

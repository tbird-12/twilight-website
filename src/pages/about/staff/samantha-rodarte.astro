---
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import '../../../styles/global.css';
import { EMAIL_ADDRESS } from "../../../data/resource";
import { Image } from 'astro:assets';
import { staff } from '../../../data/staff';

const samantha = staff.find(person => person.slug === 'samantha-rodarte')!;

const expertise = [
  "Practice Operations",
  "Patient Care Coordination",
  "Eligibility & Benefits Navigation",
  "Client Relations"
];
---

<ServiceLayout name="Samantha Rodarte | Practice Manager at Twilight Psychology"
  description="Meet Samantha Rodarte, the Practice Manager at Twilight Psychology. 
  With expertise in practice operations, patient care coordination, and insurance navigation, Samantha ensures a seamless experience for both clients and clinicians. Learn how she supports our mission to provide exceptional mental health care."
  metaDescription="Samantha Rodarte - Practice Manager at Twilight Psychology in Lexington, KY. Expert in practice operations, patient care coordination, and insurance navigation supporting exceptional mental health services."
  >
    
    <section class="relative pt-32 pb-24 px-4 border-b border-white/5 bg-linear-to-b from-slate-800/20 to-transparent">
      <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16">
        <div class="relative group">
            <div class="absolute -inset-1 bg-linear-to-r from-cta to-indigo-500 rounded-[3rem] blur opacity-25 group-hover:opacity-50 transition duration-1000"></div>
            <div class="relative w-72 h-96 bg-slate-800 rounded-[2.5rem] overflow-hidden border border-white/10 shadow-2xl">
                <Image 
                  src={samantha.image} 
                  alt={samantha.name} 
                  class="object-cover w-full h-full rounded-[2.5rem]" 
                  loading={'eager'}/>
            </div>
        </div>

        <div class="flex-1 text-center lg:text-left">
            <span class="px-4 py-1.5 mb-6 text-[10px] font-black tracking-[0.4em] text-cta uppercase bg-cta/10 border border-cta/20 rounded-full inline-block">
                Administrative Assistant
            </span>
            <h1 class="font-serif text-5xl md:text-7xl font-black text-site-text mb-4 tracking-tighter leading-none">
                Samantha <br/>
                <span class="text-cta">Rodarte.</span>
            </h1>
            <p class="text-site-sub text-lg leading-relaxed max-w-2xl mb-8">
                Ensuring a seamless, supportive experience for every client from their initial inquiry to the completion of their care.
            </p>
            <div class="flex flex-wrap justify-center lg:justify-start gap-3">
                {expertise.map(item => (
                    <span class="px-4 py-2 bg-white/5 border border-white/5 rounded-full text-[10px] font-black text-sand uppercase tracking-tighter">
                        {item}
                    </span>
                ))}
            </div>
        </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 py-24 grid lg:grid-cols-12 gap-16">
        <div class="lg:col-span-8 space-y-8 text-site-text text-lg leading-relaxed">
            <h2 class="font-serif text-3xl font-black text-site-text italic tracking-tight">The Bridge Between Care and Coordination.</h2>
            <p>
                As the Practice Manager at Twilight Psychology, Samantha is the foundational support for our clinicians and clients alike. With a deep understanding of the administrative complexities of mental healthcare, she navigates everything from complex insurance verifications to the scheduling of specialized evaluations.
            </p>
            <p>
                Samantha believes that the healing process begins the moment a client reaches out. She is dedicated to creating an environment that is organized, transparent, and empathetic, ensuring that the logistical side of therapy and testing never stands in the way of clinical progress.
            </p>
            
            <div class="bg-slate-800/30 border-l-4 border-cta p-8 rounded-r-3xl">
                <h4 class="font-serif text-site-text font-black text-sm uppercase mb-2">Direct Contact</h4>
                <p class="text-cta font-black text-lg underline underline-offset-4 decoration-amber-500/30">
                    <a href={`mailto:${EMAIL_ADDRESS}`} class="text-cta hover:text-cta transition-colors duration-200">{EMAIL_ADDRESS}</a>
                </p>
            </div>
        </div>

        <div class="lg:col-span-4 space-y-8">
            <div class="bg-white/3 border border-white/10 p-8 rounded-[2.5rem]">
                <h3 class="font-serif text-cta font-black text-xs uppercase tracking-widest mb-4">Core Focus</h3>
                <p class="text-sm text-site-text/60 leading-relaxed italic">
                    "My goal is to handle the heavy lifting of healthcare administration so our patients can focus entirely on their growth and our clinicians can focus entirely on their care."
                </p>
            </div>

            <div class="p-8 bg-slate-800/20 border border-white/5 rounded-[2.5rem]">
                <h3 class="font-serif text-site-text font-black text-xs uppercase tracking-widest mb-4">Contact Samantha For:</h3>
                <ul class="text-xs text-site-sub/60 space-y-3 font-medium">
                    <li class="flex items-center gap-2"><span class="text-cta">→</span> Benefits & Eligibility Questions</li>
                    <li class="flex items-center gap-2"><span class="text-cta">→</span> Insurance Verification</li>
                    <li class="flex items-center gap-2"><span class="text-cta">→</span> Records Requests</li>
                    <li class="flex items-center gap-2"><span class="text-cta">→</span> New Patient Onboarding</li>
                </ul>
            </div>
        </div>
    </section>

    <section class="max-w-4xl mx-auto px-4 py-24 mt-12">
      <div class="bg-linear-to-r from-cta/10 to-cta/10 border border-cta/20 rounded-3xl p-8 text-center">
        <h3 class="font-serif text-xl font-black text-site-text mb-4">Wondering About Wait Times?</h3>
        <p class="text-site-sub mb-6">Check our current waitlist times for different services and get a better idea of when you can be seen.</p>
        <a
          href="/resources/waitlist-times"
          class="inline-block px-8 py-3 bg-cta text-cta-fg font-black rounded-full hover:bg-cta/80 transition-all"
        >
          View Waitlist Times
        </a>
      </div>
    </section>
</ServiceLayout>
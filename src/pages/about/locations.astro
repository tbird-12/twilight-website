---
import Layout from "../../layouts/Layout.astro";
import PageHeroWrapper from "../../components/PageHeroWrapper.astro";
import AnimatedSection from "../../components/react/primitives/AnimatedSection";
import PageLinksSection from "../../components/PageLinksSection.astro";
import {
  MAIN_OFFICE_STREET_ADDRESS,
  MAIN_OFFICE_CITY_STATE_ZIP,
  MAIN_OFFICE_MAP_LINK,
} from "../../data/resource";

const locations = [
  {
    type: "Main Office",
    providers: "Heather Cornett, Emeli Evans, Jatana Boggs, Jonica Davis, Stephen Shu, Tiffany Roundtree, Ethan Puckett",
    address: MAIN_OFFICE_STREET_ADDRESS,
    city: MAIN_OFFICE_CITY_STATE_ZIP,
    mapLink: MAIN_OFFICE_MAP_LINK,
  },
  {
    type: "Medication Management",
    providers: "Nicola Allen",
    address: "1040 Monarch St., Office 305",
    city: "Lexington, KY 40513",
    mapLink:
      "https://www.google.com/maps/search/?api=1&query=1040+Monarch+St+Office+305+Lexington+KY+40513",
  },
];

const telehealthProviders = [
  { name: "Heather Cornett, PhD", coverage: "40+ states nationwide via PsyPact" },
  { name: "Michael Burns, PhD", coverage: "Kentucky & Tennessee" },
  { name: "Jatana Boggs, MS", coverage: "Kentucky & Ohio" },
  { name: "All other clinicians", coverage: "Kentucky statewide" },
];

const locationLinks = [
  {
    href: "/about/twilight-psychology",
    label: "Mission and values",
    description:
      "See the principles that shape the practice and the kind of care Twilight aims to provide.",
  },
  {
    href: "/about/clinicians/clinicians-lex-ky",
    label: "Meet the team",
    description:
      "Match each office location with the clinicians and services available there.",
  },
  {
    href: "/about/careers",
    label: "Careers at Twilight",
    description:
      "Learn how our offices support therapists, evaluators, and future openings.",
  },
];
---

<Layout
  title="Office Locations & Service Area | Twilight Psychology"
  description="Twilight Psychology has offices in Lexington, KY and offers telehealth services statewide across Kentucky. Select providers are also licensed in Tennessee and Ohio, and Dr. Cornett is available nationwide via PsyPact."
>
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  
  <PageHeroWrapper
    title="Our Locations"
    accentWord="Locations"
    badge="Lexington, KY · Telehealth Statewide"
    subtitle="Twilight Psychology is located in Lexington, KY, with dedicated spaces for psychological evaluations, therapy, and medication management — and telehealth services available statewide across Kentucky and beyond."
    size="lg"
  />

  <AnimatedSection client:visible animation="fadeInUp" delay={100}>
  <section class="max-w-4xl mx-auto px-4 -mt-8 relative z-20 space-y-6">
    <div
      class="bg-cta p-6 rounded-2xl shadow-xl flex items-center gap-4"
    >
      <span class="text-2xl">🗓️</span>
      <p class="font-bold text-sm sm:text-base inverted-text">
        All visits are by appointment only. If you plan to drop by without one, 
        please call before visiting our office to ensure staff are present and available to assist you.
      </p>
    </div>

    <div
      class="bg-surface border border-cta/30 text-site-text p-6 rounded-2xl flex items-center gap-4"
    >
      <p class="font-bold text-sm sm:text-base">
        Curious about how long we're booked out? Check our <a href="/resources/waitlist-times" class="text-cta underline hover:text-cta transition-colors">current waitlist times</a> to see when appointments are available.
      </p>
    </div>
  </section>
  </AnimatedSection>

  <AnimatedSection client:visible animation="fadeInUp" delay={200}>
  <section class="max-w-7xl mx-auto px-4 py-24">
    <div class="grid lg:grid-cols-2 gap-4 sm:gap-8 max-w-4xl mx-auto">
      {
        locations.map((loc) => (
          <div class="bg-surface-soft border border-border rounded-[2.5rem] p-6 sm:p-10 flex flex-col justify-between hover:border-cta/30 active:scale-[0.98] transition-all group">
            <div>
              <div class="mb-6">
                <h2 class="font-serif text-2xl font-black text-site-text group-hover:text-cta transition-colors">
                  {loc.type}
                </h2>
                <p class="text-xs font-black uppercase tracking-widest text-site-sub mt-1">
                  Providers:
                </p>
                <p class="text-sm font-bold text-sand">{loc.providers}</p>
              </div>

              <div class="space-y-1 mb-10">
                <p class="text-lg font-medium text-site-text">{loc.address}</p>
                <p class="text-site-sub">{loc.city}</p>
              </div>
            </div>

            <a
              href={loc.mapLink}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full py-4 bg-surface-soft border border-border rounded-xl font-black text-cta/80 text-xs uppercase tracking-widest hover:bg-cta hover:text-cta-fg transition-all"
            >
              Get Directions <span>↗</span>
            </a>
          </div>
        ))
      }
    </div>
  </section>
  </AnimatedSection>

  <AnimatedSection client:visible animation="fadeInUp" delay={300}>
  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="rounded-[2.5rem] border border-border bg-surface p-8 md:p-10">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-2xl" aria-hidden="true">💻</span>
        <div>
          <p class="text-xs font-black uppercase tracking-widest text-site-sub">Virtual Care</p>
          <h2 class="font-serif text-2xl font-black text-site-text">Telehealth — Statewide & Beyond</h2>
        </div>
      </div>
      <p class="text-site-text leading-relaxed font-medium mb-6">
        All of our clinical services are also available via secure telehealth for clients who prefer remote appointments or live outside the Lexington area. Several of our providers hold licensure in multiple states, extending telehealth availability well beyond Kentucky.
      </p>
      <ul class="space-y-3 mb-8">
        {telehealthProviders.map((p) => (
          <li class="flex items-start gap-3">
            <span class="mt-0.5 text-cta font-black text-sm">✓</span>
            <div>
              <span class="font-bold text-site-text text-sm">{p.name}</span>
              <span class="text-site-sub text-sm"> — {p.coverage}</span>
            </div>
          </li>
        ))}
      </ul>
      <a
        href="/about/service-area"
        class="inline-flex items-center gap-2 text-xs font-black uppercase tracking-widest text-cta hover:underline"
      >
        View full service area & telehealth details →
      </a>
    </div>
  </section>
  </AnimatedSection>

  <section class="max-w-4xl mx-auto px-4 py-24 text-center">
    <div class="p-12 bg-surface-soft border border-border rounded-[3rem]">
      <h3 class="font-serif text-2xl font-black mb-4 italic text-site-text!">Choosing the Right Door</h3>
      <p class="text-site-sub leading-relaxed mb-0">
        Twilight Psychology operates out of two distinct suites to provide
        privacy and specialized clinical environments for our clients. Please double-check
        your appointment reminder for your specific suite number before your
        visit.
      </p>
    </div>
  </section>

  <PageLinksSection
    title="Explore more about the practice"
    description="Locations make more sense when you can connect them to the team, the mission, and current opportunities."
    links={locationLinks}
  />
      </div>
    </div>
</Layout>

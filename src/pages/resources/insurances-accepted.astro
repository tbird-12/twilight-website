---
import ServiceLayout from "../../layouts/ServiceLayout.astro";
import "../../styles/global.css";
import { Image } from "astro:assets";
import { PHONE_NUMBER } from "../../data/resource";
import { insuranceProviders } from "../../data/insurances";

const images = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/images/insurance/*.png",
);
---

<ServiceLayout 
  name="Insurance Coverage"
  description="We accept most major insurance providers"
  metaDescription="View accepted insurance plans at Twilight Psychology in Kentucky, plus options for out-of-network billing and private pay care."
>
  <section class="bg-site-bg min-h-screen py-24 px-4">
    <div class="max-w-7xl mx-auto">
      <header class="text-center mb-12">
        <h1 class="font-serif text-4xl md:text-5xl font-black text-site-text mb-4">
          Accepted <span class="text-cta">Insurances</span>
        </h1>
        <p class="text-sand text-lg max-w-2xl mx-auto">
          We maintain credentials with most major insurance providers to ensure our specialized services remain broadly accessible.
        </p>
      </header>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {
          insuranceProviders.map((provider) => {
            // We dynamically build the path to match the imported images
            const imagePath = `../../assets/images/insurance/${provider.fileName}`;

            return (
              <div class="bg-white md:bg-white/5 border border-white/10 rounded-2xl p-6 flex flex-col items-center justify-center group md:hover:bg-white transition-all duration-300">
                <div class="h-16 flex items-center justify-center mb-4">
                  {images[imagePath] ? (
                    <Image
                      src={images[imagePath]()}
                      alt={provider.name}
                      width={200}
                      height={80}
                      class="max-h-12 w-auto object-contain grayscale-0 md:grayscale md:group-hover:grayscale-0 transition-all duration-500"
                    />
                  ) : (
                    <span class="text-cta-fg md:text-site-text md:group-hover:text-cta-fg font-bold">
                      {provider.name}
                    </span>
                  )}
                </div>
                <p class="text-[10px] font-black uppercase tracking-widest text-cta-fg md:text-site-sub md:group-hover:text-cta-fg">
                  {provider.name}
                </p>
              </div>
            );
          })
        }
      </div>

      <section class="max-w-4xl mx-auto mt-16">
      <div
        class="bg-cta/10 border border-cta/30 p-10 rounded-[3rem] text-center"
      >
        <h2 class="font-serif text-2xl font-black text-site-text mb-4 italic">
          Don't see your provider?
        </h2>
        <p class="text-site-text/70 leading-relaxed mb-8">
          Insurance panels are frequently updated, and not all clinicians maintain
          in-network status with every listed provider. We also offer out-of-network billing
          support and private pay options for clients seeking expedited access to care.
        </p>
        <a
          href={`tel:${PHONE_NUMBER}`}
          class="inline-block px-10 py-4 bg-cta text-cta-fg font-black rounded-full hover:bg-white transition-all"
        >
          Verify Your Coverage
        </a>
      </div>
      </section>
    </div>
  </section>
</ServiceLayout>

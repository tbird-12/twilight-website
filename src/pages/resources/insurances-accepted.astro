---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { PHONE_NUMBER } from "../../data/resource";
import { insuranceProviders } from "../../data/insurances";
import { categoryColorMap } from "../../data/blogCategories";
import PageHeroWrapper from "../../components/PageHeroWrapper.astro";
import AnimatedSection from "../../components/react/primitives/AnimatedSection";

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/images/insurance/*.png",
  { eager: true },
);

const insuranceCards = insuranceProviders.map((provider) => ({
  ...provider,
  image:
    imageModules[`../../assets/images/insurance/${provider.fileName}`]?.default,
}));

const insuranceCategoryClass = categoryColorMap.insurance;
const announcementCategoryClass = categoryColorMap.announcements;
---

<Layout
  title="Insurance Coverage | Twilight Psychology"
  description="Accepted insurance at Twilight Psychology in Kentucky for covered behavioral health services: Aetna, Cigna, UHC, Anthem, Medicaid, Medicare, Tricare, and more."
>
    <PageHeroWrapper
      title="Accepted Insurances"
      accentWord="Insurances"
      subtitle="We accept most major insurance plans for covered mental health diagnoses, including Aetna, Cigna, UHC, Anthem, Medicaid, and Medicare."
      size="lg"
    />
    <section class="bg-site-bg py-24 px-4">
      <div class="max-w-7xl mx-auto">

      <AnimatedSection client:visible animation="fadeInUp" delay={100}>
      <div class="insurance-logo-grid grid grid-cols-2 md:grid-cols-4 gap-4">
        {
          insuranceCards.map((provider) => {
            return (
              <div class="insurance-logo-card border rounded-2xl p-6 flex flex-col items-center justify-center group active:scale-95 active:bg-surface-2 transition-all duration-300">
                <div class="h-16 flex items-center justify-center mb-4">
                  {provider.image ? (
                    <Image
                      src={provider.image}
                      alt={provider.name}
                      widths={[200, 300]}
                      sizes="(min-width: 768px) 200px, 150px"
                      class="max-h-20 max-w-full w-auto h-auto object-contain grayscale-0 md:grayscale md:group-hover:grayscale-0 transition-all duration-500"
                    />
                  ) : (
                    <span class="insurance-logo-card-fallback text-site-text font-bold transition-colors duration-300">
                      {provider.name}
                    </span>
                  )}
                </div>
                <p class="insurance-logo-card-label text-xs font-black uppercase tracking-widest text-site-sub transition-colors duration-300">
                  {provider.name}
                </p>
              </div>
            );
          })
        }
      </div>
      </AnimatedSection>

      <AnimatedSection client:visible animation="fadeInUp" delay={200}>
      <section class="max-w-4xl mx-auto mt-12">
        <div class="bg-surface-soft border border-border-strong p-8 rounded-[2.5rem]">
          <h2 class="font-serif text-2xl font-black text-site-text mb-4">Coverage depends on the service</h2>
          <div class="space-y-4 text-site-sub leading-relaxed">
            <p>
              We accept the plans shown above for <strong class="text-site-text">covered behavioral health services</strong>.
              Therapy and medication management are usually the clearest places to use in-network benefits.
            </p>
            <p>
              For psychological evaluations, coverage depends on the referral question and the number of testing units
              a plan approves. Insurance-based testing hours include record collection, collateral information,
              interviewing clients and parents, test administration, reviewing and integrating data, researching
              concerns, consulting with other providers, and documentation, so we focus on the most clinically
              relevant tests within the hours authorized. Kentucky Medicaid plans in particular often require services
              to be <strong class="text-site-text">treatment-focused, medically necessary, and authorized in advance</strong>,
              and Medicaid clients cannot be charged beyond covered amounts. Evaluations requested mainly for school,
              court, disability or waiver eligibility, benefits paperwork, or other third-party documentation are
              typically handled through self-pay or another funding source instead of insurance.
            </p>
          </div>
        </div>
      </section>
      </AnimatedSection>

      <AnimatedSection client:visible animation="fadeInUp" delay={300}>
      <section class="max-w-4xl mx-auto mt-16">
      <div
        class="bg-cta/10 border border-cta/30 p-10 rounded-[3rem] text-center"
      >
        <h2 class="font-serif text-2xl font-black text-site-text mb-4 italic">
          Don't see your provider?
        </h2>
        <p class="text-site-sub leading-relaxed mb-8">
          Insurance panels are frequently updated, and not all clinicians maintain
          in-network status with every listed provider. Therapy and medication management are usually the clearest
          places to use insurance. Evaluation referrals depend on medical necessity and the number of testing units a
          plan authorizes, and self-pay can be used when someone wants broader testing or documentation than a plan
          will cover. We also offer out-of-network billing support when appropriate.
        </p>
        <a
          href={`tel:${PHONE_NUMBER}`}
          class="inline-block px-10 py-4 bg-cta text-cta-fg font-black rounded-full hover:bg-cta/80 transition-all"
        >
          Verify Your Coverage
        </a>
      </div>
      </section>
      </AnimatedSection>

      <AnimatedSection client:visible animation="fadeInUp" delay={400}>
      <section class="max-w-4xl mx-auto mt-12">
          <h2 class="font-serif text-2xl font-black text-site-text mb-6">Insurance Resources from Our Blog</h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <a href="/blog/insurance/understanding-health-insurance" class="group p-6 bg-surface-soft border border-border rounded-2xl hover:border-cta/30 transition-all">
              <p class={`inline-flex items-center rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-widest mb-2 ${insuranceCategoryClass}`}>Insurance</p>
              <h3 class="font-serif text-sm font-black text-site-text group-hover:text-cta transition-colors mb-1">Understanding Health Insurance</h3>
              <p class="text-xs text-site-sub">Commercial plans, Kentucky Medicaid MCOs, and Medicare explained.</p>
            </a>
            <a href="/blog/insurance/aetna-better-health-in-network" class="group p-6 bg-surface-soft border border-border rounded-2xl hover:border-cta/30 transition-all">
              <p class={`inline-flex items-center rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-widest mb-2 ${insuranceCategoryClass}`}>Insurance</p>
              <h3 class="font-serif text-sm font-black text-site-text group-hover:text-cta transition-colors mb-1">Aetna Better Health — Prior Auth & Appeals</h3>
              <p class="text-xs text-site-sub">Medical necessity, exclusions, prior authorization, and appeals for Kentucky Medicaid testing.</p>
            </a>
            <a href="/blog/announcements/wellcare-kentucky-in-network" class="group p-6 bg-surface-soft border border-border rounded-2xl hover:border-cta/30 transition-all">
              <p class={`inline-flex items-center rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-widest mb-2 ${announcementCategoryClass}`}>Announcement</p>
              <h3 class="font-serif text-sm font-black text-site-text group-hover:text-cta transition-colors mb-1">Now In-Network with Wellcare of Kentucky</h3>
              <p class="text-xs text-site-sub">Therapy and medication management under Wellcare benefits.</p>
            </a>
        </div>
        <div class="mt-4 text-center">
          <a href="/blog/category/insurance" class="text-cta text-sm font-bold hover:underline">View all insurance posts →</a>
        </div>
      </section>
      </AnimatedSection>
      </div>
    </section>
</Layout>

<style>
  /* Keep insurance cards light in both themes so logos and fallback text stay legible in dark mode. */
  .insurance-logo-card {
    background-color: #c0c0c0;
    border-color: var(--color-border);
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
  }

  .insurance-logo-card-label,
  .insurance-logo-card-fallback {
    color: #334155;
  }

  @media (min-width: 768px) {
    .insurance-logo-card:hover {
      background-color: #c0c0c0;
      border-color: var(--color-border-strong);
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
      transform: translateY(-2px);
    }
  }
</style>

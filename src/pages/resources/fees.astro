---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import '../../styles/global.css';
import { PHONE_NUMBER, PHONE_NUMBER_FORMATTED } from '../../data/resource';

const psychologicalServices = [
  { name: "ADHD Assessments", price: "$1,300" },
  { name: "Autism Assessments", price: "$1,300" },
  { name: "Personality Disorder Assessments", price: "$1,300" },
  { name: "Full Psychological Evaluation", price: "$1,300", note: "Covers Autism, ADHD, and Personality" },
  { name: "Learning Disorder (Disability) Assessments", price: "$1,500", note: "Self-pay only" },
  { name: "Guardianship Evaluation", price: "$500", note: "Additional cost for court/extra testing" },
  { name: "Emotional Support Animal (ESA) Evaluation", price: "$200" },
  { name: "Diagnostic Clarification", price: "$220" },
];

const psychotherapyServices = [
  { name: "60-Minute Session", price: "$250" },
  { name: "45-Minute Session", price: "$175" },
  { name: "Clinical Supervision", price: "$150", note: "Per hour" },
];

const medManagement = [
  { name: "Intake Session", price: "$250" },
  { name: "Follow-up Sessions", price: "$100" },
  { name: "Medical Marijuana Consultations", price: "$150" },
  { name: "Paperwork (e.g., FMLA)", price: "$75", note: "Per hour" },
];
---

<ServiceLayout 
  name="Investment & Pricing"
  description="Transparent pricing and payment options"
  metaDescription="Twilight Psychology pricing and fees for psychological evaluations, therapy, and medication management in Kentucky. Transparent pricing, insurance accepted, flexible payment options available."
>
  <section class="bg-site-bg min-h-screen py-24 px-4">
    <div class="max-w-4xl mx-auto">
      
      <header class="text-center mb-12">
        <h1 class="font-serif text-4xl md:text-5xl font-black text-site-text mb-4">
          Fees & <span class="text-cta">Insurance</span>
        </h1>
        <p class="text-sand text-lg max-w-2xl mx-auto">
          Transparency is part of the journey. We are committed to providing top-tier behavioral health services that are accessible and affordable.
        </p>
      </header>

      <section class="mb-12 bg-slate-800/40 border-l-4 border-cta p-6 rounded-r-2xl">
        <h2 class="font-serif text-site-text font-bold text-xl mb-2">Insurance Information</h2>
        <p class="text-site-text leading-relaxed">
          Clients with <strong>Kentucky Medicaid</strong> typically have $0 copays for covered services. For 
          <a href="/resources/insurances-accepted" class="text-cta underline">commercial insurance</a>
          we recommend calling 
          <a href={`tel:${PHONE_NUMBER}`} class="text-cta underline">{PHONE_NUMBER_FORMATTED}</a> to determine approximate rates, though you should always confirm benefits, copays, deductibles with your insurance provider prior to your appointment.
        </p>
      </section>

      <section class="mt-10" data-fee-tabs-root>
        <div class="mb-3 flex items-center justify-between px-1 text-xs text-site-sub/80">
          <p class="font-semibold uppercase tracking-wider">Choose a pricing category</p>
          <p class="sm:hidden">Swipe for more</p>
        </div>
        <div class="relative">
          <div class="pointer-events-none absolute inset-y-0 left-0 w-8 bg-linear-to-r from-site-bg to-transparent sm:hidden"></div>
          <div class="pointer-events-none absolute inset-y-0 right-0 w-8 bg-linear-to-l from-site-bg to-transparent sm:hidden"></div>
          <div
            class="mb-6 flex gap-3 overflow-x-auto pb-2 snap-x snap-mandatory"
            role="tablist"
            aria-label="Fee categories"
          >
          <button
            type="button"
            id="fee-tab-psychological"
            role="tab"
            aria-controls="fee-panel-psychological"
            aria-selected="true"
            data-fee-tab-trigger
            data-target="fee-panel-psychological"
            class="snap-start min-w-max px-5 py-4 rounded-2xl border transition-all duration-200 font-serif font-black text-sm tracking-wide bg-cta text-site-bg border-cta shadow-lg shadow-cta/20"
          >
            <span class="flex items-center gap-3 text-left">
              <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-site-bg/20 text-[11px] font-black">1</span>
              <span class="leading-tight">
                <span class="block">Psychological Evaluations</span>
                <span class="block text-[10px] uppercase tracking-wider opacity-80">{psychologicalServices.length} services</span>
              </span>
            </span>
          </button>
          <button
            type="button"
            id="fee-tab-psychotherapy"
            role="tab"
            aria-controls="fee-panel-psychotherapy"
            aria-selected="false"
            data-fee-tab-trigger
            data-target="fee-panel-psychotherapy"
            class="snap-start min-w-max px-5 py-4 rounded-2xl border transition-all duration-200 font-serif font-black text-sm tracking-wide bg-white/5 text-site-text border-white/10 hover:border-cta/50 hover:text-cta opacity-80"
          >
            <span class="flex items-center gap-3 text-left">
              <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10 text-[11px] font-black">2</span>
              <span class="leading-tight">
                <span class="block">Psychotherapy</span>
                <span class="block text-[10px] uppercase tracking-wider opacity-80">{psychotherapyServices.length} services</span>
              </span>
            </span>
          </button>
          <button
            type="button"
            id="fee-tab-medication"
            role="tab"
            aria-controls="fee-panel-medication"
            aria-selected="false"
            data-fee-tab-trigger
            data-target="fee-panel-medication"
            class="snap-start min-w-max px-5 py-4 rounded-2xl border transition-all duration-200 font-serif font-black text-sm tracking-wide bg-white/5 text-site-text border-white/10 hover:border-cta/50 hover:text-cta opacity-80"
          >
            <span class="flex items-center gap-3 text-left">
              <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10 text-[11px] font-black">3</span>
              <span class="leading-tight">
                <span class="block">Medication Management</span>
                <span class="block text-[10px] uppercase tracking-wider opacity-80">{medManagement.length} services</span>
              </span>
            </span>
          </button>
          </div>
        </div>

        <article
          id="fee-panel-psychological"
          role="tabpanel"
          aria-labelledby="fee-tab-psychological"
          data-fee-tab-panel
          class="bg-slate-800/20 border border-slate-700 rounded-3xl p-8"
        >
          <h3 class="font-serif text-2xl font-black text-site-text mb-6 flex items-center gap-3">
            <span class="w-2 h-8 bg-cta rounded-full"></span>
            Psychological Evaluations
          </h3>
          <div class="space-y-4">
            {psychologicalServices.map((service) => (
              <div class="flex justify-between items-start py-3 border-b border-slate-800/50">
                <div>
                  <p class="text-site-text font-bold">{service.name}</p>
                  {service.note && <p class="text-xs text-sand uppercase tracking-wider">{service.note}</p>}
                </div>
                <span class="text-cta font-black">{service.price}</span>
              </div>
            ))}
          </div>
        </article>

        <article
          id="fee-panel-psychotherapy"
          role="tabpanel"
          aria-labelledby="fee-tab-psychotherapy"
          data-fee-tab-panel
          class="hidden bg-slate-800/20 border border-slate-700 rounded-3xl p-8"
        >
          <h3 class="font-serif text-2xl font-black text-site-text mb-6">Psychotherapy</h3>
          <div class="space-y-4">
            {psychotherapyServices.map((service) => (
              <div class="flex justify-between items-center py-3 border-b border-slate-800/50">
                <div>
                  <span class="text-site-text font-bold">{service.name}</span>
                  {service.note && <p class="text-xs text-sand uppercase tracking-wider">{service.note}</p>}
                </div>
                <span class="text-cta font-black">{service.price}</span>
              </div>
            ))}
          </div>
        </article>

        <article
          id="fee-panel-medication"
          role="tabpanel"
          aria-labelledby="fee-tab-medication"
          data-fee-tab-panel
          class="hidden bg-slate-800/20 border border-slate-700 rounded-3xl p-8"
        >
          <h3 class="font-serif text-2xl font-black text-site-text mb-6">Medication Management</h3>
          <div class="space-y-4">
            {medManagement.map((service) => (
              <div class="flex justify-between items-center py-3 border-b border-slate-800/50">
                <div>
                  <span class="text-site-text font-bold">{service.name}</span>
                  {service.note && <p class="text-xs text-sand uppercase tracking-wider">{service.note}</p>}
                </div>
                <span class="text-cta font-black">{service.price}</span>
              </div>
            ))}
          </div>
        </article>
      </section>

      <section class="mt-12 p-8 bg-linear-to-br from-slate-800 to-site-bg rounded-3xl border border-slate-700">
        <h3 class="font-serif text-site-text font-black text-xl mb-4">Flexible Payment Plans</h3>
        <p class="text-site-sub mb-6">
          We offer payment plans where testing costs can be split into 2-3 equal payments due 24 hours before your appointments. 
          For a standard $1,300 battery, this typically looks like:
        </p>
        <div class="grid grid-cols-3 gap-4 text-center">
          <div class="p-4 bg-site-bg rounded-xl border border-slate-800">
            <p class="text-[10px] text-sand uppercase">Intake</p>
            <p class="text-xl font-black text-cta">$450</p>
          </div>
          <div class="p-4 bg-site-bg rounded-xl border border-slate-800">
            <p class="text-[10px] text-sand uppercase">Testing</p>
            <p class="text-xl font-black text-cta">$450</p>
          </div>
          <div class="p-4 bg-site-bg rounded-xl border border-slate-800">
            <p class="text-[10px] text-sand uppercase">Feedback</p>
            <p class="text-xl font-black text-cta">$400</p>
          </div>
        </div>
      </section>

      <section class="mt-10">
        <div class="grid gap-6 md:grid-cols-2 bg-slate-800/20 border border-slate-700 rounded-3xl p-8">
          <div>
            <h3 class="font-serif text-site-text font-black text-xl mb-3">Accepted Payment Methods</h3>
            <ul class="text-site-sub list-disc list-inside">
              <li><a href="/resources/insurances-accepted" class="underline hover:text-cta">Insurance</a></li>
              <li>FSA/HSA Card</li>
              <li>Credit card</li>
              <li>Debit card</li>
              <li>Cash</li>
              <li>Zelle, Venmo</li>
            </ul>
          </div>
          <div>
            <h3 class="font-serif text-site-text font-black text-xl mb-6">Financing Options</h3>
            <a href="https://www.carecredit.com/go/VSM688/?dtc=DS9X&sitecode=CCLBADS9X" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center p-4 rounded-lg hover:bg-white/5">
              <img width="175" 
                src="https://www.carecredit.com/sites/pc/image/flexible-financing-prequal-apply-pay-375x320.png" 
                alt="CareCredit - Flexible Financing for Healthcare" class="w-full md:w-56 hover:scale-105 transition-all" />
            </a>
          </div>
        </div>
      </section>

      <footer class="mt-12 text-center text-site-sub/60 text-sm space-y-4">
        <p>Rates in effect from 01/01/2026</p>
        <p class="max-w-2xl mx-auto">
          Under the <strong>No Surprises Act</strong>, you have the right to receive a Good Faith Estimate prior to services. 
          For additional information, visit <a href="https://www.cms.gov/medical-bill-rights" class="underline hover:text-cta">cms.gov/medical-bill-rights</a>.
        </p>
      </footer>

    </div>
  </section>

  <script is:inline>
    const feeTabsRoot = document.querySelector("[data-fee-tabs-root]");

    if (feeTabsRoot) {
      const triggers = Array.from(
        feeTabsRoot.querySelectorAll("[data-fee-tab-trigger]"),
      );
      const panels = Array.from(
        feeTabsRoot.querySelectorAll("[data-fee-tab-panel]"),
      );

      const activateFeeTab = (targetId) => {
        triggers.forEach((trigger) => {
          const isActive = trigger.dataset.target === targetId;
          trigger.setAttribute("aria-selected", String(isActive));
          trigger.classList.toggle("bg-cta", isActive);
          trigger.classList.toggle("text-site-bg", isActive);
          trigger.classList.toggle("border-cta", isActive);
          trigger.classList.toggle("shadow-lg", isActive);
          trigger.classList.toggle("shadow-cta/20", isActive);
          trigger.classList.toggle("opacity-100", isActive);
          trigger.classList.toggle("bg-white/5", !isActive);
          trigger.classList.toggle("text-site-text", !isActive);
          trigger.classList.toggle("border-white/10", !isActive);
          trigger.classList.toggle("opacity-80", !isActive);
        });

        panels.forEach((panel) => {
          panel.classList.toggle("hidden", panel.id !== targetId);
        });
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener("click", () => {
          const targetId = trigger.dataset.target;
          if (targetId) {
            activateFeeTab(targetId);
          }
        });
      });
    }
  </script>
</ServiceLayout>
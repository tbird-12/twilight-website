---
import Layout from '../../layouts/Layout.astro';
import { PHONE_NUMBER, PHONE_NUMBER_FORMATTED, WIDGET_LINK } from '../../data/resource';
import { categoryColorMap } from '../../data/blogCategories';
import PageHeroWrapper from '../../components/PageHeroWrapper.astro';
import FeeTabsWrapper from '../../components/FeeTabsWrapper.astro';
import AnimatedSection from '../../components/react/primitives/AnimatedSection';
import PageLinksSection from '../../components/PageLinksSection.astro';

const feeCategories = [
  {
    id: "psychological",
    title: "Psychological Evaluations",
    services: [
      { name: "ADHD Assessments", price: "$1,300" },
      { name: "Autism Assessments", price: "$1,300" },
      { name: "Personality Evaluations", price: "$1,300" },
      { name: "Full Psychological Evaluation", price: "$1,300", note: "Covers Autism, ADHD, and Personality" },
      { name: "Child Psychological Evaluations", price: "$1,000", note: "Ages 2-6; personality evaluation add-on not included" },
      { name: "Learning Disorder (Disability) Assessments", price: "$1,500", note: "Offered on a self-pay basis" },
      { name: "Guardianship Evaluation", price: "$500", note: "Additional cost for court/extra testing" },
      { name: "Emotional Support Animal (ESA) Evaluation", price: "$300" },
      { name: "Diagnostic Clarification", price: "$250" },
    ],
  },
  {
    id: "therapy",
    title: "Therapy",
    services: [
      { name: "60-Minute Session", price: "$200", note: "Dr. Cornett" },
      { name: "45-Minute Session", price: "$150", note: "Dr. Cornett" },
      { name: "Individual Session (55 min)", price: "$150", note: "Jatana Boggs" },
      { name: "Couples Session (75 min)", price: "$200", note: "Jatana Boggs" },
      { name: "Individual Intensive (2 hr)", price: "$350", note: "Jatana Boggs" },
      { name: "Couples Intensive (3 hr)", price: "$650", note: "Jatana Boggs" },
      { name: "Clinical Supervision", price: "$150", note: "Per hour" },
      { name: "60-Minute Session", price: "$100", note: "Pre-licensed clinicians" },
      { name: "45-Minute Session", price: "$80", note: "Pre-licensed clinicians" },
    ],
  },
  {
    id: "medication",
    title: "Medication Management",
    services: [
      { name: "Intake Session", price: "$250" },
      { name: "Follow-up Sessions", price: "$100" },
      { name: "Paperwork (e.g., FMLA)", price: "$75", note: "Per hour" },
    ],
  },
];

const relatedResourceLinks = [
  {
    href: "/resources/insurances-accepted",
    label: "Accepted insurance plans",
    description:
      "See which commercial, Medicaid, Medicare, and other plans we currently accept.",
  },
  {
    href: "/resources/new-client",
    label: "New client guide",
    description:
      "Review the intake sequence, paperwork, and what to bring.",
  },
  {
    href: "/resources/faq",
    label: "FAQ",
    description:
      "Get plain-language answers about costs, coverage, and evaluation timelines.",
  },
];
---

<Layout
  title="Service Fees & Rates"
  description="Review Twilight Psychology fees for evaluations, therapy, and medication management in Kentucky, plus insurance-supported care and payment planning."
>
    <section class="bg-site-bg py-24 px-4">
      <div class="max-w-4xl mx-auto">

      <PageHeroWrapper
        title="Fees & Insurance"
        accentWord="Insurance"
        subtitle="Transparent fee schedules for psychological evaluations, therapy, and medication management — including what insurance most often covers for therapy and medication, self-pay evaluation rates, and specialty assessment costs."
      />

      <AnimatedSection client:visible animation="fadeInUp" delay={100}>
        <section class="mb-12 bg-surface-soft border-l-4 border-cta p-6 rounded-r-2xl">
          <h2 class="font-serif text-site-text font-bold text-xl mb-2">Insurance Information</h2>
          <div class="space-y-4 text-site-text leading-relaxed">
          <p>
            Therapy and medication management are the services most often billed through insurance. Clients
            with <strong>Kentucky Medicaid</strong> typically have $0 copays for
            <a href="/blog/insurance/understanding-health-insurance" class="text-cta underline">covered services</a>.
            For <a href="/resources/insurances-accepted" class="text-cta underline">commercial insurance</a>
            we recommend calling
            <a href={`tel:${PHONE_NUMBER}`} class="text-cta underline"> {PHONE_NUMBER_FORMATTED}</a> to determine approximate rates,
            though you should always confirm benefits, copays, and deductibles with your insurance provider prior to your appointment.
          </p>
          <p>
            We do accept insurance for select treatment-focused evaluation referrals. Insurance typically authorizes
            only a limited number of psychological testing units, and those hours include record collection, collateral
            information, interviewing clients and parents, test administration, reviewing and integrating data,
            researching concerns, consulting with other providers, and report writing. When we bill insurance, we use
            the most clinically relevant tests within the hours approved. 
          </p>
          <p>  
            Self-pay is available when a referral needs a
            broader battery or more documentation than insurance allows. Kentucky Medicaid clients cannot be charged
            beyond covered amounts, so Medicaid evaluations are limited to the hours approved by the plan. Court,
            school, benefits, ESA, and many educational or accommodation-focused evaluations are usually self-pay or
            funded by a third party rather than billed to insurance.
          </p>
          </div>
        </section>
      </AnimatedSection>

      <section class="mt-10">
        <FeeTabsWrapper categories={feeCategories} />
      </section>

      <AnimatedSection client:visible animation="fadeInUp" delay={175}>
        <section class="mt-10 bg-surface-soft border border-border rounded-[2.5rem] p-10">
          <h2 class="font-serif text-site-text font-black text-2xl mb-6">Coverage for Therapy & Medication Management</h2>
          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <h3 class="font-serif text-site-text font-black text-lg mb-3">Kentucky Medicaid</h3>
              <p class="text-site-sub leading-relaxed mb-4">
                We accept <strong class="text-site-text">Kentucky Medicaid</strong> for individual therapy and medication management. Medicaid clients typically have <strong class="text-site-text">$0 copays</strong> for covered therapy sessions and psychiatric follow-ups.
              </p>
              <a href="/resources/insurances-accepted" class="text-cta text-sm font-black uppercase tracking-widest hover:underline">See all accepted plans →</a>
            </div>
            <div>
              <h3 class="font-serif text-site-text font-black text-lg mb-3">ADHD Testing Cost</h3>
              <p class="text-site-sub leading-relaxed mb-4">
                ADHD evaluations are <strong class="text-site-text">$1,300</strong> on a self-pay basis and can be split into 2–3 payments across your appointments. Payment plans are available with no added fees.
              </p>
              <a href={WIDGET_LINK} class="text-cta text-sm font-black uppercase tracking-widest hover:underline">Schedule an intake →</a>
            </div>
          </div>
        </section>
      </AnimatedSection>

      <AnimatedSection client:visible animation="fadeInUp" delay={300}>
        <section class="mt-10">
          <div class="grid gap-6 md:grid-cols-2 bg-surface-soft border rounded-3xl p-8" style="border-color: var(--color-border-strong)">
            <div>
              <h3 class="font-serif text-site-text font-black text-xl mb-3">Accepted Payment Methods</h3>
              <ul class="text-site-sub list-disc list-inside">
                <li><a href="/resources/insurances-accepted" class="underline text-cta hover:text-cta">Insurance</a></li>
                <li>FSA/HSA Card</li>
                <li>Credit card</li>
                <li>Debit card</li>
                <li>Cash</li>
                <li>Zelle, Venmo</li>
              </ul>
            </div>
            <div>
              <h3 class="font-serif text-site-text font-black text-xl mb-6">Financing Options</h3>
              <a href="https://www.carecredit.com/go/VSM688/?dtc=DS9X&sitecode=CCLBADS9X" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center p-4 rounded-lg hover:bg-surface-soft">
                <img width="175" 
                  src="https://www.carecredit.com/sites/pc/image/flexible-financing-prequal-apply-pay-375x320.png" 
                  alt="CareCredit - Flexible Financing for Healthcare" class="w-full md:w-56 hover:scale-105 transition-all"
                  loading="lazy"
                  decoding="async" />
              </a>
            </div>
          </div>
        </section>
      </AnimatedSection>

      <footer class="mt-12 text-center text-site-sub text-sm space-y-4">
        <p>Rates in effect from 01/01/2026</p>
        <p class="max-w-2xl mx-auto">
          Under the <strong>No Surprises Act</strong>, you have the right to receive a Good Faith Estimate prior to services. 
          For additional information, visit <a href="https://www.cms.gov/medical-bill-rights" class="underline text-cta hover:text-cta">cms.gov/medical-bill-rights</a>.
        </p>
      </footer>

      <AnimatedSection client:visible animation="fadeInUp" delay={400}>
        <section class="mt-12">
          <h2 class="font-serif text-2xl font-black text-site-text mb-6">Billing & Insurance Resources</h2>
          <div class="grid gap-4 sm:grid-cols-2">
            <a href="/blog/billing/understanding-your-eob" class="group p-6 bg-surface-soft border border-border rounded-2xl hover:border-cta/30 transition-all">
              <p class={`inline-flex items-center rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-widest mb-2 ${categoryColorMap.billing}`}>Billing</p>
              <h3 class="font-serif text-sm font-black text-site-text group-hover:text-cta transition-colors mb-1">Understanding Your EOB</h3>
              <p class="text-xs text-site-sub">A plain-language guide to reading your explanation of benefits.</p>
            </a>
            <a href="/blog/insurance/understanding-health-insurance" class="group p-6 bg-surface-soft border border-border rounded-2xl hover:border-cta/30 transition-all">
              <p class={`inline-flex items-center rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-widest mb-2 ${categoryColorMap.insurance}`}>Insurance</p>
              <h3 class="font-serif text-sm font-black text-site-text group-hover:text-cta transition-colors mb-1">Understanding Health Insurance</h3>
              <p class="text-xs text-site-sub">Deductibles, copays, and how plan types affect your costs.</p>
            </a>
          </div>
          <div class="mt-4 text-center">
            <a href="/blog/category/billing" class="text-cta text-sm font-bold hover:underline">View all billing posts →</a>
          </div>
        </section>
      </AnimatedSection>

      <PageLinksSection
        title="Continue planning your intake"
        description="These pages usually answer the follow-up questions that come after pricing."
        links={relatedResourceLinks}
      />

      </div>
    </section>
</Layout>

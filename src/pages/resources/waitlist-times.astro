---
import Layout from '../../layouts/Layout.astro';
import WaitlistDirectoryWrapper from '../../components/interactive/WaitlistDirectoryWrapper.astro';
import PageLinksSection from '../../components/PageLinksSection.astro';

const planningLinks = [
  {
    href: "/resources/new-client",
    label: "New client guide",
    description:
      "Use the intake guide when you are ready to move from availability into booking.",
  },
  {
    href: "/services/therapy/clinicians",
    label: "Therapy clinicians",
    description:
      "Compare therapist fit, specialties, and clinician-specific availability.",
  },
  {
    href: "/contact",
    label: "Contact us",
    description:
      "Ready to move forward? Reach out to get on the right waitlist for your needs.",
  },
];
---

<Layout
  title="Waitlist Times"
  description="Current waitlist times at Twilight Psychology in Lexington, KY for evaluations, therapy ages 3-99, and medication management."
>
  <section class="bg-site-bg min-h-screen py-24 px-4">
    <div class="max-w-7xl mx-auto">
      <header class="text-center mb-12">
        <h1 class="font-serif text-4xl md:text-5xl font-black text-site-text mb-4">
          Waitlist <span class="text-cta">Times</span>
        </h1>
        <p class="text-sand text-lg max-w-2xl mx-auto">
          Filter by service or state to view current wait times for our providers, including therapy options for ages 3-99.
        </p>
      </header>

      <WaitlistDirectoryWrapper />

      <PageLinksSection
        title="Plan your next step"
        description="Once you have a timing sense, these pages help you choose the right clinician, process, or office context."
        links={planningLinks}
      />
    </div>
    <div class="text-center mt-12 text-sm text-sand">
      <p>
        * Insurance-based psychological testing depends on medical-necessity review, prior authorization, and the
        number of testing hours a plan approves. 
      </p>
      <p>Kentucky clients can be seen statewide, with additional telehealth availability in Ohio, Tennessee, and 40+ states through PSYPACT depending on provider. For a full list, visit <a href="https://psypact.gov/page/psypactmap" class="text-cta underline">PSYPACT Map</a>.
      </p>
    </div>
  </section>
</Layout>
---
import Layout from '../../layouts/Layout.astro';
import { EMAIL_ADDRESS, WIDGET_LINK } from '../../data/resource';
import PageHeroWrapper from "../../components/PageHeroWrapper.astro";
import AnimatedSection from "../../components/preact/primitives/AnimatedSection";

const steps = [
  {
    number: "01",
    title: "Outreach",
    desc: "Reach out via our online portal, phone, or email. We will match you with the clinician best suited to your specific clinical needs.",
    link: WIDGET_LINK,
    linkText: "Schedule Online"
  },
  {
    number: "02",
    title: "Intake Forms",
    desc: "Complete your digital paperwork from the comfort of home. This allows us to review your clinical history prior to your first appointment.",
  },
  {
    number: "03",
    title: "Verification",
    desc: "We manage the insurance verification process. Our team will confirm your coverage and benefits in advance so your financial obligations are clear from the start.",
  },
  {
    number: "04",
    title: "Schedule Session",
    desc: "We will schedule your appointment and provide all relevant details via email and text confirmation.",
  }
];

const checklist = [
  "Valid photo ID",
  "Insurance card",
  "Current medications list",
  "Previous psychiatric records",
  "Completed digital forms"
];
---

<Layout
  title="New Client Guide | Twilight Psychology"
  description="New to Twilight Psychology? Review intake steps, required documents, insurance verification, and what to expect at your first appointment in Kentucky."
>
  <div class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-site-text
                  prose-headings:text-site-text
                  prose-strong:text-site-text
                  prose-li:text-site-text
                  mb-12">
  <PageHeroWrapper
    title="Your Journey Starts Here"
    accentWord="Starts Here"
    badge="New Patient Guide"
    subtitle="We appreciate your decision to partner with Twilight Psychology. From your first interaction, our goal is to provide a seamless, affirming, and professionally guided experience."
    size="lg"
  />
  <section class="bg-site-bg py-24 px-4">
    <div class="max-w-6xl mx-auto">

      <div class="grid lg:grid-cols-3 gap-8">
        
        <AnimatedSection client:visible animation="fadeInUp" delay={100}>
        <div class="lg:col-span-2 space-y-6">
          <div class="bg-surface-soft border border-border-strong p-8 md:p-12 rounded-4xl backdrop-blur-sm">
            <h2 class="font-serif text-2xl font-black text-site-text mb-10 flex items-center gap-3">
              The Path to Your First Visit
            </h2>

            

            <div class="relative space-y-12">
              <div class="absolute left-[1.4rem] top-2 bottom-2 w-0.5 bg-linear-to-b from-cta via-border to-transparent"></div>

              {steps.map((step) => (
                <div class="relative pl-16 group">
                  <div class="absolute left-0 top-0 w-12 h-12 bg-site-bg border-2 border-cta rounded-2xl flex items-center justify-center text-cta font-black z-10 group-hover:bg-cta group-hover:text-cta-fg transition-colors duration-300">
                    {step.number}
                  </div>
                  <div>
                    <h3 class="font-serif text-xl font-black text-site-text mb-2">{step.title}</h3>
                    <p class="text-site-sub leading-relaxed mb-4">{step.desc}</p>
                    {step.link && (
                      <a href={step.link} target="_blank" class="inline-flex items-center gap-2 text-cta font-bold text-sm hover:translate-x-1 transition-transform">
                        {step.linkText} <span class="text-lg">→</span>
                      </a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-surface-2 border border-border-strong p-8 rounded-4xl">
            <h2 class="font-serif text-2xl font-black text-site-text mb-4">Your First Appointment</h2>
            <p class="text-site-text leading-relaxed">
              Your first session is designed to be thorough and collaborative. Over the course of the hour, we will discuss your clinical goals, relevant history, and presenting concerns. This structured dialogue ensures your clinician has the context needed to develop an informed, individualized plan.
            </p>
          </div>
        </div>
        </AnimatedSection>

        <AnimatedSection client:visible animation="fadeInUp" delay={200}>
        <div class="space-y-8">
          <div class="bg-cta p-8 rounded-4xl text-cta-fg shadow-xl shadow-cta/10">
            <h2 class="font-serif text-xl font-black inverted-text uppercase tracking-tight mb-6 flex items-center gap-2">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
              What to Bring
            </h2>
            <ul class="space-y-4">
              {checklist.map((item) => (
                <li class="flex items-center gap-3 font-bold inverted-text text-sm">
                  <div class="w-5 h-5 rounded-full bg-site-bg/20 flex items-center justify-center">✓</div>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-surface-soft border border-border-strong p-8 rounded-4xl text-center">
            <h3 class="font-serif text-xl font-black text-site-text mb-4">Questions?</h3>
            <p class="text-site-sub text-sm mb-6">Our office is available to assist with any pre-appointment questions.</p>
            <a href={`mailto:${EMAIL_ADDRESS}`} class="block w-full py-3 bg-surface-soft hover:bg-surface-2 border border-border-strong text-site-text font-bold rounded-full transition-all duration-300">
              Email our Office
            </a>
          </div>
        </div>
        </AnimatedSection>

      </div>
    </div>
  </section>
      </div>
    </div>
  </div>
</Layout>
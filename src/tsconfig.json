{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
   "strictNullChecks": true,
    "allowJs": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": ["../.astro/types.d.ts", "**/*"],
  "exclude": ["dist/"]
}

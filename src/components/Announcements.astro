---
import { Icon } from "astro-icon/components";
---

<div
  class="flex items-center gap-2 overflow-hidden px-4 py-2 relative bg-site-ann/50 border-b theme-border"
>
  <div class="flex items-center gap-3">
    <Icon name={"mdi:moon-and-stars"} class="w-6 h-6 text-site-sub shrink-0" style="color: var(--color-icon);" 
    />
    
    <p class="text-site-sub font-medium text-xs sm:text-sm truncate">
      Currently accepting new clients for <span class="text-site-text">Spring 2026!</span>
    </p>
  </div>
</div>

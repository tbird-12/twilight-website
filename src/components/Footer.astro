---
import { Image } from "astro:assets";
import logoImage from "../assets/images/logo.png";
import {
  PHONE_NUMBER,
  PHONE_NUMBER_FORMATTED,
  EMAIL_ADDRESS,
  FAX_NUMBER,
  FAX_NUMBER_FORMATTED,
  MAIN_OFFICE_ADDRESS_SINGLE_LINE,
  MAIN_OFFICE_MAP_LINK,
} from "../data/resource";
import { siteConfig } from "../data/siteConfig";
import { Icon } from "astro-icon/components";

const year = new Date().getFullYear();

const links = [
  {
    title: "Resources",
    items: [
      { name: "FAQ", href: "/resources/faq" },
      { name: "Fees & Insurance", href: "/resources/fees" },
      { name: "Accepted Insurance", href: "/resources/insurances-accepted" },
      { name: "Careers", href: "/about/careers" },
      { name: "Blog", href: "/blog" },
    ],
  },
  {
    title: "Services",
    items: [
      { name: "ADHD Assessments", href: "/services/adhd-testing" },
      { name: "Autism Evaluations", href: "/services/autism-testing" },
      { name: "Therapy", href: "/services/therapy" },
      { name: "Medication Management", href: "/services/medication-management" },
    ],
  },
  {
    title: "Specialties",
    items: [
      { name: "Learning Disabilities", href: "/specialties/dyslexia-testing" },
      { name: "Psychoeducational Evaluations", href: "/specialties/psychoeducational-evaluations" },
      { name: "Adoption Evaluations", href: "/specialties/adoption-evaluations" },
      { name: "ESA Evaluations", href: "/specialties/esa-evaluations" },
      { name: "IEE for KY", href: "/specialties/IEE" },
    ],
  },
];

---

<footer class="relative site-footer">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-12 gap-4 gap-y-10 sm:gap-8">

      <!-- Brand -->
      <div class="col-span-12 lg:col-span-3">
        <a href="/" class="inline-flex items-center gap-2 mb-4 group">
          <Image
            src={logoImage}
            alt="Twilight Psychology Logo"
            width={80}
            height={80}
            format="webp"
            loading="lazy"
            decoding="async"
            class="h-10 w-auto"
          />
          <span class="font-serif font-black text-site-text group-hover:text-cta transition-colors">
            Twilight Psychology
          </span>
        </a>

        <p class="text-sm text-site-sub mb-4 leading-relaxed">
          Specialized psychological evaluations, psychiatric medication
          management, and evidence-based therapy.
        </p>

        <a
          href={MAIN_OFFICE_MAP_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-link block mb-5"
        >
          {MAIN_OFFICE_ADDRESS_SINGLE_LINE}
        </a>

        <div class="flex gap-3">
          {
            siteConfig.socialProfiles.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-site-sub theme-hover-surface-2 focus:outline-none focus:ring-4 focus:ring-cta/30 rounded-lg text-sm p-2.5 inline-flex items-center"
                aria-label={social.label}
              >
                <Icon name={social.icon} class="w-5 h-5" style="color: var(--color-icon);" />
              </a>
            ))
          }
        </div>
      </div>

      <!-- Link columns -->
      {
        links.map(({ title, items }) => (
          <div class="col-span-6 md:col-span-4 lg:col-span-2">
            <div class="footer-heading">{title}</div>
            <ul class="space-y-2">
              {items.map(({ name, href }) => (
                <li>
                  <a class="footer-link" href={href}>{name}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <!-- Contact -->
      <div class="col-span-12 md:col-span-4 lg:col-span-3">
        <div class="footer-heading">Contact</div>
        <div class="text-sm text-site-sub space-y-3">
          <div class="space-y-1">
            <p>P: <a href={`tel:${PHONE_NUMBER}`} class="footer-link">{PHONE_NUMBER_FORMATTED}</a></p>
            <p>F: <a href={`fax:${FAX_NUMBER}`} class="footer-link">{FAX_NUMBER_FORMATTED}</a></p>
            <p>E: <a href={`mailto:${EMAIL_ADDRESS}`} class="footer-link">{EMAIL_ADDRESS}</a></p>
          </div>
          <div>
            <p class="font-semibold text-site-text">Hours</p>
            <p>Mon &ndash; Fri: 9 AM &ndash; 7 PM</p>
            <p>Sat &ndash; Sun: By appointment</p>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 pt-8 mt-10 border-t theme-border">
      <p class="text-sm text-site-sub">
        &copy; {year} Twilight Psychology, PLLC. All rights reserved.
      </p>
      <a href="/privacy" class="footer-link">Privacy Policy</a>
    </div>
  </div>
</footer>

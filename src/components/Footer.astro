---
const year = new Date().getFullYear();
import { PHONE_NUMBER, PHONE_NUMBER_FORMATTED, EMAIL_ADDRESS, FAX_NUMBER, FAX_NUMBER_FORMATTED } from "../data/resource";
import { Icon } from "astro-icon/components";
const links = [
  {
    title: "Resources",
    items: [
      { name: "Testing FAQ", href: "/resources/faq" },
      { name: "Fees ", href: "/resources/fees" },
      { name: "Insurance", href: "/resources/insurances-accepted" },
      { name: "Locations", href: "/about/locations" },
      { name: "Careers", href: "/about/careers" },
    ],
  },
  {
    title: "Services",
    items: [
      { name: "ADHD Assessments", href: "/services/adhd-testing" },
      { name: "Autism Evaluations", href: "/services/autism-testing" },
      { name: "Therapy", href: "/services/therapy" },
      {
        name: "Medication Management",
        href: "/services/medication-management",
      },
      {
        name: "Psychological Evaluations",
        href: "/services/psychological-evaluations",
      },
    ],
  }
];

// Social Media Placeholders
const socials = [
  { label: "Facebook", icon: "mdi:facebook", href: "https://www.facebook.com/people/Twilight-Psychology-PLLC/61555270131003/" },
  { label: "Instagram", icon: "mdi:instagram", href: "https://www.instagram.com/twilight_psychology_pllc/" },
  { label: "LinkedIn", icon: "mdi:linkedin", href: "https://www.linkedin.com/company/twilight-psychology/?viewAsMember=true" },
];
---

<footer
  class="relative site-footer"
>
  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-12 gap-4 gap-y-8 sm:gap-8">
      <div class="col-span-12 lg:col-span-4">
        <div class="mb-2">
          <a
            class="inline-block font-heading font-bold text-xl text-site-text transition-transform duration-200 hover:scale-105"
            href="/"
          >
            Twilight Psychology, PLLC
          </a>
        </div>
        <p class="text-sm text-site-text mb-4">
          Specialized psychological evaluations, psychiatric medication
          management, and evidence-based therapy.
        </p>

        <a href="https://www.google.com/maps/search/?api=1&query=Twilight+Psychology,+PLLC,+501+Darby+Creek+Rd+UNIT+7,+Lexington,+KY+40509"
        target="_blank" class="footer-link block mb-4">
          501 Darby Creek Rd. Suite 7, Lexington, KY 40509
        </a>

        <div class="flex gap-3">
          {
            socials.map((social) => (
              <a
                href={social.href}
                class="text-site-sub theme-hover-surface-2 focus:outline-none focus:ring-4 focus:ring-cta/30 rounded-lg text-sm p-2.5 inline-flex items-center"
                aria-label={social.label}
              >
                <Icon name={social.icon} class="w-5 h-5 text-site-text" style="color: var(--color-icon);"/>
              </a>
            ))
          }
        </div>
      </div>

      {
        links.map(({ title, items }) => (
          <div class="col-span-6 md:col-span-3 lg:col-span-2">
            <div class="footer-heading">
              {title}
            </div>
            <ul>
              {items.map(({ name, href }) => (
                <li class="mb-2">
                  <a
                    class="footer-link"
                    href={href}
                  >
                    {name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <div class="col-span-12 md:col-span-3 lg:col-span-2">
        <div
          class="footer-heading"
        >
          Practice Info
        </div>
        <div class="text-sm text-site-sub space-y-3">
          <div>
            <p class="font-semibold text-site-text">Contact Us</p>
            <p>P: <a href={`tel:${PHONE_NUMBER}`} class="footer-link">{PHONE_NUMBER_FORMATTED}</a></p>
            <p>F: <a href={`fax:${FAX_NUMBER}`} class="footer-link">{FAX_NUMBER_FORMATTED}</a></p>
            <p>E: <a href={`mailto:${EMAIL_ADDRESS}`} class="footer-link">{EMAIL_ADDRESS}</a></p>
          </div>
          <div>
            <p class="font-semibold text-site-text">Hours of Operation</p>
            <p>Mon - Fri: 8 AM - 7 PM</p>
            <p>Sat - Sun: By appointment</p>
          </div>
        </div>
      </div>
    </div>

    <div
      class="md:flex md:items-center md:justify-between pt-8 border-t theme-border"
    >
      <div class="text-sm text-site-sub">
        © {year} · Twilight Psychology PLLC. All rights reserved. 
        <a href="/privacy" class="footer-link">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>

---
import { REFERRAL_LINK } from '../data/resource';

interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = "Answers You Deserve, Care You Can Trust",
  subtitle = "Whether you're seeking an evaluation for ADHD, Autism, or a learning disorder — or looking for therapy and medication support — our neuro-affirming team in Lexington, Kentucky is here to help. Now accepting new clients."
} = Astro.props;

---

<div class="hero-section text-center">
  <h1 class="hero-title font-serif text-[2rem] sm:text-4xl md:text-6xl xl:text-7xl font-black text-site-text mb-2 sm:mb-6 tracking-tighter leading-[1.02]">
    {title}
  </h1>

  <p class="hero-subtitle max-w-xl mx-auto text-base sm:text-lg md:text-xl text-site-sub mb-6 sm:mb-10 leading-relaxed font-medium">
    {subtitle}
  </p>

  <div class="hero-actions flex flex-col sm:flex-row gap-4 sm:gap-5 items-center justify-center">
    <a
      href="/catalog"
      class="inline-block text-center bg-cta text-cta-fg font-black rounded-full shadow-lg shadow-cta/20 hover:bg-cta/80 hover:ring-4 hover:ring-cta/30 active:scale-95 animate-[glowPulse_3s_ease-in-out_infinite] px-10 py-3 sm:px-12 sm:py-4 text-base transition-all duration-200 hover:scale-[1.02] hover:shadow-xl hover:shadow-cta/30"
    >
      Explore Our Services
    </a>
    <a
      href={REFERRAL_LINK}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm font-bold text-site-sub hover:text-icon transition-colors underline underline-offset-4 decoration-site-sub/30 hover:decoration-cta/50"
    >
      Referring a client? Submit a referral →
    </a>
  </div>
</div>

<style>
  .hero-title,
  .hero-subtitle,
  .hero-actions {
    animation-fill-mode: both;
  }

  .hero-title {
    animation: focusBlur 700ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero-subtitle {
    animation: fadeInUp 700ms cubic-bezier(0.4, 0, 0.2, 1);
    animation-delay: 100ms;
  }

  .hero-actions {
    animation: fadeInUp 700ms cubic-bezier(0.4, 0, 0.2, 1);
    animation-delay: 200ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title,
    .hero-subtitle,
    .hero-actions {
      animation: none;
    }
  }
</style>

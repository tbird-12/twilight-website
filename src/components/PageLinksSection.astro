---
interface PageLink {
  href: string;
  label: string;
  description: string;
}

interface Props {
  title: string;
  description?: string;
  links: PageLink[];
}

const { title, description, links } = Astro.props;
---

<section class="max-w-7xl mx-auto px-4 mt-16">
  <div class="rounded-[2.5rem] border border-border bg-surface-soft p-8 md:p-10">
    <h2 class="font-serif text-2xl md:text-3xl font-black text-site-text mb-4 tracking-tight">
      {title}
    </h2>
    {description && (
      <p class="max-w-3xl text-site-sub leading-relaxed mb-8">
        {description}
      </p>
    )}
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {links.map((link) => (
        <a
          href={link.href}
          class="group rounded-3xl border border-border bg-surface p-6 transition-all hover:border-cta/30 hover:shadow-lg hover:shadow-cta/5"
        >
          <h3 class="font-serif text-lg font-black text-site-text group-hover:text-cta transition-colors mb-2">
            {link.label}
          </h3>
          <p class="text-sm leading-relaxed text-site-sub mb-4">
            {link.description}
          </p>
          <span class="inline-flex items-center gap-2 text-sm font-black text-cta">
            Open page
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">
              →
            </span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

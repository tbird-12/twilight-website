---
import type { CollectionEntry } from "astro:content";
import CategoryBadge from "./CategoryBadge.astro";
import { getDisplayBlogDate } from "../../utils/blogDates";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, category, author } = post.data;
const href = `/blog/${post.id}`;
const { displayDate, formattedDate, isUpdated } = getDisplayBlogDate(pubDate, updatedDate);
---

<article class="group flex h-full flex-col gap-3 rounded-xl border border-border bg-surface p-5 transition-all hover:border-border-strong hover:shadow-sm">
  <div class="flex items-center justify-between gap-3">
    <CategoryBadge category={category} />
    <time
      datetime={displayDate.toISOString()}
      class="text-xs text-site-sub shrink-0"
    >
      {isUpdated ? `Updated ${formattedDate}` : formattedDate}
    </time>
  </div>

  <a href={href} class="block">
    <h2 class="text-base font-semibold text-site-text group-hover:text-icon transition-colors leading-snug">
      {title}
    </h2>
  </a>

  <p class="text-sm text-site-sub line-clamp-3 leading-relaxed">
    {description}
  </p>

  <div class="flex items-center justify-between mt-auto pt-2">
    <span class="text-xs text-site-sub">{author}</span>
    <a
      href={href}
      class="text-xs font-medium text-icon hover:underline underline-offset-2"
      aria-label={`Read full article: ${title}`}
    >
      Read →
    </a>
  </div>
</article>

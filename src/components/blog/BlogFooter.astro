---
import { Image } from "astro:assets";
import { blogCategories } from "../../data/blogCategories";
import logoImage from "../../assets/images/logo.png";
import {
  PHONE_NUMBER,
  PHONE_NUMBER_FORMATTED,
  EMAIL_ADDRESS,
  FAX_NUMBER,
  FAX_NUMBER_FORMATTED,
  MAIN_OFFICE_STREET_ADDRESS,
  MAIN_OFFICE_CITY_STATE_ZIP,
  MAIN_OFFICE_MAP_LINK,
} from "../../data/resource";

const year = new Date().getFullYear();

const exploreLinks = [
  { label: "Services", href: "/services" },
  { label: "Specialties", href: "/specialties" },
  { label: "Fees & Insurance", href: "/resources/fees" },
  { label: "New Client Guide", href: "/resources/new-client" },
];
---

<footer class="border-t border-border bg-site-footer mt-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-10">
      <!-- Brand / Logo -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 mb-4 group">
          <Image
            src={logoImage}
            alt="Twilight Psychology Logo"
            width={72}
            height={72}
            format="webp"
            loading="lazy"
            decoding="async"
            class="h-9 w-auto"
          />
          <span
            class="font-serif font-black text-site-text group-hover:text-cta transition-colors leading-tight"
          >
            Twilight<br />Psychology
          </span>
        </a>
        <p class="text-sm text-site-sub leading-relaxed">
          Specialized psychological evaluations, psychiatric medication
          management, and evidence-based therapy.
        </p>
      </div>

      <!-- Contact -->
      <div>
        <p
          class="text-xs font-bold tracking-widest uppercase text-site-sub mb-4"
        >
          Contact
        </p>
        <div class="space-y-2 text-sm text-site-sub">
          <p>
            P:&nbsp;<a href={`tel:${PHONE_NUMBER}`} class="footer-link">
              {PHONE_NUMBER_FORMATTED}
            </a>
          </p>
          <p>
            F:&nbsp;<a href={`fax:${FAX_NUMBER}`} class="footer-link">
              {FAX_NUMBER_FORMATTED}
            </a>
          </p>
          <p>
            E:&nbsp;<a
              href={`mailto:${EMAIL_ADDRESS}`}
              class="footer-link break-all"
            >
              {EMAIL_ADDRESS}
            </a>
          </p>
        </div>
      </div>

      <!-- Locations -->
      <div>
        <p
          class="text-xs font-bold tracking-widest uppercase text-site-sub mb-4"
        >
          Locations
        </p>
        <div class="space-y-4 text-sm text-site-sub">
          <p
            class="font-semibold text-site-text text-xs uppercase tracking-wide mb-1"
          >
            Lexington, KY
          </p>
          <a
            href={MAIN_OFFICE_MAP_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link leading-snug block"
          >
            {MAIN_OFFICE_STREET_ADDRESS}<br />{MAIN_OFFICE_CITY_STATE_ZIP}
          </a>
        </div>
      </div>

      <!-- Blog categories + quick links -->
      <div>
        <p
          class="text-xs font-bold tracking-widest uppercase text-site-sub mb-4"
        >
          Blog Topics
        </p>
        <nav
          class="flex flex-col gap-2 text-sm text-site-sub"
          aria-label="Blog footer topics"
        >
          {
            blogCategories.map((cat) => (
              <a href={`/blog/category/${cat.slug}`} class="footer-link">
                {cat.label}
              </a>
            ))
          }
        </nav>
      </div>

      <div>
        <p
          class="text-xs font-bold tracking-widest uppercase text-site-sub mb-4"
        >
          Explore
        </p>
        <nav
          class="flex flex-col gap-2 text-sm text-site-sub"
          aria-label="Blog footer site links"
        >
          {
            exploreLinks.map((link) => (
              <a href={link.href} class="footer-link">
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>
    </div>

    <hr class="my-8 border-border" />

    <div
      class="flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-site-sub"
    >
      <span>© {year} Twilight Psychology, PLLC. All rights reserved.</span>
      <a href="/privacy" class="footer-link underline underline-offset-2">
        Privacy Policy
      </a>
    </div>
  </div>
</footer>

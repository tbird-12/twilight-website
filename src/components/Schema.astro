---
import logo from "../assets/images/logo.png";
import { MAIN_OFFICE_STREET_ADDRESS_SCHEMA, MAIN_OFFICE_CITY_STATE_ZIP } from "../data/resource";

const siteUrl = Astro.site || "http://localhost:4321";

const imageUrl = new URL(logo.src, siteUrl).href;
const [addressLocality, addressRegionAndPostalCode] = MAIN_OFFICE_CITY_STATE_ZIP.split(", ");
const [addressRegion, postalCode] = addressRegionAndPostalCode.split(" ");

type JsonLd = Record<string, unknown>;

interface Props {
  type?: string;
  name?: string;
  schema?: JsonLd;
  schemas?: JsonLd[];
}

const props = Astro.props as Props & Record<string, unknown>;
const {
  type = "WebSite",
  name,
  schema,
  schemas,
  ...extra
} = props;

const defaultSchema: JsonLd = {
  "@context": "https://schema.org",
  "@type": type,
  name: name || "Twilight Psychology",
  description:
    "Neuro-affirming psychological evaluations, therapy, and medication management in Lexington, Kentucky. Accepting 20+ insurance panels including Medicaid, Medicare, and Tricare.",
  url: "https://www.twilightpsychology.com",
  address: {
    "@type": "PostalAddress",
    streetAddress: MAIN_OFFICE_STREET_ADDRESS_SCHEMA,
    addressLocality,
    addressRegion,
    postalCode,
    addressCountry: "US",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: "38.0406",
    longitude: "-84.5037",
  },
  areaServed: [
    {
      "@type": "State",
      name: "Kentucky",
      sameAs: "https://en.wikipedia.org/wiki/Kentucky",
    },
    {
      "@type": "City",
      name: "Lexington",
      containedInPlace: {
        "@type": "State",
        name: "Kentucky",
      },
    },
  ],
  priceRange: "$$",
  telephone: "+1-859-687-5843",
  image: {
    "@type": "ImageObject",
    url: imageUrl,
    height: "400",
    width: "400",
  },
  logo: imageUrl,
  paymentAccepted: "Medicaid, Medicare, Tricare, Aetna, Cigna, UnitedHealthcare, Humana, Ambetter, Passport, UMR, CHAMPVA, Self-Pay",
  currenciesAccepted: "USD",
  knowsAbout: [
    "ADHD Testing",
    "Autism Evaluation",
    "Psychological Evaluations",
    "Learning Disability Testing",
    "Dyslexia Testing",
    "Medication Management",
    "Cognitive Behavioral Therapy",
    "Psychoeducational Evaluations",
    "ESA Evaluations",
    "Adoption Evaluations",
    "Guardianship Evaluations",
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Psychological Services",
    itemListElement: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "MedicalTest",
          name: "ADHD Testing in Kentucky",
          description:
            "Comprehensive ADHD evaluations for children and adults in Kentucky. Insurance accepted including Medicaid and major commercial plans.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "MedicalTest",
          name: "Autism Evaluation in Kentucky",
          description:
            "Neuro-affirming autism spectrum evaluations in Lexington, KY. We accept Medicaid and major commercial insurance plans.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "MedicalTest",
          name: "Psychological Evaluations",
          description:
            "Comprehensive psychological evaluations for learning disorders, personality profiles, and cognitive assessments in Kentucky.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "PsychologicalTreatment",
          name: "Therapy Services in Kentucky",
          description:
            "Evidence-based, neuro-affirming individual therapy for teens and adults in Lexington, KY and via telehealth.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "PsychologicalTreatment",
          name: "Medication Management",
          description:
            "Psychiatric medication management by our in-house Nurse Practitioner in Lexington, Kentucky.",
        },
      },
    ],
  },
  ...extra,
};

const structuredData = schemas ?? (schema ? [schema] : [defaultSchema]);
---

{
  structuredData.map((entry) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
  ))
}

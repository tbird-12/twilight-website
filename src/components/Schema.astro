---
import { getImage } from "astro:assets";
import logo from "../assets/images/logo.png";
import {
  EMAIL_ADDRESS,
  MAIN_OFFICE_CITY_STATE_ZIP,
  MAIN_OFFICE_MAP_LINK,
  MAIN_OFFICE_STREET_ADDRESS_SCHEMA,
  PHONE_NUMBER,
} from "../data/resource";
import { siteConfig } from "../data/siteConfig";

const siteUrl = Astro.site || new URL(siteConfig.siteUrl);
const schemaLogo = await getImage({
  src: logo,
  width: 256,
  format: "webp",
});
const imageUrl = new URL(schemaLogo.src, siteUrl).href;
const [addressLocality, addressRegionAndPostalCode] = MAIN_OFFICE_CITY_STATE_ZIP.split(", ");
const [addressRegion, postalCode] = addressRegionAndPostalCode.split(" ");

type JsonLd = Record<string, unknown>;

interface Props {
  type?: string;
  name?: string;
  schema?: JsonLd;
  schemas?: JsonLd[];
}

const props = Astro.props as Props & Record<string, unknown>;
const {
  type = "WebSite",
  name,
  schema,
  schemas,
  ...extra
} = props;

const defaultSchema: JsonLd = {
  "@context": "https://schema.org",
  "@type": type,
  name: name || siteConfig.siteName,
  description:
    "Twilight Psychology provides ADHD, autism, psychoeducational, and other psychological evaluations in Lexington, Kentucky, with telehealth services available statewide across Kentucky and in select additional states. Neuro-affirming therapy for ages 3-99 and medication management are also offered, with broad insurance participation including Medicaid and Medicare.",
  url: siteConfig.siteUrl,
  address: {
    "@type": "PostalAddress",
    streetAddress: MAIN_OFFICE_STREET_ADDRESS_SCHEMA,
    addressLocality,
    addressRegion,
    postalCode,
    addressCountry: "US",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: "38.0406",
    longitude: "-84.5037",
  },
  areaServed: [
    {
      "@type": "State",
      name: "Kentucky",
      sameAs: "https://en.wikipedia.org/wiki/Kentucky",
    },
    {
      "@type": "City",
      name: "Lexington",
      containedInPlace: {
        "@type": "State",
        name: "Kentucky",
      },
    },
    {
      "@type": "State",
      name: "Tennessee",
      sameAs: "https://en.wikipedia.org/wiki/Tennessee",
    },
    {
      "@type": "State",
      name: "Ohio",
      sameAs: "https://en.wikipedia.org/wiki/Ohio",
    },
  ],
  availableChannel: {
    "@type": "ServiceChannel",
    name: "Telehealth",
    serviceType: "Telehealth",
    availableLanguage: ["en"],
    serviceUrl: siteConfig.siteUrl,
  },
  priceRange: "$$",
  telephone: PHONE_NUMBER,
  email: EMAIL_ADDRESS,
  hasMap: MAIN_OFFICE_MAP_LINK,
  image: {
    "@type": "ImageObject",
    url: imageUrl,
    height: "400",
    width: "400",
  },
  logo: imageUrl,
  sameAs: siteConfig.socialProfiles.map(({ href }) => href),
  contactPoint: [
    {
      "@type": "ContactPoint",
      contactType: "patient support",
      telephone: PHONE_NUMBER,
      email: EMAIL_ADDRESS,
      availableLanguage: ["en"],
    },
  ],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: [
        "https://schema.org/Monday",
        "https://schema.org/Tuesday",
        "https://schema.org/Wednesday",
        "https://schema.org/Thursday",
        "https://schema.org/Friday",
      ],
      opens: "08:00",
      closes: "19:00",
    },
  ],
  paymentAccepted: "Self-Pay, Medicaid, Medicare, Tricare, Aetna, Cigna, UnitedHealthcare, Humana, Ambetter, Passport, UMR, CHAMPVA",
  currenciesAccepted: "USD",
  knowsAbout: [
    "Psychoeducational Evaluations",
    "Learning Disability Testing",
    "Gifted Testing",
    "Twice-Exceptional (2e) Evaluations",
    "Autism Evaluation",
    "ADHD Testing",
    "Independent Educational Evaluations",
    "Psychological Evaluations",
    "Dyslexia Testing",
    "School Accommodation Evaluations",
    "Medication Management",
    "Cognitive Behavioral Therapy",
    "Couples Counseling",
    "ESA Evaluations",
    "Adoption Evaluations",
    "Guardianship Evaluations",
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Psychological Services",
    itemListElement: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "MedicalTest",
          name: "Psychoeducational Evaluations in Kentucky",
          description:
            "Self-pay psychoeducational evaluations for learning differences, giftedness, twice-exceptional profiles, IEP and 504 planning, and school or college accommodation documentation.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "MedicalTest",
          name: "ADHD Testing in Kentucky",
          description:
            "ADHD evaluations for children and adults in Kentucky, with nuanced diagnostic clarification and recommendations for school, work, and treatment planning.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "MedicalTest",
          name: "Autism Evaluation in Kentucky",
          description:
            "Neuro-affirming autism evaluations for children and adults in Kentucky, including high-masking presentations, diagnostic depth, and support-oriented recommendations.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "MedicalTest",
          name: "Learning Disability and Dyslexia Testing",
          description:
            "Self-pay dyslexia and learning disability testing for dyslexia, dysgraphia, dyscalculia, giftedness, and related school accommodation questions.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "PsychologicalTreatment",
          name: "Therapy Services in Kentucky",
          description:
            "Evidence-based, neuro-affirming individual therapy and couples counseling for ages 3-99 in Lexington, KY, with broad insurance participation for covered care.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "PsychologicalTreatment",
          name: "Medication Management",
          description:
            "Psychiatric medication management by our in-house Nurse Practitioner in Lexington, Kentucky, with broad insurance participation for covered visits.",
        },
      },
    ],
  },
  ...extra,
};

const structuredData = schemas ?? (schema ? [schema] : [defaultSchema]);
---

{
  structuredData.map((entry) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
  ))
}

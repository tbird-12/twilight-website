---
import { Icon } from "astro-icon/components";
---

<div class="fixed bottom-3 right-3 md:bottom-5 md:right-5 z-60">
  <button id="bot-trigger"
    type="button"
    aria-label="Open chat assistant"
    class="w-11 h-11 md:w-14 md:h-14 rounded-full border theme-border bg-site-bg hover:bg-site-bg/80 flex items-center justify-center transition-colors shadow-md touch-manipulation">
    <Icon
      name="mdi:chat-bubble-outline"
      class="w-5 h-5 md:w-6 md:h-6"
      style="color: var(--color-icon);"
    />
  </button>
</div>

<div id="chat-container"
  class="fixed bottom-16 left-3 right-3
  md:bottom-24 md:left-auto md:right-5
  md:w-fit w-auto
  max-h-[60vh] md:max-h-[75vh] h-auto
  max-w-[92vw] md:max-w-96
  rounded-2xl border border-border bg-site-bg shadow-lg
  hidden flex-col overflow-hidden z-60 animate-slide-up">

  <div class="flex items-center justify-between border-b border-border bg-surface-soft px-4 py-3 md:p-4 text-site-text text-sm md:text-base font-bold">
    <span>Hi, I'm Liv</span>
    <button id="close-chat" type="button" class="text-xl md:text-2xl leading-none hover:text-site-sub transition-colors">×</button>
  </div>

  <div id="chatbot-root" class="flex-1 min-h-0">
    <div
      id="chatbot-loading"
      class="flex h-full items-center justify-center p-4 text-center text-sm text-site-sub"
      aria-live="polite"
    >
      Loading chat assistant...
    </div>
  </div>
</div>

<script>
const chatbotRoot = document.getElementById('chatbot-root');
const chatbotLoading = document.getElementById('chatbot-loading');
const chatContainer = document.getElementById('chat-container');
const botTrigger = document.getElementById('bot-trigger');
const closeChat = document.getElementById('close-chat');
let chatbotModulePromise: Promise<typeof import('./interactive/chatbot.client')> | undefined;
let chatbotMountPromise: Promise<void> | undefined;

function showChatLoading(message = 'Loading chat assistant...') {
  if (!chatbotLoading) return;
  chatbotLoading.textContent = message;
  chatbotLoading.classList.remove('hidden');
}

function hideChatLoading() {
  chatbotLoading?.classList.add('hidden');
}

function loadChatbotModule() {
  chatbotModulePromise ??= import('./interactive/chatbot.client');
  return chatbotModulePromise;
}

async function ensureChatbotMounted() {
  if (!chatbotRoot) return;
  if (chatbotRoot.dataset.mounted === 'true') {
    hideChatLoading();
    return;
  }

  chatbotMountPromise ??= loadChatbotModule()
    .then((module) => {
      module.mountChatbot(chatbotRoot);
      chatbotRoot.dataset.mounted = 'true';
      hideChatLoading();
    })
    .catch((error: unknown) => {
      chatbotModulePromise = undefined;
      chatbotMountPromise = undefined;
      showChatLoading('Chat is unavailable right now. Please use the contact page instead.');
      throw error;
    });

  showChatLoading();
  await chatbotMountPromise;
}

async function openChat() {
  if (!chatContainer) return;
  chatContainer.classList.remove('hidden');
  chatContainer.classList.add('flex');
  await ensureChatbotMounted();
}

function closeChatPanel() {
  if (!chatContainer) return;
  chatContainer.classList.add('hidden');
  chatContainer.classList.remove('flex');
}

async function toggleChat() {
  if (!chatContainer) return;
  const isHidden = chatContainer.classList.contains('hidden');
  if (isHidden) {
    await openChat();
    return;
  }

  closeChatPanel();
}

function prefetchChatbot() {
  void loadChatbotModule();
}

if (botTrigger) {
  botTrigger.addEventListener('pointerenter', prefetchChatbot, { once: true });
  botTrigger.addEventListener('focus', prefetchChatbot, { once: true });
  botTrigger.addEventListener('touchstart', prefetchChatbot, { passive: true, once: true });
  botTrigger.addEventListener('click', toggleChat);
  botTrigger.addEventListener('touchend', (event) => {
    event.preventDefault();
    void toggleChat();
  }, { passive: false });
}

if (closeChat) {
  closeChat.addEventListener('click', closeChatPanel);
  closeChat.addEventListener('touchend', (event) => {
    event.preventDefault();
    closeChatPanel();
  }, { passive: false });
}
</script>

---
import Logo from "./header/Logo.astro";
import MenuIcon from "./icons/MenuIcon.astro";
import DesktopNav from "./header/DesktopNav.astro";
import MobileNav from "./header/MobileNav.astro";
---

<header
  class="sticky top-0 z-100 w-full bg-site-bg/80 backdrop-blur-md border-b theme-border font-sans"
>
  <div
    class="max-w-5xl mx-auto px-4 sm:px-6 h-16 sm:h-20 flex items-center justify-between"
  >
    <!-- Mobile menu button -->
    <button
      id="mobileMenuBtn"
      class="md:hidden text-site-text p-3 -ml-2 focus:outline-none focus:ring-2 focus:ring-cta/50 rounded-lg transition-colors active:bg-surface-soft"
      aria-label="Open main menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <MenuIcon />
    </button>

    <Logo />

    <!-- Mobile contact shortcut -->
    <div class="md:hidden flex items-center gap-2">
      <a
        href="/contact"
        class="bg-cta text-cta-fg px-4 py-2 rounded-full font-black text-xs hover:bg-cta/80 transition-all shadow-lg flex items-center gap-1"
      >
        <span>Contact Us</span>
      </a>
    </div>

    <DesktopNav />
  </div>
</header>

<MobileNav />

<script is:inline>
  (function () {
    var root = document.documentElement;

    function applyTheme(theme) {
      root.classList.remove("light", "dark");
      root.classList.add(theme);
      root.style.colorScheme = theme;
      localStorage.setItem("theme", theme);
      var label = theme === "dark" ? "light" : "dark";
      document.querySelectorAll("[data-theme-toggle]").forEach(function (btn) {
        btn.setAttribute("aria-label", "Switch to " + label + " mode");
        btn.setAttribute("title", "Switch to " + label + " mode");
        btn.classList.toggle("is-on", theme === "light");
      });
    }

    function currentTheme() {
      return root.classList.contains("light") ? "light" : "dark";
    }

    applyTheme(currentTheme());

    document.querySelectorAll("[data-theme-toggle]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        applyTheme(currentTheme() === "dark" ? "light" : "dark");
      });
    });

    // Desktop nav: enable click-to-toggle for touch/rotated devices
    function closeAllDesktopOpen() {
      document.querySelectorAll('.group.open').forEach(function (g) {
        g.classList.remove('open');
      });
    }

    document.addEventListener('click', function (e) {
      // only apply on desktop breakpoint widths
      if (window.innerWidth < 768) return;

      var btn = e.target.closest('.desktop-nav-trigger');
      if (!btn) return;

      var group = btn.closest('.group');
      if (!group) return;

      // Toggle this group's open state, close others
      var isOpen = group.classList.contains('open');
      closeAllDesktopOpen();
      if (!isOpen) group.classList.add('open');
      else group.classList.remove('open');
    });

    // Close on escape
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeAllDesktopOpen();
    });

    // Close desktop menus when resizing to mobile
    window.addEventListener('resize', function () {
      if (window.innerWidth < 768) closeAllDesktopOpen();
    });
  })();
</script>

---
interface MenuItem {
  name: string;
  slug: string;
  desc?: string;
  hasNested?: boolean;
  children?: any[];
  childLabel?: string;
  childHrefBase?: string;
}

interface Props {
  id: string;
  title: string;
  items: MenuItem[];
  baseHref?: string;
  moreLink?: { href: string; label: string };
}

const { id, title, items, baseHref = "", moreLink } = Astro.props;
---

<div class="mb-2 font-sans">
  <button
    id={`${id}Toggle`}
    class="w-full flex items-center justify-between px-4 py-3 text-sm font-serif font-bold text-site-text theme-hover-surface-2 rounded-lg"
  >
    <span>{title}</span>
    <svg
      class="w-4 h-4 text-cta transition-transform"
      id={`${id}Icon`}
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path d="M19 9l-7 7-7-7" stroke-width="3"></path>
    </svg>
  </button>
  <div id={`${id}Content`} class="hidden mt-1 ml-4">
    {
      items.map((item) =>
        item.hasNested ? (
          <div class="mb-2">
            <button
              id={`${id}NestedToggle-${item.slug}`}
              class="w-full flex items-center justify-between px-4 py-2 text-sm text-site-sub theme-hover-surface-2 rounded-lg"
            >
              <span>{item.name}</span>
              <svg
                class="w-3 h-3 text-cta transition-transform"
                id={`${id}NestedIcon-${item.slug}`}
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path d="M19 9l-7 7-7-7" stroke-width="3" />
              </svg>
            </button>
            <div
              id={`${id}NestedContent-${item.slug}`}
              class="hidden mt-1 ml-4"
            >
              {item.children?.map((child: any) => (
                <a
                  href={`${item.childHrefBase}/${child.slug}`}
                  class="block px-4 py-2 text-sm text-site-sub theme-hover-surface-2 rounded-lg"
                >
                  {child.name}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={`${baseHref}/${item.slug}`}
            class="block px-4 py-2 text-sm text-site-sub theme-hover-surface-2 rounded-lg"
          >
            {item.name}
          </a>
        ),
      )
    }
    {moreLink && (
      <div class="border-t theme-border mt-2 pt-2 mx-4">
        <a
          href={moreLink.href}
          class="flex items-center gap-2 px-4 py-2 text-sm font-bold text-cta hover:text-cta/80 transition-colors rounded-lg"
        >
          {moreLink.label}
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M9 5l7 7-7 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    )}
  </div>
</div>

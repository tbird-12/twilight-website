---
import Layout from './Layout.astro';
import '../styles/global.css'

interface Props {
  name: string;
  description: string;
  metaDescription?: string;
  image?: string;
  canonical?: string;
  robots?: string;
  title?: string;
}

const {
  name,
  description,
  metaDescription,
  image,
  canonical,
  robots,
  title,
} = Astro.props;

const pageTitle =
  title ||
  (/twilight psychology/i.test(name)
    ? name
    : `${name} | Twilight Psychology`);

const pageDescription =
  metaDescription ||
  `${name} services at Twilight Psychology. ${description}`;
---

<Layout 
  title={pageTitle}
  description={pageDescription}
  image={image}
  canonical={canonical}
  robots={robots}
>
  <main class="bg-site-bg min-h-screen pb-24">
    <div class="max-w-4xl mx-auto px-6">

      <div class="prose prose-lg max-w-none prose-custom
                  prose-p:text-zinc-900 dark:prose-p:text-zinc-100 
                  prose-headings:text-black dark:prose-headings:text-site-text
                  prose-strong:text-black dark:prose-strong:text-site-text
                  prose-li:text-zinc-900 dark:prose-li:text-zinc-100
                  mb-12">
        <slot />
      </div>
    </div>
  </main>
</Layout>

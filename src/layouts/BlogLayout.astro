---
import "../styles/global.css";
import BlogHeader from "../components/blog/BlogHeader.astro";
import BlogFooter from "../components/blog/BlogFooter.astro";
import favicon from "../assets/favicons/favicon.svg";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  category?: string;
  robots?: string;
}

const {
  title,
  description = "Insights, updates, and clinical resources from Twilight Psychology.",
  canonical,
  pubDate,
  updatedDate,
  author,
  category,
  robots = "index, follow",
} = Astro.props;

const siteUrl = "https://www.twilightpsychology.com";

const canonicalURL = canonical || new URL(Astro.url.pathname, siteUrl).href;
const isArticle = !!pubDate;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={favicon.src} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title} | Twilight Psychology Blog</title>
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />

    <!-- Open Graph -->
    <meta property="og:type" content={isArticle ? "article" : "website"} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Twilight Psychology Blog`} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Twilight Psychology Blog" />
    {isArticle && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
    {isArticle && updatedDate && (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    )}
    {isArticle && author && (
      <meta property="article:author" content={author} />
    )}
    {isArticle && category && (
      <meta property="article:section" content={category} />
    )}

    <!-- Back-link to main site for SEO -->
    <link rel="home" href={siteUrl} />
  </head>

  <body class="bg-site-bg text-site-text antialiased">
    <!-- Theme initializer: prevents flash on load -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored || (prefersDark ? "dark" : "light");
        document.documentElement.classList.add(theme);
      })();
    </script>

    <BlogHeader />

    <main id="main-content">
      <slot />
    </main>

    <BlogFooter />
  </body>
</html>

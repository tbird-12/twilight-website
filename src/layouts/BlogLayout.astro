---
import "../styles/global.css";
import BlogHeader from "../components/blog/BlogHeader.astro";
import BlogFooter from "../components/blog/BlogFooter.astro";
import Schema from "../components/Schema.astro";
import SearchModal from "../components/SearchModal.astro";
import favicon from "../assets/favicons/favicon.svg";
import { siteConfig } from "../data/siteConfig";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  category?: string;
  image?: string;
  imageAlt?: string;
  seoTitle?: string;
  robots?: string;
}

const {
  title,
  description = "Insights, updates, and clinical resources from Twilight Psychology.",
  canonical,
  pubDate,
  updatedDate,
  author,
  category,
  image,
  imageAlt,
  seoTitle,
  robots = "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1",
} = Astro.props;

const siteUrl = Astro.site || new URL(siteConfig.siteUrl);

const canonicalURL = canonical || new URL(Astro.url.pathname, siteUrl).href;
const isArticle = !!pubDate;
const metaTitle = seoTitle || title;
const ogImage = image || new URL("/og-image.png", siteUrl).href;
const ogImageAlt = imageAlt || `${metaTitle} preview image`;
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.siteName,
  url: siteConfig.siteUrl,
  inLanguage: "en-US",
};
const webpageSchema = {
  "@context": "https://schema.org",
  "@type": isArticle ? "WebPage" : "CollectionPage",
  name: metaTitle,
  description,
  url: canonicalURL,
  inLanguage: "en-US",
  isPartOf: {
    "@type": "WebSite",
    name: siteConfig.siteName,
    url: siteConfig.siteUrl,
  },
  primaryImageOfPage: {
    "@type": "ImageObject",
    url: ogImage,
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href={favicon.src} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet" />
    <title>{metaTitle}</title>
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    {author && <meta name="author" content={author} />}

    <!-- Theme initializer: prevents flash on load -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored || (prefersDark ? "dark" : "light");
        document.documentElement.classList.add(theme);
        document.documentElement.style.colorScheme = theme;
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content={isArticle ? "article" : "website"} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:locale" content="en_US" />
    {isArticle && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
    {isArticle && updatedDate && (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    )}
    {isArticle && author && (
      <meta property="article:author" content={author} />
    )}
    {isArticle && category && (
      <meta property="article:section" content={category} />
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Back-link to main site for SEO -->
    <link rel="home" href={siteConfig.siteUrl} />
    <Schema type="MentalHealthOrganization" name={siteConfig.siteName} />
    <Schema schemas={[websiteSchema, webpageSchema]} />
    <slot name="page-schema" />
  </head>

  <body class="flex min-h-screen flex-col bg-site-bg text-site-text antialiased">
    <BlogHeader />

    <main id="main-content" class="grow" data-pagefind-body>
      <slot />
    </main>

    <BlogFooter />
    <button
      type="button"
      class="fixed bottom-5 right-5 z-95 inline-flex h-9 w-9 items-center justify-center rounded-full bg-site-bg/90 p-0 text-icon shadow-lg ring-1 ring-border/80 backdrop-blur-xl transition-all duration-200 hover:-translate-y-0.5 hover:bg-surface hover:shadow-md"
      data-blog-theme-toggle
      aria-label="Switch theme"
      aria-pressed="false"
      title="Switch theme"
    >
      <svg
        data-theme-icon="sun"
        class="hidden h-6 w-6"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
      </svg>
      <svg
        data-theme-icon="moon"
        class="hidden h-6 w-6"
        fill="currentColor"
        stroke="none"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
      <span class="sr-only">Switch theme</span>
    </button>
    <SearchModal />
    <script>
      const themeToggle = document.querySelector("[data-blog-theme-toggle]");

      if (themeToggle instanceof HTMLButtonElement) {
        const sunIcon = themeToggle.querySelector('[data-theme-icon="sun"]');
        const moonIcon = themeToggle.querySelector('[data-theme-icon="moon"]');
        const srText = themeToggle.querySelector(".sr-only");

        const syncThemeToggle = () => {
          const isDark = document.documentElement.classList.contains("dark");
          const nextTheme = isDark ? "light" : "dark";

          themeToggle.setAttribute("aria-label", `Switch to ${nextTheme} mode`);
          themeToggle.setAttribute("aria-pressed", String(isDark));
          themeToggle.title = `Switch to ${nextTheme} mode`;

          if (srText) {
            srText.textContent = `Switch to ${nextTheme} mode`;
          }

          sunIcon?.classList.toggle("hidden", !isDark);
          moonIcon?.classList.toggle("hidden", isDark);
        };

        syncThemeToggle();

        themeToggle.addEventListener("click", () => {
          const nextTheme = document.documentElement.classList.contains("dark") ? "light" : "dark";
          document.documentElement.classList.remove("light", "dark");
          document.documentElement.classList.add(nextTheme);
          document.documentElement.style.colorScheme = nextTheme;
          localStorage.setItem("theme", nextTheme);
          syncThemeToggle();
        });
      }
    </script>
  </body>
</html>

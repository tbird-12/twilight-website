---
import GoogleAnalytics from "../components/GoogleAnalytics.astro";
import favicon from "../assets/favicons/favicon.svg";
import Schema from "../components/Schema.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  robots?: string;
}

const {
  title,
  description,
  canonical,
  image,
  robots = "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1",
} = Astro.props;

const siteUrl = Astro.site || new URL("http://localhost:4321");
const canonicalURL = canonical || new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image || new URL("../assets/images/logo.png", import.meta.url).href;
const siteName = "Twilight Psychology";
const seoDescription =
  description ||
  "Twilight Psychology offers neuro-affirming psychological evaluations, therapy, and medication management in Kentucky.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href={favicon.src} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <GoogleAnalytics />

    <title>{title}</title>
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={seoDescription} />
    <meta name="robots" content={robots} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Twilight Psychology logo" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />

    <Schema type="MentalHealthOrganization" name="Twilight Psychology" />
    <slot name="page-schema" />

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const storedTheme = localStorage.getItem("theme");
        const theme = storedTheme === "light" || storedTheme === "dark"
          ? storedTheme
          : "dark";

        root.classList.remove("light", "dark");
        root.classList.add(theme);
        root.style.colorScheme = theme;
      })();
    </script>
  </head>

  <body class="min-h-screen bg-site-bg text-site-text">
    <main>
      <slot />
    </main>
  </body>
</html>

---
import HeaderWithProvider from "../components/react/HeaderWithProvider";
import Footer from "../components/Footer.astro";
import GoogleAnalytics from "../components/GoogleAnalytics.astro";
import Chatbot from "../components/Chatbot.astro";
import favicon from "../assets/favicons/favicon.svg";
import Schema from "../components/Schema.astro";
import { siteConfig } from "../data/siteConfig";
import "../styles/global.css";

// This is the "Frontmatter" where you can pass data to the layout
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  robots?: string;
}

const {
  title,
  description,
  canonical,
  image,
  robots = "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1",
} = Astro.props;

const siteUrl = Astro.site || new URL("http://localhost:4321");
const canonicalURL = canonical || new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image || new URL('/og-image.png', siteUrl).href;
const siteName = "Twilight Psychology";
const seoDescription =
  description ||
  "Twilight Psychology offers neuro-affirming psychological evaluations, therapy, and medication management in Kentucky.";
---

<!doctype html>
<html lang="en">
  
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href={favicon.src} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet" />
    <GoogleAnalytics gaId={siteConfig.gaId} />

    <title>{title}</title>
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={seoDescription} />
    <meta name="robots" content={robots} />

    <!-- Geo tags for Kentucky local SEO -->
    <meta name="geo.region" content="US-KY" />
    <meta name="geo.placename" content="Lexington, Kentucky" />
    <meta name="geo.position" content="38.0406;-84.5037" />
    <meta name="ICBM" content="38.0406, -84.5037" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Twilight Psychology logo" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />

    
    <Schema type="MentalHealthOrganization" name="Twilight Psychology" />
    <slot name="page-schema" />

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const storedTheme = localStorage.getItem("theme");
        const theme = storedTheme === "light" || storedTheme === "dark"
          ? storedTheme
          : (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");

        root.classList.remove("light", "dark");
        root.classList.add(theme);
        root.style.colorScheme = theme;
      })();
    </script>
  </head>

  <body
    class="flex flex-col min-h-screen"
  >
    <HeaderWithProvider client:load logoSrc={favicon.src} />

    <main class="grow">
      <slot />
    </main>

    <Footer />

    <Chatbot />
  </body>
</html>

<style is:global>
  /* Add any global CSS transitions or base styles here */
  :root {
    --accent-gradient: linear-gradient(45deg, #4f46e5, #818cf8);
  }

  /* Chatbot animations and scrollbar */
  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  .animate-slide-up { 
    animation: slideUp 0.3s ease-out; 
  }
  .chat-scrollbar::-webkit-scrollbar { 
    width: 4px; 
  }
  .chat-scrollbar::-webkit-scrollbar-thumb { 
    background: var(--color-border-strong); 
    border-radius: 10px; 
  }
</style>